---
import type { CollectionEntry } from "astro:content";

interface Props {
  work: CollectionEntry<"works">;
  studentNames?: string[];
}

const { work, studentNames = [] } = Astro.props;
const { title, slug, medium, media } = work.data;

const thumbnail = media[0];
const href = `/showcase/works/${slug}/`;
---

<a href={href} class="work-card reveal">
  <article>
    {thumbnail && (
      <div class="work-thumbnail">
        {thumbnail.type === "image" ? (
          <img
            src={thumbnail.thumbnail ?? thumbnail.src}
            alt={thumbnail.alt ?? title}
            loading="lazy"
          />
        ) : (
          <div class="thumbnail-placeholder" aria-label={title}>
            <span>{thumbnail.type}</span>
          </div>
        )}
      </div>
    )}
    <div class="work-info">
      <h3 class="work-title">{title}</h3>
      {studentNames.length > 0 && (
        <p class="work-artists">{studentNames.join(", ")}</p>
      )}
      {medium && <p class="work-medium">{medium}</p>}
    </div>
  </article>
</a>

<style>
  .work-card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    overflow: hidden;
    position: relative;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  /* Gradient border overlay on hover */
  .work-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    z-index: 1;
    background: var(--gradient-prismatic);
    border-radius: 5px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  /* Inner mask to create border effect */
  .work-card::after {
    content: "";
    position: absolute;
    inset: 1px;
    z-index: 1;
    background: var(--color-surface);
    border-radius: 3px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .work-card:hover::before,
  .work-card:hover::after {
    opacity: 1;
  }

  .work-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .work-card > article {
    position: relative;
    z-index: 2;
  }

  .work-thumbnail {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-border);
    position: relative;
  }

  .work-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .work-card:hover .work-thumbnail img {
    transform: scale(1.03);
  }

  /* Prismatic overlay on image hover */
  .work-thumbnail::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gradient-prismatic);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .work-card:hover .work-thumbnail::after {
    opacity: 0.1;
  }

  .thumbnail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    color: var(--color-text);
    text-transform: uppercase;
  }

  .work-info {
    padding: var(--space-4);
  }

  .work-title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-base);
    margin-bottom: var(--space-1);
  }

  .work-artists {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .work-medium {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-xs);
    color: var(--color-text);
  }
</style>
