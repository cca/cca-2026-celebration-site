---
interface Props {
  /** Unique ID prefix for SVG filters (must be unique per page) */
  id: string;
  /** Cycle duration in seconds */
  cycleDuration?: number;
  /** Crossfade overlap (0–1) */
  fadeOverlap?: number;
  /** Scale amount during transitions */
  scaleAmount?: number;
  /** 3D spin degrees per transition */
  spinDegrees?: number;
  /** Spin axis: 'X', 'Y', or 'random' */
  spinAxis?: 'X' | 'Y' | 'random';
  /** CSS perspective value in px */
  perspective?: number;
  /** Size variance per arrow (0–1) */
  sizeVariance?: number;
  /** Arrow tint color (CSS color) */
  color?: string;
  /** Delay before starting the loop (seconds) — use to offset multiple instances */
  startDelay?: number;
  /** CSS class for outer wrapper */
  class?: string;
}

const {
  id,
  cycleDuration = 3,
  fadeOverlap = 0.15,
  scaleAmount = 0.04,
  spinDegrees = 180,
  spinAxis = 'Y',
  perspective = 300,
  sizeVariance = 0.3,
  color = '#ffffff',
  startDelay = 0,
  class: className = '',
} = Astro.props;
---

<div
  class:list={['arrow-loop-3d', className]}
  data-arrow-loop
  data-cycle-duration={cycleDuration}
  data-fade-overlap={fadeOverlap}
  data-scale-amount={scaleAmount}
  data-spin-degrees={spinDegrees}
  data-spin-axis={spinAxis}
  data-perspective={perspective}
  data-size-variance={sizeVariance}
  data-color={color}
  data-start-delay={startDelay}
  style={`perspective: ${perspective}px;`}
>
  <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <filter id={`${id}-warp-a`} x="-20%" y="-20%" width="140%" height="140%">
        <feFlood flood-color={color} result="color" />
        <feComposite in="color" in2="SourceAlpha" operator="in" />
      </filter>
      <filter id={`${id}-warp-b`} x="-20%" y="-20%" width="140%" height="140%">
        <feFlood flood-color={color} result="color" />
        <feComposite in="color" in2="SourceAlpha" operator="in" />
      </filter>
    </defs>
  </svg>
  <div class="arrow-loop-3d__slot" data-slot="a" style={`filter: url(#${id}-warp-a);`}>
    <img data-img="a" src="" alt="" />
  </div>
  <div class="arrow-loop-3d__slot" data-slot="b" style={`filter: url(#${id}-warp-b);`}>
    <img data-img="b" src="" alt="" />
  </div>
</div>

<style>
  .arrow-loop-3d {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .arrow-loop-3d__slot {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: opacity, transform;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .arrow-loop-3d__slot img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
</style>
