---
interface Props {
  /** Unique ID prefix (must be unique per page) */
  id: string;
  /** Cycle duration in seconds */
  cycleDuration?: number;
  /** Crossfade overlap (0–1) */
  fadeOverlap?: number;
  /** Scale amount during transitions */
  scaleAmount?: number;
  /** 3D spin degrees per transition */
  spinDegrees?: number;
  /** Spin axis: 'X', 'Y', or 'random' */
  spinAxis?: 'X' | 'Y' | 'random';
  /** CSS perspective value in px */
  perspective?: number;
  /** Size variance per arrow (0–1) */
  sizeVariance?: number;
  /** Arrow tint color (CSS color). Overridden by `colors` if provided. */
  color?: string;
  /** Array of colors to cycle through */
  colors?: string[];
  /** Delay before starting the loop (seconds) — use to offset multiple instances */
  startDelay?: number;
  /** CSS class for outer wrapper */
  class?: string;
}

const {
  cycleDuration = 3,
  fadeOverlap = 0.15,
  scaleAmount = 0.04,
  spinDegrees = 180,
  spinAxis = 'Y',
  perspective = 300,
  sizeVariance = 0.3,
  color = '#ffffff',
  colors,
  startDelay = 0,
  class: className = '',
} = Astro.props;
---

<div
  class:list={['arrow-loop-3d', className]}
  data-arrow-loop
  data-cycle-duration={cycleDuration}
  data-fade-overlap={fadeOverlap}
  data-scale-amount={scaleAmount}
  data-spin-degrees={spinDegrees}
  data-spin-axis={spinAxis}
  data-perspective={perspective}
  data-size-variance={sizeVariance}
  data-colors={colors ? colors.join(',') : color}
  data-start-delay={startDelay}
  style={`perspective: ${perspective}px;`}
>
  <div class="arrow-loop-3d__slot" data-slot="a">
    <div class="arrow-loop-3d__shape" data-shape="a"></div>
  </div>
  <div class="arrow-loop-3d__slot" data-slot="b">
    <div class="arrow-loop-3d__shape" data-shape="b"></div>
  </div>
</div>

<style>
  .arrow-loop-3d {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .arrow-loop-3d__slot {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity, transform;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .arrow-loop-3d__shape {
    position: absolute;
    inset: 0;
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
  }
</style>
