---
/**
 * ConfettiCanvas — Decorative canvas-based confetti particle system
 * Renders geometric shapes floating upward with gentle rotation and sine-wave drift.
 * Purely decorative, aria-hidden, and respects prefers-reduced-motion.
 */
---

<canvas class="confetti-canvas" aria-hidden="true"></canvas>

<style>
  .confetti-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('.confetti-canvas');
  if (!canvas) throw new Error('ConfettiCanvas: canvas element not found');

  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('ConfettiCanvas: 2d context not available');

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const COLORS = ['#00BFB3', '#563D82', '#FFC845', '#E57200', '#005776'];
  const PARTICLE_COUNT = 70;

  interface Particle {
    x: number;
    y: number;
    size: number;
    color: string;
    opacity: number;
    rotation: number;
    rotationSpeed: number;
    speed: number;
    drift: number;
    driftPhase: number;
    shape: 'rect' | 'circle' | 'triangle';
  }

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas!.getBoundingClientRect();
    canvas!.width = rect.width * dpr;
    canvas!.height = rect.height * dpr;
    ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function createParticle(): Particle {
    const rect = canvas!.getBoundingClientRect();
    const shapes: Particle['shape'][] = ['rect', 'circle', 'triangle'];
    return {
      x: Math.random() * rect.width,
      y: Math.random() * rect.height,
      size: 3 + Math.random() * 5,
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
      opacity: 0.3 + Math.random() * 0.5,
      rotation: Math.random() * Math.PI * 2,
      rotationSpeed: (Math.random() - 0.5) * 0.02,
      speed: 0.15 + Math.random() * 0.35,
      drift: 0.3 + Math.random() * 0.7,
      driftPhase: Math.random() * Math.PI * 2,
      shape: shapes[Math.floor(Math.random() * shapes.length)],
    };
  }

  function drawParticle(p: Particle) {
    const c = ctx!;
    c.save();
    c.translate(p.x, p.y);
    c.rotate(p.rotation);
    c.globalAlpha = p.opacity;
    c.fillStyle = p.color;

    switch (p.shape) {
      case 'rect':
        c.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.6);
        break;
      case 'circle':
        c.beginPath();
        c.arc(0, 0, p.size / 2, 0, Math.PI * 2);
        c.fill();
        break;
      case 'triangle':
        c.beginPath();
        c.moveTo(0, -p.size / 2);
        c.lineTo(p.size / 2, p.size / 2);
        c.lineTo(-p.size / 2, p.size / 2);
        c.closePath();
        c.fill();
        break;
    }

    c.restore();
  }

  if (prefersReducedMotion) {
    // Show a single static frame for reduced-motion users
    resize();
    const particles = Array.from({ length: PARTICLE_COUNT }, createParticle);
    particles.forEach(drawParticle);
  } else {
    const particles = Array.from({ length: PARTICLE_COUNT }, createParticle);
    let time = 0;

    resize();
    window.addEventListener('resize', resize);

    function animate() {
      const rect = canvas!.getBoundingClientRect();
      ctx!.clearRect(0, 0, rect.width, rect.height);
      time += 0.01;

      for (const p of particles) {
        p.y -= p.speed;
        p.x += Math.sin(time + p.driftPhase) * p.drift * 0.3;
        p.rotation += p.rotationSpeed;

        // Wrap particles that float off the top back to the bottom
        if (p.y < -p.size) {
          p.y = rect.height + p.size;
          p.x = Math.random() * rect.width;
        }
        // Wrap horizontal overflow
        if (p.x < -p.size) p.x = rect.width + p.size;
        if (p.x > rect.width + p.size) p.x = -p.size;

        drawParticle(p);
      }

      requestAnimationFrame(animate);
    }

    animate();
  }
</script>
