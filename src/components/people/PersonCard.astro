---
interface Props {
  person: {
    name: string;
    slug: string;
    role: string;
    photo?: { src: string; alt: string };
    title?: string;
    bio?: string;
    ccaConnection?: string;
  };
}

const { person } = Astro.props;

const roleLabels: Record<string, string> = {
  "student-speaker": "Student Speaker",
  "honorary-doctorate": "Honorary Doctorate",
  "professor-emeritus": "Professor Emeritus",
  "distinguished-alumni": "Distinguished Alumni",
  other: "Honoree",
};
const roleLabel = roleLabels[person.role] ?? person.role;
---

<article class="person-card reveal">
  <div class="person-photo">
    {person.photo ? (
      <img src={person.photo.src} alt={person.photo.alt} loading="lazy" />
    ) : (
      <div class="photo-placeholder" />
    )}
  </div>
  <div class="person-info">
    <span class="person-role">{roleLabel}</span>
    <h3 class="person-name">{person.name}</h3>
    {person.title && <p class="person-title">{person.title}</p>}
    {person.bio && <p class="person-bio">{person.bio}</p>}
    {person.ccaConnection && (
      <p class="person-cca">{person.ccaConnection}</p>
    )}
  </div>
</article>

<style>
  .person-card {
    display: block;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .person-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
  }

  .person-photo {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-border);
  }

  .person-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: outline-color 0.3s ease, outline-offset 0.3s ease;
    outline: 2px solid transparent;
    outline-offset: 0px;
  }

  .person-card:hover .person-photo img {
    outline-color: var(--color-accent);
    outline-offset: 3px;
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    background: var(--gradient-prismatic);
    opacity: 0.3;
  }

  .person-info {
    padding: var(--space-4);
  }

  .person-role {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent-tint);
    color: var(--color-accent);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    margin-bottom: var(--space-2);
  }

  .person-name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
    transition: color 0.2s ease;
  }

  .person-card:hover .person-name {
    color: var(--color-accent);
  }

  .person-title {
    font-size: var(--text-sm);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .person-bio {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .person-cca {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .person-cca::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
</style>
