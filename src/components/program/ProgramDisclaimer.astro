---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="program-disclaimer">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="disclaimer-icon">
    <circle cx="8" cy="8" r="7" />
    <line x1="8" y1="5" x2="8" y2="8" />
    <circle cx="8" cy="11" r="0.5" fill="currentColor" />
  </svg>
  <p>{text}</p>
</div>

<style>
  .program-disclaimer {
    display: flex;
    gap: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-gold, var(--color-accent));
    border-radius: var(--radius-card);
    padding: var(--space-5);
  }

  .disclaimer-icon {
    flex-shrink: 0;
    color: var(--color-gold, var(--color-accent));
    margin-top: 2px;
  }

  p {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    margin: 0;
  }
</style>
