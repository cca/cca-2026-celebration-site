---
import type { CandidateGroup } from "../../lib/utils/collections";

interface Props {
  groups: CandidateGroup[];
  degreeLabel?: string;
  totalCount?: number;
}

const { groups, degreeLabel = "degree", totalCount } = Astro.props;
const uniqueIds = new Set<string>();
for (const g of groups) for (const p of g.programs) for (const s of p.students) uniqueIds.add(s.id);
const totalCandidates = totalCount ?? uniqueIds.size;

// The ceremony's own graduation term — students expecting to graduate in a
// later term are flagged with an asterisk and a footnote.
const CEREMONY_TERM = "Spring 2026";
const isAsterisked = (s: { expectedGraduation?: string }) =>
  !!s.expectedGraduation && s.expectedGraduation !== CEREMONY_TERM;
const expectedTerms = new Set<string>();
for (const g of groups) for (const p of g.programs) for (const s of p.students) {
  if (isAsterisked(s)) expectedTerms.add(s.expectedGraduation!);
}
const footnotes = [...expectedTerms].sort();
---

<div class="candidates-list">
  <h3 class="candidates-subhead">
    Celebrating <span class="count-number">{totalCandidates}</span> {degreeLabel} candidates
  </h3>

  {groups.map((group) => (
    <details class="division-group" open>
      <summary class="division-header">
        <span class="division-name">{group.divisionLabel}</span>
      </summary>

      <div class="division-content">
        {group.programs.map((program) => (
          <div class="program-block">
            <h4 class="program-name">{program.degreeType} {program.programName}</h4>
            <ul class="student-list" role="list">
              {program.students.map((student) => (
                <li class="student-name">
                  {student.firstName} {student.lastName}{isAsterisked(student) ? "*" : ""}
                  {student.multiProgramNote && <span class="student-note"> ({student.multiProgramNote})</span>}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </details>
  ))}

  {footnotes.length > 0 && (
    <p class="candidates-footnote">
      {footnotes.map((term) => <span>*Expected graduation {term}.</span>)}
    </p>
  )}
</div>

<style>
  .candidates-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .candidates-subhead {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: normal;
    color: var(--color-text);
    margin: 0;
  }

  .student-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.7;
  }

  .count-number {
    font-weight: 700;
    color: var(--color-accent);
  }

  .division-group {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .division-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    min-height: 44px;
    user-select: none;
    transition: background 0.15s ease;
    list-style: none;
  }

  .division-header::-webkit-details-marker {
    display: none;
  }

  .division-header::before {
    content: "";
    display: inline-block;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--color-text);
    border-bottom: 2px solid var(--color-text);
    transform: rotate(-45deg);
    margin-right: var(--space-3);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  details[open] > .division-header::before {
    transform: rotate(45deg);
  }

  .division-header:hover {
    background: color-mix(in srgb, var(--color-border) 30%, transparent);
  }

  .division-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    flex: 1;
  }

  .division-content {
    padding: 0 var(--space-6) var(--space-6);
  }

  .program-block {
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .program-block:first-child {
    border-top: none;
    margin-top: 0;
    padding-top: 0;
  }

  .program-name {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-gold, var(--color-accent));
  }

  .student-list {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 1;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .student-list {
      columns: 2;
    }
  }

  @media (min-width: 900px) {
    .student-list {
      columns: 3;
    }
  }

  .student-list li {
    break-inside: avoid;
    padding-block: var(--space-1);
  }

  .student-name {
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .candidates-footnote {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.7;
  }
</style>
