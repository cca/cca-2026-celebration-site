---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatTime } from "../../lib/utils/format";
import { generateGoogleCalendarUrl } from "../../lib/utils/calendar";

interface Props {
  event: CollectionEntry<"events">;
  titlePrefix?: string;
  subtitle?: string;
  intro?: string;
}

const { event, titlePrefix = "", subtitle = "119th Commencement", intro } = Astro.props;
const { title, date, time, location, address, description } = event.data;
const dateDisplay = formatDate(date);
const introText = intro ?? description;
const calendarUrl = generateGoogleCalendarUrl({ title, date, time, location, address, description });
---

<section class="program-hero">
  <div class="container">
    <h1 class="hero-title">{titlePrefix}{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    <p class="hero-details">
      <span>{dateDisplay}</span>
      {time && <><span class="hero-divider" aria-hidden="true">|</span><span>{formatTime(time)}</span></>}
      <span class="hero-divider" aria-hidden="true">|</span>
      <a href={`https://maps.google.com/?q=${encodeURIComponent(address)}`} target="_blank" rel="noopener noreferrer">
        {location}
      </a>
    </p>
    {introText && <p class="hero-intro">{introText}</p>}
    <p class="hero-actions">
      <a class="hero-action" href={calendarUrl} target="_blank" rel="noopener noreferrer">Add to Calendar</a>
      <span class="hero-divider" aria-hidden="true">|</span>
      <button class="hero-action share-link" data-share-title={title} data-share-url={Astro.url.pathname}>Share</button>
    </p>
  </div>
</section>

<style>
  .program-hero {
    padding-block: var(--space-10) var(--space-8);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .program-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--color-accent) 6%, transparent), transparent 70%);
    pointer-events: none;
  }

  .program-hero .container {
    position: relative;
    text-align: center;
  }

  .program-hero .container > * {
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: normal;
    background: var(--theme-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-text);
    margin-top: var(--space-2);
    text-align: center;
  }

  .hero-details {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-text);
    margin-top: var(--space-6);
  }

  .hero-details a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hero-details a:hover {
    color: var(--color-accent);
  }

  .hero-divider {
    color: var(--color-accent);
    opacity: 0.6;
  }

  .hero-intro {
    margin-top: var(--space-5);
    max-width: 56ch;
    margin-inline: auto;
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .hero-actions {
    margin-top: var(--space-5);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .hero-action {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    background: transparent;
    border: 0;
    padding: 0;
    font: inherit;
    cursor: pointer;
  }

  .hero-action:hover {
    text-decoration-thickness: 2px;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.program-hero .share-link').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const title = btn.dataset.shareTitle ?? '';
      const url = new URL(btn.dataset.shareUrl ?? '', window.location.origin).href;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // User cancelled or share failed — fall through to clipboard
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = original; }, 2000);
      } catch {
        // Clipboard not available
      }
    });
  });
</script>
