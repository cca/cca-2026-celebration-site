---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatDateRange, formatTime } from "../../lib/utils/format";
import { generateGoogleCalendarUrl } from "../../lib/utils/calendar";
import Button from "../ui/Button.astro";
import FramedImage from "../ui/FramedImage.astro";

const FALLBACK_FRAMES = ['frame-04', 'frame-11', 'frame-07'];

interface Props {
  event: CollectionEntry<"events">;
  heroImageSize?: 'default' | 'large';
}

const { event, heroImageSize = 'default' } = Astro.props;
const { title, date, endDate, time, location, address, description, image, heroImages, rsvpUrl, livestreamUrl } = event.data;
const dateDisplay = endDate ? formatDateRange(date, endDate) : formatDate(date);
const calendarUrl = generateGoogleCalendarUrl({ title, date, endDate, time, location, address, description });
---

<section class={`event-hero reveal${heroImageSize === 'large' ? ' event-hero--large-frame' : ''}`}>

  <div class="hero-inner">
    <div class="hero-content">
      <h1 class="hero-title stagger-1">{title}</h1>
      <div class="hero-meta stagger-2">
        <time class="hero-date">{dateDisplay}</time>
        {time && (
          <>
            <span class="hero-separator" aria-hidden="true">&#9670;</span>
            <span class="hero-time">{formatTime(time)}</span>
          </>
        )}
        <span class="hero-separator" aria-hidden="true">&#9670;</span>
        <span class="hero-location">{location}</span>
      </div>
      {description && (
        <p class="hero-description stagger-3">{description}</p>
      )}
      <div class="hero-actions stagger-4">
        {rsvpUrl && (
          <Button href={rsvpUrl} variant="primary" target="_blank" rel="noopener noreferrer">
            RSVP
          </Button>
        )}
        {livestreamUrl && (
          <Button href={livestreamUrl} variant="outline" target="_blank" rel="noopener noreferrer">
            Watch Livestream
          </Button>
        )}
        <a href={calendarUrl} target="_blank" rel="noopener noreferrer" class="calendar-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="3" width="12" height="12" rx="1" />
            <line x1="2" y1="7" x2="14" y2="7" />
            <line x1="5" y1="1" x2="5" y2="4" />
            <line x1="11" y1="1" x2="11" y2="4" />
          </svg>
          Add to Calendar
        </a>
        <button class="share-link" data-share-title={title} data-share-url={Astro.url.pathname}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6.5 9.5a3.5 3.5 0 0 0 5 0l2-2a3.5 3.5 0 0 0-5-5l-1 1" />
            <path d="M9.5 6.5a3.5 3.5 0 0 0-5 0l-2 2a3.5 3.5 0 0 0 5 5l1-1" />
          </svg>
          Share
        </button>
      </div>
    </div>
    {heroImages && heroImages.length > 0 ? (
      <div class={`hero-framed-images hero-framed-images--${heroImages.length > 1 ? 'multi' : 'single'} stagger-3`}>
        {heroImages.map((img, i) => (
          <div class={`hero-framed-images__item hero-framed-images__item--${i + 1}`}>
            <FramedImage
              frameId={img.frameId ?? FALLBACK_FRAMES[i % FALLBACK_FRAMES.length]}
              src={img.src}
              alt={img.alt}
              uid={`event-hero-${event.data.slug}-${i}`}
            />
          </div>
        ))}
      </div>
    ) : image && (
      <div class="hero-media stagger-3">
        <div class="hero-frame">
          <img src={image.src} alt={image.alt} loading="eager" style={image.aspectRatio ? `aspect-ratio: ${image.aspectRatio}` : undefined} />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .event-hero {
    position: relative;
    min-height: 80vh;
    min-height: 80dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Decorative seal — centered behind content */
  .hero-seal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(280px, 50vw, 500px);
    aspect-ratio: 1;
    background: var(--color-accent);
    opacity: 0.04;
    mask-image: url('/images/cca-seal.svg');
    -webkit-mask-image: url('/images/cca-seal.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme="commencement"]) .hero-seal,
  :global([data-theme="thesis-grad"]) .hero-seal {
    opacity: 0.06;
  }

  @media (min-width: 768px) {
    .hero-seal {
      left: 65%;
      width: clamp(200px, 35vw, 400px);
      opacity: 0.05;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-seal {
      animation: seal-hero-breathe 12s ease-in-out infinite;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: var(--space-8);
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding-inline: var(--space-4);
    padding-block: var(--space-16) var(--space-12);
  }

  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
      padding-inline: var(--space-10);
    }
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 55fr 45fr;
      padding-inline: var(--space-12);
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: normal;
    line-height: 1.1;
    margin-bottom: var(--space-4);
    position: relative;
    display: inline-block;
    background: var(--theme-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-title::after {
    content: "";
    display: block;
    width: 60px;
    height: 3px;
    background: var(--theme-gradient);
    margin-top: var(--space-3);
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-muted);
    margin-top: var(--space-4);
  }

  @media (min-width: 768px) {
    .hero-meta {
      font-size: var(--text-lg);
    }
  }

  .hero-date {
    color: var(--color-accent);
  }

  .hero-separator {
    color: var(--color-accent);
    opacity: 0.5;
    font-size: 0.6em;
  }

  .hero-description {
    max-width: 55ch;
    color: var(--color-muted);
    line-height: 1.7;
    margin-top: var(--space-6);
    font-size: var(--text-base);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .calendar-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .calendar-link:hover {
    color: var(--color-accent);
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    background-color: transparent;
    background-image: linear-gradient(var(--color-accent), var(--color-accent));
    background-size: 0% 1px;
    background-position: left bottom;
    background-repeat: no-repeat;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-size var(--duration-base) var(--ease-out-expo),
                color var(--duration-base) var(--ease-out-expo);
  }

  .share-link:hover {
    color: var(--color-accent);
    background-size: 100% 1px;
  }

  /* ── Hero image (plain, used by commencement etc.) ── */
  .hero-media {
    display: flex;
    justify-content: center;
  }

  .hero-frame {
    border-radius: var(--radius-card);
    padding: 3px;
    background: linear-gradient(135deg, #00BFB3, #B7BF10);
    background-size: 200% 200%;
    width: 95%;
    max-width: 560px;
  }

  @media (min-width: 768px) {
    .hero-frame {
      width: 100%;
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-frame {
      animation: prismatic-shift 6s linear infinite;
    }
  }

  .hero-frame img {
    display: block;
    width: 100%;
    border-radius: calc(var(--radius-card) - 2px);
  }

  /* ── Framed images (thesis-style scanned frames) ── */
  .hero-framed-images {
    --frame-color: var(--color-accent);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Single image — centered, generous width */
  .hero-framed-images--single {
    padding: var(--space-4);
  }

  .hero-framed-images--single .hero-framed-images__item--1 {
    width: clamp(220px, 80%, 420px);
  }

  .event-hero--large-frame .hero-framed-images--single .hero-framed-images__item--1 {
    width: clamp(320px, 100%, 680px);
  }

  /* Two images — overlapping collage */
  .hero-framed-images--multi {
    min-height: 340px;
  }

  .hero-framed-images--multi .hero-framed-images__item {
    position: absolute;
  }

  .hero-framed-images--multi .hero-framed-images__item--1 {
    width: clamp(200px, 62%, 340px);
    top: 0;
    right: 0;
    rotate: 2.5deg;
    z-index: 2;
  }

  .hero-framed-images--multi .hero-framed-images__item--2 {
    width: clamp(160px, 50%, 280px);
    bottom: 0;
    left: 0;
    rotate: -3deg;
    z-index: 1;
  }

  @media (max-width: 767px) {
    .hero-framed-images--multi {
      min-height: 240px;
    }

    .hero-framed-images--multi .hero-framed-images__item--2 {
      display: none;
    }

    .hero-framed-images--multi .hero-framed-images__item--1 {
      position: static;
      rotate: 2deg;
      width: clamp(180px, 70%, 320px);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-framed-images__item {
      opacity: 0;
      animation: fragment-enter 0.6s var(--ease-out-expo) both;
    }

    .hero-framed-images__item--1 { animation-delay: 0.1s; }
    .hero-framed-images__item--2 { animation-delay: 0.28s; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-link').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const title = btn.dataset.shareTitle ?? '';
      const url = new URL(btn.dataset.shareUrl ?? '', window.location.origin).href;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // User cancelled or share failed — fall through to clipboard
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => {
          btn.textContent = '';
          // Reconstruct with icon
          btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6.5 9.5a3.5 3.5 0 0 0 5 0l2-2a3.5 3.5 0 0 0-5-5l-1 1" /><path d="M9.5 6.5a3.5 3.5 0 0 0-5 0l-2 2a3.5 3.5 0 0 0 5 5l1-1" /></svg> Share`;
        }, 2000);
      } catch {
        // Clipboard not available
      }
    });
  });
</script>
