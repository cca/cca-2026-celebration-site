---
import type { CollectionEntry } from "astro:content";

interface Props {
  speaker: {
    name: string;
    program: string;
    speechHighlights?: string;
  };
  student?: CollectionEntry<"students"> | null;
}

const { speaker, student } = Astro.props;
const studentHref = student ? `/students/${student.data.slug}/` : null;
---

<div class="speaker-feature reveal">
  {student?.data.photo && (
    <div class="speaker-photo">
      <img src={student.data.photo.src} alt={student.data.photo.alt} loading="lazy" />
    </div>
  )}
  <div class="speaker-info">
    <span class="speaker-label">Student Speaker</span>
    <h3 class="speaker-name">
      {studentHref ? (
        <a href={studentHref}>{speaker.name}</a>
      ) : (
        speaker.name
      )}
    </h3>
    <p class="speaker-program">{speaker.program}</p>
    {speaker.speechHighlights && (
      <p class="speaker-highlights">{speaker.speechHighlights}</p>
    )}
  </div>
</div>

<style>
  .speaker-feature {
    display: flex;
    gap: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    padding: var(--space-6);
  }

  .speaker-photo {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-border);
  }

  .speaker-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .speaker-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .speaker-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  .speaker-name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xl);
  }

  .speaker-name a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .speaker-name a:hover {
    color: var(--color-accent);
  }

  .speaker-program {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .speaker-highlights {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
    margin-top: var(--space-1);
  }

  @media (max-width: 600px) {
    .speaker-feature {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
