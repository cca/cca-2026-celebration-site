---
import type { CollectionEntry } from "astro:content";
import { Image } from 'astro:assets';

interface Props {
  speaker: {
    name: string;
    program: string;
    speechHighlights?: string;
  };
  student?: CollectionEntry<"students"> | null;
  focusArea?: "center" | "top";
}

const { speaker, student, focusArea = "center" } = Astro.props;
const speechParagraphs = speaker.speechHighlights
  ? speaker.speechHighlights.split(/\n\n+/).map(p => p.trim()).filter(Boolean)
  : [];
---

<div class="speaker-feature reveal">
  {student?.data.photo && (
    <div class="speaker-photo" data-focus={focusArea}>
      <Image src={student.data.photo.src} alt={student.data.photo.alt} loading="lazy" width={240} />
    </div>
  )}
  <div class="speaker-info">
    <h3 class="speaker-name">{speaker.name}</h3>
    <p class="speaker-program">{speaker.program}</p>
    {speechParagraphs.length > 0 && (
      <div class="speaker-highlights">
        {speechParagraphs.map(p => <p>{p}</p>)}
      </div>
    )}
  </div>
</div>

<style>
  .speaker-feature {
    display: flex;
    gap: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    padding: var(--space-6);
  }

  .speaker-photo {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-border);
  }

  .speaker-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .speaker-photo[data-focus="top"] img {
    object-position: center 20%;
  }

  .speaker-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .speaker-name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-xl);
  }

  .speaker-program {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .speaker-highlights {
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    margin-top: var(--space-1);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .speaker-highlights p {
    margin: 0;
  }

  @media (max-width: 600px) {
    .speaker-feature {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
