---
import type { CollectionEntry } from "astro:content";
import { Image } from 'astro:assets';

interface Props {
  speaker: {
    name: string;
    program: string;
    speechHighlights?: string;
    attribution?: string;
  };
  student?: CollectionEntry<"students"> | null;
}

const { speaker, student } = Astro.props;
const studentHref = student ? `/students/${student.data.slug}/` : null;
const speechParagraphs = speaker.speechHighlights
  ? speaker.speechHighlights.split(/\n\n+/).map(p => p.trim()).filter(Boolean)
  : [];
const caption = `${speaker.name} (${speaker.program})`;
---

<div class="speaker-feature reveal">
  {student?.data.photo && (
    <figure class="speaker-photo">
      <Image src={student.data.photo.src} alt={student.data.photo.alt} loading="lazy" width={480} height={600} />
      <figcaption class="speaker-caption">{caption}</figcaption>
    </figure>
  )}
  <div class="speaker-info">
    <h3 class="speaker-name">
      {studentHref ? (
        <a href={studentHref}>{speaker.name}</a>
      ) : (
        speaker.name
      )}
    </h3>
    <p class="speaker-program">{speaker.program}</p>
    {speechParagraphs.length > 0 && (
      <div class="speaker-highlights">
        {speechParagraphs.map(p => <p>{p}</p>)}
      </div>
    )}
    {speaker.attribution && (
      <p class="speaker-attribution">{speaker.attribution}</p>
    )}
  </div>
</div>

<style>
  .speaker-feature {
    display: flex;
    gap: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    padding: var(--space-6);
    align-items: flex-start;
  }

  .speaker-photo {
    margin: 0;
    flex-shrink: 0;
    width: 240px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .speaker-photo img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-card);
    background: var(--color-border);
  }

  .speaker-caption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: none;
    color: var(--color-text);
    opacity: 0.8;
    text-align: center;
  }

  .speaker-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .speaker-name {
    font-family: var(--font-display);
    font-weight: normal;
    font-size: var(--text-2xl);
    margin: 0;
  }

  .speaker-name a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .speaker-name a:hover {
    color: var(--color-accent);
  }

  .speaker-program {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.85;
    margin: 0;
  }

  .speaker-highlights {
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .speaker-highlights p {
    margin: 0;
  }

  .speaker-attribution {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.85;
    margin: 0;
  }

  @media (max-width: 720px) {
    .speaker-feature {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .speaker-photo {
      width: 200px;
    }
  }
</style>
