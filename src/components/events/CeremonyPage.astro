---
import { getEntry, getCollection } from 'astro:content';
import EventLayout from '../../layouts/EventLayout.astro';
import EventHero from './EventHero.astro';

import WorkGrid from '../works/WorkGrid.astro';
import Breadcrumb from '../ui/Breadcrumb.astro';
import TableOfContents from '../ui/TableOfContents.astro';
import VideoEmbed from '../ui/VideoEmbed.astro';
import QuoteBlock from '../ui/QuoteBlock.astro';
import DownloadLink from '../ui/DownloadLink.astro';
import Button from '../ui/Button.astro';
import PersonGrid from '../people/PersonGrid.astro';
import StatisticsGrid from '../sections/StatisticsGrid.astro';
import { getWorksByEvent, getPeopleByCeremony } from '../../lib/utils/collections';
import { fullName } from '../../lib/utils/format';

interface Props {
  eventId: string;
  breadcrumbLabel: string;
}

const { eventId, breadcrumbLabel } = Astro.props;

// --- Data fetching ---
const event = await getEntry('events', eventId);
if (!event) throw new Error(`Event ${eventId} not found`);

const people = await getPeopleByCeremony(eventId);
const works = await getWorksByEvent(eventId);
const students = await getCollection('students');
const studentMap = new Map(students.map(s => [s.id, fullName(s)]));

const commencementInfo = await getEntry('commencement-info', 'current');

// Build program page URL from eventId (e.g. "commencement-graduate" → "/commencement/graduate/program/")
const ceremonySlug = eventId.replace('commencement-', '');
const programUrl = `/commencement/${ceremonySlug}/program/`;

// Resolve ceremony program refs
const { ceremonyProgram, schedule, videoUrl, videoCaption } = event.data;

// Pull key times from the schedule for the Digital Program section
const keyTimeLabels = ['Doors Open', 'Ceremony Begins', 'Reception'];
const keyTimes = (schedule ?? [])
  .filter((item: { label: string }) => keyTimeLabels.includes(item.label))
  .map((item: { time: string; label: string }) => ({ time: item.time, label: item.label }));

// Filter downloadable assets: program booklet only appears on the program subpage
const diyKitAssets = commencementInfo?.data.downloadableAssets?.filter(
  (a: { label: string }) => a.label !== 'Commencement Program'
) ?? [];

// Build a person-like object from the student speaker so it renders in the same grid
let speakerAsPerson = null;
if (ceremonyProgram?.studentSpeaker) {
  const sp = ceremonyProgram.studentSpeaker;
  const studentEntry = sp.student
    ? await getEntry('students', sp.student.id)
    : null;
  speakerAsPerson = {
    name: sp.name,
    slug: `speaker-${sp.name.toLowerCase().replace(/\s+/g, '-')}`,
    role: 'student-speaker',
    title: sp.program,
    bio: sp.speechHighlights,
    photo: studentEntry?.data.photo,
  };
}

// Prepend speaker to people array for a unified grid
const allFeaturedPeople = [
  ...(speakerAsPerson ? [speakerAsPerson] : []),
  ...people.map(p => p.data),
];

// --- Build dynamic TOC ---
const tocItems: Array<{ label: string; href: string }> = [];

const hasFeaturedPeople = allFeaturedPeople.length > 0;
if (hasFeaturedPeople) tocItems.push({ label: 'Featured Speakers & Honorees', href: '#featured-people' });
if (commencementInfo?.data.presidentQuote) tocItems.push({ label: "President's Message", href: '#president-message' });
if (diyKitAssets.length > 0) tocItems.push({ label: 'DIY Celebration Kit', href: '#diy-kit' });
if (commencementInfo?.data.statistics) tocItems.push({ label: 'By the Numbers', href: '#statistics' });
if (works.length > 0) tocItems.push({ label: 'Student Works', href: '#works' });
if (videoUrl) tocItems.push({ label: 'Ceremony Video', href: '#video' });
tocItems.push({ label: 'Digital Program', href: '#digital-program' });
tocItems.push({ label: 'Questions & Contact', href: '#contact' });
---

<EventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Commencement', href: '/commencement/' },
      { label: breadcrumbLabel },
    ]} />
  </div>

  <EventHero event={event} />

  <div class="container">
    <div class="ceremony-layout">
      <div class="ceremony-main">
        {/* Featured Speakers & Honorees */}
        {hasFeaturedPeople && (
          <section id="featured-people" class="ceremony-section reveal">
            <h2 class="section-heading">Featured Speakers & Honorees</h2>
            <PersonGrid people={allFeaturedPeople} />
          </section>
        )}

        {/* President's Message */}
        {commencementInfo?.data.presidentQuote && (
          <section id="president-message" class="ceremony-section reveal">
            <QuoteBlock
              text={commencementInfo.data.presidentQuote.text}
              attribution={commencementInfo.data.presidentQuote.attribution}
            />
          </section>
        )}

        {/* DIY Celebration Kit */}
        {diyKitAssets.length > 0 && (
          <section id="diy-kit" class="ceremony-section reveal">
            <h2 class="section-heading">DIY Celebration Kit</h2>
            <p class="diy-kit-intro">Celebrate your way — download printable decorations, social media frames, and more to make the day your own.</p>
            <div class="downloads-list">
              {diyKitAssets.map((asset: { label: string; url: string; description?: string }) => (
                <DownloadLink
                  label={asset.label}
                  url={asset.url}
                  description={asset.description}
                />
              ))}
            </div>
          </section>
        )}

        {/* By the Numbers */}
        {commencementInfo?.data.statistics && (
          <section id="statistics" class="ceremony-section reveal">
            <h2 class="section-heading">By the Numbers</h2>
            <StatisticsGrid statistics={commencementInfo.data.statistics} />
          </section>
        )}

        {/* Student Works */}
        {works.length > 0 && (
          <section id="works" class="ceremony-section reveal">
            <h2 class="section-heading">Student Works</h2>
            <WorkGrid works={works} studentMap={studentMap} />
          </section>
        )}

        {/* Ceremony Video */}
        {videoUrl && (
          <section id="video" class="ceremony-section reveal">
            <h2 class="section-heading">Ceremony Video</h2>
            <VideoEmbed url={videoUrl} caption={videoCaption} />
          </section>
        )}

        {/* Digital Program */}
        <section id="digital-program" class="ceremony-section reveal">
          <h2 class="section-heading">Digital Program</h2>
          {keyTimes.length > 0 && (
            <div class="key-times">
              {keyTimes.map((item: { time: string; label: string }) => (
                <div class="key-time">
                  <span class="key-time-value">{item.time}</span>
                  <span class="key-time-label">{item.label}</span>
                </div>
              ))}
            </div>
          )}
          <div class="program-cta-actions">
            <Button href={programUrl} variant="primary">View Full Program &rarr;</Button>
          </div>
        </section>

        {/* Questions & Contact */}
        <section id="contact" class="ceremony-section reveal">
          <h2 class="section-heading">Questions & Contact</h2>
          <div class="contact-card">
            <p class="contact-text">For details on regalia, guest tickets, accessibility, parking, and everything else about ceremony day, visit the CCA Commencement Portal.</p>
            {commencementInfo?.data.intranetUrl && (
              <a href={commencementInfo.data.intranetUrl} class="contact-portal-link">
                CCA Commencement Portal &rarr;
              </a>
            )}
            {commencementInfo?.data.contact && (
              <div class="contact-details">
                {commencementInfo.data.contact.email && (
                  <a href={`mailto:${commencementInfo.data.contact.email}`} class="contact-detail">
                    {commencementInfo.data.contact.email}
                  </a>
                )}
                {commencementInfo.data.contact.phone && (
                  <a href={`tel:${commencementInfo.data.contact.phone.replace(/\D/g, '')}`} class="contact-detail">
                    {commencementInfo.data.contact.phone}
                  </a>
                )}
              </div>
            )}
          </div>
        </section>
      </div>

      {/* Sticky sidebar TOC (desktop right) / inline TOC (mobile top) */}
      <aside class="ceremony-sidebar">
        <TableOfContents items={tocItems} />
      </aside>
    </div>
  </div>
</EventLayout>

<style>
  .ceremony-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .ceremony-sidebar {
    order: -1; /* Mobile: appear above main content */
  }

  .ceremony-main {
    flex: 1;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .ceremony-layout {
      flex-direction: row;
      gap: var(--space-10);
    }

    .ceremony-sidebar {
      order: 0; /* Desktop: natural DOM order = right side */
      flex: 0 0 220px;
      position: sticky;
      top: calc(60px + var(--space-8));
      align-self: flex-start;
    }
  }

  .ceremony-section {
    padding-block: var(--space-6);
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  .key-times {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  .key-time {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-4) var(--space-5);
    min-width: 140px;
  }

  .key-time-value {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-accent);
  }

  .key-time-label {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .program-cta-actions {
    margin-top: var(--space-6);
  }

  .diy-kit-intro {
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .downloads-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-6);
  }

  .contact-text {
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  .contact-portal-link {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-portal-link:hover {
    text-decoration: underline;
  }

  .contact-details {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .contact-detail {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-detail:hover {
    color: var(--color-accent);
  }

  /* Commencement gold accent on section borders */
  :global([data-theme^="commencement"]) .section-heading {
    position: relative;
    display: inline-block;
  }

  :global([data-theme^="commencement"]) .section-heading::after {
    content: "";
    display: block;
    width: 40px;
    height: 2px;
    background: var(--color-gold, var(--color-accent));
    margin-top: var(--space-2);
  }
</style>
