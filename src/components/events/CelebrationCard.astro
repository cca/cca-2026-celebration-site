---
import type { CollectionEntry } from "astro:content";
import { formatDate, formatTime } from "../../lib/utils/format";

interface Props {
  event: CollectionEntry<"events">;
}

const { event } = Astro.props;
const { title, date, time, location, description, slug } = event.data;
const href = `/commencement/${slug}/`;
const dateDisplay = formatDate(date);
---

<a href={href} class="celebration-card reveal">
  <article>
    <span class="celebration-badge">CELEBRATION</span>
    <h3 class="celebration-title">{title}</h3>
    <time class="celebration-date">{dateDisplay}</time>
    <p class="celebration-time">{formatTime(time)}</p>
    <p class="celebration-location">{location}</p>
    <p class="celebration-desc">{description}</p>
  </article>
</a>

<style>
  .celebration-card {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: none;
    padding: var(--space-6);
    padding-left: calc(var(--space-6) + 3px);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Animated prismatic gradient left border */
  .celebration-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 3px;
    background: var(--gradient-prismatic);
    border-radius: 4px 0 0 4px;
  }

  .celebration-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  @media (prefers-reduced-motion: no-preference) {
    .celebration-card::before {
      animation: prismatic-shift 6s linear infinite;
    }

    .celebration-card:hover::before {
      animation-duration: 2s;
    }
  }

  .celebration-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent-tint);
    color: var(--color-accent);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    margin-bottom: var(--space-3);
  }

  .celebration-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .celebration-date {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    background: var(--color-surface);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    margin-bottom: var(--space-1);
  }

  .celebration-time {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-1);
  }

  .celebration-location {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }

  .celebration-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
</style>
