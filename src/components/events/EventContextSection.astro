---
interface MetaItem {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  id?: string;
  kicker: string;
  heading?: string;
  paragraphs: string[];
  meta?: MetaItem[];
}

const { id, kicker, heading, paragraphs, meta } = Astro.props;
---

<section id={id} class:list={['context-section', 'reveal', meta ? 'has-meta' : '']}>
  <div class="context-grid">
    <div class="context-text">
      <span class="context-kicker">{kicker}</span>
      {heading && <h2 class="context-heading">{heading}</h2>}
      {paragraphs.map((p) => <p class="context-body">{p}</p>)}
    </div>
    {meta && meta.length > 0 && (
      <div class="context-meta">
        <dl class="meta-list">
          {meta.map((item) => (
            <div class="meta-item">
              <dt>{item.label}</dt>
              <dd>
                {item.href
                  ? <a href={item.href} target="_blank" rel="noopener noreferrer" class="meta-link">{item.value}</a>
                  : item.value
                }
              </dd>
            </div>
          ))}
        </dl>
      </div>
    )}
  </div>
</section>

<style>
  .context-section {
    padding-block: var(--space-12);
  }

  .context-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .has-meta .context-grid {
      grid-template-columns: 3fr 2fr;
      align-items: start;
      gap: var(--space-14);
    }
  }

  .context-kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .context-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: normal;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .context-body {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 55ch;
    margin-bottom: var(--space-4);
  }

  .context-body:last-child {
    margin-bottom: 0;
  }

  .meta-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .meta-item dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: var(--space-1);
  }

  .meta-item dd {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
  }

  .meta-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .meta-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
