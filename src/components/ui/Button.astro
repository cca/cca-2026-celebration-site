---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "link";
  arrow?: string;
  [key: string]: any;
}

const { href, variant = "primary", arrow, ...rest } = Astro.props;
const Tag = href ? "a" : "button";

// Pick a random arrow SVG (1-13, skipping 1) if variant is link and no arrow specified
const LONG_TAIL_ARROWS = ['02', '05', '06', '07', '11', '12'];
const arrowIndex = arrow ?? LONG_TAIL_ARROWS[Math.floor(Math.random() * LONG_TAIL_ARROWS.length)];
---

<Tag href={href} class:list={["btn", `btn-${variant}`]} {...rest}>
  <slot />
  {variant === "link" && (
    <span
      class="btn-link__arrow"
      aria-hidden="true"
      style={`--arrow-src: url(/images/scanned-graphics/arrows/arrow-${arrowIndex}.svg)`}
    />
  )}
</Tag>

<style>
  .btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    border: none;
    border-radius: var(--radius-card);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform var(--duration-fast) var(--ease-out-expo),
                box-shadow var(--duration-base) var(--ease-out-expo),
                background var(--duration-base) var(--ease-out-expo);
  }

  .btn:active {
    transform: scale(0.97);
  }

  /* ── Primary: solid accent ── */
  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, #FFC845);
    box-shadow: 0 4px 24px rgba(var(--color-accent-rgb), 0.3);
  }

  /* ── Secondary: accent border ── */
  .btn-secondary {
    background: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .btn-secondary:hover {
    color: color-mix(in srgb, var(--color-accent) 80%, #000);
    border-color: color-mix(in srgb, var(--color-accent) 80%, #000);
  }

  /* ── Outline: solid accent border, fill on hover ── */
  .btn-outline {
    background: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .btn-outline::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out-expo);
    z-index: -1;
  }

  .btn-outline:hover {
    color: #fff;
  }

  .btn-outline:hover::before {
    transform: scaleX(1);
  }

  /* ── Link: text + wavy arrow, no box ── */
  .btn-link {
    background: none;
    padding: 0 var(--space-16) var(--space-12) 0;
    border-radius: 0;
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    display: inline-block;
    text-align: left;
    position: relative;
    overflow: visible;
    transition: color var(--duration-base) var(--ease-out-expo);
  }

  .btn-link:hover {
    color: color-mix(in srgb, var(--color-accent) 80%, #000);
  }

  .btn-link:hover .btn-link__arrow {
    transform: translateX(8px);
  }

  .btn-link:active {
    transform: none;
  }

  .btn-link__arrow {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 64px;
    height: 64px;
    background: currentColor;
    mask-image: var(--arrow-src);
    -webkit-mask-image: var(--arrow-src);
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    transition: transform var(--duration-base) var(--ease-out-expo);
  }
</style>
