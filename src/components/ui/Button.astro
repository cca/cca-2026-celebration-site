---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline";
  [key: string]: any;
}

const { href, variant = "primary", ...rest } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag href={href} class:list={["btn", `btn-${variant}`]} {...rest}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    border: none;
    border-radius: var(--radius-card);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform var(--duration-fast) var(--ease-out-expo),
                box-shadow var(--duration-base) var(--ease-out-expo),
                background var(--duration-base) var(--ease-out-expo);
  }

  .btn:active {
    transform: scale(0.97);
  }

  /* ── Primary: solid accent ── */
  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, #FFC845);
    box-shadow: 0 4px 24px rgba(var(--color-accent-rgb), 0.3);
  }

  /* ── Secondary: accent border ── */
  .btn-secondary {
    background: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .btn-secondary:hover {
    color: color-mix(in srgb, var(--color-accent) 80%, #000);
    border-color: color-mix(in srgb, var(--color-accent) 80%, #000);
  }

  /* ── Outline: solid accent border, fill on hover ── */
  .btn-outline {
    background: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .btn-outline::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out-expo);
    z-index: -1;
  }

  .btn-outline:hover {
    color: #fff;
  }

  .btn-outline:hover::before {
    transform: scaleX(1);
  }
</style>
