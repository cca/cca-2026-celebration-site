---
interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
  credit?: string;
}

interface Props {
  title: string;
  label: string;
  images: GalleryImage[];
  marqueeDuration?: number;
  link?: { href: string; text: string };
}

const { title, label, images, marqueeDuration = 60, link } = Astro.props;
const hasCaption = images.some((img) => img.caption || img.credit);
const doubledImages = [...images, ...images];
---

<section class="past-gallery">
  <div class="container past-gallery__header">
    <div>
      <span class="section-label reveal">{label}</span>
      <h2 class="section-heading reveal">{title}</h2>
    </div>
    <div class="past-gallery__header-actions">
      {link && (
        <a href={link.href} class="past-gallery__link reveal">
          {link.text}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="8" x2="13" y2="8" />
            <polyline points="9 4 13 8 9 12" />
          </svg>
        </a>
      )}
      <button
        class="past-gallery__pause-btn reveal"
        type="button"
        data-pause-btn
        aria-label="Pause gallery animation"
      >
        Pause
      </button>
    </div>
  </div>
  <div class="past-gallery__viewport reveal">
    <div
      class="past-gallery__track"
      data-gallery-track
      data-marquee-duration={marqueeDuration}
    >
      {doubledImages.map(({ src, alt, caption, credit }) => (
        <button class={`past-gallery__item ${hasCaption ? 'past-gallery__item--captioned' : ''}`} type="button" data-lightbox-trigger>
          <img src={src} alt={alt} loading="lazy" />
          {(caption || credit) && (
            <span class="past-gallery__caption">
              {caption && <span class="past-gallery__caption-title">{caption}</span>}
              {credit && <span class="past-gallery__caption-credit">{credit}</span>}
            </span>
          )}
        </button>
      ))}
    </div>
  </div>
  <dialog class="past-gallery__lightbox" data-lightbox>
    <button class="past-gallery__lightbox-close" type="button" aria-label="Close lightbox">&times;</button>
    <img class="past-gallery__lightbox-img" src="" alt="" />
  </dialog>
</section>

<script>
  let cleanupFn: (() => void) | undefined;

  function initPastGallery() {
    cleanupFn?.();

  document.querySelectorAll<HTMLElement>('.past-gallery').forEach((section) => {
    // Skip already-initialized sections
    if (section.dataset.galleryInit) return;
    section.dataset.galleryInit = 'true';
    const track = section.querySelector<HTMLElement>('[data-gallery-track]');
    const pauseBtn = section.querySelector<HTMLButtonElement>('[data-pause-btn]');
    const dialog = section.querySelector<HTMLDialogElement>('[data-lightbox]');
    const lightboxImg = dialog?.querySelector<HTMLImageElement>('.past-gallery__lightbox-img');
    const triggers = section.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]');

    if (!track || !pauseBtn || !dialog || !lightboxImg) return;

    // Marquee state
    const duration = parseFloat(track.dataset.marqueeDuration || '60');
    const halfWidth = track.scrollWidth / 2;
    const baseSpeed = halfWidth / (duration * 60); // px per frame at 60fps
    let position = 0;
    let currentSpeed = baseSpeed;
    let targetSpeed = baseSpeed;
    let paused = false;
    let hovering = false;
    const lerpFactor = 0.03;

    // Respect prefers-reduced-motion
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let reducedMotion = motionQuery.matches;

    function updatePauseBtn() {
      const stopped = paused || reducedMotion;
      pauseBtn!.textContent = stopped ? 'Play' : 'Pause';
      pauseBtn!.setAttribute('aria-label', stopped ? 'Play gallery animation' : 'Pause gallery animation');
    }

    function recalcTarget() {
      targetSpeed = (paused || hovering || reducedMotion) ? 0 : baseSpeed;
    }

    motionQuery.addEventListener('change', (e) => {
      reducedMotion = e.matches;
      recalcTarget();
      updatePauseBtn();
    });

    if (reducedMotion) {
      targetSpeed = 0;
      currentSpeed = 0;
      updatePauseBtn();
    }

    // Pause/Play toggle
    pauseBtn.addEventListener('click', () => {
      paused = !paused;
      recalcTarget();
      updatePauseBtn();
    });

    // Hover pause
    const viewport = section.querySelector<HTMLElement>('.past-gallery__viewport');
    viewport?.addEventListener('mouseenter', () => {
      hovering = true;
      recalcTarget();
    });
    viewport?.addEventListener('mouseleave', () => {
      hovering = false;
      recalcTarget();
    });

    // Animation loop
    let rafId: number;
    function animate() {
      currentSpeed += (targetSpeed - currentSpeed) * lerpFactor;

      // Snap to zero when close enough to avoid jittering
      if (Math.abs(currentSpeed) < 0.01 && targetSpeed === 0) {
        currentSpeed = 0;
      }

      position -= currentSpeed;

      // Seamless loop reset
      if (position <= -halfWidth) {
        position += halfWidth;
      }

      track!.style.transform = `translateX(${position}px)`;
      rafId = requestAnimationFrame(animate);
    }

    rafId = requestAnimationFrame(animate);
    cleanupFn = () => {
      cancelAnimationFrame(rafId);
      cleanupFn = undefined;
    };
    document.addEventListener('astro:before-swap', () => cleanupFn?.(), { once: true });

    // Lightbox
    triggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        const img = btn.querySelector('img');
        if (!img) return;
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        dialog.showModal();
      });
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        dialog.close();
      }
    });

    dialog.querySelector('.past-gallery__lightbox-close')?.addEventListener('click', () => {
      dialog.close();
    });
  });
  }

  initPastGallery();
  document.addEventListener('astro:page-load', initPastGallery);
</script>

<style>
  .past-gallery {
    padding-block: var(--space-20);
    border-top: 1px solid var(--color-border);
    overflow: hidden;
  }

  .past-gallery__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .past-gallery__header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .past-gallery__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.2s var(--ease-out-expo);
  }

  .past-gallery__link:hover {
    gap: var(--space-3);
  }

  .past-gallery__pause-btn {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .past-gallery__pause-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .past-gallery__viewport {
    margin-top: var(--space-8);
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 4%,
      black 96%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 4%,
      black 96%,
      transparent 100%
    );
    overflow: hidden;
  }

  .past-gallery__track {
    display: flex;
    gap: var(--space-4);
    padding-block: var(--space-2);
    width: max-content;
    will-change: transform;
  }

  .past-gallery__item {
    flex-shrink: 0;
    width: 380px;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .past-gallery__item:hover {
    transform: scale(1.02);
  }

  @media (min-width: 768px) {
    .past-gallery__item {
      width: 520px;
    }
  }

  .past-gallery__item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: none;
  }

  .past-gallery__caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-2) var(--space-1) 0;
    text-align: left;
  }

  .past-gallery__caption-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .past-gallery__caption-credit {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  /* Lightbox */
  .past-gallery__lightbox {
    border: none;
    background: transparent;
    padding: 0;
    max-width: none;
    max-height: none;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    inset: 0;
  }

  .past-gallery__lightbox:not([open]) {
    display: none;
  }

  .past-gallery__lightbox::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }

  .past-gallery__lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-card);
    transform: scale(0.9);
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .past-gallery__lightbox[open] .past-gallery__lightbox-img {
    transform: scale(1);
    opacity: 1;
  }

  .past-gallery__lightbox-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    padding: var(--space-2);
    z-index: 1;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .past-gallery__lightbox-close:hover {
    opacity: 1;
  }
</style>
