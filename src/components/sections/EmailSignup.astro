---
import Button from '../ui/Button.astro';
import ArrowLoop3D from '../effects/ArrowLoop3D.astro';
import ChimeraLoop3D from '../effects/ChimeraLoop3D.astro';

interface Props {
  heading?: string;
  description?: string;
  buttonText?: string;
  /** Use 'chimera' for chimera expanded shapes instead of arrows */
  doodleVariant?: 'arrows' | 'chimera';
}

const {
  heading = "Stay connected",
  description = "Join the CCA 2026 Celebrations list to get event updates, schedule changes, and RSVP reminders.",
  buttonText = "Subscribe",
  doodleVariant = "arrows",
} = Astro.props;
---

<section class="signup-section reveal" aria-labelledby={heading ? "signup-heading" : undefined} data-cursor-scope>
  <div class="container">
    <div class="signup-card-wrapper">
      <div class="signup-card">
      {heading && <h2 id="signup-heading" class="signup-heading">{heading}</h2>}
      {description && <p class="signup-description">{description}</p>}

      <form class="signup-form" action="https://cca.us7.list-manage.com/subscribe/post?u=1f736fa8e375bd406f10f81ae&id=080b9b28e9&f_id=0002d4e4f0" method="POST" target="_self" novalidate aria-label="Email signup">
        {/* Mailchimp bot protection */}
        <div class="signup-hp" aria-hidden="true">
          <label for="signup-hp">Leave blank</label>
          <input type="text" id="signup-hp" name="b_1f736fa8e375bd406f10f81ae_080b9b28e9" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="tags" value="8268898" />

        <div class="signup-fields">
          <label for="mce-EMAIL" class="sr-only">Email address</label>
          <input
            type="email"
            id="mce-EMAIL"
            name="EMAIL"
            placeholder="you@example.com"
            required
            autocomplete="email"
          />
          <Button type="submit" variant="primary">{buttonText}</Button>
        </div>
        <p class="signup-privacy">We respect your privacy. Unsubscribe anytime.</p>
      </form>
    </div>
    </div>
  </div>
  <!-- Doodles after container so they paint on top and receive pointer events -->
  <div
    class="floating-img floating-img-behind"
    data-cursor-track
    data-cursor-strength="0.04"
    data-cursor-max="30"
    data-cursor-lerp="0.08"
    aria-hidden="true"
  >
    {doodleVariant === 'chimera' ? (
      <ChimeraLoop3D
        id="signup-chimera-1"
        cycleDuration={4}
        fadeOverlap={0.3}
        elasticIntensity={1}
        skewAmount={15}
        driftSpeed={1}
        sizeVariance={0.25}
        color="#ffffff"
      />
    ) : (
      <ArrowLoop3D
        id="signup-arrow-1"
        cycleDuration={3}
        fadeOverlap={0.15}
        scaleAmount={0.04}
        spinDegrees={180}
        spinAxis="Y"
        perspective={300}
        sizeVariance={0.3}
        color="#ffffff"
      />
    )}
  </div>
  <div
    class="floating-img floating-img-front"
    data-cursor-track
    data-cursor-strength="0.05"
    data-cursor-max="35"
    data-cursor-lerp="0.1"
    aria-hidden="true"
  >
    {doodleVariant === 'chimera' ? (
      <ChimeraLoop3D
        id="signup-chimera-2"
        cycleDuration={4}
        fadeOverlap={0.3}
        elasticIntensity={1}
        skewAmount={15}
        driftSpeed={1}
        sizeVariance={0.25}
        color="#ffffff"
        startDelay={2}
      />
    ) : (
      <ArrowLoop3D
        id="signup-arrow-2"
        cycleDuration={3}
        fadeOverlap={0.15}
        scaleAmount={0.04}
        spinDegrees={180}
        spinAxis="Y"
        perspective={300}
        sizeVariance={0.3}
        color="#ffffff"
        startDelay={1.5}
      />
    )}
  </div>
</section>

<script src="../../scripts/arrow-loop-3d.ts"></script>
<script src="../../scripts/chimera-loop-3d.ts"></script>
<script>
  // Find the component's own section (not an outer wrapper that shares the class name)
  const signupSection = document.querySelector('.signup-card-wrapper')?.closest('.signup-section') as HTMLElement | null;

  // Hovering doodles → toggle hover state on section for card lift + drift
  const doodles = signupSection?.querySelectorAll('.floating-img');
  doodles?.forEach((img) => {
    img.addEventListener('mouseenter', () => signupSection?.classList.add('is-hovered'));
    img.addEventListener('mouseleave', () => signupSection?.classList.remove('is-hovered'));
  });

  // Newsletter form submit → push generate_lead before Mailchimp navigation
  const form = signupSection?.querySelector('.signup-form');
  form?.addEventListener('submit', () => {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'generate_lead' });
  });

  // Click anywhere on the card → focus the email input
  const card = signupSection?.querySelector('.signup-card') as HTMLElement | null;
  const emailInput = signupSection?.querySelector<HTMLInputElement>('#mce-EMAIL');

  card?.addEventListener('click', (e) => {
    // Don't steal focus from interactive elements the user actually clicked
    const target = e.target as HTMLElement;
    if (target.closest('input, button, a, label')) return;
    emailInput?.focus();
  });
</script>

<style>
  .signup-section {
    position: relative;
    padding-block: var(--space-16);
  }

  .signup-card {
    position: relative;
    max-width: 600px;
    margin-inline: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    text-align: center;
    box-shadow: var(--shadow-card-rest);
    overflow: visible;
    transition: transform 0.4s var(--ease-out-expo),
                box-shadow 0.4s var(--ease-out-expo);
  }

  .signup-card:has(input:focus) {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .signup-card-wrapper:hover .signup-card,
  .signup-section.is-hovered .signup-card {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  /* Speed up prismatic border on hover */
  @media (prefers-reduced-motion: no-preference) {
    .signup-card-wrapper:hover .signup-card::before,
    .signup-section.is-hovered .signup-card::before {
      animation-duration: 2s;
    }
  }

  /* Glow on signup fields when card is hovered */
  .signup-card-wrapper:hover .signup-fields,
  .signup-section.is-hovered .signup-fields {
    box-shadow: 0 0 20px rgba(44, 181, 160, 0.1);
  }

  .signup-card-wrapper:hover .signup-fields input[type="email"],
  .signup-section.is-hovered .signup-fields input[type="email"] {
    border-color: var(--color-accent);
  }

  /* Card wrapper */
  .signup-card-wrapper {
    position: relative;
    max-width: 600px;
    margin-inline: auto;
  }

  /* Floating doodles — positioned relative to .signup-section */
  .floating-img {
    position: absolute;
    opacity: 1;
    cursor: pointer;
    z-index: 2;
    transition: transform 0.4s var(--ease-out-expo);
  }

  .floating-img-behind {
    width: clamp(48px, 6vw, 90px);
    height: clamp(48px, 6vw, 90px);
    bottom: var(--space-16);
    left: calc(50% - 420px);
    transform: rotate(-6deg);
  }

  .floating-img-front {
    width: clamp(36px, 4.5vw, 64px);
    height: clamp(36px, 4.5vw, 64px);
    top: var(--space-16);
    right: calc(50% - 400px);
    transform: rotate(4deg);
  }

  /* On hover, drift images outward */
  .signup-section.is-hovered .floating-img-behind {
    transform: rotate(-6deg) translate(-8px, 8px);
  }

  .signup-section.is-hovered .floating-img-front {
    transform: rotate(4deg) translate(8px, -8px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .floating-img-behind {
      animation: float-behind 8s ease-in-out infinite;
    }

    .floating-img-front {
      animation: float-front 9s ease-in-out infinite;
      animation-delay: 1s;
    }
  }

  @keyframes float-behind {
    0%, 100% { transform: rotate(-6deg) translateY(0); }
    50% { transform: rotate(-6deg) translateY(-6px); }
  }

  @keyframes float-front {
    0%, 100% { transform: rotate(4deg) translateY(0); }
    50% { transform: rotate(4deg) translateY(-6px); }
  }

  /* Pause float animation on hover so the element is stable/clickable */
  .floating-img:hover {
    animation-play-state: paused;
  }

  /* Hide floating images on small screens */
  @media (max-width: 768px) {
    .floating-img {
      display: none;
    }
  }

  /* Reduced motion: keep hover lift/shadow, disable float animations and drift */
  @media (prefers-reduced-motion: reduce) {
    .signup-section.is-hovered .floating-img-behind {
      transform: rotate(-6deg);
    }

    .signup-section.is-hovered .floating-img-front {
      transform: rotate(4deg);
    }
  }

  /* Decorative seal watermark behind card */
  .signup-card::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-height: 100%;
    aspect-ratio: 1;
    background: var(--color-accent);
    opacity: 0.03;
    mask-image: url('/images/cca-seal.svg');
    -webkit-mask-image: url('/images/cca-seal.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme="commencement"]) .signup-card::after,
  :global([data-theme="thesis-grad"]) .signup-card::after {
    opacity: 0.04;
  }

  /* Prismatic gradient top border */
  .signup-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-prismatic);
    border-radius: var(--radius-card) var(--radius-card) 0 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .signup-card::before {
      animation: prismatic-shift 6s linear infinite;
    }
  }

  .signup-heading,
  .signup-description,
  .signup-form {
    position: relative;
    z-index: 1;
  }

  .signup-heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .signup-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
    max-width: 50ch;
    margin-inline: auto;
  }

  /* Honeypot — must be invisible but not display:none for bot compat */
  .signup-hp {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    overflow: hidden;
  }

  .signup-fields {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
  }

  .signup-fields input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .signup-fields input[type="email"]:focus {
    border-color: var(--color-accent);
  }

  .signup-privacy {
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-top: var(--space-3);
  }

  /* Stack vertically on small screens */
  @media (max-width: 480px) {
    .signup-card {
      padding: var(--space-6);
    }

    .signup-fields {
      flex-direction: column;
    }
  }
</style>
