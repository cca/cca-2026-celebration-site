---
interface Props {
  heading: string;
  content: string;
  collapsible?: boolean;
}

const { heading, content, collapsible = false } = Astro.props;

/** Generate a URL-safe slug from heading text. */
function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

/** Convert a simple markdown string to HTML. */
function markdownToHtml(md: string): string {
  let html = md;

  // Convert ### headings to h4 (with id for anchor links)
  html = html.replace(/^### (.+)$/gm, (_, text) => `<h4 id="${slugify(text)}">${text}</h4>`);
  // Convert ## headings to h3 (with id for anchor links)
  html = html.replace(/^## (.+)$/gm, (_, text) => `<h3 id="${slugify(text)}">${text}</h3>`);

  // Convert **bold** to strong
  html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");

  // Convert [text](url) to anchors
  html = html.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>',
  );

  // Convert unordered list blocks (consecutive lines starting with -)
  html = html.replace(
    /(^- .+(?:\n- .+)*)/gm,
    (match) => {
      const items = match
        .split("\n")
        .map((line) => `<li>${line.replace(/^- /, "")}</li>`)
        .join("");
      return `<ul>${items}</ul>`;
    },
  );

  // Wrap remaining bare lines in <p> tags (skip lines already wrapped in tags)
  html = html
    .split("\n\n")
    .map((block) => {
      const trimmed = block.trim();
      if (!trimmed) return "";
      if (trimmed.startsWith("<")) return trimmed;
      return `<p>${trimmed}</p>`;
    })
    .join("\n");

  return html;
}

const rendered = markdownToHtml(content);
---

{collapsible ? (
  <details class="info-section info-section--collapsible reveal">
    <summary class="info-heading">{heading}</summary>
    <div class="info-content" set:html={rendered} />
  </details>
) : (
  <section class="info-section reveal">
    <h2 class="info-heading">{heading}</h2>
    <div class="info-content" set:html={rendered} />
  </section>
)}

<style>
  .info-section {
    padding-block: var(--space-8);
  }

  .info-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  /* Collapsible variant */
  .info-section--collapsible {
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 8px;
    padding: var(--space-6);
  }

  .info-section--collapsible .info-heading {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: 0;
    user-select: none;
  }

  .info-section--collapsible .info-heading::-webkit-details-marker {
    display: none;
  }

  .info-section--collapsible .info-heading::before {
    content: "";
    display: inline-block;
    width: 8px;
    height: 8px;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .info-section--collapsible[open] .info-heading::before {
    transform: rotate(45deg);
  }

  .info-section--collapsible[open] .info-heading {
    margin-bottom: var(--space-6);
    color: var(--color-accent);
  }

  .info-content {
    max-width: 72ch;
    line-height: 1.7;
    color: var(--color-text);
  }

  .info-content :global(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .info-content :global(h4) {
    font-size: var(--text-lg);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .info-content :global(p) {
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
  }

  .info-content :global(ul) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .info-content :global(li) {
    margin-bottom: var(--space-2);
    font-size: var(--text-base);
  }

  .info-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .info-content :global(a:hover) {
    opacity: 0.8;
  }

  .info-content :global(strong) {
    font-weight: 600;
  }
</style>
