---
import type { Phase } from '../../config/phases';
import { isPhaseBefore } from '../../config/phases';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isContentVisible } from '../../lib/utils/phase';

interface Props {
  minimal?: boolean;
}

interface NavSubItem {
  label: string;
  href: string;
}

interface NavItem {
  label: string;
  href: string;
  hiddenIn?: Phase[];
  visibleIn?: Phase[];
  children?: NavSubItem[];
  activePrefix?: string;
}

const { minimal = false } = Astro.props;
const currentPath = Astro.url.pathname;
const phase = getCurrentPhase(Astro.url);

const allNavItems: NavItem[] = [
  {
    label: "Commencement",
    href: "/commencement/",
    activePrefix: "/commencement/",
    children: isPhaseBefore(phase, 'pre-event') ? undefined : [
      { label: "Master's Ceremony", href: "/commencement/graduate/" },
      { label: "Bachelor's Ceremony", href: "/commencement/undergraduate/" },
      { label: "Multicultural Celebration", href: "/commencement/multicultural-celebration/" },
      { label: "Lavender Celebration", href: "/commencement/lavender-celebration/" },
    ],
  },
  {
    label: "Graduation Exhibitions",
    href: "/thesis/",
    activePrefix: "/thesis/",
  },
  {
    label: "Student Showcase",
    href: "/showcase/",
    activePrefix: "/showcase/",
    hiddenIn: ['save-the-date'],
    children: [
      { label: "Graduating Students", href: "/showcase/students/" },
      { label: "Thesis Work", href: "/showcase/works/" },
    ],
  },
];

const navItems = allNavItems.filter(item =>
  isContentVisible(phase, item.visibleIn, item.hiddenIn)
);

const isSubscribeActive = currentPath.startsWith("/subscribe");
---

<header class:list={["site-header", { "site-header--minimal": minimal }]}>
  <div class="scroll-progress" aria-hidden="true"></div>
  <div class="header-inner container">
    <a href="/" class="site-logo">
      <svg class="logo-mark" viewBox="0 0 200 65" aria-label="CCA" role="img">
        <path d="M32.9004 0C39.7701 5.58807e-05 45.2899 1.47995 50.9697 5.21973V17.1904C44.5498 11.5105 39.4602 9.25984 32.6104 9.25977C19.6004 9.25977 10.4805 18.9604 10.4805 32.6904C10.4807 46.4202 19.4505 55.5703 32.6104 55.5703C39.7701 55.5702 44.5501 53.6201 51.1299 47.8203V59.5996C44.86 63.4895 39.7802 64.9902 32.9004 64.9902L32.0352 64.96C13.9342 64.5311 0 50.663 0 32.5996C0.000205257 14.2498 14.5205 0 32.9004 0ZM104.22 0C111.07 0 116.61 1.47986 122.3 5.21973V17.1904C115.85 11.5104 110.78 9.25977 103.93 9.25977C90.8899 9.25992 81.7998 18.9605 81.7998 32.6904C81.8 46.4201 90.75 55.5702 103.93 55.5703C111.07 55.5703 115.85 53.6201 122.43 47.8203V59.5996C116.16 63.4896 111.07 64.9902 104.22 64.9902L103.354 64.96C85.2156 64.5309 71.3203 50.6533 71.3203 32.5898C71.3204 14.24 85.8199 0.000145654 104.22 0ZM164.01 22.2002C175.8 22.2002 185.4 31.7999 185.4 43.5898C185.4 55.3798 175.8 64.9795 164.01 64.9795C152.22 64.9794 142.62 55.3898 142.62 43.5898C142.62 31.79 152.22 22.2003 164.01 22.2002ZM199.97 63.4102H189.97V11.2305H151.14L156.57 1.73047H199.97V63.4102ZM164.01 30.8896C157.07 30.8898 151.42 36.6302 151.42 43.5801C151.42 50.5299 157.06 56.2801 164.01 56.2803C170.95 56.2803 176.6 50.52 176.6 43.5801C176.6 36.6401 170.95 30.8896 164.01 30.8896Z" fill="currentColor"/>
      </svg>
      <span class="logo-year" role="img" aria-label="2026"></span>
    </a>

    {/* ── Desktop nav ── */}
    {!minimal && (
      <nav class="desktop-nav" aria-label="Main navigation">
        <ul class="nav-list" role="list">
          {navItems.map((item) =>
            item.children ? (
              <li class="has-dropdown">
                <a
                  href={item.href}
                  class="nav-link dropdown-trigger"
                  aria-expanded="false"
                  aria-haspopup="true"
                  data-active={item.activePrefix && currentPath.startsWith(item.activePrefix) ? "true" : undefined}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                  <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
                <div class="nav-dropdown" role="menu">
                  <ul role="list">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          role="menuitem"
                          aria-current={currentPath === child.href ? "page" : undefined}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ) : (
              <li>
                <a
                  href={item.href}
                  class="nav-link"
                  data-active={item.activePrefix && currentPath.startsWith(item.activePrefix) ? "true" : undefined}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            )
          )}
        </ul>
      </nav>
    )}

    <div class="header-actions">
      {!minimal && <a href="/subscribe/" class="nav-cta">Join Us</a>}

      {/* ── Hamburger ── */}
      <button
        class="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  {/* ── Mobile drawer ── */}
  <div class="mobile-backdrop" aria-hidden="true"></div>
  <nav id="mobile-menu" class="mobile-menu" aria-label="Mobile navigation" aria-hidden="true" inert>
    <ul class="mobile-nav-list" role="list">
      {(() => {
        let staggerIndex = 0;
        return navItems.map((item) => {
          if (item.children) {
            const sectionDelay = staggerIndex * 60;
            const result = (
              <li class="mobile-section" style={`--stagger-delay: ${sectionDelay}ms`}>
                {staggerIndex === 0 && <span class="mobile-section-label">Events</span>}
                <div class="mobile-group">
                  <a href={item.href} class="mobile-group-label" aria-current={currentPath === item.href ? "page" : undefined}>{item.label}</a>
                  <ul role="list">
                    {item.children.map((child, i) => {
                      staggerIndex++;
                      return (
                        <li class="mobile-nav-item" style={`--stagger-delay: ${staggerIndex * 60}ms`}>
                          <a
                            href={child.href}
                            aria-current={currentPath === child.href ? "page" : undefined}
                          >
                            {child.label}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              </li>
            );
            staggerIndex++;
            return result;
          } else {
            staggerIndex++;
            return (
              <li class="mobile-nav-item" style={`--stagger-delay: ${staggerIndex * 60}ms`}>
                <a
                  href={item.href}
                  class="mobile-top-link"
                  data-active={item.activePrefix && currentPath.startsWith(item.activePrefix) ? "true" : undefined}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          }
        });
      })()}
      {(() => {
        const totalItems = navItems.reduce((sum, item) => sum + 1 + (item.children?.length ?? 0), 0);
        return (
          <li class="mobile-nav-item" style={`--stagger-delay: ${(totalItems + 1) * 60}ms`}>
            <a
              href="/subscribe/"
              class="mobile-top-link"
              aria-current={isSubscribeActive ? "page" : undefined}
            >
              Join Us
            </a>
          </li>
        );
      })()}
    </ul>
  </nav>
</header>

<script>
  function initHeaderNav() {
    // ── Hamburger toggle ──
    const hamburger = document.querySelector(".hamburger") as HTMLButtonElement;
    const mobileMenu = document.getElementById("mobile-menu") as HTMLElement;
    const backdrop = document.querySelector(".mobile-backdrop") as HTMLElement;

    if (!hamburger || !mobileMenu) return;

    // Reset mobile menu state after navigation
    mobileMenu.classList.remove("is-open");
    backdrop?.classList.remove("is-open");
    hamburger.setAttribute("aria-expanded", "false");
    hamburger.setAttribute("aria-label", "Open menu");
    mobileMenu.setAttribute("aria-hidden", "true");
    mobileMenu.setAttribute("inert", "");
    document.body.style.overflow = "";

    function openDrawer() {
      mobileMenu.classList.add("is-open");
      backdrop.classList.add("is-open");
      mobileMenu.removeAttribute("inert");
      mobileMenu.setAttribute("aria-hidden", "false");
      hamburger.setAttribute("aria-expanded", "true");
      hamburger.setAttribute("aria-label", "Close menu");
      document.body.style.overflow = "hidden";
      const firstLink = mobileMenu.querySelector("a");
      firstLink?.focus({ preventScroll: true });
    }

    function closeDrawer() {
      mobileMenu.classList.remove("is-open");
      backdrop.classList.remove("is-open");
      hamburger.setAttribute("aria-expanded", "false");
      hamburger.setAttribute("aria-label", "Open menu");
      document.body.style.overflow = "";

      function onTransitionEnd(e: TransitionEvent) {
        if (e.propertyName !== "transform") return;
        mobileMenu.removeEventListener("transitionend", onTransitionEnd);
        if (!mobileMenu.classList.contains("is-open")) {
          mobileMenu.setAttribute("aria-hidden", "true");
          mobileMenu.setAttribute("inert", "");
        }
      }
      mobileMenu.addEventListener("transitionend", onTransitionEnd);

      hamburger.focus();
    }

    hamburger.addEventListener("click", () => {
      const isOpen = mobileMenu.classList.contains("is-open");
      isOpen ? closeDrawer() : openDrawer();
    });

    backdrop?.addEventListener("click", closeDrawer);

    // ── Desktop dropdowns ──
    const dropdownContainers = document.querySelectorAll<HTMLElement>(".has-dropdown");

    dropdownContainers.forEach((container) => {
      const trigger = container.querySelector(".dropdown-trigger") as HTMLAnchorElement;
      const dropdown = container.querySelector(".nav-dropdown") as HTMLElement;
      let closeTimeout: ReturnType<typeof setTimeout>;

      function openDropdown() {
        clearTimeout(closeTimeout);
        dropdownContainers.forEach((other) => {
          if (other !== container) {
            other.querySelector(".dropdown-trigger")?.setAttribute("aria-expanded", "false");
          }
        });
        trigger?.setAttribute("aria-expanded", "true");
      }

      function closeDropdown() {
        closeTimeout = setTimeout(() => {
          trigger?.setAttribute("aria-expanded", "false");
        }, 150);
      }

      trigger?.addEventListener("click", (e) => {
        const isOpen = trigger.getAttribute("aria-expanded") === "true";
        if (!isOpen) {
          e.preventDefault();
          openDropdown();
        }
      });

      container.addEventListener("mouseenter", openDropdown);
      container.addEventListener("mouseleave", closeDropdown);

      dropdown?.addEventListener("focusin", openDropdown);
      dropdown?.addEventListener("focusout", closeDropdown);
      trigger?.addEventListener("focusout", (e) => {
        if (!container.contains((e as FocusEvent).relatedTarget as Node)) {
          closeDropdown();
        }
      });
    });

    // Close all dropdowns on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        dropdownContainers.forEach((container) => {
          container.querySelector(".dropdown-trigger")?.setAttribute("aria-expanded", "false");
        });
        if (mobileMenu.classList.contains("is-open")) {
          closeDrawer();
        }
      }
    });

    // ── Scroll-based header styling ──
    const header = document.querySelector(".site-header") as HTMLElement;
    function onScroll() {
      if (window.scrollY > 10) {
        header?.classList.add("scrolled");
      } else {
        header?.classList.remove("scrolled");
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('astro:page-load', initHeaderNav);
</script>

<style>
  /* ── Header shell ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    overflow-x: clip;
    transition: background var(--duration-base) var(--ease-out-expo),
                border-color var(--duration-base) var(--ease-out-expo),
                backdrop-filter var(--duration-base) var(--ease-out-expo);
  }

  .site-header.scrolled {
    background: var(--color-header-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
  }

  /* ── Logo: CCA lettermark + 2026 shimmer ── */
  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo-mark {
    height: 1.2em;
    width: auto;
    display: block;
    color: var(--color-header-logo, var(--color-accent));
  }

  .logo-year {
    display: inline-block;
    height: 1.1em;
    aspect-ratio: 948.8 / 269.9;
    transform: translateY(0.04em);
    background: linear-gradient(
      90deg,
      var(--color-shimmer-base) 0%,
      color-mix(in srgb, var(--color-shimmer-base) 70%, var(--color-shimmer-warm)) 25%,
      var(--color-shimmer-base) 50%,
      var(--color-shimmer-warm) 75%,
      var(--color-shimmer-base) 100%
    );
    background-size: 200% auto;
    -webkit-mask-image: url('/images/logos/2026.svg');
    mask-image: url('/images/logos/2026.svg');
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    animation: shimmer 12s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-year {
      animation: none;
    }
  }

  /* ── Shared nav link style ── */
  .nav-link {
    appearance: none;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-decoration: none;
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .nav-link:hover,
  .nav-link[aria-current="page"],
  .nav-link[data-active="true"] {
    color: var(--color-accent);
  }

  .chevron {
    display: inline;
    width: 10px;
    height: 6px;
    transition: transform var(--duration-fast) var(--ease-out-expo);
  }

  .dropdown-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* ── Desktop nav ── */
  .desktop-nav {
    display: none;
  }

  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding: 0;
    margin: 0;
  }

  /* ── Header actions (RSVP + hamburger) ── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* ── RSVP CTA button ── */
  .nav-cta {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-decoration: none;
    color: #fff;
    background: var(--color-accent);
    border-radius: var(--radius-card);
    transition: background var(--duration-fast) var(--ease-out-expo),
                transform var(--duration-fast) var(--ease-out-expo);
  }

  .nav-cta:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, #000);
  }

  .nav-cta:active {
    transform: scale(0.97);
  }

  /* ── Nav dropdown ── */
  .has-dropdown {
    position: relative;
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 200;
    min-width: 200px;
    background: var(--color-dropdown-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-top: 2px solid transparent;
    border-image: var(--gradient-prismatic) 1;
    border-image-slice: 1 0 0 0;
    box-shadow: 0 8px 30px rgb(0 0 0 / 0.1);
    border-radius: 0 0 4px 4px;
    padding: var(--space-3) var(--space-4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity var(--duration-fast) var(--ease-out-expo),
                transform var(--duration-fast) var(--ease-out-expo),
                visibility var(--duration-fast);
  }

  .dropdown-trigger[aria-expanded="true"] + .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .nav-dropdown ul a {
    font-size: var(--text-xs);
    line-height: 1.2;
    white-space: nowrap;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .nav-dropdown ul a:hover,
  .nav-dropdown ul a[aria-current="page"] {
    color: var(--color-accent);
  }

  .dropdown-separator hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2) 0;
  }

  /* ── Hamburger ── */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition: transform var(--duration-base) var(--ease-in-out-quint),
                opacity var(--duration-base) var(--ease-in-out-quint);
    transform-origin: center;
  }

  /* Animate to X when open */
  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile backdrop overlay ── */
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-slow) var(--ease-out-expo),
                visibility var(--duration-slow);
  }

  .mobile-backdrop.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* ── Mobile drawer ── */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 151;
    height: 100dvh;
    width: min(85vw, 400px);
    background: var(--color-mobile-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6) var(--grid-gutter);
    overflow-y: auto;
    overscroll-behavior: contain;
    transform: translateX(100%);
    visibility: hidden;
    transition: transform var(--duration-slow) var(--ease-in-out-quint),
                visibility var(--duration-slow);
  }

  .mobile-menu.is-open {
    transform: translateX(0);
    visibility: visible;
  }

  .mobile-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Staggered reveal transitions for mobile nav items */
  .mobile-nav-item {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity var(--duration-base) var(--ease-out-expo),
                transform var(--duration-base) var(--ease-out-expo);
    transition-delay: var(--stagger-delay, 0ms);
  }

  .mobile-menu.is-open .mobile-nav-item {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-section-label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-group {
    margin-bottom: var(--space-4);
  }

  .mobile-group-label {
    display: block;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: var(--space-2);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .mobile-group-label:hover,
  .mobile-group-label[aria-current="page"] {
    color: var(--color-accent);
  }

  .mobile-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-4);
  }

  .mobile-group ul a {
    font-size: var(--text-sm);
    line-height: 1.2;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .mobile-group ul a:hover,
  .mobile-group ul a[aria-current="page"] {
    color: var(--color-accent);
  }

  .mobile-top-link {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .mobile-top-link:hover,
  .mobile-top-link[aria-current="page"] {
    color: var(--color-accent);
  }

  /* ── Reduced motion: collapse drawer transitions ── */
  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .mobile-backdrop,
    .mobile-nav-item {
      transition: none;
    }
  }

  /* ── Responsive: show desktop nav at 768px+, hide hamburger ── */
  @media (min-width: 768px) {
    .desktop-nav {
      display: block;
    }

    .hamburger {
      display: none;
    }

    /* Minimal header: keep hamburger visible on desktop */
    .site-header--minimal .hamburger {
