              </svg>
            </a>
          </div>
        </div>
      </nav>
    </div>

    <div class="footer-land">
      <hr class="footer-divider" />
      <p class="footer-land-text">
        <em>CCA is situated on the unceded territories of the Ohlone peoples.</em>
        <a href="https://www.cca.edu/about/indigenous-land-acknowledgment/" target="_blank" rel="noopener noreferrer">Learn more</a>
      </p>
    </div>

    <div class="footer-bottom">
      <p class="copyright">&copy; {year} California College of the Arts. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-surface);
    padding-block: var(--space-12) var(--space-8);
    margin-top: var(--space-16);
  }

  /* Prismatic gradient top border */
  .site-footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--theme-gradient);
  }

  /* Main content grid */
  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: var(--space-16);
    padding-bottom: var(--space-10);
  }

  /* Brand tagline */
  .footer-brand {
    max-width: 320px;
  }

  .footer-brand__lockup {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .footer-brand__year {
    display: inline-block;
    height: 40px;
    aspect-ratio: 948.8 / 269.9;
    background: linear-gradient(
      90deg,
      var(--color-shimmer-base) 0%,
      var(--color-shimmer-highlight) 25%,
      var(--color-shimmer-base) 50%,
      var(--color-shimmer-warm) 75%,
      var(--color-shimmer-base) 100%
    );
    background-size: 200% auto;
    -webkit-mask-image: url('/images/logos/2026.svg');
    mask-image: url('/images/logos/2026.svg');
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: left center;
    mask-position: left center;
    animation: shimmer 6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-brand__year {
      animation: none;
    }
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .footer-tagline a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .footer-tagline a:hover {
    color: var(--color-accent);
  }

  /* Nav columns */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0;
    margin: 0;
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  /* Address */
  .footer-address {
    font-style: normal;
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .footer-address a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
    margin-bottom: var(--space-1);
  }

  .footer-address a:hover {
    color: var(--color-accent);
  }

  .footer-address-street {
    color: var(--color-text);
  }

  .footer-address-street:hover {
    color: var(--color-accent);
  }

  /* Contact */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .footer-contact a {
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact a:hover {
    color: var(--color-accent);
  }

  /* Social icons */
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

  .footer-social svg {
    width: 20px;
    height: 20px;
  }

  /* Land acknowledgement */
  .footer-land {
    padding-bottom: var(--space-6);
  }

  .footer-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0 0 var(--space-6);
  }

  .footer-land-text {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0;
    line-height: 1.6;
  }

  .footer-land-text a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: var(--space-1);
    transition: color 0.2s ease;
  }

  .footer-land-text a:hover {
    color: var(--color-accent);
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .copyright {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    margin: 0;
  }

  .footer-bottom-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-bottom-link:hover {
    color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-brand {
      max-width: none;
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
