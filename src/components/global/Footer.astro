---
import CcaSeal from '../ui/CcaSeal.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content container">
    <div class="footer-main">
      <div class="footer-brand">
        <div class="footer-brand__lockup">
          <CcaSeal size="52px" color="var(--color-teal)" opacity={0.7} />
          <span class="footer-brand__year" role="img" aria-label="2026"></span>
        </div>
        <p class="footer-tagline">
          Celebrate the achievements of CCA's commencement class of 2026 at commencement ceremonies, exhibitions, and showcases.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <ul class="footer-links" role="list">
            <li><a href="/commencement/">Commencement</a></li>
            <li><a href="/thesis/">Graduation Exhibitions</a></li>
          </ul>
        </div>

        <div class="footer-col footer-col--cca">
          <address class="footer-address">
            <a href="https://www.cca.edu" target="_blank" rel="noopener noreferrer">
              California College of the Arts
            </a>
            <a href="https://goo.gl/maps/qVqfyQnk4Wp" target="_blank" rel="noopener noreferrer" class="footer-address-street">
              145 Hooper Street<br>
              San Francisco, CA 94107
            </a>
          </address>
