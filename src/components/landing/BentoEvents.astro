---
/**
 * BentoEvents — Auto-flow bento grid for celebration events.
 * Past events sort to the end and render with a "PAST EVENT" badge.
 */
import type { CollectionEntry } from "astro:content";
import BentoEventCard from "./BentoEventCard.astro";

interface Props {
  events: CollectionEntry<"events">[];
}

const { events } = Astro.props;

type Size = "large" | "tall" | "wide" | "compact";

// Per-event size in the bento. Unlisted events fall back to "compact".
const sizeBySlug: Record<string, Size> = {
  "fine-arts-senior-exhibition":        "tall",
  "grad-lab-mfa-first-year-exhibition": "compact",
  "mfa-writing-25th-anniversary":       "tall",
  "vcs-spring-symposium":               "compact",
  "2d-programs-open-studios":           "compact",
  "architecture-studio-conversations":  "tall",
  "mfa-exhibition":                     "tall",
  "film-screenings":                    "wide",
  "animation-senior-showcase":          "wide",
  "game-arts-showcase":                 "compact",
  "dmba-venture-showcase":              "compact",
  "extension-reception":                "wide",
  "all-campus-graduation-exhibition":   "large",
  "illustration-senior-show":           "compact",
  "industrial-design-senior-show":      "compact",
  "graphic-design-senior-show":         "compact",
  "fashion-design-senior-show":         "compact",
  "interaction-design-showcase":        "compact",
  "mfa-design-silver-linings":          "compact",
};

function spanFor(size: Size) {
  if (size === "large") return { col: 2, row: 2 };
  if (size === "tall")  return { col: 1, row: 2 };
  if (size === "wide")  return { col: 2, row: 1 };
  return { col: 1, row: 1 };
}

const today = new Date().toISOString().slice(0, 10);
const effectiveEnd = (e: CollectionEntry<"events">) => e.data.endDate ?? e.data.date;
const isPast = (e: CollectionEntry<"events">) => effectiveEnd(e) < today;

const items = [...events]
  .sort((a, b) => {
    const aPast = isPast(a) ? 1 : 0;
    const bPast = isPast(b) ? 1 : 0;
    if (aPast !== bPast) return aPast - bPast;
    return a.data.date.localeCompare(b.data.date);
  })
  .map(e => ({
    event: e,
    size: sizeBySlug[e.data.slug] ?? "compact",
    past: isPast(e),
  }));
---

<div class="bento-grid">
  {items.map(({ event, size, past }) => {
    const { col, row } = spanFor(size);
    return (
      <div class="bento-grid__cell" style={`grid-column: span ${col}; grid-row: span ${row};`}>
        <BentoEventCard event={event} size={size} badgeOverride={past ? "PAST EVENT" : undefined} />
      </div>
    );
  })}
</div>

<style>
  .bento-grid {
    display: grid;
    gap: var(--grid-gutter);
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(180px, auto);
    grid-auto-flow: dense;
  }

  .bento-grid__cell {
    min-width: 0;
    overflow: visible;
  }

  @media (min-width: 768px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .bento-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
