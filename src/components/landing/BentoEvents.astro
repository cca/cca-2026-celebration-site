---
/**
 * BentoEvents — Asymmetric bento box grid for homepage events section.
 * Mixes sized event cards with decorative shape cells.
 */
import type { CollectionEntry } from "astro:content";
import BentoEventCard from "./BentoEventCard.astro";
import ArrowLoop3D from "../effects/ArrowLoop3D.astro";

interface Props {
  events: CollectionEntry<"events">[];
}

const { events } = Astro.props;

// Map events by slug for explicit grid placement
const bySlug = Object.fromEntries(events.map(e => [e.data.slug, e]));

// Grid layout definition: slug → { size, gridArea }
const layout: { slug: string; size: "large" | "tall" | "wide" | "compact"; area: string }[] = [
  { slug: "all-campus-graduation-exhibition",  size: "large",   area: "show" },
  { slug: "mfa-exhibition",                    size: "tall",    area: "mfa" },
  { slug: "animation-senior-showcase",         size: "wide",    area: "anim" },
  { slug: "game-arts-showcase",                size: "compact", area: "game" },
  { slug: "architecture-studio-conversations", size: "tall",    area: "arch" },
  { slug: "fine-arts-senior-exhibition",       size: "tall",    area: "fase" },
  { slug: "2d-open-studios",                   size: "compact", area: "twod" },
  { slug: "film-screenings",                   size: "compact", area: "film" },
  { slug: "mfa-fine-arts-open-house",          size: "wide",    area: "mopen" },
  { slug: "vcs-spring-symposium",              size: "compact", area: "vcs" },
  { slug: "extension-reception",               size: "wide",    area: "ext" },
  { slug: "dmba-venture-showcase",             size: "wide",    area: "dmba" },
  { slug: "mfa-writing-25th-anniversary",      size: "wide",    area: "mwrit" },
];
---

<div class="bento-grid">
  {layout.map(({ slug, size, area }) => {
    const event = bySlug[slug];
    return event ? (
      <div class="bento-grid__cell" style={`grid-area: ${area}`}>
        <BentoEventCard event={event} size={size} />
      </div>
    ) : null;
  })}

  {/* Decorative arrow cells — visible on desktop only */}
  <div class="bento-grid__deco bento-grid__deco--1" aria-hidden="true">
    <div class="deco-arrow-wrap">
      <ArrowLoop3D
        id="bento-arrow-1"
        cycleDuration={3}
        fadeOverlap={0.15}
        scaleAmount={0.04}
        spinDegrees={180}
        spinAxis="Y"
        perspective={300}
        sizeVariance={0.3}
        color="#00BFB3"
      />
    </div>
  </div>
  <div class="bento-grid__deco bento-grid__deco--2" aria-hidden="true">
    <div class="deco-arrow-wrap">
      <ArrowLoop3D
        id="bento-arrow-2"
        cycleDuration={3}
        fadeOverlap={0.15}
        scaleAmount={0.04}
        spinDegrees={180}
        spinAxis="Y"
        perspective={300}
        sizeVariance={0.3}
        color="#B7BF10"
        startDelay={1}
      />
    </div>
  </div>
<div class="bento-grid__deco bento-grid__deco--3" aria-hidden="true">
    <div class="deco-arrow-wrap">
      <ArrowLoop3D
        id="bento-arrow-3"
        cycleDuration={3}
        fadeOverlap={0.15}
        scaleAmount={0.04}
        spinDegrees={180}
        spinAxis="Y"
        perspective={300}
        sizeVariance={0.3}
        color="#00BFB3"
        startDelay={0.5}
      />
    </div>
  </div>
  <div class="bento-grid__deco bento-grid__deco--4" aria-hidden="true">
    <div class="deco-arrow-wrap">
      <ArrowLoop3D
        id="bento-arrow-4"
        cycleDuration={3}
        fadeOverlap={0.15}
        scaleAmount={0.04}
        spinDegrees={180}
        spinAxis="X"
        perspective={300}
        sizeVariance={0.3}
        color="#B7BF10"
        startDelay={1.5}
      />
    </div>
  </div>
</div>

<style>
  /* ---- Mobile: single column stack ---- */
  .bento-grid {
    display: grid;
    gap: var(--grid-gutter);
    grid-template-columns: 1fr;
    grid-template-areas:
      "show"
      "mfa"
      "fase"
      "arch"
      "anim"
      "game"
      "film"
      "twod"
      "mopen"
      "vcs"
      "ext"
      "dmba"
      "mwrit";
  }

  .bento-grid__cell {
    min-width: 0;
    overflow: visible;
  }

  /* Decorative cells hidden below desktop */
  .bento-grid__deco {
    display: none;
    pointer-events: none;
  }

  /* ---- Tablet: 2 columns ---- */
  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-areas:
        "show       show"
        "mfa        arch"
        "anim       arch"
        "fase       fase"
        "film       game"
        "twod       mopen"
        "vcs        ext"
        "dmba       dmba"
        "mwrit      mwrit";
    }
  }

  /* ---- Desktop: 4 columns, explicit bento layout ---- */
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(180px, auto);
      grid-template-areas:
        "show   show   deco-1  mfa"
        "show   show   arch    mfa"
        "twod   deco-2 arch    fase"
        "film   anim   anim    fase"
        "mopen  mopen  game    deco-4"
        "deco-3 vcs    ext     ext"
        "dmba   dmba   mwrit   mwrit";
    }

    .bento-grid__deco {
      display: grid;
      place-items: center;
    }

    .bento-grid__deco--1 { grid-area: deco-1; }
    .bento-grid__deco--2 { grid-area: deco-2; }
    .bento-grid__deco--3 { grid-area: deco-3; }
    .bento-grid__deco--4 { grid-area: deco-4; }
  }

  /* Arrow wrapper sizing within decorative cells */
  .deco-arrow-wrap {
    width: clamp(70px, 9vw, 130px);
    height: clamp(70px, 9vw, 130px);
  }
</style>

<script src="../../scripts/arrow-loop-3d.ts"></script>
