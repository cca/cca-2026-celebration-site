---
/**
 * BentoEventCard — Size-aware event card for bento grid layout.
 * Supports large (2×2), tall (1×2), wide (2×1), and compact (1×1) variants.
 */
import type { CollectionEntry } from "astro:content";
import { Image } from 'astro:assets';
import { formatDate, formatDateRange } from "../../lib/utils/format";

interface Props {
  event: CollectionEntry<"events">;
  size: "large" | "tall" | "wide" | "compact";
  class?: string;
}

const { event, size, class: className } = Astro.props;
const { title, shortTitle, slug, date, endDate, location, description, type, degreeLevel, externalUrl, image } = event.data;

function getEventUrl(type: string, degreeLevel: string, slug: string): string {
  if (type === "commencement") return degreeLevel === "all" ? "/commencement/" : `/commencement/${degreeLevel}/`;
  if (type === "celebration") return `/commencement/${slug}/`;
  return `/thesis/${slug}/`;
}

const isExternal = !!externalUrl;
const href = externalUrl ?? getEventUrl(type, degreeLevel, slug);
const dateDisplay = endDate ? formatDateRange(date, endDate) : formatDate(date);

const badgeLabels: Record<string, string> = {
  commencement: "COMMENCEMENT",
  showcase: "CAMPUS-WIDE CELEBRATIONS",
  "thesis-exhibition": "EXHIBITION",
  celebration: "CELEBRATION",
  "studio-review": "STUDIO REVIEW",
  screening: "SCREENING",
  "game-showcase": "GAME SHOWCASE",
  "senior-exhibition": "4-WEEK SERIES",
  "senior-show": "SENIOR SHOW",
  "open-studios": "OPEN STUDIOS",
  "symposium": "SYMPOSIUM",
  "venture-showcase": "VENTURE SHOWCASE",
};
const badgeLabel = badgeLabels[type] ?? type.toUpperCase();
const hasImage = !!image && !image.heroOnly;
---

<a href={href} class:list={['bento-card', `bento-card--${size}`, hasImage && 'bento-card--has-image', 'reveal', className]} {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
  {hasImage && (
    <div class="bento-card__img-wrap">
      <Image
        src={image.src}
        alt={image.alt}
        class="bento-card__img"
        loading="lazy"
        widths={[400, 800]}
        sizes="(min-width: 1200px) 560px, (min-width: 768px) 50vw, 95vw"
      />
    </div>
  )}
  <article>
    <span class="bento-badge">{badgeLabel}</span>

    {size === 'compact' ? (
      <>
        <h3 class="bento-title">{shortTitle || title}</h3>
        <time class="bento-date">{dateDisplay}</time>
      </>
    ) : size === 'wide' ? (
      <>
        <h3 class="bento-title">{title}</h3>
        <div class="bento-meta">
          <time class="bento-date">{dateDisplay}</time>
          <p class="bento-location">{location}</p>
        </div>
      </>
    ) : (
      <>
        <h3 class="bento-title">{title}</h3>
        <time class="bento-date">{dateDisplay}</time>
        <p class="bento-location">{location}</p>
        {description && <p class="bento-desc">{description}</p>}
      </>
    )}
  </article>
</a>

<style>
  /* ---- Base card ---- */
  .bento-card {
    height: 100%;
    display: flex;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: none;
    padding: var(--space-6);
    padding-left: calc(var(--space-6) + 3px);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    position: relative;
    transition: transform var(--duration-base) var(--ease-out-expo),
                box-shadow var(--duration-base) var(--ease-out-expo);
  }

  /* Prismatic left border */
  .bento-card::before {
    content: "";
    position: absolute;
    top: 30%;
    left: 0;
    height: 40%;
    width: 3px;
    background: var(--gradient-prismatic);
    border-radius: 4px 0 0 4px;
    transition: top var(--duration-base) var(--ease-out-expo),
                height var(--duration-base) var(--ease-out-expo);
  }

  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .bento-card:hover::before {
    top: 0;
    height: 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .bento-card::before {
      animation: prismatic-shift 6s linear infinite;
    }

    .bento-card:hover::before {
      animation-duration: 2s;
    }
  }

  /* ---- Large variant ---- */
  .bento-card--large {
    padding: var(--space-8);
    padding-left: calc(var(--space-8) + 3px);
    flex-direction: column;
    justify-content: flex-end;
  }

  .bento-card--large .bento-title {
    font-size: var(--text-2xl);
  }

  /* ---- Tall variant ---- */
  .bento-card--tall {
    flex-direction: column;
  }

  /* ---- Wide variant — horizontal layout ---- */
  .bento-card--wide {
    align-items: center;
    gap: var(--space-4);
  }

  .bento-card--wide article {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .bento-card--wide .bento-title {
    margin-bottom: var(--space-1);
  }

  .bento-card--wide .bento-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .bento-card--wide .bento-meta .bento-date,
  .bento-card--wide .bento-meta .bento-location {
    margin-bottom: 0;
  }

  /* ---- Compact variant ---- */
  .bento-card--compact {
    padding: var(--space-4);
    padding-left: calc(var(--space-4) + 3px);
  }

  .bento-card--compact .bento-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  /* ---- Shared inner elements ---- */
  .bento-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent-tint);
    color: var(--color-accent);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    margin-bottom: var(--space-3);
  }

  .bento-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .bento-date {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }

  .bento-location {
    font-size: var(--text-sm);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .bento-desc {
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  /* ---- Image variant — split layout ---- */
  .bento-card--has-image {
    padding: 0;
    overflow: hidden;
  }

  .bento-card--has-image::before {
    display: none;
  }

  .bento-card__img-wrap {
    overflow: hidden;
    flex-shrink: 0;
  }

  .bento-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-base) var(--ease-out-expo);
  }

  .bento-card--has-image:hover .bento-card__img {
    transform: scale(1.04);
  }

  .bento-card--has-image article {
    padding: var(--space-4);
  }

  /* Tall + image: image on top, content below */
  .bento-card--tall.bento-card--has-image {
    flex-direction: column;
  }

  .bento-card--tall.bento-card--has-image .bento-card__img-wrap {
    height: 200px; /* fixed — 50% of auto is undefined */
  }

  /* Compact + image: side-by-side layout */
  .bento-card--compact.bento-card--has-image {
    flex-direction: row;
    align-items: stretch;
    min-height: 120px;
  }

  .bento-card--compact.bento-card--has-image .bento-card__img-wrap {
    width: 38%;
    position: relative;
    flex-shrink: 0;
  }

  .bento-card--compact.bento-card--has-image .bento-card__img {
    position: absolute;
    inset: 0;
  }

  .bento-card--compact.bento-card--has-image article {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
  }

  /* Wide + image: image on left, content on right */
  .bento-card--wide.bento-card--has-image {
    flex-direction: row;
    align-items: stretch;
    min-height: 160px;
  }

  .bento-card--wide.bento-card--has-image .bento-card__img-wrap {
    width: 40%;
  }

  .bento-card--wide.bento-card--has-image .bento-card__img {
    position: absolute;
    inset: 0;
  }

  .bento-card--wide.bento-card--has-image .bento-card__img-wrap {
    position: relative;
  }

  .bento-card--wide.bento-card--has-image article {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-5);
  }

  .bento-card--wide.bento-card--has-image .bento-title {
    margin-bottom: var(--space-2);
  }

  /* Large variant + image: full-bleed overlay with gradient scrim */
  .bento-card--large.bento-card--has-image {
    padding: var(--space-8);
    padding-left: var(--space-8);
    min-height: 340px;
    color: #fff;
    border: none;
  }

  .bento-card--large.bento-card--has-image::before {
    display: none;
  }

  .bento-card--large.bento-card--has-image .bento-badge {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .bento-card--large.bento-card--has-image .bento-date {
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.1);
  }

  .bento-card--large.bento-card--has-image .bento-location,
  .bento-card--large.bento-card--has-image .bento-desc {
    color: rgba(255, 255, 255, 0.75);
  }

  .bento-card--large.bento-card--has-image .bento-card__img-wrap {
    position: absolute;
    inset: 0;
    height: 100%;
    z-index: 0;
  }

  .bento-card--large.bento-card--has-image .bento-card__img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.2) 55%, transparent 100%);
  }

  .bento-card--large.bento-card--has-image article {
    position: relative;
    z-index: 1;
    padding: 0;
  }
</style>
