---
/**
 * EventListView — Chronological list view of thesis events.
 * Companion to BentoEvents; toggled by EventViewToggle.
 */
import type { CollectionEntry } from "astro:content";
import { formatDate, formatDateRange } from "../../lib/utils/format";

interface Props {
  events: CollectionEntry<"events">[];
}

const { events } = Astro.props;

// Sort chronologically by start date for "what's coming up" utility
const sorted = [...events].sort((a, b) => a.data.date.localeCompare(b.data.date));

function getEventUrl(type: string, degreeLevel: string, slug: string): string {
  if (type === "commencement") return degreeLevel === "all" ? "/commencement/" : `/commencement/${degreeLevel}/`;
  if (type === "celebration") return `/commencement/${slug}/`;
  return `/thesis/${slug}/`;
}

const badgeLabels: Record<string, string> = {
  commencement: "COMMENCEMENT",
  showcase: "CAMPUS-WIDE CELEBRATIONS",
  "thesis-exhibition": "EXHIBITION",
  celebration: "CELEBRATION",
  "studio-review": "STUDIO REVIEW",
  screening: "SCREENING",
  "game-showcase": "GAME SHOWCASE",
  "senior-exhibition": "4-WEEK SERIES",
  "open-studios": "OPEN STUDIOS",
  "symposium": "SYMPOSIUM",
  "venture-showcase": "VENTURE SHOWCASE",
  "reception": "RECEPTION",
};
---

<ol class="event-list" role="list">
  {sorted.map((event) => {
    const { title, slug, date, endDate, location, type, degreeLevel, externalUrl } = event.data;
    const isExternal = !!externalUrl;
    const href = externalUrl ?? getEventUrl(type, degreeLevel, slug);
    const dateDisplay = endDate ? formatDateRange(date, endDate) : formatDate(date);
    const badge = badgeLabels[type] ?? type.toUpperCase();

    return (
      <li class="event-list__item">
        <a
          href={href}
          class="event-row reveal"
          {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
        >
          <span class="event-row__badge">{badge}</span>
          <span class="event-row__title">{title}</span>
          <span class="event-row__meta">
            <time class="event-row__date">{dateDisplay}</time>
            <span class="event-row__dot" aria-hidden="true">·</span>
            <span class="event-row__location">{location}</span>
          </span>
          <span class="event-row__arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4"/>
            </svg>
          </span>
        </a>
      </li>
    );
  })}
</ol>

<style>
  .event-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* ---- Row ---- */
  .event-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    padding-left: calc(var(--space-6) + 3px);
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: none;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-rest);
    position: relative;
    transition: transform var(--duration-base) var(--ease-out-expo),
                box-shadow var(--duration-base) var(--ease-out-expo);
  }

  /* Prismatic left bar */
  .event-row::before {
    content: "";
    position: absolute;
    top: 30%;
    left: 0;
    height: 40%;
    width: 3px;
    background: var(--gradient-prismatic);
    border-radius: 4px;
    transition: top var(--duration-base) var(--ease-out-expo),
                height var(--duration-base) var(--ease-out-expo);
  }

  .event-row:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .event-row:hover::before {
    top: 0;
    height: 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .event-row::before {
      animation: prismatic-shift 6s linear infinite;
    }

    .event-row:hover::before {
      animation-duration: 2s;
    }
  }

  /* ---- Badge ---- */
  .event-row__badge {
    display: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent-tint);
    color: var(--color-accent);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ---- Title ---- */
  .event-row__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    min-width: 0;
    flex: 1;
  }

  /* ---- Meta (date + location) ---- */
  .event-row__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .event-row__date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  .event-row__dot,
  .event-row__location {
    display: none;
  }

  /* ---- Arrow ---- */
  .event-row__arrow {
    color: var(--color-text);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: color var(--duration-base) var(--ease-out-expo),
                transform var(--duration-base) var(--ease-out-expo);
  }

  .event-row:hover .event-row__arrow {
    color: var(--color-accent);
    transform: translateX(2px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    .event-row {
      gap: var(--space-3);
      padding: var(--space-4) var(--space-4);
      padding-left: calc(var(--space-4) + 3px);
    }

    .event-row__title {
      font-size: var(--text-base);
    }

    .event-row__meta {
      white-space: normal;
    }
  }
</style>
