---
/**
 * EventViewToggle — Grid/list icon buttons for switching event display mode.
 * Toggles data-view on #events-view-container; persists to localStorage.
 */
---

<div class="view-toggle" role="group" aria-label="Events display">
  <button
    class="view-toggle__btn"
    data-view="bento"
    aria-pressed="true"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <rect x="1" y="1" width="6" height="6" rx="1"/>
      <rect x="9" y="1" width="6" height="6" rx="1"/>
      <rect x="1" y="9" width="6" height="6" rx="1"/>
      <rect x="9" y="9" width="6" height="6" rx="1"/>
    </svg>
    Grid
  </button>
  <button
    class="view-toggle__btn"
    data-view="list"
    aria-pressed="false"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
      <line x1="1" y1="4" x2="15" y2="4"/>
      <line x1="1" y1="8" x2="15" y2="8"/>
      <line x1="1" y1="12" x2="15" y2="12"/>
    </svg>
    List
  </button>
</div>

<style>
  .view-toggle {
    display: flex;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  .view-toggle__btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    height: 34px;
    padding-inline: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    transition: color var(--duration-fast, 150ms) var(--ease-out-expo),
                background var(--duration-fast, 150ms) var(--ease-out-expo),
                border-color var(--duration-fast, 150ms) var(--ease-out-expo);
  }

  .view-toggle__btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .view-toggle__btn[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .view-toggle__btn[aria-pressed="true"]:hover {
    color: #fff;
  }
</style>

<script>
  function initToggle() {
    const container = document.getElementById('events-view-container');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.view-toggle__btn');

    function setView(view: string) {
      if (!container) return;
      container.dataset.view = view;
      buttons.forEach(btn => {
        btn.setAttribute('aria-pressed', btn.dataset.view === view ? 'true' : 'false');
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view;
        if (view) setView(view);
      });
    });
  }

  initToggle();
</script>
