---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'interaction-design-showcase');
if (!event) throw new Error('Event interaction-design-showcase not found');

const gallery = [
  { src: '/images/ixd-showcase-sp26/ixd-sp26-001.jpg', alt: 'Two students examine the OwnWay accessibility cane at the BFA Interaction Design showcase, with student project posters visible on the wall behind them.' },
  { src: '/images/ixd-showcase-sp26/ixd-sp26-002.jpg', alt: 'Two students demonstrate the Revive CPR training device—an open equipment case containing a chest compression simulator and tablet display.' },
  { src: '/images/ixd-showcase-sp26/ixd-sp26-003.jpg', alt: 'Three visitors lean in to explore a touchscreen coffee table displaying an experimental coffee education interface at the Interaction Design showcase.' },
  { src: '/images/ixd-showcase-sp26/ixd-sp26-004.jpg', alt: 'A student presents her interactive fitness project in a purple-lit room, with dumbbells on a display shelf and neon floor elements as part of the installation.' },
  { src: '/images/ixd-showcase-sp26/ixd-sp26-005.jpg', alt: 'A group of visitors interact with a large touchscreen table displaying space telescope imagery at the BFA Interaction Design senior showcase.' },
];
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: 'BFA Interaction Design: Me, Myself and A.I.' },
    ]} />
  </div>

  <EventHero event={event} heroImageSize="large" />

  <div class="container">
    <div class="page-layout">
      <div class="page-main">
        <section id="gallery" class="gallery-section reveal">
          <span class="gallery-kicker">From the BFA Interaction Design Showcase</span>
          <div class="gallery-grid">
            {gallery.map((img, i) => (
              <div class:list={['gallery-item', i === 0 && 'gallery-item--featured']}>
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>
</ThesisEventLayout>

<style>
  .page-layout { padding-block: var(--space-8) var(--space-20); }

  .gallery-section { margin-block-start: var(--space-12); }

  .gallery-kicker {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-block-end: var(--space-4);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .gallery-item { overflow: hidden; border-radius: 2px; }

  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img { transform: scale(1.04); }

  .gallery-item--featured { grid-column: span 2; aspect-ratio: 16 / 9; }
  .gallery-item:not(.gallery-item--featured) { aspect-ratio: 4 / 3; }

  @media (min-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    .gallery-item--featured { grid-column: span 3; }
  }
</style>
