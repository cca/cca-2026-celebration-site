---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import EventContextSection from '../../components/events/EventContextSection.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'extension-reception');
if (!event) throw new Error('Event extension-reception not found');
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: 'Extension Nights + Weekends' },
    ]} />
  </div>

  <EventHero event={event} />

  <div class="container">
    <div class="page-layout">
      <div class="page-main">
        <EventContextSection
          id="about"
          kicker="About the Exhibition"
          paragraphs={[
            "At CCA Extension, we know that some of the most profound creative breakthroughs happen after the traditional 9-to-5 ends. Whether it's a passion project sparked after dinner or a new technique mastered on a Sunday morning, we want to celebrate the work you cultivate in those dedicated “off-hours” moments when you are learning, practicing, and creating in community.",
            "We are thrilled to announce NIGHTS & WEEKENDS, an upcoming studio exhibition dedicated to the hustle, heart, and creative output of our vibrant Extension community. We will be showcasing work from our current Fall 2025 and Winter/Spring 2026 faculty and students.",
            "As we end our final season of adult programming, we gather to celebrate each other and our shared experiences at our opening reception in the Hubbell Street Galleries on Friday, May 8, 5–7 pm.",
          ]}
        />

        <section id="hours" class="content-section reveal">
          <p class="hours-line">Open to the public May 6&ndash;14, Noon &ndash; 6:30 pm</p>
        </section>
      </div>
    </div>
  </div>
</ThesisEventLayout>

<style>
  .page-layout {
    padding-block: var(--space-8) var(--space-20);
  }

  .content-section {
    margin-block-start: var(--space-8);
  }

  .hours-line {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }
</style>
