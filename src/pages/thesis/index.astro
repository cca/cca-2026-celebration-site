---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import BentoEvents from '../../components/landing/BentoEvents.astro';
import Button from '../../components/ui/Button.astro';
import PastGallery from '../../components/sections/PastGallery.astro';
import FramedImage from '../../components/ui/FramedImage.astro';
import { formatDateRange, formatTime } from '../../lib/utils/format';
import HalftoneProceduralScan from '../../components/effects/HalftoneProceduralScan.astro';
import ArrowLoop3D from '../../components/effects/ArrowLoop3D.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseAtLeast, isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);


const event = await getEntry('events', 'showcase');
if (!event) throw new Error('Event showcase not found');

const allEvents = (await getCollection('events')).sort((a, b) => a.data.order - b.data.order);
const events = allEvents.filter(e => e.data.type !== 'commencement' && e.data.type !== 'celebration');
// Phase-based logic replaces date-computed isPostEvent
const isPostEvent = isPhaseAtLeast(phase, 'post-event');
---

<BaseLayout title="Graduation Exhibitions" themeKey="showcase">
  <HalftoneProceduralScan
    dotColor="#00BFB3"
    dotOpacity={0.22}
    dotSpacing={18}
    dotRadius={4.5}
    scanSpeed={45}
    displacement={28}
    scanWidth={200}
    scannerCount={3}
    direction="xy"
    bidirectional
  />

  {/* ── Hero ── */}
  <section class="showcase-hero" data-cursor-scope>
<div class="showcase-hero__collage" aria-hidden="true">
      <div
        class="showcase-hero__fragment showcase-hero__fragment--1"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.035"
        data-cursor-max="36"
        data-cursor-lerp="0.06"
      >
        <FramedImage
          frameId="frame-04"
          src="/images/cca-photography/eoy-show-sp25.jpg"
          alt="Students and visitors at the CCA end-of-year show"
          uid="thesis-hero-1"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__fragment--2"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.055"
        data-cursor-max="28"
        data-cursor-lerp="0.12"
      >
        <FramedImage
          frameId="frame-11"
          src="/images/cca-photography/design-senior-show-fa25-54.jpg"
          alt="Design senior show installation view"
          uid="thesis-hero-2"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__fragment--3"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.042"
        data-cursor-max="24"
        data-cursor-lerp="0.08"
      >
        <FramedImage
          frameId="frame-07"
          src="/images/cca-photography/illustration-senior-show-fa25-43.jpg"
          alt="Illustration senior show artwork"
          uid="thesis-hero-3"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__doodle showcase-hero__doodle--1"
        data-cursor-track
        data-cursor-strength="0.05"
        data-cursor-max="45"
        data-cursor-lerp="0.12"
      >
        <ArrowLoop3D
          id="hero-arrow-1"
          cycleDuration={3}
          fadeOverlap={0.15}
          scaleAmount={0.04}
          spinDegrees={180}
          spinAxis="Y"
          perspective={300}
          sizeVariance={0.3}
          color="#00BFB3"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__doodle showcase-hero__doodle--2"
        data-cursor-track
        data-cursor-strength="0.038"
        data-cursor-max="32"
        data-cursor-lerp="0.09"
      >
        <ArrowLoop3D
          id="hero-arrow-2"
          cycleDuration={3}
          fadeOverlap={0.15}
          scaleAmount={0.04}
          spinDegrees={180}
          spinAxis="Y"
          perspective={300}
          sizeVariance={0.3}
          color="#00BFB3"
          startDelay={1.5}
        />
      </div>
    </div>
    <div class="showcase-hero__content">
      <h1 class="showcase-hero__logo-wrap">
        <img
          src="/images/graduation-exhibitions/graduation-exhibitions-logo-primary.svg"
          alt="CCA Graduation Exhibitions 2026"
          class="showcase-hero__logo"
          width="900"
          height="630"
        />
      </h1>
    </div>
    <div class="showcase-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── About ── */}
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-grid__content">
          <span class="section-label reveal">About the exhibitions</span>
          <h2 class="section-heading reveal">An evening of art, design &amp; making</h2>
          <p class="about-desc reveal">{event.data.description}</p>
          {isPhaseAtLeast(phase, 'pre-event') && (
            <div class="about-details reveal">
              <div class="about-detail">
                <span class="about-detail__label">When</span>
                <span class="about-detail__value">{formatDateRange(event.data.date, event.data.endDate)}</span>
                {event.data.time && <span class="about-detail__sub">{formatTime(event.data.time)}</span>}
              </div>
              <div class="about-detail">
                <span class="about-detail__label">Where</span>
                <span class="about-detail__value">{event.data.location}</span>
                {event.data.address && <a href={`https://maps.google.com/?q=${encodeURIComponent(event.data.address)}`} target="_blank" rel="noopener noreferrer" class="about-detail__sub">{event.data.address.substring(0, event.data.address.indexOf(','))}<br />{event.data.address.substring(event.data.address.indexOf(',') + 2)}</a>}
              </div>
            </div>
          )}
          <div class="about-subscribe reveal">
            <Button href="/subscribe" variant="link">Subscribe for updates</Button>
          </div>
        </div>
        {isPhaseBefore(phase, 'pre-event') ? (
          <div class="about-grid__sidebar reveal">
            <div class="about-details">
              <div class="about-detail">
                <span class="about-detail__label">When</span>
                <span class="about-detail__value">{formatDateRange(event.data.date, event.data.endDate)}</span>
                {event.data.time && <span class="about-detail__sub">{formatTime(event.data.time)}</span>}
              </div>
              <div class="about-detail">
                <span class="about-detail__label">Where</span>
                <span class="about-detail__value">{event.data.location}</span>
                {event.data.address && <a href={`https://maps.google.com/?q=${encodeURIComponent(event.data.address)}`} target="_blank" rel="noopener noreferrer" class="about-detail__sub">{event.data.address.substring(0, event.data.address.indexOf(','))}<br />{event.data.address.substring(event.data.address.indexOf(',') + 2)}</a>}
              </div>
            </div>
          </div>
        ) : (
          <div class="about-grid__poster reveal">
            <img src="/images/thesis/poster.png" alt="Graduation Exhibitions 2026 poster" class="about-poster" />
          </div>
        )}
      </div>
    </div>
  </section>

  {/* ── All Celebration Events ── */}
  {isPhaseAtLeast(phase, 'pre-event') && (
    <section class="all-events-section">
      <div class="container">
        <span class="section-label reveal">Class of 2026</span>
        <h2 class="section-heading reveal">All celebration events</h2>
        <p class="all-events-desc reveal">
          From commencement ceremonies to thesis exhibitions and showcases, explore the full range of events celebrating the Class of 2026.
        </p>
        <BentoEvents events={events} />
      </div>
    </section>
  )}

  {/* ── Past Exhibitions Gallery ── */}
  <PastGallery
    label="Past exhibitions"
    title="A legacy of creative work"
    marqueeDuration={180}
    images={[
      { src: '/images/eoy-show-past/previousEOYShowPhotos-001-03-2026.jpg', alt: 'Gallery visitors interact with a colorful sculptural installation featuring turquoise and coral architectural forms with text reading \'SAINT SUSIE\' at a CCA End of Year Show exhibition.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-002-03-2026.jpg', alt: 'A bright orange sculptural model with curved and geometric forms sits on a light wood base in a gallery space with polished floors.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-003-03-2026.jpg', alt: 'An art installation featuring a figure wearing a deer head mask seated on a patterned textile floor, creating a surreal and contemplative composition.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-004-03-2026.jpg', alt: 'A smiling student artist holds a vibrant bouquet of flowers while standing in front of her colorful paintings featuring warm tones and figurative subjects.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-005-03-2026.jpg', alt: 'Wooden chairs and a table are repurposed as planters with grass and flora growing from their seats at a gallery installation exploring nature and function.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-006-03-2026.jpg', alt: 'Four student artists pose together in front of their large-scale white exhibition display in a gallery space.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-007-03-2026.jpg', alt: 'A woman in white clothing stands at a wooden table with grass-filled chair installations while gallery visitors explore the exhibition behind her.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-008-03-2026.jpg', alt: 'Overhead view of a bustling gallery space with multiple levels showing numerous visitors viewing diverse student artwork installations and displays.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-009-03-2026.jpg', alt: 'Two visitors examine colorful printed materials and publications at a gallery display table with framed photographs visible on a blue wall panel behind them.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-010-03-2026.jpg', alt: 'Two visitors view a digital display showing vibrant floral imagery mounted on a dark wall, with water glasses placed on a shelf below.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-011-03-2026.jpg', alt: 'A student artist presents her colorful digital project at a gallery booth, with vibrant yellow, blue, and coral colored posters and signage visible in the background.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-012-03-2026.jpg', alt: 'Visitors crouch around an orange exhibition display on the ground featuring a potted plant, printed materials, and colorful geometric graphics.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-013-03-2026.jpg', alt: 'A large crowd of visitors gathers outside a contemporary building with distinctive wooden architectural framework and white flowers in the landscaping.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-014-03-2026.jpg', alt: 'A performer wearing a bright yellow jacket and pink wings stands on a paved outdoor plaza surrounded by spectators and tall wooden pillars with colorful artwork.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-015-03-2026.jpg', alt: 'Visitors examine a gallery space featuring wooden geometric sculptures and architectural models displayed on white pedestals.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-016-03-2026.jpg', alt: 'Two visitors view a gallery wall covered with colorful patterned wallpaper and displaying various framed artworks in mixed media.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-017-03-2026.jpg', alt: 'A large circular wooden sculptural installation features geometric patterns, carved elements, and various hand-crafted wooden pieces arranged in a mandala-like composition.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-018-03-2026.jpg', alt: 'Two terracotta sculptural hands with textured surfaces emerge from a mound of dark soil on a gallery floor.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-019-03-2026.jpg', alt: 'A bright gallery space with industrial ceilings displays multiple large-scale installations including colorful panels and a dark sculptural structure with mixed media elements.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-020-03-2026.jpg', alt: 'A vibrant portrait painting featuring a young figure with decorative face patterns wearing a bright green jacket against a pink background with orange flame-like motifs.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-021-03-2026.jpg', alt: 'A student sits on a wooden bench in a minimalist studio space with green plants, shelving with decorative objects, and mood boards pinned to the wall behind him.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-022-03-2026.jpg', alt: 'A student in a yellow patterned shirt sits cross-legged on the floor surrounded by colorful design work, sketches, and fabric swatches displayed on black panels and teal fabric.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-023-03-2026.jpg', alt: 'An interactive gallery installation with the heading \'WHAT DOES THIS MEME?\' displays dozens of printed images and memes pinned to a white wall, with a QR code for viewer engagement.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-024-03-2026.jpg', alt: 'A student presents their work beside a monitor displaying brain imaging scans and a blue sculptural form with spikes mounted on the white gallery wall.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-025-03-2026.jpg', alt: 'A large-scale installation of accordion-folded yellow panels with illustrated figures and handwritten text arranged in an industrial gallery space.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-026-03-2026.jpg', alt: 'A close-up of hands using wooden tools to interact with a collection of textured, carved ceramic or wooden sculptural forms displayed at eye level.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-027-03-2026.jpg', alt: 'A student stands before their artwork featuring colorful geometric paintings with blue and white pottery imagery and a sculptural black form emerging from the white gallery floor.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-028-03-2026.jpg', alt: 'A vibrant large-scale digital projection displays abstract fiery patterns of reds, blues, and yellows on a curved screen in a modern gallery with visitors viewing the installation.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-029-03-2026.jpg', alt: 'A grid-based wall installation composed of small tiles alternating between copper-textured reliefs, black and white drawings, and teal backgrounds creating a modular artistic pattern.' },
      { src: '/images/eoy-show-past/previousEOYShowPhotos-030-03-2026.jpg', alt: 'A wooden cross-shaped display structure holds leather-bound books and white pages with black and white photographic prints and imagery arranged in a contemplative studio setting.' },
    ]}
  />

  {/* ── Email Signup ── */}
  <EmailSignup />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>
<script src="../../scripts/doodle-antics.ts"></script>
<script src="../../scripts/arrow-loop-3d.ts"></script>

<style>
  /* ── Hero ── */
  .showcase-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-x: clip;
    overflow-y: visible;
  }

  .showcase-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
  }

  .showcase-hero__logo-wrap {
    margin: 0 0 var(--space-6);
    line-height: 0;
  }

  .showcase-hero__logo {
    width: clamp(300px, 52vw, 640px);
    height: auto;
    display: block;
    margin: 0 auto;
    /* Drop shadow to lift logo off dark bg */
    filter: drop-shadow(0 2px 24px rgba(0, 191, 179, 0.18));
  }

  .showcase-hero__cta {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Collage fragments ── */
  .showcase-hero__collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .showcase-hero__fragment {
    position: absolute;
    --frame-color: #B7BF10;
  }

  .showcase-hero__fragment--1 {
    top: 4%;
    right: 2%;
    width: clamp(180px, 34vw, 460px);
    rotate: 3deg;
  }

  .showcase-hero__fragment--2 {
    bottom: 8%;
    left: 8%;
    width: clamp(120px, 22vw, 300px);
    rotate: -4deg;
  }

  .showcase-hero__fragment--3 {
    bottom: -14%;
    left: 68%;
    width: clamp(140px, 22vw, 280px);
    rotate: -3deg;
    --frame-color: #B7BF10;
  }

  .showcase-hero__doodle {
    pointer-events: auto;
    cursor: pointer;
  }

  .showcase-hero__doodle--1 {
    bottom: 28%;
    right: 7%;
    width: clamp(70px, 9vw, 130px);
    height: clamp(70px, 9vw, 130px);
  }

  .showcase-hero__doodle--2 {
    top: 14%;
    left: 7%;
    width: clamp(50px, 7vw, 100px);
    height: clamp(50px, 7vw, 100px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .showcase-hero__logo {
      opacity: 0;
      animation: fragment-enter 0.8s var(--ease-out-expo) 0.05s both;
    }

    .showcase-hero__fragment {
      opacity: 0;
      animation: fragment-enter 0.6s var(--ease-out-expo) both;
    }

    .showcase-hero__fragment--1 { animation-delay: 0.1s; }
    .showcase-hero__fragment--2 { animation-delay: 0.25s; }
    .showcase-hero__fragment--3 { animation-delay: 0.38s; }
    .showcase-hero__doodle--1 { animation-delay: 0.5s; }
    .showcase-hero__doodle--2 { animation-delay: 0.65s; }
  }

  @media (max-width: 767px) {

    .showcase-hero__fragment--1 {
      width: clamp(120px, 44vw, 240px);
      right: -5%;
    }

    .showcase-hero__fragment--2 {
      width: clamp(90px, 32vw, 170px);
      left: -3%;
    }

    .showcase-hero__fragment--3 {
      display: none;
    }

    .showcase-hero__doodle {
      display: none;
    }
  }

.showcase-hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    z-index: 2;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }

  /* ── Section rhythm ── */
  .about-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    margin-bottom: var(--space-10);
  }

  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: var(--space-16);
    }
  }

  .about-grid__poster {
    order: -1;
  }

  @media (min-width: 768px) {
    .about-grid__poster {
      order: 0;
    }
  }

  .about-poster {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    object-fit: cover;
  }


  .about-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  .about-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .about-subscribe {
    margin-top: var(--space-8);
  }

  @media (min-width: 640px) {
    .about-details {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-detail__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .about-detail__value {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
  }

  .about-detail__sub {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-1);
  }

  /* ── All Events ── */
  .all-events-section {
    padding-block: var(--space-20);
    border-top: 1px solid var(--color-border);
  }

  .all-events-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }
</style>
