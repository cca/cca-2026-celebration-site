---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConfettiCanvas from '../../components/effects/ConfettiCanvas.astro';
import WorkGrid from '../../components/works/WorkGrid.astro';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import Button from '../../components/ui/Button.astro';
import { getWorksByEvent } from '../../lib/utils/collections';
import { fullName, formatDateRange } from '../../lib/utils/format';

const event = await getEntry('events', 'showcase');
if (!event) throw new Error('Event showcase not found');

const works = await getWorksByEvent('showcase');
const students = await getCollection('students');
const studentMap = new Map(students.map(s => [s.id, fullName(s)]));

const events = await getCollection('events');
const undergradEvent = events.find(e => e.id === 'thesis-undergraduate');
const gradEvent = events.find(e => e.id === 'thesis-graduate');

// Determine if showcase has passed
const isPostEvent = new Date() > new Date(event.data.endDate ?? event.data.date);
---

<BaseLayout title="Graduation Exhibitions" themeKey="showcase">
  {/* ── Hero ── */}
  <section class="showcase-hero" data-cursor-scope>
    <ConfettiCanvas />
    <div class="showcase-hero__seal" aria-hidden="true"></div>
    <div class="showcase-hero__collage" aria-hidden="true">
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--1"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.035"
        data-cursor-max="36"
        data-cursor-lerp="0.06"
        loading="eager"
      />
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--2"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.055"
        data-cursor-max="28"
        data-cursor-lerp="0.12"
        loading="eager"
      />
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--3"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.042"
        data-cursor-max="50"
        data-cursor-lerp="0.08"
        loading="eager"
      />
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--4"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.06"
        data-cursor-max="42"
        data-cursor-lerp="0.14"
        loading="eager"
      />
    </div>
    <div class="showcase-hero__content">
      <span class="showcase-hero__label">CCA 2026</span>
      <h1 class="showcase-hero__title shimmer-text">Graduation Exhibitions</h1>
      <p class="showcase-hero__subtitle">
        {formatDateRange(event.data.date, event.data.endDate)} &middot; {event.data.location}
      </p>
      <div class="showcase-hero__cta">
        {isPostEvent ? (
          <Button href="/showcase/works/" variant="primary">Browse Student Work</Button>
        ) : (
          <Button href="#about" variant="primary">Learn More</Button>
        )}
        <Button href="/showcase/students/" variant="outline">Meet the Students</Button>
      </div>
    </div>
    <div class="showcase-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── About ── */}
  <section id="about" class="about-section">
    <div class="container">
      <span class="section-label reveal">About the Exhibitions</span>
      <h2 class="section-heading reveal">Three Days of Art, Design &amp; Making</h2>
      <p class="about-desc reveal">{event.data.description}</p>
      <div class="about-details reveal">
        <div class="about-detail">
          <span class="about-detail__label">When</span>
          <span class="about-detail__value">{formatDateRange(event.data.date, event.data.endDate)}</span>
          {event.data.time && <span class="about-detail__sub">{event.data.time}</span>}
        </div>
        <div class="about-detail">
          <span class="about-detail__label">Where</span>
          <span class="about-detail__value">{event.data.location}</span>
          {event.data.address && <span class="about-detail__sub">{event.data.address}</span>}
        </div>
      </div>
    </div>
  </section>

  {/* ── Featured Works ── */}
  {works.length > 0 && (
    <section class="works-section">
      <div class="container">
        <span class="section-label reveal">Student Work</span>
        <h2 class="section-heading reveal">Featured Works</h2>
        <WorkGrid works={works} studentMap={studentMap} />
      </div>
    </section>
  )}

  {/* ── Explore CTA ── */}
  <section class="explore-section">
    <div class="container">
      <div class="explore-card reveal">
        <div class="explore-card__inner">
          <span class="section-label">Student Showcase</span>
          <h2 class="explore-card__heading">Explore the Full Showcase</h2>
          <p class="explore-card__desc">Browse thesis work from every program, meet graduating students, and discover the breadth of creative practice at CCA.</p>
          <div class="explore-card__ctas">
            <Button href="/showcase/students/" variant="primary">Meet the Students</Button>
            <Button href="/showcase/works/" variant="outline">Browse All Work</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Related Exhibitions ── */}
  {(undergradEvent || gradEvent) && (
    <section class="exhibitions-section">
      <div class="container">
        <span class="section-label reveal">Fine Art Thesis Exhibitions</span>
        <h2 class="section-heading reveal">Related Exhibitions</h2>
        <div class="exhibition-cards">
          {undergradEvent && (
            <a href="/thesis/undergraduate/" class="exhibition-card reveal">
              <div class="exhibition-card__accent" aria-hidden="true"></div>
              <span class="exhibition-card__badge">BFA</span>
              <h3 class="exhibition-card__title">{undergradEvent.data.title}</h3>
              <time class="exhibition-card__date">{formatDateRange(undergradEvent.data.date, undergradEvent.data.endDate)}</time>
              <p class="exhibition-card__location">{undergradEvent.data.location}</p>
              <span class="exhibition-card__cta">View Exhibition &rarr;</span>
            </a>
          )}

          {gradEvent && (
            <a href="/thesis/graduate/" class="exhibition-card reveal">
              <div class="exhibition-card__accent" aria-hidden="true"></div>
              <span class="exhibition-card__badge">MFA</span>
              <h3 class="exhibition-card__title">{gradEvent.data.title}</h3>
              <time class="exhibition-card__date">{formatDateRange(gradEvent.data.date, gradEvent.data.endDate)}</time>
              <p class="exhibition-card__location">{gradEvent.data.location}</p>
              <span class="exhibition-card__cta">View Exhibition &rarr;</span>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  {/* ── Email Signup ── */}
  <EmailSignup />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>

<style>
  /* ── Hero ── */
  .showcase-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  .showcase-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
  }

  .showcase-hero__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
  }

  .showcase-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 7rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  .showcase-hero__subtitle {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin-top: var(--space-4);
  }

  .showcase-hero__cta {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Collage fragments ── */
  .showcase-hero__collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .showcase-hero__fragment {
    position: absolute;
    border-radius: var(--radius-card);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .showcase-hero__fragment--1 {
    top: 6%;
    right: 3%;
    width: clamp(140px, 28vw, 360px);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center 30%;
    rotate: 3deg;
  }

  .showcase-hero__fragment--2 {
    bottom: 8%;
    left: 2%;
    width: clamp(120px, 22vw, 280px);
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: 70% center;
    rotate: -5deg;
  }

  .showcase-hero__fragment--3 {
    top: 10%;
    left: 5%;
    width: clamp(80px, 15vw, 200px);
    aspect-ratio: 1;
    object-fit: cover;
    object-position: 30% 60%;
    rotate: 7deg;
  }

  .showcase-hero__fragment--4 {
    bottom: 10%;
    right: 5%;
    width: clamp(100px, 18vw, 230px);
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center;
    rotate: -3deg;
  }

  @media (prefers-reduced-motion: no-preference) {
    .showcase-hero__fragment {
      animation: fragment-enter 0.6s var(--ease-out-expo) both;
    }

    .showcase-hero__fragment--1 { animation-delay: 0.1s; }
    .showcase-hero__fragment--2 { animation-delay: 0.25s; }
    .showcase-hero__fragment--3 { animation-delay: 0.4s; }
    .showcase-hero__fragment--4 { animation-delay: 0.55s; }
  }

  /* Mobile: hide fragments 3 & 4, reduce visibility of remaining */
  @media (max-width: 767px) {
    .showcase-hero__fragment--3,
    .showcase-hero__fragment--4 {
      display: none;
    }

    .showcase-hero__fragment--1 {
      width: clamp(100px, 35vw, 180px);
      opacity: 0.7;
    }

    .showcase-hero__fragment--2 {
      width: clamp(90px, 28vw, 150px);
      opacity: 0.7;
    }

  }

  .showcase-hero__seal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(280px, 60vw, 600px);
    aspect-ratio: 1;
    background: var(--color-accent);
    opacity: 0.07;
    mask-image: url('/images/cca-seal.svg');
    -webkit-mask-image: url('/images/cca-seal.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .showcase-hero__seal {
      animation: seal-hero-breathe 12s ease-in-out infinite;
    }
  }

  .showcase-hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    z-index: 2;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }

  /* ── Section rhythm ── */
  .about-section,
  .works-section,
  .explore-section,
  .exhibitions-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    margin-bottom: var(--space-10);
  }

  /* ── About ── */
  .about-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  .about-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  @media (min-width: 640px) {
    .about-details {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-detail__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .about-detail__value {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
  }

  .about-detail__sub {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-1);
  }

  /* ── Works ── */
  .works-section {
    border-top: 1px solid var(--color-border);
  }

  /* ── Explore CTA card ── */
  .explore-card {
    position: relative;
    border-radius: var(--radius-card);
    padding: 3px;
    background: var(--gradient-prismatic);
    background-size: 200% 200%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .explore-card {
      animation: prismatic-shift 6s linear infinite;
    }
  }

  .explore-card__inner {
    background: var(--color-surface);
    border-radius: calc(var(--radius-card) - 2px);
    padding: var(--space-10) var(--space-8);
    text-align: center;
  }

  .explore-card__heading {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .explore-card__desc {
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 50ch;
    margin-inline: auto;
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .explore-card__ctas {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Exhibition cards ── */
  .exhibitions-section {
    border-top: 1px solid var(--color-border);
  }

  .exhibition-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .exhibition-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .exhibition-card {
    display: block;
    position: relative;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    overflow: hidden;
    transition: transform 0.3s var(--ease-out-expo),
                box-shadow 0.3s var(--ease-out-expo);
  }

  .exhibition-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .exhibition-card__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-prismatic);
  }

  @media (prefers-reduced-motion: no-preference) {
    .exhibition-card__accent {
      animation: prismatic-shift 6s linear infinite;
    }

    .exhibition-card:hover .exhibition-card__accent {
      animation-duration: 2s;
    }
  }

  .exhibition-card__badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    margin-bottom: var(--space-4);
  }

  .exhibition-card__title {
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .exhibition-card__date {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .exhibition-card__location {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-6);
  }

  .exhibition-card__cta {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    transition: letter-spacing 0.2s var(--ease-out-expo);
  }

  .exhibition-card:hover .exhibition-card__cta {
    letter-spacing: 0.05em;
  }
</style>
