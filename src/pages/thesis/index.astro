---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import BentoEvents from '../../components/landing/BentoEvents.astro';
import Button from '../../components/ui/Button.astro';
import PastGallery from '../../components/sections/PastGallery.astro';
import { formatDateRange } from '../../lib/utils/format';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore, isPhaseAtLeast } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);

// Redirect to home if phase is before pre-event (no exhibition content yet)
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'showcase');
if (!event) throw new Error('Event showcase not found');

const allEvents = (await getCollection('events')).sort((a, b) => a.data.order - b.data.order);
const events = allEvents.filter(e => e.data.type !== 'commencement' && e.data.type !== 'celebration');
// Phase-based logic replaces date-computed isPostEvent
const isPostEvent = isPhaseAtLeast(phase, 'post-event');
---

<BaseLayout title="Graduation Exhibitions" themeKey="showcase">
  {/* ── Hero ── */}
  <section class="showcase-hero" data-cursor-scope>
    <div class="showcase-hero__seal" aria-hidden="true"></div>
    <div class="showcase-hero__collage" aria-hidden="true">
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--1"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.035"
        data-cursor-max="36"
        data-cursor-lerp="0.06"
        loading="eager"
      />
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--2"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.055"
        data-cursor-max="28"
        data-cursor-lerp="0.12"
        loading="eager"
      />
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--3"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.042"
        data-cursor-max="50"
        data-cursor-lerp="0.08"
        loading="eager"
      />
      <img
        src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
        alt=""
        class="showcase-hero__fragment showcase-hero__fragment--4"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.06"
        data-cursor-max="42"
        data-cursor-lerp="0.14"
        loading="eager"
      />
    </div>
    <div class="showcase-hero__content">
      <span class="showcase-hero__label">CCA 2026</span>
      <h1 class="showcase-hero__title shimmer-text">Graduation Exhibitions</h1>
      <p class="showcase-hero__subtitle">
        {formatDateRange(event.data.date, event.data.endDate)} &middot; {event.data.location}
      </p>
      <div class="showcase-hero__cta">
        {isPostEvent ? (
          <Button href="/showcase/works/" variant="primary">Browse Student Work</Button>
        ) : (
          <Button href="https://www.eventbrite.com/" variant="primary">RSVP</Button>
        )}
        <Button href="#about" variant="outline">Learn More</Button>
      </div>
    </div>
    <div class="showcase-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── About ── */}
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-grid__content">
          <span class="section-label reveal">About the Exhibitions</span>
          <h2 class="section-heading reveal">Three Days of Art, Design &amp; Making</h2>
          <p class="about-desc reveal">{event.data.description}</p>
          <div class="about-details reveal">
            <div class="about-detail">
              <span class="about-detail__label">When</span>
              <span class="about-detail__value">{formatDateRange(event.data.date, event.data.endDate)}</span>
              {event.data.time && <span class="about-detail__sub">{event.data.time}</span>}
            </div>
            <div class="about-detail">
              <span class="about-detail__label">Where</span>
              <span class="about-detail__value">{event.data.location}</span>
              {event.data.address && <span class="about-detail__sub">{event.data.address}</span>}
            </div>
          </div>
          <a href="https://www.eventbrite.com/" class="about-rsvp reveal">RSVP on Eventbrite &rarr;</a>
        </div>
        <div class="about-grid__poster reveal">
          <img src="/images/thesis/poster.png" alt="Graduation Exhibitions 2026 poster" class="about-poster" />
        </div>
      </div>
    </div>
  </section>

  {/* ── All Celebration Events ── */}
  <section class="all-events-section">
    <div class="container">
      <span class="section-label reveal">Class of 2026</span>
      <h2 class="section-heading reveal">All Celebration Events</h2>
      <p class="all-events-desc reveal">
        From commencement ceremonies to thesis exhibitions and showcases, explore the full range of events celebrating the Class of 2026.
      </p>
      <BentoEvents events={events} />
    </div>
  </section>

  {/* ── Past Exhibitions Gallery ── */}
  <PastGallery
    label="Past Exhibitions"
    title="A Legacy of Creative Work"
    images={[
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Student artwork from a previous CCA exhibition' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Installation view from a past graduation exhibition' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Gallery view of student design work' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Visitors engaging with student installations' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Mixed media works on display' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Graduate thesis exhibition walkthrough' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Detail of student sculpture work' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Opening night at a previous exhibition' },
    ]}
  />

  {/* ── Email Signup ── */}
  <EmailSignup />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>

<style>
  /* ── Hero ── */
  .showcase-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .showcase-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
  }

  .showcase-hero__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
  }

  .showcase-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 7rem);
    font-weight: normal;
    line-height: 1;
    margin: 0;
  }

  .showcase-hero__subtitle {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin-top: var(--space-4);
  }

  .showcase-hero__cta {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Collage fragments ── */
  .showcase-hero__collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .showcase-hero__fragment {
    position: absolute;
    border-radius: var(--radius-card);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  .showcase-hero__fragment--1 {
    top: 6%;
    right: 3%;
    width: clamp(140px, 28vw, 360px);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center 30%;
    rotate: 3deg;
  }

  .showcase-hero__fragment--2 {
    bottom: 8%;
    left: 2%;
    width: clamp(120px, 22vw, 280px);
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: 70% center;
    rotate: -5deg;
  }

  .showcase-hero__fragment--3 {
    top: 10%;
    left: 5%;
    width: clamp(80px, 15vw, 200px);
    aspect-ratio: 1;
    object-fit: cover;
    object-position: 30% 60%;
    rotate: 7deg;
  }

  .showcase-hero__fragment--4 {
    bottom: 10%;
    right: 5%;
    width: clamp(100px, 18vw, 230px);
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center;
    rotate: -3deg;
  }

  @media (prefers-reduced-motion: no-preference) {
    .showcase-hero__fragment {
      animation: fragment-enter 0.6s var(--ease-out-expo) both;
    }

    .showcase-hero__fragment--1 { animation-delay: 0.1s; }
    .showcase-hero__fragment--2 { animation-delay: 0.25s; }
    .showcase-hero__fragment--3 { animation-delay: 0.4s; }
    .showcase-hero__fragment--4 { animation-delay: 0.55s; }
  }

  /* Mobile: hide fragments 3 & 4, reduce visibility of remaining */
  @media (max-width: 767px) {
    .showcase-hero__fragment--3,
    .showcase-hero__fragment--4 {
      display: none;
    }

    .showcase-hero__fragment--1 {
      width: clamp(100px, 35vw, 180px);
      opacity: 0.7;
    }

    .showcase-hero__fragment--2 {
      width: clamp(90px, 28vw, 150px);
      opacity: 0.7;
    }

  }

  .showcase-hero__seal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(280px, 60vw, 600px);
    aspect-ratio: 1;
    background: var(--color-accent);
    opacity: 0.07;
    mask-image: url('/images/cca-seal.svg');
    -webkit-mask-image: url('/images/cca-seal.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .showcase-hero__seal {
      animation: seal-hero-breathe 12s ease-in-out infinite;
    }
  }

  .showcase-hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    z-index: 2;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }

  /* ── Section rhythm ── */
  .about-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    margin-bottom: var(--space-10);
  }

  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: var(--space-16);
    }
  }

  .about-grid__poster {
    order: -1;
  }

  @media (min-width: 768px) {
    .about-grid__poster {
      order: 0;
    }
  }

  .about-poster {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    object-fit: cover;
  }

  .about-rsvp {
    display: inline-block;
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s ease;
  }

  .about-rsvp:hover {
    color: var(--color-accent, var(--color-muted));
  }

  .about-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  .about-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  @media (min-width: 640px) {
    .about-details {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-detail__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .about-detail__value {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
  }

  .about-detail__sub {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-1);
  }

  /* ── All Events ── */
  .all-events-section {
    padding-block: var(--space-20);
    border-top: 1px solid var(--color-border);
  }

  .all-events-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }
</style>
