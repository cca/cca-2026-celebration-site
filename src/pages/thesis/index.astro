---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import BentoEvents from '../../components/landing/BentoEvents.astro';
import Button from '../../components/ui/Button.astro';
import PastGallery from '../../components/sections/PastGallery.astro';
import FramedImage from '../../components/ui/FramedImage.astro';
import { formatDateRange } from '../../lib/utils/format';
import HalftoneProceduralScan from '../../components/effects/HalftoneProceduralScan.astro';
import ArrowLoop3D from '../../components/effects/ArrowLoop3D.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseAtLeast, isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);


const event = await getEntry('events', 'showcase');
if (!event) throw new Error('Event showcase not found');

const allEvents = (await getCollection('events')).sort((a, b) => a.data.order - b.data.order);
const events = allEvents.filter(e => e.data.type !== 'commencement' && e.data.type !== 'celebration');
// Phase-based logic replaces date-computed isPostEvent
const isPostEvent = isPhaseAtLeast(phase, 'post-event');
---

<BaseLayout title="Graduation Exhibitions" themeKey="showcase">
  <HalftoneProceduralScan
    dotColor="#00BFB3"
    dotOpacity={0.22}
    dotSpacing={18}
    dotRadius={4.5}
    scanSpeed={45}
    displacement={28}
    scanWidth={200}
    scannerCount={3}
    direction="xy"
    bidirectional
  />

  {/* ── Hero ── */}
  <section class="showcase-hero" data-cursor-scope>
<div class="showcase-hero__collage" aria-hidden="true">
      <div
        class="showcase-hero__fragment showcase-hero__fragment--1"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.035"
        data-cursor-max="36"
        data-cursor-lerp="0.06"
      >
        <FramedImage
          frameId="frame-04"
          src="/images/cca-photography/eoy-show-sp25.jpg"
          alt="Students and visitors at the CCA end-of-year show"
          uid="thesis-hero-1"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__fragment--2"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.055"
        data-cursor-max="28"
        data-cursor-lerp="0.12"
      >
        <FramedImage
          frameId="frame-11"
          src="/images/cca-photography/design-senior-show-fa25-54.jpg"
          alt="Design senior show installation view"
          uid="thesis-hero-2"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__fragment--3"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.042"
        data-cursor-max="24"
        data-cursor-lerp="0.08"
      >
        <FramedImage
          frameId="frame-07"
          src="/images/cca-photography/illustration-senior-show-fa25-43.jpg"
          alt="Illustration senior show artwork"
          uid="thesis-hero-3"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__doodle showcase-hero__doodle--1"
        data-cursor-track
        data-cursor-strength="0.05"
        data-cursor-max="45"
        data-cursor-lerp="0.12"
      >
        <ArrowLoop3D
          id="hero-arrow-1"
          cycleDuration={3}
          fadeOverlap={0.15}
          scaleAmount={0.04}
          spinDegrees={180}
          spinAxis="Y"
          perspective={300}
          sizeVariance={0.3}
          color="#00BFB3"
        />
      </div>
      <div
        class="showcase-hero__fragment showcase-hero__doodle showcase-hero__doodle--2"
        data-cursor-track
        data-cursor-strength="0.038"
        data-cursor-max="32"
        data-cursor-lerp="0.09"
      >
        <ArrowLoop3D
          id="hero-arrow-2"
          cycleDuration={3}
          fadeOverlap={0.15}
          scaleAmount={0.04}
          spinDegrees={180}
          spinAxis="Y"
          perspective={300}
          sizeVariance={0.3}
          color="#00BFB3"
          startDelay={1.5}
        />
      </div>
    </div>
    <div class="showcase-hero__content">
      <h1 class="showcase-hero__logo-wrap">
        <img
          src="/images/graduation-exhibitions/graduation-exhibitions-logo-primary.svg"
          alt="CCA Graduation Exhibitions 2026"
          class="showcase-hero__logo"
          width="900"
          height="630"
        />
      </h1>
    </div>
    <div class="showcase-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── About ── */}
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-grid__content">
          <span class="section-label reveal">About the Exhibitions</span>
          <h2 class="section-heading reveal">An Evening of Art, Design &amp; Making</h2>
          <p class="about-desc reveal">{event.data.description}</p>
          {isPhaseAtLeast(phase, 'pre-event') && (
            <div class="about-details reveal">
              <div class="about-detail">
                <span class="about-detail__label">When</span>
                <span class="about-detail__value">{formatDateRange(event.data.date, event.data.endDate)}</span>
                {event.data.time && <span class="about-detail__sub">{event.data.time}</span>}
              </div>
              <div class="about-detail">
                <span class="about-detail__label">Where</span>
                <span class="about-detail__value">{event.data.location}</span>
                {event.data.address && <a href={`https://maps.google.com/?q=${encodeURIComponent(event.data.address)}`} target="_blank" rel="noopener noreferrer" class="about-detail__sub">{event.data.address}</a>}
              </div>
            </div>
          )}
          <div class="about-subscribe reveal">
            <Button href="/subscribe" variant="link">Subscribe for Updates</Button>
          </div>
        </div>
        {isPhaseBefore(phase, 'pre-event') ? (
          <div class="about-grid__sidebar reveal">
            <div class="about-details">
              <div class="about-detail">
                <span class="about-detail__label">When</span>
                <span class="about-detail__value">{formatDateRange(event.data.date, event.data.endDate)}</span>
                {event.data.time && <span class="about-detail__sub">{event.data.time}</span>}
              </div>
              <div class="about-detail">
                <span class="about-detail__label">Where</span>
                <span class="about-detail__value">{event.data.location}</span>
                {event.data.address && <a href={`https://maps.google.com/?q=${encodeURIComponent(event.data.address)}`} target="_blank" rel="noopener noreferrer" class="about-detail__sub">{event.data.address}</a>}
              </div>
            </div>
          </div>
        ) : (
          <div class="about-grid__poster reveal">
            <img src="/images/thesis/poster.png" alt="Graduation Exhibitions 2026 poster" class="about-poster" />
          </div>
        )}
      </div>
    </div>
  </section>

  {/* ── All Celebration Events ── */}
  {isPhaseAtLeast(phase, 'pre-event') && (
    <section class="all-events-section">
      <div class="container">
        <span class="section-label reveal">Class of 2026</span>
        <h2 class="section-heading reveal">All Celebration Events</h2>
        <p class="all-events-desc reveal">
          From commencement ceremonies to thesis exhibitions and showcases, explore the full range of events celebrating the Class of 2026.
        </p>
        <BentoEvents events={events} />
      </div>
    </section>
  )}

  {/* ── Past Exhibitions Gallery ── */}
  <PastGallery
    label="Past Exhibitions"
    title="A Legacy of Creative Work"
    images={[
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Student artwork from a previous CCA exhibition' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Installation view from a past graduation exhibition' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Gallery view of student design work' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Visitors engaging with student installations' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Mixed media works on display' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Graduate thesis exhibition walkthrough' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Detail of student sculpture work' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Opening night at a previous exhibition' },
    ]}
  />

  {/* ── Email Signup ── */}
  <EmailSignup />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>
<script src="../../scripts/doodle-antics.ts"></script>
<script src="../../scripts/arrow-loop-3d.ts"></script>

<style>
  /* ── Hero ── */
  .showcase-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-x: clip;
    overflow-y: visible;
  }

  .showcase-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
  }

  .showcase-hero__logo-wrap {
    margin: 0 0 var(--space-6);
    line-height: 0;
  }

  .showcase-hero__logo {
    width: clamp(300px, 52vw, 640px);
    height: auto;
    display: block;
    margin: 0 auto;
    /* Drop shadow to lift logo off dark bg */
    filter: drop-shadow(0 2px 24px rgba(0, 191, 179, 0.18));
  }

  .showcase-hero__cta {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Collage fragments ── */
  .showcase-hero__collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .showcase-hero__fragment {
    position: absolute;
    --frame-color: #B7BF10;
  }

  .showcase-hero__fragment--1 {
    top: 4%;
    right: 2%;
    width: clamp(180px, 34vw, 460px);
    rotate: 3deg;
  }

  .showcase-hero__fragment--2 {
    bottom: 8%;
    left: 8%;
    width: clamp(120px, 22vw, 300px);
    rotate: -4deg;
  }

  .showcase-hero__fragment--3 {
    bottom: -14%;
    left: 68%;
    width: clamp(140px, 22vw, 280px);
    rotate: -3deg;
    --frame-color: #B7BF10;
  }

  .showcase-hero__doodle {
    pointer-events: auto;
    cursor: pointer;
  }

  .showcase-hero__doodle--1 {
    bottom: 28%;
    right: 7%;
    width: clamp(70px, 9vw, 130px);
    height: clamp(70px, 9vw, 130px);
  }

  .showcase-hero__doodle--2 {
    top: 14%;
    left: 7%;
    width: clamp(50px, 7vw, 100px);
    height: clamp(50px, 7vw, 100px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .showcase-hero__logo {
      opacity: 0;
      animation: fragment-enter 0.8s var(--ease-out-expo) 0.05s both;
    }

    .showcase-hero__fragment {
      opacity: 0;
      animation: fragment-enter 0.6s var(--ease-out-expo) both;
    }

    .showcase-hero__fragment--1 { animation-delay: 0.1s; }
    .showcase-hero__fragment--2 { animation-delay: 0.25s; }
    .showcase-hero__fragment--3 { animation-delay: 0.38s; }
    .showcase-hero__doodle--1 { animation-delay: 0.5s; }
    .showcase-hero__doodle--2 { animation-delay: 0.65s; }
  }

  @media (max-width: 767px) {
    .showcase-hero__collage {
      opacity: 0.5;
    }

    .showcase-hero__fragment--1 {
      width: clamp(120px, 44vw, 240px);
      right: -5%;
    }

    .showcase-hero__fragment--2 {
      width: clamp(90px, 32vw, 170px);
      left: -3%;
    }

    .showcase-hero__fragment--3 {
      display: none;
    }

    .showcase-hero__doodle {
      display: none;
    }
  }

.showcase-hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    z-index: 2;
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }

  /* ── Section rhythm ── */
  .about-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    margin-bottom: var(--space-10);
  }

  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: var(--space-16);
    }
  }

  .about-grid__poster {
    order: -1;
  }

  @media (min-width: 768px) {
    .about-grid__poster {
      order: 0;
    }
  }

  .about-poster {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    object-fit: cover;
  }


  .about-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  .about-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .about-subscribe {
    margin-top: var(--space-8);
  }

  @media (min-width: 640px) {
    .about-details {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-detail__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .about-detail__value {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
  }

  .about-detail__sub {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-1);
  }

  /* ── All Events ── */
  .all-events-section {
    padding-block: var(--space-20);
    border-top: 1px solid var(--color-border);
  }

  .all-events-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }
</style>
