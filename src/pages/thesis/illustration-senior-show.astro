---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'illustration-senior-show');
if (!event) throw new Error('Event illustration-senior-show not found');

const gallery = [
  { src: '/images/illus-showcase-sp26/illus-sp26-001.jpg', alt: 'A large crowd of students, families, and guests fill the CCA Main Building gallery space during the BFA Illustration Senior Show opening, with colorful illustration work displayed on the walls.' },
  { src: '/images/illus-showcase-sp26/illus-sp26-002.jpg', alt: 'A gallery wall displays "Welcome Home," a large triptych illustration by Wei Huang, alongside a grid of narrative paintings and mixed sculptural works at the BFA Illustration Senior Show.' },
  { src: '/images/illus-showcase-sp26/illus-sp26-003.jpg', alt: 'An overhead view of the packed BFA Illustration Senior Show opening reception, with guests mingling around a central drinks table and illustration work covering every wall.' },
  { src: '/images/illus-showcase-sp26/illus-sp26-004.jpg', alt: 'Students and faculty gather in a circle to celebrate during the BFA Illustration Senior Show, with an instructor holding a colorful printed illustration at the center.' },
  { src: '/images/illus-showcase-sp26/illus-sp26-005.jpg', alt: "Kaeli McLeod's illustrated booth at the BFA Illustration Senior Show features pink patterned wallpaper, framed prints, disco balls, and a hand-lettered display pedestal." },
];
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: 'BFA Illustration Senior Show' },
    ]} />
  </div>

  <EventHero event={event} heroImageSize="large" />

  <div class="container">
    <div class="page-layout">
      <div class="page-main">
        <section id="gallery" class="gallery-section reveal">
          <span class="gallery-kicker">From the BFA Illustration Senior Show</span>
          <div class="gallery-grid">
            {gallery.map((img, i) => (
              <div class:list={['gallery-item', i === 0 && 'gallery-item--featured']}>
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>
</ThesisEventLayout>

<style>
  .page-layout { padding-block: var(--space-8) var(--space-20); }

  .gallery-section { margin-block-start: var(--space-12); }

  .gallery-kicker {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-block-end: var(--space-4);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .gallery-item { overflow: hidden; border-radius: 2px; }

  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img { transform: scale(1.04); }

  .gallery-item--featured { grid-column: span 2; aspect-ratio: 16 / 9; }
  .gallery-item:not(.gallery-item--featured) { aspect-ratio: 4 / 3; }

  @media (min-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    .gallery-item--featured { grid-column: span 3; }
  }
</style>
