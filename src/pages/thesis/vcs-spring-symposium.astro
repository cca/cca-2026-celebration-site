---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import EventContextSection from '../../components/events/EventContextSection.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CeremonySchedule from '../../components/events/CeremonySchedule.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'vcs-spring-symposium');
if (!event) throw new Error('Event vcs-spring-symposium not found');

const presenters = [
  'Zedekiah Gonsalves Schild',
  'Chloe King',
  'Rosemary McDermott',
  'Hannah Fhaye Oliver',
  'Badri Valian',
];

const galleryImages = [
  { src: '/images/cca-photography/VCS-processed-images-001-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
  { src: '/images/cca-photography/VCS-processed-images-002-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
  { src: '/images/cca-photography/VCS-processed-images-003-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
  { src: '/images/cca-photography/VCS-processed-images-004-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
  { src: '/images/cca-photography/VCS-processed-images-005-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
  { src: '/images/cca-photography/VCS-processed-images-006-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
  { src: '/images/cca-photography/VCS-processed-images-007-04-2026.jpg', alt: 'VCS Spring Symposium 2025' },
];
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: '2026 VCS Spring Symposium' },
    ]} />
  </div>

  <EventHero event={event} />

  <div class="container">
    <div class="page-layout">
      <div class="page-main">
        <EventContextSection
          id="about"
          kicker="About the Symposium"
          paragraphs={[
            "The Visual + Critical Studies Spring Symposium brings together graduating VCS students for a day of presentations, discussions, and critical exchange.",
            "This year's cohort of presenters includes Zedekiah Gonsalves Schild, Chloe King, Rosemary McDermott, Hannah Fhaye Oliver, and Badri Valian. Admission is free and open to the public.",
          ]}
        />

        {event.data.schedule && (
          <section id="schedule" class="content-section reveal">
            <h2 class="section-heading">Program Schedule</h2>
            <CeremonySchedule schedule={event.data.schedule} />
          </section>
        )}

        <section id="presenters" class="content-section reveal">
          <h2 class="section-heading">Presenting Students</h2>
          <ul class="presenters-list">
            {presenters.map(name => (
              <li class="presenter-name">{name}</li>
            ))}
          </ul>
        </section>

        {/* ── Photo Gallery ── */}
        <section id="gallery" class="gallery-section reveal">
          <span class="gallery-kicker">From Last Year's Symposium</span>
          <div class="gallery-grid">
            {galleryImages.map((img, i) => (
              <div class:list={['gallery-item', i === 0 && 'gallery-item--featured']}>
                <img src={img.src} alt={img.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>
</ThesisEventLayout>

<style>
  .page-layout {
    padding-block: var(--space-8) var(--space-20);
  }

  /* ── Content Sections ── */
  .content-section {
    margin-block-start: var(--space-12);
  }

  .section-heading {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-block-end: var(--space-6);
  }

  .presenters-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .presenter-name {
    font-size: var(--text-base);
    padding-block: var(--space-2);
    border-block-end: 1px solid var(--color-border);
  }

  .presenter-name:first-child {
    border-block-start: 1px solid var(--color-border);
  }

  /* ── Gallery ── */
  .gallery-section {
    margin-block-start: var(--space-12);
  }

  .gallery-kicker {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-block-end: var(--space-4);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 2px;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .gallery-item--featured {
    grid-column: span 2;
    aspect-ratio: 16 / 9;
  }

  .gallery-item:not(.gallery-item--featured) {
    aspect-ratio: 4 / 3;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .gallery-item--featured {
      grid-column: span 3;
    }
  }
</style>
