---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import EventContextSection from '../../components/events/EventContextSection.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CeremonySchedule from '../../components/events/CeremonySchedule.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'film-screenings');
if (!event) throw new Error('Event film-screenings not found');
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: 'BFA & MFA Film Screenings' },
    ]} />
  </div>

  <EventHero event={event} hideDescription>
    <div slot="after-actions" class="hero-extras">
      <EventContextSection
        id="screenings"
        kicker="About the Screenings"
        paragraphs={[
          "Join us for an evening of graduating BFA and MFA Film students' thesis and capstone films — a showcase of new voices in cinema and moving image.",
        ]}
      />

      {event.data.schedule && (
        <section id="schedule" class="content-section reveal">
          <h2 class="section-heading">Program Schedule</h2>
          <CeremonySchedule schedule={event.data.schedule} />
        </section>
      )}
    </div>
  </EventHero>
</ThesisEventLayout>

<style>
  .hero-extras {
    margin-block-start: var(--space-10);
  }

  .content-section {
    margin-block-start: var(--space-10);
  }

  .section-heading {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-block-end: var(--space-6);
  }
</style>
