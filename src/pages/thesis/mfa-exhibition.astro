---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import EventContextSection from '../../components/events/EventContextSection.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'mfa-exhibition');
if (!event) throw new Error('Event mfa-exhibition not found');
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: 'MFA Thesis Exhibition' },
    ]} />
  </div>

  <EventHero event={event} />

  <div class="container">
    <div class="page-layout">
      <div class="page-main">
        <EventContextSection
          id="about"
          kicker="About the Exhibition"
          paragraphs={[
            "The 2026 MFA Thesis Exhibition is the culminating public presentation of graduate candidates across CCA's fine arts disciplines — a multi-week exhibition held at the Wattis Institute and the Deborah and Kenneth Novack Gallery.",
            "Spanning painting, sculpture, photography, film, performance, and interdisciplinary practice, the exhibition brings together the full breadth of MFA thesis work. The exhibition is open Wednesday–Saturday, noon–6 pm, and free to the public. The closing reception coincides with the All-Campus Graduation Exhibition event on May 15.",
          ]}
          meta={[
            { label: 'Format', value: 'Public exhibition with closing reception' },
            { label: 'Degree level', value: 'MFA Fine Arts' },
            { label: 'Duration', value: 'Wednesday–Saturday, May 1–16, 12–6 PM' },
            { label: 'Venues', value: 'Wattis Institute & Novack Gallery' },
            { label: 'Campus map', value: "View CCA's gallery map", href: 'https://cca.edu/exhibitions/galleries/#section-campus-map' },
          ]}
        />
      </div>
    </div>
  </div>

</ThesisEventLayout>
