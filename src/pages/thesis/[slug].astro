---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

export async function getStaticPaths() {
  return [
    'illustration-senior-show',
    'industrial-design-senior-show',
    'graphic-design-senior-show',
    'fashion-design-senior-show',
    'interaction-design-showcase',
    'mfa-design-silver-linings',
  ].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', slug);
if (!event) throw new Error(`Event ${slug} not found`);

const { gallery, galleryKicker = "From Last Year's Graduation Exhibition" } = event.data;
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: event.data.shortTitle || event.data.title },
    ]} />
  </div>

  <EventHero event={event} heroImageSize="large" />

  {gallery && gallery.length > 0 && (
    <div class="container">
      <div class="page-layout">
        <div class="page-main">
          <section id="gallery" class="gallery-section reveal">
            <span class="gallery-kicker">{galleryKicker}</span>
            <div class="gallery-grid">
              {gallery.map((img, i) => (
                <div class:list={['gallery-item', i === 0 && 'gallery-item--featured']}>
                  <img src={img.src} alt={img.alt} loading="lazy" />
                </div>
              ))}
            </div>
          </section>
        </div>
      </div>
    </div>
  )}
</ThesisEventLayout>

<style>
  .page-layout { padding-block: var(--space-8) var(--space-20); }

  .gallery-section { margin-block-start: var(--space-12); }

  .gallery-kicker {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-block-end: var(--space-4);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  .gallery-item { overflow: hidden; border-radius: 2px; }

  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img { transform: scale(1.04); }

  .gallery-item--featured { grid-column: span 2; aspect-ratio: 16 / 9; }
  .gallery-item:not(.gallery-item--featured) { aspect-ratio: 4 / 3; }

  @media (min-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    .gallery-item--featured { grid-column: span 3; }
  }
</style>
