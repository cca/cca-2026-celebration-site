---
import { getEntry } from 'astro:content';
import ThesisEventLayout from '../../layouts/ThesisEventLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import EventContextSection from '../../components/events/EventContextSection.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event')) {
  return Astro.redirect('/');
}

const event = await getEntry('events', 'mfa-fine-arts-open-house');
if (!event) throw new Error('Event mfa-fine-arts-open-house not found');
---

<ThesisEventLayout event={event}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Graduation Exhibitions', href: '/thesis/' },
      { label: 'MFA Fine Arts Open House' },
    ]} />
  </div>

  <EventHero event={event} heroImageSize="large" />

  <div class="container">
    <div class="page-layout">
      <div class="page-main">
        <EventContextSection
          id="about"
          kicker="About the Event"
          paragraphs={[
            "The MFA Fine Arts Open House invites visitors into the graduate studios to experience thesis work-in-progress and the full breadth of practice across CCA's MFA Fine Arts program — from painting and sculpture to installation, performance, and new media.",
            "More details coming soon.",
          ]}
        />
      </div>
    </div>
  </div>
</ThesisEventLayout>

<style>
  .page-layout {
    padding-block: var(--space-8) var(--space-20);
  }
</style>
