---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticleField from '../components/effects/ParticleField.astro';
import EmailSignup from '../components/sections/EmailSignup.astro';
---

<BaseLayout title="Subscribe" description="Sign up for the CCA 2026 Celebrations mailing list to receive event updates and RSVP reminders." minimalHeader>
  <ParticleField
    colors={['#00BFB3', '#563D82', '#FFC845', '#E57200', '#005776']}
    count={80}
    sizeRange={[3, 9]}
    opacityRange={[0.12, 0.45]}
  />

  <div class="subscribe-page">
    <div class="subscribe-main">
      <h1 class="subscribe-title">Stay connected</h1>
      <p class="subscribe-intro">
        Join the CCA 2026 Celebrations list to get event updates, schedule changes, and RSVP reminders.
      </p>
      <EmailSignup heading="" description="" />
    </div>
  </div>
</BaseLayout>

<style>
  .subscribe-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - 60px);
    padding: var(--space-10) var(--space-8);
  }

  .subscribe-main {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 640px;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .subscribe-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .subscribe-intro {
    color: var(--color-muted);
    font-size: var(--text-base);
    margin-bottom: var(--space-8);
    max-width: 55ch;
  }

  /* Let the EmailSignup card render with its full styling */
  .subscribe-main :global(.signup-section) {
    padding-block: 0;
  }

  .subscribe-main :global(.signup-section > .container) {
    padding-inline: 0;
  }

  .subscribe-main :global(.signup-card-wrapper) {
    max-width: none;
  }

  .subscribe-main :global(.signup-card) {
    max-width: none;
  }

  /* Pull floating arrows closer on this narrower layout */
  .subscribe-main :global(.floating-img-behind) {
    left: calc(50% - 380px);
  }

  .subscribe-main :global(.floating-img-front) {
    right: calc(50% - 360px);
  }
</style>
