---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticleField from '../components/effects/ParticleField.astro';

import EmailSignup from '../components/sections/EmailSignup.astro';

import Button from '../components/ui/Button.astro';
import FramedImage from '../components/ui/FramedImage.astro';
import { getCurrentPhase } from '../lib/utils/phase';
import { isPhaseAtLeast } from '../config/phases';

const events = (await getCollection('events')).sort((a, b) => a.data.order - b.data.order);

// Commencement data (use undergraduate entry for the shared ceremony info)
const commencementEntry = await getEntry('events', 'commencement-undergraduate');

// Showcase / Graduation Exhibitions data
const showcaseEntry = await getEntry('events', 'showcase');

// Phase-based logic replaces date-computed isPostEvent
const phase = getCurrentPhase(Astro.url);
const isPostEvent = isPhaseAtLeast(phase, 'post-event');
---

<BaseLayout title="2026 Celebrations" description="Celebrate the achievements of CCA's Class of 2026 at commencement ceremonies, exhibitions, and showcases.">

  <ParticleField
    colors={['#00BFB3', '#563D82', '#FFC845', '#E57200', '#005776']}
    count={80}
    sizeRange={[3, 9]}
    opacityRange={[0.12, 0.45]}
  />

  <!-- 1. Hero -->
  <section class="hero" data-cursor-scope>
    <div class="hero__seal" aria-hidden="true"></div>
    <div class="hero__collage" aria-hidden="true">
      <div
        class="hero__fragment hero__fragment--1"
        data-cursor-track
        data-cursor-strength="0.028"
        data-cursor-max="20"
        data-cursor-lerp="0.07"
      >
        <FramedImage
          frameId="frame-23"
          src="/images/cca-photography/commencement-masters24.jpg"
          alt=""
          uid="home-hero-1"
        />
      </div>
      <div
        class="hero__fragment hero__fragment--2"
        data-cursor-track
        data-cursor-strength="0.02"
        data-cursor-max="24"
        data-cursor-lerp="0.05"
        style="background-image: url('/images/cca-photography/eoy-show-sp25.jpg'); mask-image: url('/images/chimera-expanded-2026/shape-040.svg'); -webkit-mask-image: url('/images/chimera-expanded-2026/shape-040.svg');"
      ></div>
    </div>
    <div class="hero__content" id="hero-content">
      <img src="/images/logos/wordmark-single.svg" alt="California College of the Arts" class="hero__eyebrow stagger-1" />
      <span class="hero__year stagger-2" role="img" aria-label="2026"></span>
      <span class="hero__label stagger-3">{isPostEvent ? 'Congratulations' : 'Celebrations'}</span>
      <p class="hero__tagline stagger-4">
        {isPostEvent
          ? 'Honoring the creativity, resilience, and vision of the Class of 2026.'
          : 'Honoring the creativity, resilience, and vision of a class that will carry CCA forward.'}
      </p>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  <!-- 2. Hero Media — Video -->
  <section class="hero-media">
    <div class="hero-media__frame" id="hero-frame">
      <video
        class="hero-media__video"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      >
        <source src="https://storage.googleapis.com/ccaedu-prod/media/media/CCAEDU-Homepage-SP26-jrl.webm" type="video/webm" />
      </video>
    </div>
  </section>

  <!-- 3. Commencement -->
  {commencementEntry && (
    <section id="events" class="anchor-section anchor-section--commencement reveal">
      <div class="container">
        <div class="anchor-section__layout">
          <div class="anchor-section__content">
            <div class="anchor-section__header">
              <span class="section-label">May 16, 2026</span>
              <h2 class="anchor-section__title">119<sup>th</sup> Commencement</h2>
            </div>
            <div class="anchor-section__body">
              <p class="anchor-section__desc">{commencementEntry.data.description}</p>
              <div class="anchor-section__cta">
                <Button href="/commencement/" variant="link">Commencement details</Button>
              </div>
            </div>
          </div>
          <div class="anchor-section__image">
            <img
              src="https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg"
              alt="Graduates celebrating at CCA's commencement ceremony"
              loading="lazy"
              width="640"
              height="480"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 5. Graduation Exhibitions -->
    {showcaseEntry && (
      <section class="anchor-section anchor-section--exhibitions reveal">
        <div class="container">
          <div class="anchor-section__layout anchor-section__layout--reverse">
            <div class="anchor-section__content">
              <div class="anchor-section__header">
                <span class="section-label">May 15, 2026</span>
                <h2 class="anchor-section__title">CCA Graduation Exhibitions 2026</h2>
              </div>
              <div class="anchor-section__body">
                <p class="anchor-section__desc">{showcaseEntry.data.description}</p>
                <div class="anchor-section__cta">
                  <Button href="/thesis/" variant="link">Join the all-campus celebration</Button>
                </div>
              </div>
            </div>
            <div class="anchor-section__image">
              <img
                src="https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg"
                alt="Student work on display at CCA's Graduation Exhibitions"
                loading="lazy"
                width="480"
                height="640"
              />
            </div>
          </div>
        </div>
      </section>
    )}

  <!-- 7. Email Signup -->
  <section id="subscribe" class="signup-section">
    <div class="signup-section__glow" aria-hidden="true"></div>
    <EmailSignup />
  </section>

</BaseLayout>

<script src="../scripts/hero-scale.ts"></script>
<script src="../scripts/cursor-track.ts"></script>
<script src="../scripts/doodle-antics.ts"></script>
<script src="../scripts/arrow-loop-3d.ts"></script>
<script src="../scripts/chimera-loop-3d.ts"></script>

<!-- Hero parallax: fade + translate content on scroll -->
<script>
  function initHeroParallax() {
    const content = document.getElementById('hero-content');
    if (!content) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const viewH = window.innerHeight;
        const progress = Math.min(scrollY / (viewH * 0.6), 1);
        content!.style.opacity = String(1 - progress);
        content!.style.transform = `translateY(${-progress * 60}px)`;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    // Reset on page load (Astro view transitions)
    content.style.opacity = '1';
    content.style.transform = 'translateY(0)';
  }

  initHeroParallax();
  document.addEventListener('astro:page-load', initHeroParallax);
</script>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
    will-change: transform, opacity;
  }

  .hero__eyebrow {
    display: block;
    width: clamp(180px, 28vw, 320px);
    height: auto;
    margin-bottom: var(--space-4);
  }

  .hero__year {
    display: block;
    height: clamp(4rem, 13vw, 10rem);
    aspect-ratio: 948.8 / 269.9;
    margin-block: var(--space-6);
    background: linear-gradient(
      90deg,
      var(--color-shimmer-base) 0%,
      var(--color-shimmer-highlight) 25%,
      var(--color-shimmer-base) 50%,
      var(--color-shimmer-warm) 75%,
      var(--color-shimmer-base) 100%
    );
    background-size: 200% auto;
    -webkit-mask-image: url('/images/logos/2026.svg');
    mask-image: url('/images/logos/2026.svg');
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    animation: shimmer 6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__year {
      animation: none;
    }
  }

  .hero__label {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    margin-top: 0;
    line-height: 1.2;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 36ch;
    margin-top: var(--space-4);
    line-height: 1.5;
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-8);
    flex-wrap: wrap;
    justify-content: center;
  }


  /* ---- Seal watermark ---- */
  .hero__seal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(300px, 64vw, 640px);
    aspect-ratio: 1;
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      color-mix(in srgb, var(--color-accent) 50%, white) 25%,
      var(--color-accent) 50%,
      color-mix(in srgb, var(--color-accent) 60%, #004040) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% auto;
    opacity: 0.08;
    mask-image: url('/images/cca-seal.svg');
    -webkit-mask-image: url('/images/cca-seal.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme="commencement"]) .hero__seal,
  :global([data-theme="thesis-grad"]) .hero__seal {
    opacity: 0.11;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__seal {
      animation: seal-hero-breathe 12s ease-in-out infinite, shimmer 8s ease-in-out infinite;
    }
  }

  /* ---- Photo + Geometric Collage ---- */
  .hero__collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__fragment {
    position: absolute;
    opacity: 0;
    animation: fragment-enter 0.6s var(--ease-out-expo) forwards;
  }

  .hero__fragment--1 {
    top: 8%;
    right: 4%;
    width: 22vw;
    rotate: 4deg;
    animation-delay: 0.15s;
  }

  .hero__fragment--2 {
    bottom: 10%;
    left: 3%;
    width: 22vw;
    aspect-ratio: 9.49 / 8.47;
    background-size: cover;
    background-position: center 30%;
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    rotate: -5deg;
    animation-delay: 0.3s;
  }


  @media (max-width: 767px) {
    .hero__collage {
      opacity: 0.6;
    }

    .hero__fragment--1 {
      width: 35vw;
      right: -5%;
    }

    .hero__fragment--2 {
      width: 28vw;
      left: -3%;
    }

  }

  /* ---- Scroll indicator ---- */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  /* ---- Hero Media ---- */
  .hero-media {
    padding-block: var(--space-4) var(--space-20);
    overflow: hidden;
  }

  .hero-media__frame {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--grid-gutter);
    transform: scale(0.65);
    will-change: transform;
    transition: transform 0.1s linear;
  }

  .hero-media__video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--color-surface);
    border-radius: 20px;
    overflow: hidden;
    will-change: border-radius;
    transition: border-radius 0.1s linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media__frame {
      transform: scale(1) !important;
    }
    .hero-media__video {
      border-radius: var(--radius-card, 12px) !important;
    }
  }

  /* ---- Anchor Sections (Commencement / Exhibitions) ---- */
  .anchor-section {
    padding-block: var(--space-24);
  }

  .anchor-section__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  @media (min-width: 768px) {
    .anchor-section__layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }

    .anchor-section__layout--reverse .anchor-section__content {
      order: 2;
    }

    .anchor-section__layout--reverse .anchor-section__image {
      order: 1;
    }
  }

  .anchor-section__header {
    margin-bottom: var(--space-8);
  }

  .anchor-section__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
  }

  .anchor-section__title sup {
    font-size: 0.5em;
    vertical-align: super;
  }

  .anchor-section__meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
  }

  .anchor-section__desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .anchor-section__cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .anchor-section__image {
    position: relative;
    border-radius: var(--radius-card, 12px);
    overflow: hidden;
  }

  .anchor-section__image img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-card, 12px);
  }

  @media (max-width: 767px) {
    .anchor-section__image img {
      aspect-ratio: 16 / 9;
    }
  }

  /* ---- Email Signup Section ---- */
  .signup-section {
    position: relative;
    overflow: hidden;
  }

  .signup-section__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(
      ellipse at center,
      var(--color-accent) 0%,
      transparent 70%
    );
    opacity: 0.06;
    pointer-events: none;
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
