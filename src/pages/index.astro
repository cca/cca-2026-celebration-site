---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ConfettiCanvas from '../components/effects/ConfettiCanvas.astro';
import BentoEvents from '../components/landing/BentoEvents.astro';
import WorkCard from '../components/works/WorkCard.astro';
import EmailSignup from '../components/sections/EmailSignup.astro';
import Button from '../components/ui/Button.astro';
import { fullName } from '../lib/utils/format';

const events = (await getCollection('events')).sort((a, b) => a.data.order - b.data.order);

// Featured works
const works = await getCollection('works');
const students = await getCollection('students');
const studentMap = new Map(students.map(s => [s.id, fullName(s)]));
const featuredWorks = works
  .filter(w => w.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 4);

// Determine if commencement has passed (use latest ceremony date)
const commencementEvents = events.filter(e => e.data.type === 'commencement');
const latestDate = commencementEvents.reduce((latest, e) => {
  const d = new Date(e.data.date);
  return d > latest ? d : latest;
}, new Date(0));
const isPostEvent = new Date() > latestDate;
---

<BaseLayout title="2026 Celebrations" description="Celebrate the achievements of CCA's Class of 2026 at commencement ceremonies, exhibitions, and showcases.">
  <section class="hero">
    <ConfettiCanvas />
    <div class="hero__content">
      <span class="hero__cca">CCA</span>
      <span class="hero__year shimmer-text">2026</span>
      <p class="hero__subtitle">{isPostEvent ? 'Congratulations, Class of 2026' : 'Celebrations'}</p>
      <div class="hero__cta stagger-1">
        {isPostEvent ? (
          <Button href="/commencement/recap/" variant="primary">Relive the Celebrations</Button>
        ) : (
          <Button href="#events" variant="primary">Explore Events</Button>
        )}
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  <section class="hero-media">
    <div class="hero-media__frame" id="hero-frame">
      <div class="hero-media__placeholder" aria-hidden="true"></div>
    </div>
  </section>

  <section id="events" class="events-section">
    <div class="container">
      <span class="section-label">{isPostEvent ? 'Class of 2026' : 'Upcoming'}</span>
      <h2 class="section-heading">{isPostEvent ? 'Celebrations' : 'Events'}</h2>
      <BentoEvents events={events} />
    </div>
  </section>

  {featuredWorks.length > 0 && (
    <section class="works-section">
      <div class="container">
        <span class="section-label">Featured</span>
        <h2 class="section-heading">Student Works</h2>
        <div class="works-grid">
          {featuredWorks.map(work => {
            const names = work.data.students?.map(ref => studentMap.get(ref.id)).filter(Boolean) as string[] ?? [];
            return (
              <div class="reveal">
                <WorkCard work={work} studentNames={names} />
              </div>
            );
          })}
        </div>
        <div class="works-cta">
          <Button href="/showcase/works/" variant="outline">View All Works</Button>
        </div>
      </div>
    </section>
  )}

  <EmailSignup />
</BaseLayout>

<script src="../scripts/hero-scale.ts"></script>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
  }

  .hero__cca {
    display: block;
    font-family: var(--font-body);
    font-size: clamp(4rem, 10vw, 10rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
  }

  .hero__year {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 10rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-muted);
    margin-top: var(--space-4);
  }

  .hero__cta {
    margin-top: var(--space-6);
  }

  /* ---- Scroll indicator ---- */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  /* ---- Hero Media (scaling image section) ---- */
  .hero-media {
    padding: var(--space-4) var(--space-4) var(--space-20);
    overflow: hidden;
  }

  .hero-media__frame {
    transform: scale(0.78);
    border-radius: 16px;
    overflow: hidden;
    will-change: transform, border-radius;
    transition: transform 0.1s linear, border-radius 0.1s linear;
  }

  .hero-media__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--gradient-prismatic);
    background-size: 200% 200%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-media__placeholder {
      animation: prismatic-shift 6s linear infinite;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media__frame {
      transform: scale(1) !important;
      border-radius: 0 !important;
    }
  }

  /* ---- Sections ---- */
  .events-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    margin-bottom: var(--space-10);
  }

  /* ---- Featured Works ---- */
  .works-section {
    padding-block: var(--space-20);
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .works-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-10);
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
