---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import StudentGrid from '../../../../components/students/StudentGrid.astro';
import FilterChips from '../../../../components/ui/FilterChips.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import { getStudentsByProgram } from '../../../../lib/utils/collections';
import { CURRENT_PHASE, isPhaseBefore } from '../../../../config/phases';

export async function getStaticPaths() {
  if (isPhaseBefore(CURRENT_PHASE, 'pre-event')) return [];
  const programs = await getCollection('programs');
  return programs.map(program => ({
    params: { slug: program.data.slug },
    props: { program },
  }));
}

const { program } = Astro.props;

const students = await getStudentsByProgram(program.id);
const programs = await getCollection('programs');
const programMap = new Map(programs.map(p => [p.id, p.data.name]));

const programChips = [
  { label: 'All', href: '/showcase/students/' },
  ...programs.map(p => ({
    label: p.data.name,
    href: `/showcase/students/program/${p.data.slug}/`,
    active: p.id === program.id,
  })),
];
---

<BaseLayout title={`Students — ${program.data.name}`}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Student Showcase', href: '/showcase/' },
      { label: 'Students', href: '/showcase/students/' },
      { label: program.data.name },
    ]} />

    <section class="students-intro reveal">
      <h1>{program.data.name}</h1>
      <p>{program.data.description}</p>
    </section>

    <FilterChips items={programChips} />

    <section class="students-grid-section reveal">
      {students.length > 0 ? (
        <StudentGrid students={students} programMap={programMap} />
      ) : (
        <p class="empty-state">No students found in this program.</p>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .students-intro {
    padding-block: var(--space-10) var(--space-6);
  }

  .students-intro h1 {
    margin-bottom: var(--space-4);
  }

  .students-intro p {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
  }

  .students-grid-section {
    padding-block: var(--space-6) var(--space-12);
  }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
  }
</style>
