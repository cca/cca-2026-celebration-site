---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CreditsRoll from '../../../components/showcase/CreditsRoll.astro';

import { getAllStudentsGroupedByDivision } from '../../../lib/utils/collections';
import { getCurrentPhase } from '../../../lib/utils/phase';
import { isPhaseBefore } from '../../../config/phases';

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'pre-event') || phase === 'during-event') {
  return Astro.redirect('/');
}

const students = await getCollection('students');
const groups = await getAllStudentsGroupedByDivision();
---

<BaseLayout title="Students — Student Showcase" description="Meet the talented artists, designers, writers, and architects of CCA's Class of 2026." themeKey="showcase">

  <CreditsRoll groups={groups} totalCount={students.length} />

</BaseLayout>
