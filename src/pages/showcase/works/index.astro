---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import WorkGrid from '../../../components/works/WorkGrid.astro';
import FilterChips from '../../../components/ui/FilterChips.astro';
import { fullName } from '../../../lib/utils/format';
import { getAllTags } from '../../../lib/utils/collections';

const works = (await getCollection('works')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const students = await getCollection('students');
const studentMap = new Map(students.map(s => [s.id, fullName(s)]));
const tags = await getAllTags();

const tagChips = [
  { label: 'All', href: '/showcase/works/', active: true },
  ...tags.map(tag => ({
    label: tag,
    href: `/showcase/works/tag/${tag}/`,
  })),
];
---

<BaseLayout title="Works" description="Browse creative works by CCA's Class of 2026 across exhibitions and showcases.">
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Student Showcase', href: '/showcase/' },
      { label: 'Works' },
    ]} />

    <section class="works-intro reveal">
      <h1>Works</h1>
      <p>Browse creative works by CCA's Class of 2026, showcased across commencement, thesis exhibitions, and the end-of-year showcase.</p>
    </section>

    <FilterChips items={tagChips} />

    {works.length > 0 && (
      <section class="works-grid-section">
        <WorkGrid works={works} studentMap={studentMap} />
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .works-intro {
    padding-block: var(--space-10) var(--space-6);
  }

  .works-intro h1 {
    margin-bottom: var(--space-4);
  }

  .works-intro p {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: 60ch;
  }

  .works-grid-section {
    padding-block: var(--space-4) var(--space-16);
  }
</style>
