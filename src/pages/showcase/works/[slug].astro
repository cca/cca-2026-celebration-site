---
import { getCollection, getEntry } from 'astro:content';
import WorkLayout from '../../../layouts/WorkLayout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import { fullName } from '../../../lib/utils/format';
import { CURRENT_PHASE, isPhaseBefore } from '../../../config/phases';

export async function getStaticPaths() {
  if (isPhaseBefore(CURRENT_PHASE, 'pre-event')) return [];
  const works = await getCollection('works');
  return works.map(work => ({
    params: { slug: work.data.slug },
    props: { work },
  }));
}

const { work } = Astro.props;

const studentEntries = await Promise.all(
  work.data.students.map(ref => getEntry('students', ref.id))
);
const students = studentEntries.filter(Boolean);

const eventEntries = await Promise.all(
  work.data.events.map(ref => getEntry('events', ref.id))
);
const events = eventEntries.filter(Boolean);

const typeMap: Record<string, string> = {
  commencement: '/commencement/',
  showcase: '/thesis/all-campus-graduation-exhibition/',
  'thesis-exhibition': '/thesis/',
};

function getEventHref(event: { data: { type: string; degreeLevel: string } }) {
  const base = typeMap[event.data.type] ?? '/';
  return event.data.degreeLevel === 'all' ? base : `${base}${event.data.degreeLevel}/`;
}
---

<WorkLayout work={work}>
  <div class="container" slot="media">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Student Showcase', href: '/showcase/' },
      { label: 'Works', href: '/showcase/works/' },
      { label: work.data.title },
    ]} />
  </div>

  <section class="work-artists-section reveal" slot="artists">
    <h2>Artists</h2>
    <ul class="artist-list">
      {students.map(student => (
        <li>
          <a href={`/showcase/students/${student!.data.slug}/`}>{fullName(student!)}</a>
          <span class="artist-degree">{student!.data.degreeType}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="work-events-section reveal" slot="navigation">
    <h2>Exhibited At</h2>
    <ul class="event-list">
      {events.map(event => (
          <li>
            <a href={getEventHref(event!)}>{event!.data.title}</a>
          </li>
      ))}
    </ul>

    {work.data.tags && work.data.tags.length > 0 && (
      <div class="work-tags">
        <h3>Tags</h3>
        <ul class="tag-list">
          {work.data.tags.map(tag => (
            <li><a href={`/showcase/works/tag/${tag}/`} class="tag">{tag}</a></li>
          ))}
        </ul>
      </div>
    )}
  </section>
</WorkLayout>

<style>
  .work-artists-section {
    margin-bottom: var(--space-8);
  }

  .work-artists-section h2,
  .work-events-section h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .artist-list,
  .event-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .artist-degree {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin-left: var(--space-2);
  }

  .work-tags {
    margin-top: var(--space-6);
  }

  .work-tags h3 {
    font-size: var(--text-base);
    margin-bottom: var(--space-3);
  }

  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
