---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import WorkGrid from '../../../../components/works/WorkGrid.astro';
import FilterChips from '../../../../components/ui/FilterChips.astro';
import { fullName } from '../../../../lib/utils/format';
import { getAllTags, getWorksByTag } from '../../../../lib/utils/collections';
import { CURRENT_PHASE, isPhaseBefore } from '../../../../config/phases';

export async function getStaticPaths() {
  if (isPhaseBefore(CURRENT_PHASE, 'pre-event') || CURRENT_PHASE === 'during-event') return [];
  const tags = await getAllTags();
  return tags.map(tag => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const works = await getWorksByTag(tag);
const students = await getCollection('students');
const studentMap = new Map(students.map(s => [s.id, fullName(s)]));
const allTags = await getAllTags();

const tagChips = [
  { label: 'All', href: '/showcase/works/' },
  ...allTags.map(t => ({
    label: t,
    href: `/showcase/works/tag/${t}/`,
    active: t === tag,
  })),
];
---

<BaseLayout title={`Works — ${tag}`} description={`Creative works tagged "${tag}" by CCA's Class of 2026.`}>
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Student Showcase', href: '/showcase/' },
      { label: 'Works', href: '/showcase/works/' },
      { label: tag },
    ]} />

    <section class="works-intro reveal">
      <h1>{tag}</h1>
      <p>Works tagged "{tag}" by CCA's Class of 2026.</p>
    </section>

    <FilterChips items={tagChips} />

    {works.length > 0 ? (
      <section class="works-grid-section">
        <WorkGrid works={works} studentMap={studentMap} />
      </section>
    ) : (
      <p class="empty-state">No works found with this tag.</p>
    )}
  </div>
</BaseLayout>

<style>
  .works-intro {
    padding-block: var(--space-10) var(--space-6);
  }

  .works-intro h1 {
    margin-bottom: var(--space-4);
    text-transform: capitalize;
  }

  .works-intro p {
    font-size: var(--text-lg);
    color: var(--color-text);
    max-width: 60ch;
  }

  .works-grid-section {
    padding-block: var(--space-4) var(--space-16);
  }

  .empty-state {
    color: var(--color-text);
    font-style: italic;
    padding-block: var(--space-8);
  }
</style>
