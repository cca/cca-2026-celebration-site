---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
---

<DemoEffectLayout title="Arrow Loop — Transform">
  <div class="stage">
    <div class="slot" id="slot-a">
      <img id="img-a" src="" alt="" />
    </div>
    <div class="slot" id="slot-b">
      <img id="img-b" src="" alt="" />
    </div>
  </div>

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Arrow Loop — Transform</h1>
    <p class="demo-technique">X-axis only · ScaleX · RotateX · TranslateX · Stationary</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Arrows stay centered while X-axis transforms animate continuously —
      scaleX squashes and stretches, rotateX flips in perspective, and translateX
      oscillates side to side. Arrows crossfade between each cycle.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="cycle-speed">Cycle Duration: <output id="cycle-speed-val">3s</output></label>
        <input type="range" id="cycle-speed" min="1" max="8" value="3" step="0.5" />
      </div>
      <div class="control-group">
        <label for="scale-x-amount">ScaleX Amount: <output id="scale-x-amount-val">0.4</output></label>
        <input type="range" id="scale-x-amount" min="0" max="1" value="0.4" step="0.05" />
      </div>
      <div class="control-group">
        <label for="scale-x-speed">ScaleX Speed: <output id="scale-x-speed-val">1.0</output>x</label>
        <input type="range" id="scale-x-speed" min="0.2" max="4" value="1.0" step="0.1" />
      </div>
      <div class="control-group">
        <label for="rotate-x-amount">RotateX Amount: <output id="rotate-x-amount-val">30</output>&deg;</label>
        <input type="range" id="rotate-x-amount" min="0" max="90" value="30" step="5" />
      </div>
      <div class="control-group">
        <label for="rotate-x-speed">RotateX Speed: <output id="rotate-x-speed-val">0.7</output>x</label>
        <input type="range" id="rotate-x-speed" min="0.1" max="4" value="0.7" step="0.1" />
      </div>
      <div class="control-group">
        <label for="translate-x-amount">TranslateX Amount: <output id="translate-x-amount-val">8</output>vw</label>
        <input type="range" id="translate-x-amount" min="0" max="30" value="8" step="1" />
      </div>
      <div class="control-group">
        <label for="translate-x-speed">TranslateX Speed: <output id="translate-x-speed-val">0.5</output>x</label>
        <input type="range" id="translate-x-speed" min="0.1" max="4" value="0.5" step="0.1" />
      </div>
      <div class="control-group">
        <label for="perspective">Perspective: <output id="perspective-val">800</output>px</label>
        <input type="range" id="perspective" min="200" max="2000" value="800" step="50" />
      </div>
      <div class="control-group">
        <label for="size-variance">Size Variance: <output id="size-variance-val">0.3</output></label>
        <input type="range" id="size-variance" min="0" max="0.6" value="0.3" step="0.05" />
      </div>
      <div class="control-group">
        <label for="fade-overlap">Crossfade Overlap: <output id="fade-overlap-val">0.3</output></label>
        <input type="range" id="fade-overlap" min="0.1" max="0.8" value="0.3" step="0.05" />
      </div>
      <div class="control-group">
        <label>Tint Colors</label>
        <div class="swatch-picker" id="tint-swatches">
          <button class="swatch active" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch active" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch active" data-color="#E57200" style="background:#E57200" title="Orange"></button>
          <button class="swatch active" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch active" data-color="#B7BF10" style="background:#B7BF10" title="Lime"></button>
          <button class="swatch active" data-color="#F1BDC8" style="background:#F1BDC8" title="Pink"></button>
          <button class="swatch active" data-color="#005776" style="background:#005776" title="Navy"></button>
        </div>
        <p class="swatch-hint">Click to toggle colors in the cycle</p>
      </div>
      <div class="control-group">
        <button class="toggle-btn" id="toggle-pause">Pause</button>
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  .stage {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 800px;
  }

  .slot {
    position: absolute;
    width: 40vmin;
    height: 40vmin;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: opacity, transform;
    transform-style: preserve-3d;
  }

  .slot img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] { display: none; }

  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open { transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .sidebar { transition: none; }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-muted);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }

  .control-group select {
    width: 100%;
    padding: var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .toggle-btn {
    width: 100%;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .toggle-btn:hover { border-color: var(--color-accent); }

  .swatch-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-1);
  }

  .swatch {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
    opacity: 0.35;
  }

  .swatch:hover { transform: scale(1.15); }

  .swatch.active {
    border-color: var(--color-text);
    opacity: 1;
  }

  .swatch-hint {
    font-size: var(--text-xs);
    color: var(--color-muted);
    opacity: 0.7;
  }
</style>

<script>
  const arrowIds = [
    'arrow-02', 'arrow-03', 'arrow-04', 'arrow-05', 'arrow-06',
    'arrow-07', 'arrow-08', 'arrow-09', 'arrow-10', 'arrow-11',
    'arrow-12', 'arrow-13',
  ];

  const allColors = ['#00BFB3', '#563D82', '#E57200', '#FFC845', '#B7BF10', '#F1BDC8', '#005776'];
  let activeColors = [...allColors];

  const slotA = document.getElementById('slot-a') as HTMLElement;
  const slotB = document.getElementById('slot-b') as HTMLElement;
  const imgA = document.getElementById('img-a') as HTMLImageElement;
  const imgB = document.getElementById('img-b') as HTMLImageElement;

  const stage = document.querySelector('.stage') as HTMLElement;

  // Transform parameters
  let cycleDuration = 3;
  let scaleXAmount = 0.4;
  let scaleXSpeed = 1.0;
  let rotateXAmount = 30;
  let rotateXSpeed = 0.7;
  let translateXAmount = 8;
  let translateXSpeed = 0.5;
  let sizeVariance = 0.3;
  let fadeOverlap = 0.3;
  let perspectiveVal = 800;
  let paused = false;
  let index = 0;
  let colorIdx = 0;

  function tint(hex: string): string {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    const l = (max + min) / 2;
    let h = 0, s = 0;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) * 60;
      else if (max === g) h = ((b - r) / d + 2) * 60;
      else h = ((r - g) / d + 4) * 60;
    }
    return `brightness(0) saturate(100%) invert(${l > 0.5 ? 1 : 0.5}) sepia(1) saturate(${Math.max(s * 600, 100)}%) hue-rotate(${h}deg) brightness(${0.4 + l * 0.8})`;
  }

  function nextArrow(): string {
    const id = arrowIds[index % arrowIds.length];
    index++;
    return id;
  }

  function nextColor(): string {
    if (activeColors.length === 0) return '#231f20';
    const c = activeColors[colorIdx % activeColors.length];
    colorIdx++;
    return c;
  }

  function easeInOut(t: number) {
    return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
  }

  // State: two slots crossfade while transforms animate continuously
  type Phase = 'idle' | 'fade-in' | 'hold' | 'fade-out';
  const state = [
    { phase: 'idle' as Phase, start: 0, arrow: '', color: '', sizeMult: 1, phaseOffset: 0 },
    { phase: 'idle' as Phase, start: 0, arrow: '', color: '', sizeMult: 1, phaseOffset: 0 },
  ];

  const els = [
    { el: slotA, img: imgA },
    { el: slotB, img: imgB },
  ];

  function kick(slot: number, now: number) {
    state[slot].arrow = nextArrow();
    state[slot].color = nextColor();
    state[slot].sizeMult = 1 + (Math.random() * 2 - 1) * sizeVariance;
    // Random phase offset so each arrow's oscillation starts at a different point
    state[slot].phaseOffset = Math.random() * Math.PI * 2;
    els[slot].img.src = `/images/scanned-graphics/arrows/${state[slot].arrow}.svg`;
    els[slot].img.style.filter = tint(state[slot].color);
    state[slot].phase = 'fade-in';
    state[slot].start = now;
  }

  // Compute the X-axis transforms based on elapsed time
  function computeTransform(elapsed: number, sizeMult: number, phaseOffset: number): string {
    const tx = Math.sin(elapsed * translateXSpeed + phaseOffset) * translateXAmount;
    const sx = 1 + Math.sin(elapsed * scaleXSpeed * 1.3 + phaseOffset) * scaleXAmount;
    const rx = Math.sin(elapsed * rotateXSpeed * 0.9 + phaseOffset + 1) * rotateXAmount;

    return `translateX(${tx}vw) scaleX(${sx * sizeMult}) rotateX(${rx}deg)`;
  }

  function tick(now: number) {
    if (paused) { requestAnimationFrame(tick); return; }

    for (let i = 0; i < 2; i++) {
      const s = state[i];
      const { el } = els[i];
      if (s.phase === 'idle') continue;

      const elapsed = (now - s.start) / 1000;
      const fadeDur = cycleDuration * fadeOverlap;
      const holdDur = cycleDuration * (1 - fadeOverlap * 2);

      // Transforms animate continuously regardless of phase
      el.style.transform = computeTransform(elapsed, s.sizeMult, s.phaseOffset);

      if (s.phase === 'fade-in') {
        const t = Math.min(elapsed / fadeDur, 1);
        el.style.opacity = String(easeInOut(t));

        if (t >= 1) {
          s.phase = 'hold';
          s.start = now;
          el.style.opacity = '1';
        }
      } else if (s.phase === 'hold') {
        const t = elapsed / Math.max(holdDur, 0.1);

        if (t >= 1) {
          s.phase = 'fade-out';
          s.start = now;
          // Kick the next slot
          const next = i === 0 ? 1 : 0;
          kick(next, now);
        }
      } else if (s.phase === 'fade-out') {
        const t = Math.min(elapsed / fadeDur, 1);
        el.style.opacity = String(1 - easeInOut(t));

        if (t >= 1) {
          s.phase = 'idle';
          el.style.opacity = '0';
        }
      }
    }
    requestAnimationFrame(tick);
  }

  // --- Controls ---
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  const rangeControls: Array<{ id: string; valId: string; suffix: string; setter: (v: number) => void }> = [
    { id: 'cycle-speed', valId: 'cycle-speed-val', suffix: 's', setter: v => { cycleDuration = v; } },
    { id: 'scale-x-amount', valId: 'scale-x-amount-val', suffix: '', setter: v => { scaleXAmount = v; } },
    { id: 'scale-x-speed', valId: 'scale-x-speed-val', suffix: '', setter: v => { scaleXSpeed = v; } },
    { id: 'rotate-x-amount', valId: 'rotate-x-amount-val', suffix: '', setter: v => { rotateXAmount = v; } },
    { id: 'rotate-x-speed', valId: 'rotate-x-speed-val', suffix: '', setter: v => { rotateXSpeed = v; } },
    { id: 'translate-x-amount', valId: 'translate-x-amount-val', suffix: '', setter: v => { translateXAmount = v; } },
    { id: 'translate-x-speed', valId: 'translate-x-speed-val', suffix: '', setter: v => { translateXSpeed = v; } },
    { id: 'perspective', valId: 'perspective-val', suffix: '', setter: v => { perspectiveVal = v; stage.style.perspective = `${v}px`; } },
    { id: 'size-variance', valId: 'size-variance-val', suffix: '', setter: v => { sizeVariance = v; } },
    { id: 'fade-overlap', valId: 'fade-overlap-val', suffix: '', setter: v => { fadeOverlap = v; } },
  ];

  for (const ctrl of rangeControls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      output.textContent = input.value + ctrl.suffix;
      ctrl.setter(parseFloat(input.value));
    });
  }

  document.getElementById('tint-swatches')!.querySelectorAll('.swatch').forEach(swatch => {
    swatch.addEventListener('click', () => {
      swatch.classList.toggle('active');
      activeColors = [];
      document.getElementById('tint-swatches')!.querySelectorAll('.swatch.active').forEach(s => {
        activeColors.push((s as HTMLElement).dataset.color!);
      });
      if (activeColors.length === 0) activeColors = ['#231f20'];
    });
  });

  const pauseBtn = document.getElementById('toggle-pause') as HTMLButtonElement;
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? 'Play' : 'Pause';
  });

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    paused = true;
    pauseBtn.textContent = 'Play';
  }

  kick(0, performance.now());
  requestAnimationFrame(tick);
</script>
