---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
---

<DemoEffectLayout title="Arrow Loop — Slingshot">
  <!-- SVG filters for directional motion blur -->
  <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <filter id="motion-blur-a" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur id="blur-a" in="SourceGraphic" stdDeviation="0 0" />
      </filter>
      <filter id="motion-blur-b" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur id="blur-b" in="SourceGraphic" stdDeviation="0 0" />
      </filter>
    </defs>
  </svg>

  <div class="stage">
    <div class="slot" id="slot-a" style="filter: url(#motion-blur-a)">
      <img id="img-a" src="" alt="" />
    </div>
    <div class="slot" id="slot-b" style="filter: url(#motion-blur-b)">
      <img id="img-b" src="" alt="" />
    </div>
    <div class="ghost" id="ghost"></div>
  </div>

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Arrow Loop — Slingshot</h1>
    <p class="demo-technique">Squash & stretch · Directional motion blur · Vibration chirp · Ghost trail</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Arrows slingshot across the screen — squashing as they coil back with increasing vibration,
      then launching explosively with directional motion blur and a ghost afterimage.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="cycle-duration">Cycle Duration: <output id="cycle-duration-val">3s</output></label>
        <input type="range" id="cycle-duration" min="1.5" max="6" value="3" step="0.25" />
      </div>
      <div class="control-group">
        <label for="windup-ratio">Wind-up Ratio: <output id="windup-ratio-val">0.50</output></label>
        <input type="range" id="windup-ratio" min="0.3" max="0.7" value="0.5" step="0.05" />
      </div>
      <div class="control-group">
        <label for="pullback-dist">Pullback Distance: <output id="pullback-dist-val">10vw</output></label>
        <input type="range" id="pullback-dist" min="2" max="20" value="10" step="1" />
      </div>
      <div class="control-group">
        <label for="squash-amount">Squash Amount: <output id="squash-amount-val">0.65</output></label>
        <input type="range" id="squash-amount" min="0.5" max="0.9" value="0.65" step="0.05" />
      </div>
      <div class="control-group">
        <label for="launch-speed">Launch Speed: <output id="launch-speed-val">0.6s</output></label>
        <input type="range" id="launch-speed" min="0.2" max="1.2" value="0.6" step="0.05" />
      </div>
      <div class="control-group">
        <label for="blur-max">Motion Blur Max: <output id="blur-max-val">20px</output></label>
        <input type="range" id="blur-max" min="0" max="40" value="20" step="1" />
      </div>
      <div class="control-group">
        <label for="vib-intensity">Vibration Intensity: <output id="vib-intensity-val">3px</output></label>
        <input type="range" id="vib-intensity" min="0" max="8" value="3" step="0.5" />
      </div>
      <div class="control-group">
        <label for="size-variance">Size Variance: <output id="size-variance-val">0.30</output></label>
        <input type="range" id="size-variance" min="0" max="0.6" value="0.3" step="0.05" />
      </div>
      <div class="control-group">
        <label>Tint Colors</label>
        <div class="swatch-picker" id="tint-swatches">
          <button class="swatch active" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch active" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch active" data-color="#E57200" style="background:#E57200" title="Orange"></button>
          <button class="swatch active" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch active" data-color="#B7BF10" style="background:#B7BF10" title="Lime"></button>
          <button class="swatch active" data-color="#F1BDC8" style="background:#F1BDC8" title="Pink"></button>
          <button class="swatch active" data-color="#005776" style="background:#005776" title="Navy"></button>
        </div>
        <p class="swatch-hint">Click to toggle colors in the cycle</p>
      </div>
      <div class="control-group">
        <button class="toggle-btn" id="toggle-pause">Pause</button>
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  .stage {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .slot {
    position: absolute;
    width: 40vmin;
    height: 40vmin;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: opacity, transform;
  }

  .slot img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .ghost {
    position: absolute;
    width: 40vmin;
    height: 40vmin;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.8s ease-out;
  }

  .ghost img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] { display: none; }

  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open { transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .sidebar { transition: none; }
    .slot { filter: none !important; }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-muted);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }

  .toggle-btn {
    width: 100%;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .toggle-btn:hover { border-color: var(--color-accent); }

  .swatch-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-1);
  }

  .swatch {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
    opacity: 0.35;
  }

  .swatch:hover { transform: scale(1.15); }

  .swatch.active {
    border-color: var(--color-text);
    opacity: 1;
  }

  .swatch-hint {
    font-size: var(--text-xs);
    color: var(--color-muted);
    opacity: 0.7;
  }
</style>

<script>
  const arrowIds = [
    'arrow-02', 'arrow-03', 'arrow-04', 'arrow-05', 'arrow-06',
    'arrow-07', 'arrow-08', 'arrow-09', 'arrow-10', 'arrow-11',
    'arrow-12', 'arrow-13',
  ];

  const allColors = ['#00BFB3', '#563D82', '#E57200', '#FFC845', '#B7BF10', '#F1BDC8', '#005776'];
  let activeColors = [...allColors];

  const slotA = document.getElementById('slot-a') as HTMLElement;
  const slotB = document.getElementById('slot-b') as HTMLElement;
  const imgA = document.getElementById('img-a') as HTMLImageElement;
  const imgB = document.getElementById('img-b') as HTMLImageElement;
  const ghost = document.getElementById('ghost') as HTMLElement;
  const blurA = document.getElementById('blur-a') as unknown as SVGFEGaussianBlurElement;
  const blurB = document.getElementById('blur-b') as unknown as SVGFEGaussianBlurElement;

  // Parameters
  let cycleDuration = 3;
  let windupRatio = 0.5;
  let pullbackDist = 10;
  let squashAmount = 0.65;
  let launchSpeed = 0.6;
  let blurMax = 20;
  let vibIntensity = 3;
  let sizeVariance = 0.3;
  let paused = false;
  let arrowIndex = 0;
  let colorIndex = 0;

  // Easing functions
  function easeOutBack(t: number): number {
    const c1 = 1.70158;
    const c3 = c1 + 1;
    return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
  }

  function cubicOut(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function tintFilter(hex: string): string {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    const l = (max + min) / 2;
    let h = 0, s = 0;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) * 60;
      else if (max === g) h = ((b - r) / d + 2) * 60;
      else h = ((r - g) / d + 4) * 60;
    }
    return `brightness(0) saturate(100%) invert(${l > 0.5 ? 1 : 0.5}) sepia(1) saturate(${Math.max(s * 600, 100)}%) hue-rotate(${h}deg) brightness(${0.4 + l * 0.8})`;
  }

  function nextArrow(): string {
    const id = arrowIds[arrowIndex % arrowIds.length];
    arrowIndex++;
    return id;
  }

  function nextColor(): string {
    if (activeColors.length === 0) return '#231f20';
    const c = activeColors[colorIndex % activeColors.length];
    colorIndex++;
    return c;
  }

  // Slot state machine
  type Phase = 'idle' | 'appear' | 'windup' | 'launch';

  type SlotState = {
    el: HTMLElement;
    img: HTMLImageElement;
    blur: SVGFEGaussianBlurElement;
    phase: Phase;
    phaseStart: number;
    arrowId: string;
    color: string;
    sizeMult: number;
  };

  const slots: [SlotState, SlotState] = [
    { el: slotA, img: imgA, blur: blurA, phase: 'idle', phaseStart: 0, arrowId: '', color: '', sizeMult: 1 },
    { el: slotB, img: imgB, blur: blurB, phase: 'idle', phaseStart: 0, arrowId: '', color: '', sizeMult: 1 },
  ];

  let activeSlot = 0;

  function kickSlot(slotIdx: number, now: number) {
    const slot = slots[slotIdx];
    slot.arrowId = nextArrow();
    slot.color = nextColor();
    slot.sizeMult = 1 + (Math.random() * 2 - 1) * sizeVariance;
    slot.img.src = `/images/scanned-graphics/arrows/${slot.arrowId}.svg`;
    slot.img.style.filter = tintFilter(slot.color);
    slot.phase = 'appear';
    slot.phaseStart = now;
    slot.blur.setAttribute('stdDeviation', '0 0');
  }

  function spawnGhost(slot: SlotState, tx: number, sx: number, sy: number) {
    ghost.innerHTML = '';
    const img = document.createElement('img');
    img.src = `/images/scanned-graphics/arrows/${slot.arrowId}.svg`;
    img.style.filter = tintFilter(slot.color);
    img.style.maxWidth = '100%';
    img.style.maxHeight = '100%';
    img.style.objectFit = 'contain';
    ghost.appendChild(img);
    ghost.style.transform = `translateX(${tx}vw) scaleX(${sx}) scaleY(${sy}) scale(${slot.sizeMult})`;
    ghost.style.opacity = '0.4';
    // Force reflow, then fade out
    ghost.offsetHeight;
    ghost.style.opacity = '0';
  }

  const APPEAR_DUR = 0.3;

  function updateSlot(slot: SlotState, now: number) {
    if (slot.phase === 'idle') return;

    const elapsed = (now - slot.phaseStart) / 1000;

    if (slot.phase === 'appear') {
      const t = Math.min(elapsed / APPEAR_DUR, 1);
      const eased = easeOutBack(t);
      const scale = 0.8 + 0.2 * eased;
      slot.el.style.opacity = String(Math.min(t / 0.6, 1));
      slot.el.style.transform = `scaleX(${scale * slot.sizeMult}) scaleY(${scale * slot.sizeMult})`;
      slot.blur.setAttribute('stdDeviation', '0 0');

      if (t >= 1) {
        slot.phase = 'windup';
        slot.phaseStart = now;
      }
    } else if (slot.phase === 'windup') {
      const windupDur = cycleDuration * windupRatio;
      const t = Math.min(elapsed / windupDur, 1);

      // Smooth ease-in for pullback
      const pullT = t * t; // quadratic ease-in

      // Pull back on X
      const tx = -pullbackDist * pullT;

      // Squash X: 1 -> squashAmount
      const sx = 1 - (1 - squashAmount) * pullT;
      // Stretch Y: 1 -> ~1.15 (volume preservation)
      const stretchY = 1 + (1 / squashAmount - 1) * pullT * 0.4;
      const sy = Math.min(stretchY, 1.2);

      // Vibration chirp: frequency ramps 15->60, amplitude grows quadratically
      const freq = 15 + 45 * t;
      const vibAmp = vibIntensity * t * t;
      const vibX = Math.sin(elapsed * freq) * vibAmp;
      const vibY = Math.cos(elapsed * freq * 0.7) * vibAmp * 0.3;

      slot.el.style.opacity = '1';
      slot.el.style.transform = `translateX(calc(${tx}vw + ${vibX}px)) translateY(${vibY}px) scaleX(${sx * slot.sizeMult}) scaleY(${sy * slot.sizeMult})`;
      slot.blur.setAttribute('stdDeviation', '0 0');

      if (t >= 1) {
        // Spawn ghost at current position before launching
        spawnGhost(slot, tx, sx * slot.sizeMult, sy * slot.sizeMult);
        slot.phase = 'launch';
        slot.phaseStart = now;
        // Kick the next slot into appear
        const next = activeSlot === 0 ? 1 : 0;
        activeSlot = next;
        kickSlot(next, now);
      }
    } else if (slot.phase === 'launch') {
      const t = Math.min(elapsed / launchSpeed, 1);
      const eased = cubicOut(t);

      // Translate: from pullback position -> off right edge
      const startTx = -pullbackDist;
      const endTx = 120;
      const tx = startTx + (endTx - startTx) * eased;

      // ScaleX stretches: squashAmount -> 2.2
      const sx = squashAmount + (2.2 - squashAmount) * eased;
      // ScaleY compresses: ~1.15 -> 0.6
      const startSy = 1 + (1 / squashAmount - 1) * 0.4;
      const sy = startSy + (0.6 - startSy) * eased;

      // Opacity fades in second half
      const opacity = t < 0.5 ? 1 : 1 - (t - 0.5) * 2;

      // Motion blur: peaks early then fades
      const blurT = t < 0.3 ? t / 0.3 : 1 - (t - 0.3) / 0.7;
      const blurVal = blurMax * blurT;
      slot.blur.setAttribute('stdDeviation', `${blurVal} 0`);

      slot.el.style.opacity = String(Math.max(opacity, 0));
      slot.el.style.transform = `translateX(${tx}vw) scaleX(${sx * slot.sizeMult}) scaleY(${sy * slot.sizeMult})`;

      if (t >= 1) {
        slot.phase = 'idle';
        slot.el.style.opacity = '0';
        slot.blur.setAttribute('stdDeviation', '0 0');
      }
    }
  }

  function animate(now: number) {
    if (!paused) {
      updateSlot(slots[0], now);
      updateSlot(slots[1], now);
    }
    requestAnimationFrame(animate);
  }

  // --- Controls ---
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  const rangeControls: Array<{ id: string; valId: string; suffix: string; setter: (v: number) => void }> = [
    { id: 'cycle-duration', valId: 'cycle-duration-val', suffix: 's', setter: v => { cycleDuration = v; } },
    { id: 'windup-ratio', valId: 'windup-ratio-val', suffix: '', setter: v => { windupRatio = v; } },
    { id: 'pullback-dist', valId: 'pullback-dist-val', suffix: 'vw', setter: v => { pullbackDist = v; } },
    { id: 'squash-amount', valId: 'squash-amount-val', suffix: '', setter: v => { squashAmount = v; } },
    { id: 'launch-speed', valId: 'launch-speed-val', suffix: 's', setter: v => { launchSpeed = v; } },
    { id: 'blur-max', valId: 'blur-max-val', suffix: 'px', setter: v => { blurMax = v; } },
    { id: 'vib-intensity', valId: 'vib-intensity-val', suffix: 'px', setter: v => { vibIntensity = v; } },
    { id: 'size-variance', valId: 'size-variance-val', suffix: '', setter: v => { sizeVariance = v; } },
  ];

  for (const ctrl of rangeControls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      output.textContent = input.value + ctrl.suffix;
      ctrl.setter(parseFloat(input.value));
    });
  }

  document.getElementById('tint-swatches')!.querySelectorAll('.swatch').forEach(swatch => {
    swatch.addEventListener('click', () => {
      swatch.classList.toggle('active');
      activeColors = [];
      document.getElementById('tint-swatches')!.querySelectorAll('.swatch.active').forEach(s => {
        activeColors.push((s as HTMLElement).dataset.color!);
      });
      if (activeColors.length === 0) activeColors = ['#231f20'];
    });
  });

  const pauseBtn = document.getElementById('toggle-pause') as HTMLButtonElement;
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? 'Play' : 'Pause';
  });

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    paused = true;
    pauseBtn.textContent = 'Play';
  }

  // --- Init ---
  kickSlot(0, performance.now());
  requestAnimationFrame(animate);
</script>
