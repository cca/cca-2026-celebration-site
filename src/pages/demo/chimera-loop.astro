---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
---

<DemoEffectLayout title="Chimera Loop">
  <div class="stage">
    <div class="slot" id="slot-a">
      <div class="shape" id="shape-a"></div>
    </div>
    <div class="slot" id="slot-b">
      <div class="shape" id="shape-b"></div>
    </div>
  </div>

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Chimera Loop</h1>
    <p class="demo-technique">Elastic morph &middot; Scale/skew &middot; Passive drama &middot; Color cycling</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Chimera letterforms morph in with elastic scale and skew, drift through a dramatic hold phase
      with breathing and slow rotation, then stretch and dissolve out.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="cycle-speed">Cycle Duration: <output id="cycle-speed-val">4s</output></label>
        <input type="range" id="cycle-speed" min="2" max="10" value="4" step="0.5" />
      </div>
      <div class="control-group">
        <label for="fade-overlap">Crossfade Overlap: <output id="fade-overlap-val">0.3</output></label>
        <input type="range" id="fade-overlap" min="0.1" max="0.45" value="0.3" step="0.05" />
      </div>
      <div class="control-group">
        <label for="elastic-intensity">Elastic Intensity: <output id="elastic-intensity-val">1.0</output></label>
        <input type="range" id="elastic-intensity" min="0" max="2" value="1" step="0.1" />
      </div>
      <div class="control-group">
        <label for="skew-amount">Skew Amount: <output id="skew-amount-val">15</output>&deg;</label>
        <input type="range" id="skew-amount" min="0" max="45" value="15" step="1" />
      </div>
      <div class="control-group">
        <label for="drift-speed">Hold Drift Speed: <output id="drift-speed-val">1.0</output></label>
        <input type="range" id="drift-speed" min="0.2" max="3" value="1" step="0.1" />
      </div>
      <div class="control-group">
        <label for="size-variance">Size Variance: <output id="size-variance-val">0.25</output></label>
        <input type="range" id="size-variance" min="0" max="0.6" value="0.25" step="0.05" />
      </div>
      <div class="control-group">
        <label>Tint Colors</label>
        <div class="swatch-picker" id="tint-swatches">
          <button class="swatch active" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch active" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch active" data-color="#E57200" style="background:#E57200" title="Orange"></button>
          <button class="swatch active" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch active" data-color="#005776" style="background:#005776" title="Navy"></button>
        </div>
        <p class="swatch-hint">Click to toggle colors in the cycle</p>
      </div>
      <div class="control-group">
        <button class="toggle-btn" id="toggle-pause">Pause</button>
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  .stage {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slot {
    position: absolute;
    width: 45vmin;
    height: 45vmin;
    opacity: 0;
    will-change: opacity, transform;
  }

  .shape {
    position: absolute;
    inset: 0;
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
  }

  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] { display: none; }

  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open { transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .sidebar { transition: none; }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-muted);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }

  .toggle-btn {
    width: 100%;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .toggle-btn:hover { border-color: var(--color-accent); }

  .swatch-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-1);
  }

  .swatch {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
    opacity: 0.35;
  }

  .swatch:hover { transform: scale(1.15); }

  .swatch.active {
    border-color: var(--color-text);
    opacity: 1;
  }

  .swatch-hint {
    font-size: var(--text-xs);
    color: var(--color-muted);
    opacity: 0.7;
  }
</style>

<script>
  const shapes = [
    'chimera-expanded-shape01',
    'chimera-expanded-shape02',
    'chimera-expanded-shape03',
    'chimera-expanded-shape04',
  ];

  const allColors = ['#00BFB3', '#563D82', '#E57200', '#FFC845', '#005776'];
  let activeColors = [...allColors];

  const slotA = document.getElementById('slot-a') as HTMLElement;
  const slotB = document.getElementById('slot-b') as HTMLElement;
  const shapeA = document.getElementById('shape-a') as HTMLElement;
  const shapeB = document.getElementById('shape-b') as HTMLElement;

  let cycleDuration = 4;
  let fadeOverlap = 0.3;
  let elasticIntensity = 1;
  let skewAmount = 15;
  let driftSpeed = 1;
  let sizeVariance = 0.25;
  let paused = false;
  let index = 0;
  let colorIdx = 0;

  function nextShape(): string {
    const shape = shapes[index % shapes.length];
    index++;
    return shape;
  }

  function nextColor(): string {
    if (activeColors.length === 0) return '#231f20';
    const c = activeColors[colorIdx % activeColors.length];
    colorIdx++;
    return c;
  }

  // Elastic ease-out: overshoots then settles
  function elasticOut(t: number): number {
    if (t === 0 || t === 1) return t;
    const p = 0.4;
    return Math.pow(2, -10 * t) * Math.sin((t - p / 4) * (2 * Math.PI) / p) + 1;
  }

  // Smooth ease-in for exits
  function easeInCubic(t: number): number {
    return t * t * t;
  }

  function easeInOut(t: number): number {
    return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
  }

  type Phase = 'idle' | 'morph-in' | 'hold' | 'morph-out';
  const state = [
    { phase: 'idle' as Phase, start: 0, shape: '', color: '', skewDir: 1, sizeMult: 1, rotDir: 1 },
    { phase: 'idle' as Phase, start: 0, shape: '', color: '', skewDir: 1, sizeMult: 1, rotDir: 1 },
  ];

  const els = [
    { el: slotA, shape: shapeA },
    { el: slotB, shape: shapeB },
  ];

  function kick(slot: number, now: number) {
    state[slot].shape = nextShape();
    state[slot].color = nextColor();
    state[slot].skewDir = Math.random() < 0.5 ? -1 : 1;
    state[slot].rotDir = Math.random() < 0.5 ? -1 : 1;
    state[slot].sizeMult = 1 + (Math.random() * 2 - 1) * sizeVariance;
    const url = `/images/chimera-expanded/${state[slot].shape}.svg`;
    els[slot].shape.style.maskImage = `url('${url}')`;
    els[slot].shape.style.setProperty('-webkit-mask-image', `url('${url}')`);
    els[slot].shape.style.backgroundColor = state[slot].color;
    state[slot].phase = 'morph-in';
    state[slot].start = now;
  }

  function tick(now: number) {
    if (paused) { requestAnimationFrame(tick); return; }

    for (let i = 0; i < 2; i++) {
      const s = state[i];
      const { el } = els[i];
      if (s.phase === 'idle') continue;

      const elapsed = (now - s.start) / 1000;
      const morphDur = cycleDuration * fadeOverlap;
      const holdDur = cycleDuration * (1 - fadeOverlap * 2);

      if (s.phase === 'morph-in') {
        const t = Math.min(elapsed / morphDur, 1);
        // Elastic overshoot on scale, skew sweeps in then settles
        const elastic = elasticOut(t) * elasticIntensity + (1 - elasticIntensity) * easeInOut(t);
        const smooth = easeInOut(t);

        // Scale: starts small, elastic overshoot to final size
        const scaleBase = s.sizeMult;
        const scale = scaleBase * (0.3 + 0.7 * elastic);

        // Skew: sweeps from skewAmount down to 0 with elastic settle
        const skew = (1 - elastic) * skewAmount * s.skewDir;

        // Slight rotation entrance
        const rotate = (1 - smooth) * 12 * s.rotDir;

        // Opacity ramps up in first 60%
        const opacity = Math.min(t / 0.6, 1);

        el.style.opacity = String(opacity);
        el.style.transform = `rotate(${rotate}deg) skew(${skew}deg) scale(${scale})`;

        if (t >= 1) {
          s.phase = 'hold';
          s.start = now;
          el.style.opacity = '1';
          el.style.transform = `scale(${scaleBase})`;
        }
      } else if (s.phase === 'hold') {
        const t = elapsed / Math.max(holdDur, 0.1);
        const baseScale = s.sizeMult;

        // Slow dramatic drift during hold
        const breathe = Math.sin(elapsed * driftSpeed * 0.8) * 0.06;
        const driftRotate = Math.sin(elapsed * driftSpeed * 0.5) * 5 * s.rotDir;
        const driftSkew = Math.sin(elapsed * driftSpeed * 0.3) * 3 * s.skewDir;
        const driftY = Math.sin(elapsed * driftSpeed * 0.4) * 8;

        el.style.transform = `translateY(${driftY}px) rotate(${driftRotate}deg) skew(${driftSkew}deg) scale(${baseScale * (1 + breathe)})`;

        if (t >= 1) {
          s.phase = 'morph-out';
          s.start = now;
          const next = i === 0 ? 1 : 0;
          kick(next, now);
        }
      } else if (s.phase === 'morph-out') {
        const t = Math.min(elapsed / morphDur, 1);
        const e = easeInCubic(t);

        const baseScale = s.sizeMult;
        // Stretch out dramatically: scaleX expands, scaleY compresses
        const scaleX = baseScale * (1 + e * 1.2);
        const scaleY = baseScale * (1 - e * 0.4);

        // Skew intensifies on exit
        const skew = e * skewAmount * 1.5 * -s.skewDir;

        // Rotate away
        const rotate = e * 20 * -s.rotDir;

        // Fade out
        const opacity = 1 - easeInOut(t);

        el.style.opacity = String(opacity);
        el.style.transform = `rotate(${rotate}deg) skew(${skew}deg) scaleX(${scaleX}) scaleY(${scaleY})`;

        if (t >= 1) { s.phase = 'idle'; el.style.opacity = '0'; }
      }
    }
    requestAnimationFrame(tick);
  }

  // --- Controls ---
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  const rangeControls: Array<{ id: string; valId: string; suffix: string; setter: (v: number) => void }> = [
    { id: 'cycle-speed', valId: 'cycle-speed-val', suffix: 's', setter: v => { cycleDuration = v; } },
    { id: 'fade-overlap', valId: 'fade-overlap-val', suffix: '', setter: v => { fadeOverlap = v; } },
    { id: 'elastic-intensity', valId: 'elastic-intensity-val', suffix: '', setter: v => { elasticIntensity = v; } },
    { id: 'skew-amount', valId: 'skew-amount-val', suffix: '', setter: v => { skewAmount = v; } },
    { id: 'drift-speed', valId: 'drift-speed-val', suffix: '', setter: v => { driftSpeed = v; } },
    { id: 'size-variance', valId: 'size-variance-val', suffix: '', setter: v => { sizeVariance = v; } },
  ];

  for (const ctrl of rangeControls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      output.textContent = input.value + ctrl.suffix;
      ctrl.setter(parseFloat(input.value));
    });
  }

  document.getElementById('tint-swatches')!.querySelectorAll('.swatch').forEach(swatch => {
    swatch.addEventListener('click', () => {
      swatch.classList.toggle('active');
      activeColors = [];
      document.getElementById('tint-swatches')!.querySelectorAll('.swatch.active').forEach(s => {
        activeColors.push((s as HTMLElement).dataset.color!);
      });
      if (activeColors.length === 0) activeColors = ['#231f20'];
    });
  });

  const pauseBtn = document.getElementById('toggle-pause') as HTMLButtonElement;
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? 'Play' : 'Pause';
  });

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    paused = true;
    pauseBtn.textContent = 'Play';
  }

  kick(0, performance.now());
  requestAnimationFrame(tick);
</script>
