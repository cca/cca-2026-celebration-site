---
import { getEntry } from "astro:content";
import EventLayout from "../../layouts/EventLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import TableOfContents from "../../components/ui/TableOfContents.astro";
import ProgramHero from "../../components/program/ProgramHero.astro";
import ProgramAgenda from "../../components/program/ProgramAgenda.astro";
import ProgramDisclaimer from "../../components/program/ProgramDisclaimer.astro";
import CandidatesList from "../../components/program/CandidatesList.astro";
import SpeakerFeature from "../../components/events/SpeakerFeature.astro";
import { getCandidatesGroupedByDivision } from "../../lib/utils/collections";

const eventId = "commencement-masters";
const event = await getEntry("events", eventId);
if (!event) throw new Error(`Event ${eventId} not found`);

const { ceremonyProgram } = event.data;

let studentSpeakerEntry = null;
if (ceremonyProgram?.studentSpeaker?.student) {
  studentSpeakerEntry = await getEntry("students", ceremonyProgram.studentSpeaker.student.id);
}

const candidateGroups = await getCandidatesGroupedByDivision(eventId);

const tocItems: Array<{ label: string; href: string }> = [];
if (ceremonyProgram?.studentSpeaker) tocItems.push({ label: "Student Speaker", href: "#speaker" });
if (ceremonyProgram?.programItems?.length) tocItems.push({ label: "Program", href: "#program" });
if (candidateGroups.length > 0) tocItems.push({ label: "Student Names", href: "#candidates" });
---

<div class="demo-banner">
  <a href="/demo/">&larr; Demo Pages</a>
  <span>Preview of <code>/commencement/masters/</code></span>
</div>

<EventLayout event={event} title={event.data.title}>
  <div class="container">
    <Breadcrumb items={[
      { label: "Home", href: "/" },
      { label: "Commencement", href: "/commencement/" },
      { label: "Master's Ceremony" },
    ]} />
  </div>

  <ProgramHero event={event} titlePrefix="2026 " />

  <div class="container">
    <div class="program-layout">
      <div class="program-main">

        {ceremonyProgram?.studentSpeaker && (
          <section id="speaker" class="program-section">
            <h2 class="section-heading">Student Speaker</h2>
            <SpeakerFeature
              speaker={ceremonyProgram.studentSpeaker}
              student={studentSpeakerEntry}
            />
          </section>
        )}

        {ceremonyProgram?.programItems && ceremonyProgram.programItems.length > 0 && (
          <section id="program" class="program-section">
            <h2 class="section-heading">Ceremony Program</h2>
            <ProgramAgenda
              items={ceremonyProgram.programItems}
              landAcknowledgmentText={ceremonyProgram.landAcknowledgment}
            />
          </section>
        )}

        {candidateGroups.length > 0 && (
          <section id="candidates" class="program-section">
            <h2 class="section-heading">Master's Degree Candidates</h2>
            <CandidatesList groups={candidateGroups} degreeLabel="master's degree" />
            {ceremonyProgram?.disclaimer && (
              <div class="subsection subsection--disclaimer">
                <ProgramDisclaimer text={ceremonyProgram.disclaimer} />
              </div>
            )}
          </section>
        )}

      </div>

      <aside class="program-sidebar">
        <TableOfContents items={tocItems} />
      </aside>
    </div>
  </div>
</EventLayout>

<style>
  .demo-banner {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: #1a1a1a;
    color: #fff;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    border-bottom: 1px solid #333;
  }

  .demo-banner a {
    color: #fff;
    text-decoration: none;
  }

  .demo-banner a:hover {
    text-decoration: underline;
  }

  .demo-banner code {
    background: rgba(255, 255, 255, 0.1);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .program-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .program-sidebar {
    order: -1;
  }

  .program-main {
    flex: 1;
    min-width: 0;
  }

  .program-main > * + * {
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 1024px) {
    .program-layout {
      flex-direction: row;
      gap: var(--space-10);
    }

    .program-sidebar {
      order: 0;
      flex: 0 0 220px;
      position: sticky;
      top: calc(60px + var(--space-8));
      align-self: flex-start;
    }
  }

  .program-section {
    padding-block: var(--space-12);
    scroll-margin-top: calc(60px + var(--space-4));
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: normal;
    line-height: 1.2;
    margin-bottom: var(--space-4);
    position: relative;
    display: inline-block;
  }

  :global([data-theme^="commencement"]) .section-heading::after {
    content: "";
    display: block;
    width: 40px;
    height: 2px;
    background: var(--color-gold, var(--color-accent));
    margin-top: var(--space-2);
  }

  .subsection--disclaimer {
    margin-top: var(--space-8);
  }
</style>
