---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getFrameData } from "../../lib/utils/frame-data";
import { ccaPhotography, photoCollections } from "../../data/cca-photography";

const photoCollectionAttr = new Map<string, string>();
for (const { id, photos } of photoCollections) {
  for (const p of photos) {
    const existing = photoCollectionAttr.get(p.src);
    photoCollectionAttr.set(p.src, existing ? `${existing} ${id}` : id);
  }
}
const getCollAttr = (src: string) => photoCollectionAttr.get(src) ?? 'cca';

// Deduplicated master list of all photos across all collections
const seenSrcs = new Set<string>();
const allPhotos = photoCollections.flatMap(c => c.photos).filter(p => {
  if (seenSrcs.has(p.src)) return false;
  seenSrcs.add(p.src);
  return true;
});

const frameIds = [
  "frame-01", "frame-02", "frame-03", "frame-04", "frame-05",
  "frame-07", "frame-09", "frame-10", "frame-11", "frame-12",
  "frame-13", "frame-14", "frame-15", "frame-16", "frame-17",
  "frame-18", "frame-19", "frame-20", "frame-21", "frame-22", "frame-23",
];

const allFrames = frameIds.map(id => getFrameData(id));
---

<BaseLayout title="Frame Editor" minimalHeader={true}>
  <!-- Expose build-time frame data to client JS -->
  <script is:inline define:vars={{ framesData: allFrames }}>
    window.__CCA_FRAME_DATA__ = framesData;
  </script>

  <main class="editor">
    <div class="editor-header">
      <a href="/demo/" class="back-link">&larr; Demo Pages</a>
      <h1>Frame Editor</h1>
    </div>

    <div class="editor-layout">
      <!-- Left: SVG viewport -->
      <div class="viewport-wrap">
        <div class="viewport" id="viewport">
          <svg id="preview-svg" xmlns="http://www.w3.org/2000/svg" style="color:#231f20;">
            <defs>
              <clipPath id="clip-active">
                <path id="clip-path" d="" />
              </clipPath>
            </defs>
            <g clip-path="url(#clip-active)">
              <image id="preview-image" href="" x="0" y="0" width="0" height="0" preserveAspectRatio="none" />
            </g>
            <g id="frame-border"></g>
          </svg>
          <div class="viewport-hint" id="viewport-hint">Drag to pan &middot; Scroll to zoom</div>
        </div>
        <div class="viewport-toolbar">
          <button id="btn-reset" class="toolbar-btn" title="Reset pan &amp; zoom">Reset View</button>
          <span class="toolbar-sep"></span>
          <label class="toolbar-label">
            Zoom: <output id="zoom-val">100%</output>
          </label>
          <input type="range" id="zoom-slider" min="10" max="500" value="100" step="5" class="toolbar-slider" />
          <span class="toolbar-sep"></span>
          <label class="toolbar-label">
            Export size
            <select id="export-size">
              <option value="660">660px (Mailchimp)</option>
              <option value="800">800px</option>
              <option value="1200">1200px</option>
              <option value="1600" selected>1600px</option>
              <option value="2400">2400px</option>
              <option value="3200">3200px</option>
            </select>
          </label>
          <button id="btn-download" class="toolbar-btn toolbar-btn-primary" title="Download as PNG">Download PNG</button>
        </div>
      </div>

      <!-- Right: Controls panel -->
      <aside class="panel">
        <!-- Frame picker -->
        <section class="panel-section">
          <h2>Frame</h2>
          <div class="shape-grid frame-grid" id="frame-grid">
            {allFrames.map((frame, i) => (
              <button
                class={`shape-thumb${i === 0 ? ' active' : ''}`}
                data-frame-index={String(i)}
                title={frame.id}
              >
                <img src={`/images/scanned-graphics/frames/${frame.id}.svg`} alt={frame.id} loading="lazy" />
              </button>
            ))}
          </div>
        </section>

        <!-- Image source -->
        <section class="panel-section">
          <h2>Image</h2>
          <div class="image-source-tabs">
            <button class="tab active" data-tab="collection">Collection</button>
            <button class="tab" data-tab="upload">Upload</button>
          </div>
          <div class="tab-content active" id="tab-collection">
            <label class="field">
              <span>Collection</span>
              <select id="collection-select">
                <option value="all">All Photos</option>
                {photoCollections.map(coll => (
                  <option value={coll.id}>{coll.label}</option>
                ))}
              </select>
            </label>
            <label class="field">
              <span>Image</span>
              <select id="image-select">
                {allPhotos.map((photo, i) => (
                  <option value={photo.src} selected={i === 0} data-collection={getCollAttr(photo.src)}>{photo.alt}</option>
                ))}
              </select>
            </label>
            <div class="image-preview-grid" id="image-preview-grid">
              {allPhotos.map((photo, i) => (
                <button
                  class={`image-thumb${i === 0 ? ' active' : ''}`}
                  data-src={photo.src}
                  data-collection={getCollAttr(photo.src)}
                  title={photo.alt}
                >
                  <img src={photo.src} alt={photo.alt} loading="lazy" />
                </button>
              ))}
            </div>
          </div>
          <div class="tab-content" id="tab-upload">
            <div class="drop-zone" id="drop-zone">
              <p>Drag &amp; drop an image here</p>
              <p class="drop-zone-or">or</p>
              <button class="toolbar-btn" id="btn-browse">Browse files</button>
              <input type="file" id="file-input" accept="image/*" hidden />
            </div>
          </div>
        </section>

        <!-- Frame color -->
        <section class="panel-section">
          <h2>Frame Color</h2>
          <div class="bg-swatches" id="frame-swatches">
            <button class="swatch active" data-color="#231f20" title="Dark (natural)" style="background:#231f20;"></button>
            <button class="swatch" data-color="#ffffff" title="White" style="background:#ffffff;"></button>
            <button class="swatch" data-color="#FDFAF5" title="Sand Light" style="background:#FDFAF5;"></button>
            <button class="swatch" data-color="#F7F3E9" title="Sand" style="background:#F7F3E9;"></button>
            <button class="swatch" data-color="#1a1a1a" title="Black" style="background:#1a1a1a;"></button>
            <button class="swatch" data-color="#00BFB3" title="Teal" style="background:#00BFB3;"></button>
            <button class="swatch" data-color="#002f40" title="Dark Teal" style="background:#002f40;"></button>
            <button class="swatch" data-color="#005776" title="Navy" style="background:#005776;"></button>
            <button class="swatch" data-color="#563D82" title="Purple" style="background:#563D82;"></button>
            <button class="swatch" data-color="#FFC845" title="Yellow" style="background:#FFC845;"></button>
            <button class="swatch" data-color="#E57200" title="Orange" style="background:#E57200;"></button>
            <button class="swatch" data-color="#B7BF10" title="Lime" style="background:#B7BF10;"></button>
            <button class="swatch" data-color="#F1BDC8" title="Pink" style="background:#F1BDC8;"></button>
          </div>
          <div class="bg-options">
            <label class="field field-inline">
              <span>Custom</span>
              <input type="color" id="frame-color" value="#231f20" />
            </label>
          </div>
        </section>
      </aside>
    </div>
  </main>
</BaseLayout>

<script>
  interface FrameData {
    id: string;
    viewBox: string;
    minX: number;
    minY: number;
    width: number;
    height: number;
    pathsVisual: string;
    clipPathD: string;
  }

  const allFrames = (window as any).__CCA_FRAME_DATA__ as FrameData[];

  // DOM refs
  const viewport = document.getElementById('viewport')!;
  const viewportHint = document.getElementById('viewport-hint')!;
  const previewSvg = document.getElementById('preview-svg') as HTMLElement;
  const clipPathEl = document.getElementById('clip-path') as HTMLElement;
  const previewImage = document.getElementById('preview-image') as HTMLElement;
  const frameBorderEl = document.getElementById('frame-border')!;
  const zoomSlider = document.getElementById('zoom-slider') as HTMLInputElement;
  const zoomVal = document.getElementById('zoom-val') as HTMLOutputElement;
  const exportSizeSelect = document.getElementById('export-size') as HTMLSelectElement;
  const imageSelect = document.getElementById('image-select') as HTMLSelectElement;
  const frameColorInput = document.getElementById('frame-color') as HTMLInputElement;
  const frameSwatchesEl = document.getElementById('frame-swatches')!;

  // State
  let currentFrame: FrameData = allFrames[0];
  let currentPhotoSrc = '';
  let photoNaturalWidth = 1;
  let photoNaturalHeight = 1;
  let zoom = 1;
  let panX = 0; // SVG units
  let panY = 0; // SVG units
  let frameColor = '#231f20';

  // --- Helpers ---

  function computeImageRect() {
    const { minX, minY, width, height } = currentFrame;
    const frameAspect = width / height;
    const photoAspect = photoNaturalWidth / photoNaturalHeight;

    let pw: number, ph: number;
    if (photoAspect > frameAspect) {
      // Photo wider: fit height to cover
      ph = height * zoom;
      pw = ph * photoAspect;
    } else {
      // Photo taller: fit width to cover
      pw = width * zoom;
      ph = pw / photoAspect;
    }

    const x = minX + (width - pw) / 2 + panX;
    const y = minY + (height - ph) / 2 + panY;
    return { x, y, pw, ph };
  }

  function renderSVG() {
    if (!currentPhotoSrc) return;
    const { x, y, pw, ph } = computeImageRect();
    previewImage.setAttribute('x', String(x));
    previewImage.setAttribute('y', String(y));
    previewImage.setAttribute('width', String(pw));
    previewImage.setAttribute('height', String(ph));
  }

  function updateZoomUI() {
    zoomSlider.value = String(Math.round(zoom * 100));
    zoomVal.textContent = Math.round(zoom * 100) + '%';
  }

  function resetView() {
    zoom = 1;
    panX = 0;
    panY = 0;
    updateZoomUI();
    renderSVG();
  }

  function loadFrame(frame: FrameData) {
    currentFrame = frame;
    previewSvg.setAttribute('viewBox', frame.viewBox);
    clipPathEl.setAttribute('d', frame.clipPathD);
    frameBorderEl.innerHTML = frame.pathsVisual;
    zoom = 1;
    panX = 0;
    panY = 0;
    updateZoomUI();
    renderSVG();
  }

  async function loadPhoto(src: string) {
    currentPhotoSrc = src;
    await new Promise<void>((resolve) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        photoNaturalWidth = img.naturalWidth;
        photoNaturalHeight = img.naturalHeight;
        resolve();
      };
      img.onerror = () => resolve();
      img.src = src;
    });
    previewImage.setAttribute('href', src);
    renderSVG();
  }

  function loadPhotoFromFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const url = e.target!.result as string;
      const img = new Image();
      img.onload = () => {
        currentPhotoSrc = url;
        photoNaturalWidth = img.naturalWidth;
        photoNaturalHeight = img.naturalHeight;
        previewImage.setAttribute('href', url);
        renderSVG();
      };
      img.src = url;
    };
    reader.readAsDataURL(file);
  }

  // --- Pan & Zoom ---

  let isDragging = false;
  let dragStartX = 0, dragStartY = 0;
  let panStartX = 0, panStartY = 0;

  viewport.addEventListener('pointerdown', (e) => {
    if ((e.target as HTMLElement).closest('button, input, select')) return;
    isDragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    panStartX = panX;
    panStartY = panY;
    viewport.setPointerCapture(e.pointerId);
    viewport.style.cursor = 'grabbing';
    viewportHint.style.display = 'none';
  });

  viewport.addEventListener('pointermove', (e) => {
    if (!isDragging) return;
    const rect = previewSvg.getBoundingClientRect();
    const scaleX = currentFrame.width / rect.width;
    const scaleY = currentFrame.height / rect.height;
    panX = panStartX + (e.clientX - dragStartX) * scaleX;
    panY = panStartY + (e.clientY - dragStartY) * scaleY;
    renderSVG();
  });

  viewport.addEventListener('pointerup', () => {
    isDragging = false;
    viewport.style.cursor = 'grab';
  });

  viewport.addEventListener('wheel', (e) => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? -0.05 : 0.05;
    zoom = Math.max(0.1, Math.min(5, zoom + delta));
    updateZoomUI();
    renderSVG();
  }, { passive: false });

  // --- Controls ---

  document.getElementById('btn-reset')!.addEventListener('click', resetView);

  zoomSlider.addEventListener('input', () => {
    zoom = parseInt(zoomSlider.value) / 100;
    zoomVal.textContent = zoomSlider.value + '%';
    renderSVG();
  });

  // Frame picker
  const frameGrid = document.getElementById('frame-grid')!;
  frameGrid.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.shape-thumb') as HTMLButtonElement | null;
    if (!btn) return;
    frameGrid.querySelector('.active')?.classList.remove('active');
    btn.classList.add('active');
    const idx = parseInt(btn.dataset.frameIndex!);
    loadFrame(allFrames[idx]);
  });

  // Image tabs
  const tabs = document.querySelectorAll<HTMLButtonElement>('.image-source-tabs .tab');
  const tabContents = document.querySelectorAll<HTMLDivElement>('.tab-content');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tabContents.forEach((tc) => tc.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`tab-${tab.dataset.tab}`)!.classList.add('active');
    });
  });

  // Image select (dropdown)
  imageSelect.addEventListener('change', () => {
    loadPhoto(imageSelect.value);
    const thumbs = document.querySelectorAll<HTMLButtonElement>('#image-preview-grid .image-thumb');
    thumbs.forEach((t) => t.classList.toggle('active', t.dataset.src === imageSelect.value));
  });

  // Image thumbnail grid
  const imagePreviewGrid = document.getElementById('image-preview-grid')!;
  imagePreviewGrid.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.image-thumb') as HTMLButtonElement | null;
    if (!btn) return;
    imagePreviewGrid.querySelector('.active')?.classList.remove('active');
    btn.classList.add('active');
    imageSelect.value = btn.dataset.src!;
    loadPhoto(btn.dataset.src!);
  });

  // Collection switching
  const collectionSelect = document.getElementById('collection-select') as HTMLSelectElement;
  const allImageOptions = Array.from(imageSelect.options).map(o => ({
    value: o.value, label: o.text, collection: o.dataset.collection ?? 'cca',
  }));
  collectionSelect.addEventListener('change', () => {
    const coll = collectionSelect.value;
    imageSelect.innerHTML = '';
    let firstSrc = '';
    allImageOptions.forEach(p => {
      if (coll !== 'all' && !p.collection.split(' ').includes(coll)) return;
      const o = document.createElement('option');
      o.value = p.value; o.text = p.label; o.dataset.collection = p.collection;
      if (!firstSrc) firstSrc = p.value;
      imageSelect.appendChild(o);
    });
    const thumbs = imagePreviewGrid.querySelectorAll<HTMLButtonElement>('.image-thumb');
    thumbs.forEach(t => {
      const visible = coll === 'all' || (t.dataset.collection ?? 'cca').split(' ').includes(coll);
      t.style.display = visible ? '' : 'none';
      t.classList.remove('active');
    });
    if (firstSrc) {
      imageSelect.value = firstSrc;
      imagePreviewGrid.querySelector<HTMLButtonElement>(`[data-src="${CSS.escape(firstSrc)}"]`)?.classList.add('active');
      loadPhoto(firstSrc);
    }
  });

  // File upload
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  document.getElementById('btn-browse')!.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) loadPhotoFromFile(fileInput.files[0]);
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('drag-over');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) {
      loadPhotoFromFile(file);
      tabs.forEach((t) => t.classList.toggle('active', t.dataset.tab === 'upload'));
      tabContents.forEach((tc) => tc.classList.toggle('active', tc.id === 'tab-upload'));
    }
  });

  // Frame color
  function applyFrameColor(color: string) {
    frameColor = color;
    frameColorInput.value = color;
    previewSvg.style.color = color;
  }

  frameSwatchesEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.swatch') as HTMLButtonElement | null;
    if (!btn) return;
    frameSwatchesEl.querySelector('.active')?.classList.remove('active');
    btn.classList.add('active');
    applyFrameColor(btn.dataset.color!);
  });

  frameColorInput.addEventListener('input', () => {
    frameSwatchesEl.querySelector('.active')?.classList.remove('active');
    applyFrameColor(frameColorInput.value);
  });

  // --- Export ---

  document.getElementById('btn-download')!.addEventListener('click', async () => {
    const frame = currentFrame;
    const exportSize = parseInt(exportSizeSelect.value);
    const canvasW = exportSize;
    const canvasH = Math.round(exportSize * frame.height / frame.width);
    const scale = exportSize / frame.width;

    const canvas = document.createElement('canvas');
    canvas.width = canvasW;
    canvas.height = canvasH;
    const ctx = canvas.getContext('2d')!;

    // Draw clipped photo
    if (currentPhotoSrc) {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      await new Promise<void>((resolve) => {
        img.onload = () => resolve();
        img.onerror = () => resolve();
        img.src = currentPhotoSrc;
      });

      if (img.naturalWidth > 0) {
        const { x, y, pw, ph } = computeImageRect();

        ctx.save();
        ctx.scale(scale, scale);
        ctx.translate(-frame.minX, -frame.minY);

        const clipPath2D = new Path2D(frame.clipPathD);
        ctx.clip(clipPath2D);
        ctx.drawImage(img, x, y, pw, ph);
        ctx.restore();
      }
    }

    // Draw frame border overlay as SVG
    const pathsWithColor = frame.pathsVisual.replace(/fill:currentColor/g, `fill:${frameColor}`);
    const svgStr = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="${frame.viewBox}" width="${canvasW}" height="${canvasH}">${pathsWithColor}</svg>`;
    const svgBlob = new Blob([svgStr], { type: 'image/svg+xml' });
    const svgUrl = URL.createObjectURL(svgBlob);
    const svgImg = new Image();
    await new Promise<void>((resolve) => {
      svgImg.onload = () => resolve();
      svgImg.onerror = () => resolve();
      svgImg.src = svgUrl;
    });
    ctx.drawImage(svgImg, 0, 0, canvasW, canvasH);
    URL.revokeObjectURL(svgUrl);

    canvas.toBlob((blob) => {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.download = `cca-frame-${frame.id}-${exportSize}px.png`;
      a.href = url;
      a.click();
      URL.revokeObjectURL(url);
    }, 'image/png');
  });

  // --- Init ---

  // URL param ?frame=N (1-based) for pre-selection
  const params = new URLSearchParams(window.location.search);
  const frameParam = params.get('frame');
  let initialFrameIdx = 0;
  if (frameParam) {
    const idx = parseInt(frameParam) - 1;
    if (idx >= 0 && idx < allFrames.length) {
      initialFrameIdx = idx;
      const btn = frameGrid.children[idx] as HTMLButtonElement;
      frameGrid.querySelector('.active')?.classList.remove('active');
      btn.classList.add('active');
      btn.scrollIntoView({ block: 'nearest' });
    }
  }

  loadFrame(allFrames[initialFrameIdx]);
  loadPhoto(imageSelect.value);
</script>

<style>
  .editor {
    max-width: 100rem;
    margin: 0 auto;
    padding: var(--space-4) var(--space-4) var(--space-8);
  }

  .editor-header {
    margin-bottom: var(--space-4);
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }

  .back-link:hover { color: var(--color-accent); }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
  }

  /* Layout */
  .editor-layout {
    display: grid;
    grid-template-columns: 1fr 22rem;
    gap: var(--space-6);
    align-items: start;
  }

  @media (max-width: 64rem) {
    .editor-layout {
      grid-template-columns: 1fr;
    }
  }

  /* Viewport */
  .viewport-wrap {
    position: sticky;
    top: var(--space-4);
  }

  .viewport {
    position: relative;
    background: repeating-conic-gradient(#e8e8e8 0% 25%, #f5f5f5 0% 50%) 0 0 / 20px 20px;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: grab;
  }

  #preview-svg {
    display: block;
    /* Never taller than the window — shrink width proportionally via SVG intrinsic sizing */
    max-height: calc(100dvh - 7rem);
    max-width: 100%;
    width: auto;
    height: auto;
  }

  .viewport-hint {
    position: absolute;
    bottom: var(--space-3);
    left: 50%;
    transform: translateX(-50%);
    background: hsla(0, 0%, 0%, 0.6);
    color: #fff;
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: 1rem;
    pointer-events: none;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .viewport-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .toolbar-btn {
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    white-space: nowrap;
  }

  .toolbar-btn:hover {
    border-color: var(--color-accent);
  }

  .toolbar-btn-primary {
    background: var(--color-accent, #00BFB3);
    color: #fff;
    border-color: transparent;
    font-weight: 600;
  }

  .toolbar-btn-primary:hover {
    opacity: 0.9;
  }

  .toolbar-label {
    font-size: var(--text-sm);
    color: var(--color-muted);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }

  .toolbar-label output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    min-width: 3rem;
  }

  .toolbar-label select {
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .toolbar-slider {
    width: 6rem;
    cursor: pointer;
  }

  .toolbar-sep {
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
  }

  /* Panel */
  .panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .panel-section {
