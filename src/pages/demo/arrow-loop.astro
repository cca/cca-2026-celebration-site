---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
---

<DemoEffectLayout title="Arrow Animation Loop">
  <!-- SVG filters for materialize/dissolve effects -->
  <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <!-- Materialize filter: turbulence displacement that animates from chaotic to clear -->
      <filter id="arrow-warp-a" x="-50%" y="-50%" width="200%" height="200%">
        <feTurbulence id="turb-a" type="turbulence" baseFrequency="0.012" numOctaves="3" seed="1" result="noise" />
        <feDisplacementMap id="disp-a" in="SourceGraphic" in2="noise" scale="100" xChannelSelector="R" yChannelSelector="G" />
      </filter>
      <filter id="arrow-warp-b" x="-50%" y="-50%" width="200%" height="200%">
        <feTurbulence id="turb-b" type="turbulence" baseFrequency="0.012" numOctaves="3" seed="5" result="noise" />
        <feDisplacementMap id="disp-b" in="SourceGraphic" in2="noise" scale="100" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <!-- Two arrow slots that crossfade with displacement -->
  <div class="arrow-stage" id="arrow-stage">
    <div class="arrow-slot" id="slot-a" style="filter: url(#arrow-warp-a)">
      <img class="arrow-img" id="img-a" src="" alt="" />
    </div>
    <div class="arrow-slot" id="slot-b" style="filter: url(#arrow-warp-b)">
      <img class="arrow-img" id="img-b" src="" alt="" />
    </div>
    <!-- Ghost trail of previous arrow -->
    <div class="arrow-ghost" id="ghost"></div>
  </div>

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Arrow Animation Loop</h1>
    <p class="demo-technique">SVG displacement · Materialize / dissolve · Color cycling</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Wavy arrows materialize from turbulent displacement noise, hold briefly with a subtle breathing warp,
      then dissolve back into chaos as the next arrow coalesces. Each arrow is tinted with a cycling
      celebration palette color.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="cycle-speed">Cycle Duration: <output id="cycle-speed-val">3.5s</output></label>
        <input type="range" id="cycle-speed" min="1" max="8" value="3.5" step="0.5" />
      </div>
      <div class="control-group">
        <label for="warp-intensity">Warp Intensity: <output id="warp-intensity-val">100</output></label>
        <input type="range" id="warp-intensity" min="20" max="400" value="100" step="10" />
      </div>
      <div class="control-group">
        <label for="turbulence-freq">Turbulence Frequency: <output id="turbulence-freq-val">0.012</output></label>
        <input type="range" id="turbulence-freq" min="0.003" max="0.04" value="0.012" step="0.001" />
      </div>
      <div class="control-group">
        <label for="hold-breathe">Hold Breathe Amount: <output id="hold-breathe-val">6</output></label>
        <input type="range" id="hold-breathe" min="0" max="50" value="6" step="1" />
      </div>
      <div class="control-group">
        <label for="ghost-opacity">Ghost Trail: <output id="ghost-opacity-val">0.06</output></label>
        <input type="range" id="ghost-opacity" min="0" max="0.3" value="0.06" step="0.01" />
      </div>
      <div class="control-group">
        <label>Tint Colors</label>
        <div class="swatch-picker" id="tint-swatches">
          <button class="swatch active" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch active" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch active" data-color="#E57200" style="background:#E57200" title="Orange"></button>
          <button class="swatch active" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch active" data-color="#B7BF10" style="background:#B7BF10" title="Lime"></button>
          <button class="swatch active" data-color="#F1BDC8" style="background:#F1BDC8" title="Pink"></button>
          <button class="swatch active" data-color="#005776" style="background:#005776" title="Navy"></button>
        </div>
        <p class="swatch-hint">Click to toggle colors in the cycle</p>
      </div>
      <div class="control-group">
        <button class="toggle-btn" id="toggle-pause">Pause</button>
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  .arrow-stage {
    position: fixed;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .arrow-slot {
    position: absolute;
    width: 45vmin;
    height: 45vmin;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: filter, opacity, transform;
  }

  .arrow-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .arrow-ghost {
    position: absolute;
    width: 45vmin;
    height: 45vmin;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.5s ease-out;
  }

  .arrow-ghost img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  /* Overlay info */
  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  /* Sidebar toggle */
  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] {
    display: none;
  }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open {
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar { transition: none; }
    .arrow-slot { filter: none !important; }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }

  .toggle-btn {
    width: 100%;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .toggle-btn:hover {
    border-color: var(--color-accent);
  }

  .swatch-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-1);
  }

  .swatch {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
    opacity: 0.35;
  }

  .swatch:hover { transform: scale(1.15); }

  .swatch.active {
    border-color: var(--color-text);
    opacity: 1;
  }

  .swatch-hint {
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.7;
  }
</style>

<script>
  const arrowIds = [
    'arrow-02', 'arrow-03', 'arrow-04', 'arrow-05', 'arrow-06',
    'arrow-07', 'arrow-08', 'arrow-09', 'arrow-10', 'arrow-11',
    'arrow-12', 'arrow-13',
  ];

  // Celebration palette
  const allColors = [
    '#00BFB3', '#563D82', '#E57200', '#FFC845', '#B7BF10', '#F1BDC8', '#005776',
  ];
  let activeColors = [...allColors];

  // DOM refs
  const slotA = document.getElementById('slot-a') as HTMLElement;
  const slotB = document.getElementById('slot-b') as HTMLElement;
  const imgA = document.getElementById('img-a') as HTMLImageElement;
  const imgB = document.getElementById('img-b') as HTMLImageElement;
  const ghost = document.getElementById('ghost') as HTMLElement;
  const turbA = document.getElementById('turb-a') as unknown as SVGFETurbulenceElement;
  const turbB = document.getElementById('turb-b') as unknown as SVGFETurbulenceElement;
  const dispA = document.getElementById('disp-a') as unknown as SVGFEDisplacementMapElement;
  const dispB = document.getElementById('disp-b') as unknown as SVGFEDisplacementMapElement;

  // State
  let cycleDuration = 3.5; // seconds per full cycle
  let maxWarp = 100;
  let turbFreq = 0.012;
  let holdBreathe = 6;
  let ghostOpacity = 0.06;
  let paused = false;
  let arrowIndex = 0;
  let colorIndex = 0;
  let animId = 0;

  function easeOutBack(t: number) {
    const c1 = 1.70158;
    const c3 = c1 + 1;
    return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
  }

  function easeInOut(t: number) {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
  }

  function hexToHSL(hex: string): { h: number; s: number; l: number } {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    const l = (max + min) / 2;
    let h = 0, s = 0;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) * 60;
      else if (max === g) h = ((b - r) / d + 2) * 60;
      else h = ((r - g) / d + 4) * 60;
    }
    return { h, s, l };
  }

  function tintFilter(hex: string): string {
    if (hex === '#231f20' || hex === '#000000') return 'none';
    const { h, s, l } = hexToHSL(hex);
    return `brightness(0) saturate(100%) invert(${l > 0.5 ? 1 : 0.5}) sepia(1) saturate(${Math.max(s * 600, 100)}%) hue-rotate(${h}deg) brightness(${0.4 + l * 0.8})`;
  }

  function nextColor(): string {
    if (activeColors.length === 0) return '#231f20';
    const c = activeColors[colorIndex % activeColors.length];
    colorIndex++;
    return c;
  }

  function nextArrow(): string {
    const id = arrowIds[arrowIndex % arrowIds.length];
    arrowIndex++;
    return id;
  }

  // Phase durations as fractions of cycleDuration:
  //   materialize: 0.35  |  hold: 0.30  |  dissolve: 0.35
  // Slots A and B alternate. While A dissolves, B materializes (overlap).

  type SlotState = {
    el: HTMLElement;
    img: HTMLImageElement;
    turb: SVGFETurbulenceElement;
    disp: SVGFEDisplacementMapElement;
    phase: 'idle' | 'materialize' | 'hold' | 'dissolve';
    phaseStart: number;
    arrowId: string;
    color: string;
  };

  const slots: [SlotState, SlotState] = [
    { el: slotA, img: imgA, turb: turbA, disp: dispA, phase: 'idle', phaseStart: 0, arrowId: '', color: '' },
    { el: slotB, img: imgB, turb: turbB, disp: dispB, phase: 'idle', phaseStart: 0, arrowId: '', color: '' },
  ];

  let activeSlot = 0;

  function startMaterialize(slot: SlotState, now: number) {
    slot.arrowId = nextArrow();
    slot.color = nextColor();
    slot.img.src = `/images/scanned-graphics/arrows/${slot.arrowId}.svg`;
    slot.img.style.filter = tintFilter(slot.color);
    slot.phase = 'materialize';
    slot.phaseStart = now;
    slot.el.style.opacity = '1';
  }

  function spawnGhost(slot: SlotState) {
    ghost.innerHTML = '';
    const img = document.createElement('img');
    img.src = `/images/scanned-graphics/arrows/${slot.arrowId}.svg`;
    img.style.filter = tintFilter(slot.color);
    img.style.maxWidth = '100%';
    img.style.maxHeight = '100%';
    img.style.objectFit = 'contain';
    ghost.appendChild(img);
    ghost.style.opacity = String(ghostOpacity);
    ghost.style.transform = slot.el.style.transform || '';
    requestAnimationFrame(() => {
      ghost.style.opacity = '0';
    });
  }

  function updateSlot(slot: SlotState, now: number) {
    if (slot.phase === 'idle') return;

    const elapsed = (now - slot.phaseStart) / 1000;
    const materializeDur = cycleDuration * 0.35;
    const holdDur = cycleDuration * 0.30;
    const dissolveDur = cycleDuration * 0.35;

    if (slot.phase === 'materialize') {
      const t = Math.min(elapsed / materializeDur, 1);
      const eased = easeInOut(t);

      // Displacement: max -> 0
      const warp = maxWarp * (1 - eased);
      slot.disp.setAttribute('scale', String(warp));

      // Turbulence seed shifts for organic motion
      const seedShift = Math.sin(t * Math.PI * 2) * 0.003;
      slot.turb.setAttribute('baseFrequency', `${turbFreq + seedShift} ${turbFreq}`);

      // Opacity ramps up
      slot.el.style.opacity = String(Math.min(eased * 1.5, 1));

      // Scale from 0.85 -> 1, rotation twist, slide in from left
      const scale = 0.92 + 0.08 * eased;
      const rotate = (1 - eased) * 3;
      const translateX = (1 - eased) * -12;
      slot.el.style.transform = `translateX(${translateX}px) rotate(${rotate}deg) scale(${scale})`;

      if (t >= 1) {
        slot.phase = 'hold';
        slot.phaseStart = now;
        slot.disp.setAttribute('scale', '0');
        slot.el.style.transform = 'translateX(0) rotate(0deg) scale(1)';
        slot.el.style.opacity = '1';
      }
    } else if (slot.phase === 'hold') {
      const t = elapsed / holdDur;

      // Subtle breathing displacement
      const breathe = Math.sin(elapsed * 3) * holdBreathe;
      slot.disp.setAttribute('scale', String(Math.abs(breathe)));

      // Gentle idle sway
      const sway = Math.sin(elapsed * 1.5) * 2;
      slot.el.style.transform = `translateY(${sway}px)`;

      if (t >= 1) {
        slot.phase = 'dissolve';
        slot.phaseStart = now;
        // Start next slot materializing
        const next = activeSlot === 0 ? 1 : 0;
        activeSlot = next;
        startMaterialize(slots[next], now);
      }
    } else if (slot.phase === 'dissolve') {
      const t = Math.min(elapsed / dissolveDur, 1);
      const eased = easeInOut(t);

      // Displacement ramps back up
      const warp = maxWarp * eased;
      slot.disp.setAttribute('scale', String(warp));

      // Turbulence frequency increases slightly
      const freqBoost = turbFreq + eased * 0.008;
      slot.turb.setAttribute('baseFrequency', `${freqBoost} ${freqBoost}`);

      // Fade out + scale away to the right
      slot.el.style.opacity = String(1 - eased);
      const translateX = eased * 15;
      const scale = 1 + eased * 0.1;
      const rotate = eased * -4;
      slot.el.style.transform = `translateX(${translateX}px) rotate(${rotate}deg) scale(${scale})`;

      if (t >= 1) {
        slot.phase = 'idle';
        slot.el.style.opacity = '0';
        spawnGhost(slot);
      }
    }
  }

  function animate(now: number) {
    if (!paused) {
      updateSlot(slots[0], now);
      updateSlot(slots[1], now);
    }
    animId = requestAnimationFrame(animate);
  }

  // --- Controls ---
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  // Range controls
  const rangeControls: Array<{ id: string; valId: string; suffix: string; setter: (v: number) => void }> = [
    { id: 'cycle-speed', valId: 'cycle-speed-val', suffix: 's', setter: v => { cycleDuration = v; } },
    { id: 'warp-intensity', valId: 'warp-intensity-val', suffix: '', setter: v => { maxWarp = v; } },
    { id: 'turbulence-freq', valId: 'turbulence-freq-val', suffix: '', setter: v => { turbFreq = v; } },
    { id: 'hold-breathe', valId: 'hold-breathe-val', suffix: '', setter: v => { holdBreathe = v; } },
    { id: 'ghost-opacity', valId: 'ghost-opacity-val', suffix: '', setter: v => { ghostOpacity = v; } },
  ];

  for (const ctrl of rangeControls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      const v = parseFloat(input.value);
      output.textContent = input.value + ctrl.suffix;
      ctrl.setter(v);
    });
  }

  // Swatch toggles
  document.getElementById('tint-swatches')!.querySelectorAll('.swatch').forEach(swatch => {
    swatch.addEventListener('click', () => {
      swatch.classList.toggle('active');
      activeColors = [];
      document.getElementById('tint-swatches')!.querySelectorAll('.swatch.active').forEach(s => {
        activeColors.push((s as HTMLElement).dataset.color!);
      });
      if (activeColors.length === 0) activeColors = ['#231f20'];
    });
  });

  // Pause
  const pauseBtn = document.getElementById('toggle-pause') as HTMLButtonElement;
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? 'Play' : 'Pause';
  });

  // Reduced motion
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (prefersReducedMotion.matches) {
    paused = true;
    pauseBtn.textContent = 'Play';
  }

  // --- Init ---
  startMaterialize(slots[0], performance.now());
  animId = requestAnimationFrame(animate);
</script>
