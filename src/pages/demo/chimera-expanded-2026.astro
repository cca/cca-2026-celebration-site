---
import BaseLayout from "../../layouts/BaseLayout.astro";

const shapeCount = 104;
const shapes = Array.from({ length: shapeCount }, (_, i) =>
  `shape-${String(i + 1).padStart(3, "0")}`
);
---

<BaseLayout title="Chimera Expanded Shapes (2026)" minimalHeader={true}>
  <main class="demo-scanned">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1>Chimera Expanded Shapes (2026)</h1>
    <p class="subtitle">
      {shapeCount} unique decorative shapes from the Chimera Expanded set
      <span class="badge">(deduplicated from 236 exports &mdash; 130 plain rects &amp; 2 duplicate pairs removed)</span>
    </p>

    <div class="grid">
      {shapes.map((name) => (
        <figure class="card">
          <img src={`/images/chimera-expanded-2026/${name}.svg`} alt={name} loading="lazy" />
          <figcaption>{name}</figcaption>
        </figure>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .demo-scanned {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .back-link {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-text);
    margin-bottom: var(--space-10);
  }

  .badge {
    display: inline-block;
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: var(--space-4);
  }

  .card {
    margin: 0;
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
  }

  .card img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 10rem;
    object-fit: contain;
    margin-bottom: var(--space-2);
  }

  .card figcaption {
    font-size: var(--text-xs);
    color: var(--color-text);
    font-family: var(--font-mono);
  }
</style>
