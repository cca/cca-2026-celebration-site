---
import BaseLayout from "../../layouts/BaseLayout.astro";
import fs from "node:fs";
import path from "node:path";
import SvgPath from "svgpath";

const framesDir = path.resolve("public/images/scanned-graphics/frames");

// All compatible frames (skip 06 and 08 — 2-path, fundamentally different structure)
const frameIds = [
  "frame-01", "frame-02", "frame-03", "frame-04", "frame-05",
  "frame-07", "frame-09", "frame-10", "frame-11", "frame-12",
  "frame-13", "frame-14", "frame-15", "frame-16", "frame-17",
  "frame-18", "frame-19", "frame-20", "frame-21", "frame-22", "frame-23",
];

// Frames where turnaround split fails — use ray-casting override
const overrideIds = new Set(["frame-09", "frame-19"]);

// --- Clip path generation: extract inner edge of each frame border ---

function flattenPath(d: string, matrix: number[], samplesPerCurve = 12) {
  const svgpath = SvgPath(d).matrix(matrix).abs().unshort().unarc();
  const points: number[][] = [];
  let curX = 0, curY = 0;
  svgpath.iterate((seg: any) => {
    const cmd = seg[0];
    if (cmd === "M") { curX = seg[1]; curY = seg[2]; points.push([curX, curY]); }
    else if (cmd === "L") { curX = seg[1]; curY = seg[2]; points.push([curX, curY]); }
    else if (cmd === "H") { curX = seg[1]; points.push([curX, curY]); }
    else if (cmd === "V") { curY = seg[1]; points.push([curX, curY]); }
    else if (cmd === "C") {
      const [, x1, y1, x2, y2, x3, y3] = seg;
      for (let i = 1; i <= samplesPerCurve; i++) {
        const t = i / samplesPerCurve, mt = 1 - t;
        points.push([
          mt*mt*mt*curX + 3*mt*mt*t*x1 + 3*mt*t*t*x2 + t*t*t*x3,
          mt*mt*mt*curY + 3*mt*mt*t*y1 + 3*mt*t*t*y2 + t*t*t*y3,
        ]);
      }
      curX = x3; curY = y3;
    }
  });
  return points;
}

/**
 * PCA: find the principal axis of a point set.
 * Returns the unit axis vector and eigenvalue ratio (eccentricity).
 * High eccentricity = clear strip/diagonal. Low = L-shaped or ambiguous.
 */
function computePrincipalAxis(points: number[][]): { axis: [number, number]; eccentricity: number } {
  const n = points.length;
  const mx = points.reduce((s, p) => s + p[0], 0) / n;
  const my = points.reduce((s, p) => s + p[1], 0) / n;
  let cxx = 0, cxy = 0, cyy = 0;
  for (const [x, y] of points) {
    const dx = x - mx, dy = y - my;
    cxx += dx * dx; cxy += dx * dy; cyy += dy * dy;
  }
  cxx /= n; cxy /= n; cyy /= n;
  const d = cxx - cyy;
  const sq = Math.sqrt(d * d + 4 * cxy * cxy);
  const lambda1 = (cxx + cyy + sq) / 2;
  const lambda2 = (cxx + cyy - sq) / 2;
  const eccentricity = Math.abs(lambda2) > 1e-10 ? lambda1 / lambda2 : Infinity;
  const vx = cxy, vy = lambda1 - cxx;
  const len = Math.hypot(vx, vy);
  const axis: [number, number] = len < 1e-10 ? [1, 0] : [vx / len, vy / len];
  return { axis, eccentricity };
}

/**
 * Extract inner edge of an L-shaped or ambiguous path using distance from frame center.
 * Returns the longest contiguous run of points closer than the median distance.
 */
function extractInnerByDistance(points: number[][], centerX: number, centerY: number): number[][] {
  const n = points.length;
  const dists = points.map(p => Math.hypot(p[0] - centerX, p[1] - centerY));
  const threshold = [...dists].sort((a, b) => a - b)[Math.floor(n / 2)];
  let bestStart = 0, bestLen = 0;
  for (let start = 0; start < n; start++) {
    if (dists[start] >= threshold) continue;
    if (bestStart > 0 && start >= bestStart && start < bestStart + bestLen) continue;
    let len = 0;
    for (let j = 0; j < n; j++) {
      if (dists[(start + j) % n] < threshold) len++;
      else break;
    }
    if (len > bestLen) { bestLen = len; bestStart = start; }
  }
  if (bestLen === 0) return points;
  return Array.from({ length: bestLen }, (_, i) => points[(bestStart + i) % n]);
}

function raySegIntersect(ox: number, oy: number, dx: number, dy: number,
  x1: number, y1: number, x2: number, y2: number) {
  const sx = x2 - x1, sy = y2 - y1;
  const denom = dx * sy - dy * sx;
  if (Math.abs(denom) < 1e-10) return null;
  const t = ((x1 - ox) * sy - (y1 - oy) * sx) / denom;
  const u = ((x1 - ox) * dy - (y1 - oy) * dx) / denom;
  if (t > 0.1 && u >= 0 && u <= 1) {
    return { dist: t, point: [ox + dx * t, oy + dy * t] as number[] };
  }
  return null;
}

function rayRectIntersect(ox: number, oy: number, dx: number, dy: number,
  x0: number, y0: number, w: number, h: number): number[] | null {
  const edges: [number, number, number, number][] = [
    [x0, y0, x0 + w, y0], [x0 + w, y0, x0 + w, y0 + h],
    [x0 + w, y0 + h, x0, y0 + h], [x0, y0 + h, x0, y0],
  ];
  let closest = Infinity, hit: number[] | null = null;
  for (const [x1, y1, x2, y2] of edges) {
    const r = raySegIntersect(ox, oy, dx, dy, x1, y1, x2, y2);
    if (r && r.dist < closest) { closest = r.dist; hit = r.point; }
  }
  return hit;
}

/**
 * Generate clip path using ray-casting from center.
 * Used for override frames (05, 09, 14, 19) where turnaround split fails.
 */
function rayCastClipPath(svg: string, centerX: number, centerY: number,
  minX: number, minY: number, frameWidth: number, frameHeight: number): string {
  const pathRegex = /<path\s+d="([^"]+)"[^>]*transform="matrix\(([^)]+)\)"/g;
  const allPaths: number[][][] = [];
  let match;

  while ((match = pathRegex.exec(svg)) !== null) {
    const [, d, matrixStr] = match;
    const matrix = matrixStr.split(/[\s,]+/).map(Number);
    allPaths.push(flattenPath(d, matrix));
  }

  if (allPaths.length === 0) return "";

  const numRays = 720;
  const clipPoints: number[][] = [];

  for (let i = 0; i < numRays; i++) {
    const angle = (2 * Math.PI * i) / numRays;
    const dx = Math.cos(angle), dy = Math.sin(angle);
    let closest = Infinity;
    let hit: number[] | null = null;

    for (const pts of allPaths) {
      for (let j = 0; j < pts.length - 1; j++) {
        const r = raySegIntersect(centerX, centerY, dx, dy,
          pts[j][0], pts[j][1], pts[j + 1][0], pts[j + 1][1]);
        if (r && r.dist < closest) { closest = r.dist; hit = r.point; }
      }
    }

    if (!hit) {
      hit = rayRectIntersect(centerX, centerY, dx, dy, minX, minY, frameWidth, frameHeight);
    }
    if (hit) clipPoints.push(hit);
  }

  if (clipPoints.length === 0) return "";
  const r = (n: number) => Math.round(n * 10) / 10;
  let d = `M${r(clipPoints[0][0])} ${r(clipPoints[0][1])}`;
  for (let i = 1; i < clipPoints.length; i++) {
    d += ` L${r(clipPoints[i][0])} ${r(clipPoints[i][1])}`;
  }
  return d + " Z";
}

/**
 * Generate clip path by:
 * 1. Using PCA to find each strip path's actual main axis (handles diagonal strips)
 * 2. Splitting at turnaround points along that axis to get inner vs outer edge
 * 3. Stitching inner legs together by nearest-endpoint proximity (no position classification)
 */
function generateClipPath(svg: string, centerX: number, centerY: number, _frameWidth: number, _frameHeight: number) {
  const pathRegex = /<path\s+d="([^"]+)"[^>]*transform="matrix\(([^)]+)\)"/g;
  const innerLegs: number[][][] = [];
  let match;

  while ((match = pathRegex.exec(svg)) !== null) {
    const [, d, matrixStr] = match;
    const matrix = matrixStr.split(/[\s,]+/).map(Number);
    const points = flattenPath(d, matrix);
    if (points.length < 4) continue;

    // Use PCA to detect whether this is a true strip (high eccentricity) or L-shaped (low).
    // True strips: turnaround split along PCA axis. L-shaped: distance-from-center extraction.
    const { axis: [ax, ay], eccentricity } = computePrincipalAxis(points);
    let innerLeg: number[][];

    if (eccentricity > 5) {
      // Clear strip (axis-aligned or diagonal): turnaround split along PCA axis
      const projs = points.map(p => p[0] * ax + p[1] * ay);
      let minIdx = 0, maxIdx = 0;
      for (let i = 1; i < points.length; i++) {
        if (projs[i] < projs[minIdx]) minIdx = i;
        if (projs[i] > projs[maxIdx]) maxIdx = i;
      }
      const s = Math.min(minIdx, maxIdx);
      const e = Math.max(minIdx, maxIdx);
      const half1 = points.slice(s, e + 1);
      const half2 = [...points.slice(e), ...points.slice(0, s + 1)];
      if (half1.length < 2 || half2.length < 2) continue;
      const px = -ay, py = ax;
      const cProj = centerX * px + centerY * py;
      const avg1 = half1.reduce((sum, p) => sum + p[0] * px + p[1] * py, 0) / half1.length;
      const avg2 = half2.reduce((sum, p) => sum + p[0] * px + p[1] * py, 0) / half2.length;
      innerLeg = Math.abs(avg1 - cProj) < Math.abs(avg2 - cProj) ? [...half1] : [...half2];
    } else {
      // L-shaped or ambiguous: extract inner edge by distance from frame center
      innerLeg = extractInnerByDistance(points, centerX, centerY);
    }

    innerLegs.push(innerLeg);
  }

  if (innerLegs.length === 0) return "";

  // Stitch inner legs by nearest-endpoint proximity
  const result = [...innerLegs[0]];
  const used = new Set([0]);
  while (used.size < innerLegs.length) {
    const last = result[result.length - 1];
    let bestIdx = -1, bestDist = Infinity, bestRev = false;
    for (let i = 0; i < innerLegs.length; i++) {
      if (used.has(i)) continue;
      const leg = innerLegs[i];
      const d1 = (last[0] - leg[0][0]) ** 2 + (last[1] - leg[0][1]) ** 2;
      const d2 = (last[0] - leg[leg.length - 1][0]) ** 2 + (last[1] - leg[leg.length - 1][1]) ** 2;
      if (d1 < bestDist) { bestDist = d1; bestIdx = i; bestRev = false; }
      if (d2 < bestDist) { bestDist = d2; bestIdx = i; bestRev = true; }
    }
    if (bestIdx === -1) break;
    used.add(bestIdx);
    const next = bestRev ? [...innerLegs[bestIdx]].reverse() : innerLegs[bestIdx];
    result.push(...next);
  }

  if (result.length === 0) return "";
  const r = (n: number) => Math.round(n * 10) / 10;
  let d_path = `M${r(result[0][0])} ${r(result[0][1])}`;
  for (let i = 1; i < result.length; i++) {
    d_path += ` L${r(result[i][0])} ${r(result[i][1])}`;
  }
  return d_path + " Z";
}

// --- Build frame data ---

const frames = frameIds.map((id) => {
  const svg = fs.readFileSync(path.join(framesDir, `${id}.svg`), "utf-8");
  const vbMatch = svg.match(/viewBox="([^"]+)"/);
  const viewBox = vbMatch ? vbMatch[1] : "0 0 100 100";
  const [minX, minY, width, height] = viewBox.split(/\s+/).map(Number);

  const pathMatches = svg.match(/<path[^>]*\/>/g) || [];
  const pathsVisual = pathMatches
    .map((p) => p.replace(/fill:#231f20/g, "fill:currentColor"))
    .join("\n");

  const centerX = minX + width / 2;
  const centerY = minY + height / 2;

  let clipPathD: string;
  if (overrideIds.has(id)) {
    clipPathD = rayCastClipPath(svg, centerX, centerY, minX, minY, width, height);
  } else {
    clipPathD = generateClipPath(svg, centerX, centerY, width, height);
  }

  return { id, viewBox, minX, minY, width, height, pathsVisual, clipPathD };
});

const photoUrls = frameIds.map((_, i) => `https://picsum.photos/seed/frame${i + 1}/800/600`);
---

<BaseLayout title="Framed Images" minimalHeader={true}>
  <main class="demo-framed">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1>Framed Images</h1>
    <p class="subtitle">Scanned SVG frames clipping photographs — inner-edge polyline clip paths.</p>

    <div class="controls">
      <label class="control">
        <span>Frame color</span>
        <input type="color" id="frame-color" value="#231f20" />
      </label>
      <label class="control">
        <span>Image set</span>
        <select id="image-set">
          <option value="photos">Placeholder photos</option>
          <option value="gradient">Gradient fill</option>
          <option value="solid">Solid color</option>
        </select>
      </label>
    </div>

    <div class="grid">
      {frames.map((frame, i) => (
        <figure class="card">
          <svg viewBox={frame.viewBox} xmlns="http://www.w3.org/2000/svg" class="framed-svg">
            <defs>
              <clipPath id={`clip-${frame.id}`}>
                <path d={frame.clipPathD} />
              </clipPath>
            </defs>

            <image
              class="frame-image"
              href={photoUrls[i]}
              x={frame.minX}
              y={frame.minY}
              width={frame.width}
              height={frame.height}
              preserveAspectRatio="xMidYMid slice"
              clip-path={`url(#clip-${frame.id})`}
            />

            <Fragment set:html={frame.pathsVisual} />
          </svg>
          <figcaption>{frame.id}</figcaption>
        </figure>
      ))}
    </div>
  </main>
</BaseLayout>

<script>
  const colorInput = document.getElementById("frame-color") as HTMLInputElement;
  const imageSetSelect = document.getElementById("image-set") as HTMLSelectElement;
  const svgs = document.querySelectorAll<SVGSVGElement>(".framed-svg");
  const images = document.querySelectorAll<SVGImageElement>(".frame-image");
  const originalHrefs = Array.from(images).map((img) => img.getAttribute("href")!);

  colorInput.addEventListener("input", () => {
    svgs.forEach((svg) => { svg.style.color = colorInput.value; });
  });

  imageSetSelect.addEventListener("change", () => {
    const set = imageSetSelect.value;
    images.forEach((img, i) => {
      switch (set) {
        case "photos":
          img.setAttribute("href", originalHrefs[i]);
          break;
        case "gradient": {
          const canvas = document.createElement("canvas");
          canvas.width = 200; canvas.height = 150;
          const ctx = canvas.getContext("2d")!;
          const hue = (i * 17) % 360;
          const grad = ctx.createLinearGradient(0, 0, 200, 150);
          grad.addColorStop(0, `hsl(${hue}, 80%, 60%)`);
          grad.addColorStop(1, `hsl(${(hue + 120) % 360}, 80%, 40%)`);
          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, 200, 150);
          img.setAttribute("href", canvas.toDataURL());
          break;
        }
        case "solid": {
          const hue = (i * 17) % 360;
          const canvas = document.createElement("canvas");
          canvas.width = 1; canvas.height = 1;
          const ctx = canvas.getContext("2d")!;
          ctx.fillStyle = `hsl(${hue}, 70%, 50%)`;
          ctx.fillRect(0, 0, 1, 1);
          img.setAttribute("href", canvas.toDataURL());
          break;
        }
      }
    });
  });
</script>

<style>
  .demo-framed {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .back-link:hover { color: var(--color-accent); }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: var(--space-6);
  }

  .controls {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    margin-bottom: var(--space-8);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .control {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .control input[type="color"] {
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    cursor: pointer;
    padding: 0;
    background: none;
  }

  .control select {
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--space-6);
  }

  .card {
    margin: 0;
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
  }

  .framed-svg {
    display: block;
    width: 100%;
    height: auto;
    color: #231f20;
    margin-bottom: var(--space-2);
  }

  .card figcaption {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-family: var(--font-mono);
  }
</style>
