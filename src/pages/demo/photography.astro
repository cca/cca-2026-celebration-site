---
import BaseLayout from "../../layouts/BaseLayout.astro";

const ccaPhotography = [
  "arch-final-conversations-fa25-022.jpg",
  "arch-final-conversations-fa25-026.jpg",
  "arch-final-conversations-fa25-083.jpg",
  "arch-final-conversations-fa25-084.jpg",
  "arch-final-conversations-fa25-150.jpg",
  "arch-final-conversations-fa25-152.jpg",
  "arch-howsoon-sp26-59.jpg",
  "arch-howsoon-sp26-68.jpg",
  "arch-howsoon-sp26-77.jpg",
  "arch-howsoon-sp26-79.jpg",
  "commencement-masters24.jpg",
  "core-2d-perspective-collage-fa25.jpg",
  "design-senior-show-fa25-39.jpg",
  "design-senior-show-fa25-54.jpg",
  "design-senior-show-fa25-67.jpg",
  "eoy-show-sp25.jpg",
  "eventbrite-dice-macro-0811.jpg",
  "fashion-materevolve-sp25.png",
  "fashion-roots-stereo-film-01.jpg",
  "fashion-roots-stereo-film-08.jpg",
  "fashion-roots-stereo-film-12.jpg",
  "fashion-roots-stereo-film-46.jpg",
  "fine-arts-senior-exhibition-sp26.png",
  "gala-event-2023.jpg",
  "game-arts-showcase.png",
  "gamearts-2026.png",
  "haavc-tea-ceremony-fa25.jpg",
  "headshot-arr.png",
  "mfa-2026-thesis-banner.png",
  "mfa-fine-arts-studio-fa22.jpg",
  "mfa-thesis.jpg",
  "pole-banners-fa25.jpg",
  "roxie.jpg",
  "staff-show-every-day-strange-fa25.jpg",
  "student-work-unnamed.jpg",
  "thesis-poster.png",
];

const eoyShowPast = Array.from({ length: 30 }, (_, i) => {
  const n = String(i + 1).padStart(3, "0");
  return `previousEOYShowPhotos-${n}-03-2026.jpg`;
});

const commencementPast = Array.from({ length: 17 }, (_, i) => {
  const n = String(i + 1).padStart(3, "0");
  return `previousCommencementPhotos-${n}-03-2026-JL.jpg`;
});

const events = ["game-arts-showcase.png", "mfathesis.jpg", "roxie.jpg"];
const thesis = ["poster.png"];

function cardId(section: string, file: string) {
  return `${section}--${file.replace(/[^a-zA-Z0-9-]/g, "-")}`;
}
---

<BaseLayout title="Photography" minimalHeader={true}>
  <main class="demo-photography">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1>Photography</h1>
    <p class="subtitle">
      All photographic and raster images used across the site, organized by directory.
      Click any image to copy its anchor link.
    </p>

    <nav class="jump-nav" aria-label="Jump to section">
      <a href="#cca-photography">CCA Photography ({ccaPhotography.length})</a>
      <a href="#eoy-show-past">EOY Show Past ({eoyShowPast.length})</a>
      <a href="#commencement-past">Commencement Past ({commencementPast.length})</a>
      <a href="#events">Events ({events.length})</a>
      <a href="#thesis">Thesis ({thesis.length})</a>
    </nav>

    <section id="cca-photography">
      <h2>CCA Photography <span class="count">({ccaPhotography.length})</span></h2>
      <p class="section-note"><code>/public/images/cca-photography/</code></p>
      <div class="grid">
        {ccaPhotography.map((file) => (
          <figure class="card" id={cardId("cca-photography", file)}>
            <img src={`/images/cca-photography/${file}`} alt={file} loading="lazy" />
            <figcaption>{file}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section id="eoy-show-past">
      <h2>EOY Show Past <span class="count">({eoyShowPast.length})</span></h2>
      <p class="section-note"><code>/public/images/eoy-show-past/</code></p>
      <div class="grid">
        {eoyShowPast.map((file) => (
          <figure class="card" id={cardId("eoy-show-past", file)}>
            <img src={`/images/eoy-show-past/${file}`} alt={file} loading="lazy" />
            <figcaption>{file}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section id="commencement-past">
      <h2>Commencement Past <span class="count">({commencementPast.length})</span></h2>
      <p class="section-note"><code>/public/images/commencement-past/</code></p>
      <div class="grid">
        {commencementPast.map((file) => (
          <figure class="card" id={cardId("commencement-past", file)}>
            <img src={`/images/commencement-past/${file}`} alt={file} loading="lazy" />
            <figcaption>{file}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section id="events">
      <h2>Events <span class="count">({events.length})</span></h2>
      <p class="section-note"><code>/public/images/events/</code></p>
      <div class="grid">
        {events.map((file) => (
          <figure class="card" id={cardId("events", file)}>
            <img src={`/images/events/${file}`} alt={file} loading="lazy" />
            <figcaption>{file}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section id="thesis">
      <h2>Thesis <span class="count">({thesis.length})</span></h2>
      <p class="section-note"><code>/public/images/thesis/</code></p>
      <div class="grid">
        {thesis.map((file) => (
          <figure class="card" id={cardId("thesis", file)}>
            <img src={`/images/thesis/${file}`} alt={file} loading="lazy" />
            <figcaption>{file}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <div id="copy-toast" aria-live="polite"></div>
  </main>
</BaseLayout>

<script>
  function setHeaderOffset() {
    const header = document.querySelector<HTMLElement>(".site-header");
    const h = header ? header.offsetHeight : 0;
    document.documentElement.style.setProperty("--photography-header-h", `${h}px`);
  }
  setHeaderOffset();
  window.addEventListener("resize", setHeaderOffset, { passive: true });

  const toast = document.getElementById("copy-toast")!;
  let toastTimer: ReturnType<typeof setTimeout>;

  document.querySelectorAll<HTMLElement>(".card").forEach((card) => {
    card.addEventListener("click", async () => {
      const url = `${location.origin}${location.pathname}#${card.id}`;
      await navigator.clipboard.writeText(url);

      toast.textContent = `Copied: #${card.id}`;
      toast.classList.add("visible");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove("visible"), 2500);
    });
  });
</script>

<style>
  .demo-photography {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .back-link {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .jump-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .jump-nav a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
    transition: color var(--duration-fast) ease, background var(--duration-fast) ease;
  }

  .jump-nav a:hover {
    color: var(--color-accent);
    background: var(--color-border);
  }

  section {
    margin-bottom: var(--space-16);
    scroll-margin-top: calc(var(--photography-header-h, 4rem) + var(--space-4));
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }

  .count {
    color: var(--color-text);
    font-weight: 400;
  }

  .section-note {
    color: var(--color-text);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    margin-bottom: var(--space-4);
  }

  .section-note code {
    font-family: inherit;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-4);
  }

  /* Card */
  .card {
    position: relative;
    margin: 0;
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
    cursor: pointer;
    scroll-margin-top: calc(var(--photography-header-h, 4rem) + var(--space-4));
    transition: border-color var(--duration-fast) ease,
      box-shadow var(--duration-fast) ease;
  }

  /* Hover overlay */
  .card::after {
    content: "Copy link";
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    border-radius: 0.5rem;
    opacity: 0;
    transition: opacity var(--duration-fast) ease;
    pointer-events: none;
  }

  .card:hover::after {
    opacity: 1;
  }

  /* Active anchor target */
  .card:target {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent);
  }

  .card:target img {
    opacity: 0.85;
  }

  .card img {
    display: block;
    width: 100%;
    height: 12rem;
    object-fit: cover;
    border-radius: 0.25rem;
    margin-bottom: var(--space-2);
  }

  .card figcaption {
    font-size: var(--text-xs);
    color: var(--color-text);
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Toast */
  #copy-toast {
    position: fixed;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%) translateY(0.75rem);
    background: var(--color-accent);
    color: #fff;
    padding: var(--space-2) var(--space-5);
    border-radius: 0.5rem;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    z-index: 100;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  #copy-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
