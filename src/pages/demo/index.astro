---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Demo Pages" minimalHeader={true}>
  <main class="demo-index">
    <h1>Demo Pages</h1>
    <p class="subtitle">Internal previews of design assets and components.</p>

    <section class="demo-section">
      <h2 class="section-heading">Assets</h2>
      <ul class="demo-list">
        <li>
          <a href="/demo/scanned-graphics/" class="demo-card">
            <strong>Scanned Graphics</strong>
            <span>Arrows, frames, and halftone textures extracted from the AI file.</span>
          </a>
        </li>
        <li>
          <a href="/demo/chimera-expanded/" class="demo-card">
            <strong>Chimera Expanded Shapes</strong>
            <span>4 decorative shape SVGs from the Chimera Expanded set.</span>
          </a>
        </li>
        <li>
          <a href="/demo/chimera-expanded-2026/" class="demo-card">
            <strong>Chimera Expanded Shapes (2026)</strong>
            <span>104 unique shapes deduplicated from 236 mass-exported SVGs.</span>
          </a>
        </li>
        <li>
          <a href="/demo/logos/" class="demo-card">
            <strong>CCA Logos</strong>
            <span>Lettermarks, lockups, and the institutional seal.</span>
          </a>
        </li>
        <li>
          <a href="/demo/brand-colors/" class="demo-card">
            <strong>Brand Colors</strong>
            <span>Full palette, semantic tokens, shimmer, celebration aliases, and gradients.</span>
          </a>
        </li>
        <li>
          <a href="/demo/graduation-exhibitions/" class="demo-card">
            <strong>Graduation Exhibitions Logo</strong>
            <span>22 logo variants across the brand color palette.</span>
          </a>
        </li>
        <li>
          <a href="/demo/commencement/" class="demo-card">
            <strong>Commencement Logo</strong>
            <span>23 primary and secondary logo variants across the brand palette.</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="demo-section">
      <h2 class="section-heading">Techniques</h2>
      <ul class="demo-list">
        <li>
          <a href="/demo/framed-images/" class="demo-card">
            <strong>Framed Images</strong>
            <span>Scanned SVG frames as decorative borders around photographs.</span>
          </a>
        </li>
        <li>
          <a href="/demo/chimera-image-mask/" class="demo-card">
            <strong>Chimera Image Masks</strong>
            <span>Chimera expanded shapes as CSS mask-image over photographs.</span>
          </a>
        </li>
        <li>
          <a href="/demo/chimera-image-mask-2026/" class="demo-card">
            <strong>Chimera Image Masks (2026)</strong>
            <span>104 unique Chimera Expanded 2026 shapes as CSS mask-image over photographs.</span>
          </a>
        </li>
        <li>
          <a href="/demo/chimera-mask-editor/" class="demo-card">
            <strong>Chimera Mask Editor</strong>
            <span>Interactive editor — pick a shape, choose or upload an image, pan &amp; zoom, then export as PNG.</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="demo-section">
      <h2 class="section-heading">Graphic Animation Loops</h2>
      <ul class="demo-list">
        <li>
          <a href="/demo/arrow-loop/" class="demo-card">
            <strong>Arrow Loop — Displacement</strong>
            <span>Wavy arrows materialize from SVG turbulence noise, hold, then dissolve away.</span>
          </a>
        </li>
        <li>
          <a href="/demo/arrow-loop-crossfade/" class="demo-card">
            <strong>Arrow Loop — Crossfade</strong>
            <span>Arrows cycle with soft opacity crossfades and gentle scale shifts.</span>
          </a>
        </li>
        <li>
          <a href="/demo/arrow-loop-transform/" class="demo-card">
            <strong>Arrow Loop — Slingshot</strong>
            <span>Arrows coil back with squash-and-stretch vibration, then slingshot off screen with directional motion blur.</span>
          </a>
        </li>
        <li>
          <a href="/demo/chimera-loop/" class="demo-card">
            <strong>Chimera Loop</strong>
            <span>Chimera letterforms morph with elastic scale, skew, and dramatic drift.</span>
          </a>
        </li>
        <li>
          <a href="/demo/frame-loop/" class="demo-card">
            <strong>Frame Loop</strong>
            <span>Scanned decorative frames cycle with rotation and color tinting.</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="demo-section">
      <h2 class="section-heading">Halftone Effects</h2>
      <ul class="demo-list">
        <li>
          <a href="/demo/halftone-mask/" class="demo-card">
            <strong>Halftone: Color Shift Mask</strong>
            <span>CSS mask-image over animated gradient — dots as windows into shifting colors.</span>
          </a>
        </li>
        <li>
          <a href="/demo/halftone-moire/" class="demo-card">
            <strong>Halftone: Moiré Drift</strong>
            <span>Stacked halftone layers with CSS transforms creating interference patterns.</span>
          </a>
        </li>
        <li>
          <a href="/demo/halftone-displacement/" class="demo-card">
            <strong>Halftone: Liquid Displacement</strong>
            <span>SVG turbulence + displacement filter for organic wavy distortion.</span>
          </a>
        </li>
        <li>
          <a href="/demo/halftone-scroll/" class="demo-card">
            <strong>Halftone: Scroll Displacement</strong>
            <span>Displacement intensity tied to scroll position — warps more as you scroll.</span>
          </a>
        </li>
        <li>
          <a href="/demo/halftone-scanner/" class="demo-card">
            <strong>Halftone: Scanner Distortion</strong>
            <span>Canvas programmatic dot grid with per-scanline displacement — flatbed scanner effect.</span>
          </a>
        </li>
        <li>
          <a href="/demo/halftone-canvas-procedural/" class="demo-card">
            <strong>Halftone: Procedural Scan</strong>
            <span>Canvas staggered dot grid with per-dot spring displacement from animated scanner heads — mobile-optimized, no SVG assets.</span>
          </a>
        </li>
        <li>
          <a href="/demo/halftone-css-scan/" class="demo-card">
            <strong>Halftone: CSS Pulse</strong>
            <span>Pure CSS radial-gradient dot grid with keyframe scan sweep and moiré shimmer — zero JS animation, near-zero GPU cost.</span>
          </a>
        </li>
        <li>
          <a href="/demo/arrow-wave-displacement/" class="demo-card">
            <strong>Arrow Grid: Wave Displacement</strong>
            <span>Tiled arrow SVGs distorted by animated SVG turbulence — liquid wave washing across the pattern.</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="demo-section">
      <h2 class="section-heading">Particle Effects</h2>
      <ul class="demo-list">
        <li>
          <a href="/demo/particle-field/" class="demo-card">
            <strong>Particle Field</strong>
            <span>Canvas-based geometric particle system with scroll-reactive wind gusts.</span>
          </a>
        </li>
        <li>
          <a href="/demo/particle-field-chimera/" class="demo-card">
            <strong>Particle Field — Chimera</strong>
            <span>Chimera Expanded letterform shapes as floating SVG path particles.</span>
          </a>
        </li>
        <li>
          <a href="/demo/particle-field-arrows/" class="demo-card">
            <strong>Particle Field — Wavy Arrows</strong>
            <span>Scanned arrow SVGs as color-tinted floating canvas particles.</span>
          </a>
        </li>
        <li>
          <a href="/demo/particle-field-chimera-2026/" class="demo-card">
            <strong>Particle Field — Chimera 2026</strong>
            <span>104 unique Chimera Expanded 2026 shapes as floating SVG path particles.</span>
          </a>
        </li>
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .demo-index {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-12) var(--space-4);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: var(--space-8);
  }

  .demo-section + .demo-section {
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-muted);
    margin-bottom: var(--space-4);
  }

  .demo-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }

  .demo-card {
    display: block;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--duration-fast) ease;
  }

  .demo-card:hover {
    border-color: var(--color-accent);
  }

  .demo-card strong {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .demo-card span {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }
</style>
