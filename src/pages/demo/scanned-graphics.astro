---
import BaseLayout from "../../layouts/BaseLayout.astro";

const arrows = [
  "arrow-02", "arrow-03", "arrow-04", "arrow-05", "arrow-06", "arrow-07",
  "arrow-08", "arrow-09", "arrow-10", "arrow-11", "arrow-12", "arrow-13",
];

const frames = [
  "frame-01", "frame-02", "frame-03", "frame-04", "frame-05", "frame-06",
  "frame-07", "frame-08", "frame-09", "frame-10", "frame-11", "frame-12",
  "frame-13", "frame-14", "frame-15", "frame-16", "frame-17", "frame-18",
  "frame-19", "frame-20", "frame-21", "frame-22", "frame-23",
];

const halftones = [
  "halftone-1x1-01", "halftone-1x1-02", "halftone-1x1-03", "halftone-1x1-04", "halftone-1x1-05",
  "halftone-16x9-01", "halftone-16x9-02", "halftone-16x9-03", "halftone-16x9-04",
  "halftone-full-01", "halftone-full-02", "halftone-full-03", "halftone-full-04",
];
---

<BaseLayout title="Scanned Graphics" minimalHeader={true}>
  <main class="demo-scanned">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1>Scanned Graphics</h1>
    <p class="subtitle">48 SVGs extracted from the AI file — arrows, frames, and halftone textures.</p>

    <section>
      <h2>Arrows <span class="count">({arrows.length})</span></h2>
      <div class="grid">
        {arrows.map((name) => (
          <figure class="card">
            <img src={`/images/scanned-graphics/arrows/${name}.svg`} alt={name} loading="lazy" />
            <figcaption>{name}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section>
      <h2>Frames <span class="count">({frames.length})</span></h2>
      <div class="grid grid--frames">
        {frames.map((name) => (
          <figure class="card">
            <img src={`/images/scanned-graphics/frames/${name}.svg`} alt={name} loading="lazy" />
            <figcaption>{name}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section>
      <h2>Halftones <span class="count">({halftones.length})</span></h2>
      <div class="grid grid--frames">
        {halftones.map((name) => (
          <figure class="card">
            <img src={`/images/scanned-graphics/halftones/${name}.svg`} alt={name} loading="lazy" />
            <figcaption>{name}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .demo-scanned {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: var(--space-10);
  }

  section {
    margin-bottom: var(--space-12);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .count {
    color: var(--color-muted);
    font-weight: 400;
  }

  .section-note {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  /* Shared grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: var(--space-4);
  }

  .grid--frames {
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
  }

  /* Card */
  .card {
    margin: 0;
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
  }

  .card img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 12rem;
    object-fit: contain;
    margin-bottom: var(--space-2);
  }

  .card figcaption {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

</style>
