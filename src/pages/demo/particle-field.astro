---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
import ParticleFieldCanvas from "../../components/effects/ParticleField.astro";
---

<DemoEffectLayout title="Particle Field Demo">
  <ParticleFieldCanvas mode="geometric" />

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Particle Field</h1>
    <p class="demo-technique">Canvas-based geometric particle system</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Geometric shapes (rect, circle, triangle) float upward with gentle rotation and sine-wave drift.
      Scroll to trigger wind gusts.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="particle-count">Particle Count: <output id="particle-count-val">70</output></label>
        <input type="range" id="particle-count" min="10" max="300" value="70" step="10" />
      </div>
      <div class="control-group">
        <label for="size-min">Min Size: <output id="size-min-val">3</output></label>
        <input type="range" id="size-min" min="1" max="20" value="3" step="1" />
      </div>
      <div class="control-group">
        <label for="size-max">Max Size: <output id="size-max-val">8</output></label>
        <input type="range" id="size-max" min="2" max="40" value="8" step="1" />
      </div>
      <div class="control-group">
        <label for="opacity-min">Min Opacity: <output id="opacity-min-val">0.3</output></label>
        <input type="range" id="opacity-min" min="0.05" max="1" value="0.3" step="0.05" />
      </div>
      <div class="control-group">
        <label for="opacity-max">Max Opacity: <output id="opacity-max-val">0.8</output></label>
        <input type="range" id="opacity-max" min="0.1" max="1" value="0.8" step="0.05" />
      </div>
      <div class="control-group">
        <label for="speed-mult">Speed: <output id="speed-mult-val">1×</output></label>
        <input type="range" id="speed-mult" min="0.1" max="3" value="1" step="0.1" />
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  /* Overlay info */
  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  /* Sidebar toggle */
  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] {
    display: none;
  }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open {
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar {
      transition: none;
    }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }
</style>

<script>
  // Sidebar toggle
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  // Controls — update data attributes on the canvas and signal the running animation loop
  const canvas = document.querySelector<HTMLCanvasElement>('.particle-field')!;

  function updateField() {
    const countInput = document.getElementById('particle-count') as HTMLInputElement;
    const sizeMinInput = document.getElementById('size-min') as HTMLInputElement;
    const sizeMaxInput = document.getElementById('size-max') as HTMLInputElement;
    const opacityMinInput = document.getElementById('opacity-min') as HTMLInputElement;
    const opacityMaxInput = document.getElementById('opacity-max') as HTMLInputElement;
    const speedMultInput = document.getElementById('speed-mult') as HTMLInputElement;

    canvas.dataset.count = countInput.value;
    canvas.dataset.sizeRange = JSON.stringify([
      parseFloat(sizeMinInput.value),
      parseFloat(sizeMaxInput.value),
    ]);
    canvas.dataset.opacityRange = JSON.stringify([
      parseFloat(opacityMinInput.value),
      parseFloat(opacityMaxInput.value),
    ]);
    canvas.dataset.speedMult = speedMultInput.value;

    canvas.dispatchEvent(new Event('particle-field:update'));
  }

  // Wire up output displays
  const controls = [
    { id: 'particle-count', valId: 'particle-count-val', suffix: '' },
    { id: 'size-min', valId: 'size-min-val', suffix: '' },
    { id: 'size-max', valId: 'size-max-val', suffix: '' },
    { id: 'opacity-min', valId: 'opacity-min-val', suffix: '' },
    { id: 'opacity-max', valId: 'opacity-max-val', suffix: '' },
    { id: 'speed-mult', valId: 'speed-mult-val', suffix: '×' },
  ];

  let debounceTimer: ReturnType<typeof setTimeout>;

  for (const ctrl of controls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      output.textContent = input.value + ctrl.suffix;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(updateField, 300);
    });
  }
</script>
