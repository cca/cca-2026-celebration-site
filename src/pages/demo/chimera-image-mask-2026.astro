---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const ccaGlob = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/cca-photography/*.{jpg,jpeg,png}',
  { eager: true }
);
const ccaPhotoSrcs = await Promise.all(
  Object.values(ccaGlob).map(async (mod) => {
    const optimized = await getImage({ src: mod.default, format: 'webp', quality: 80 });
    return optimized.src;
  })
);
const shapeCount = 104;
const shapes = Array.from({ length: shapeCount }, (_, i) => {
  const num = String(i + 1).padStart(3, "0");
  return { id: `shape-${num}`, file: `shape-${num}.svg` };
});

const seeds = [
  "alpine", "coast", "garden", "studio", "mural", "gallery",
  "terrace", "canyon", "harbor", "meadow", "summit", "plaza",
];
---

<BaseLayout title="Chimera Image Masks (2026)" minimalHeader={true}>
  <main class="demo-masks">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1>Chimera Image Masks (2026)</h1>
    <p class="subtitle">104 unique Chimera Expanded 2026 shapes as CSS mask-image over photographs.</p>

    <div class="controls">
      <label class="control">
        <span>Background</span>
        <input type="color" id="bg-color" value="#ffffff" />
      </label>
      <label class="control">
        <span>Mask size</span>
        <select id="mask-size">
          <option value="contain">contain</option>
          <option value="cover">cover</option>
          <option value="150% 150%">150%</option>
          <option value="200% 200%">200%</option>
        </select>
      </label>
      <label class="control">
        <span>Image set</span>
        <select id="image-set">
          <option value="photos">Placeholder photos</option>
          <option value="cca">CCA Photography</option>
          <option value="gradient">Gradient fill</option>
          <option value="solid">Solid color</option>
        </select>
      </label>
      <label class="control control-columns">
        <span>Columns: <output id="columns-val">6</output></span>
        <input type="range" id="columns" min="1" max="12" value="6" step="1" />
      </label>
    </div>

    <div class="grid" data-cca-photos={JSON.stringify(ccaPhotoSrcs)}>
      {shapes.map((shape, i) => {
        const seed = seeds[i % seeds.length];
        return (
          <figure class="card">
            <a href={`/demo/chimera-mask-editor/?shape=${i + 1}`} class="card-link" title="Open in editor">
              <div
                class="masked-image"
                data-seed={seed}
                data-index={i}
                style={`
                  background-image: url(https://picsum.photos/seed/chimera2026-${seed}-${i}/600/600);
                  mask-image: url(/images/chimera-expanded-2026/${shape.file});
                  -webkit-mask-image: url(/images/chimera-expanded-2026/${shape.file});
                `}
              />
            </a>
            <figcaption>
              <a href={`/demo/chimera-mask-editor/?shape=${i + 1}`}>{shape.id}</a>
            </figcaption>
          </figure>
        );
      })}
    </div>
  </main>
</BaseLayout>

<script>
  const columnsInput = document.getElementById("columns") as HTMLInputElement;
  const columnsVal = document.getElementById("columns-val") as HTMLOutputElement;
  const grid = document.querySelector<HTMLDivElement>(".grid")!;

  columnsInput.addEventListener("input", () => {
    const cols = columnsInput.value;
    columnsVal.textContent = cols;
    grid.style.setProperty("--grid-columns", cols);
  });

  const bgColorInput = document.getElementById("bg-color") as HTMLInputElement;
  const maskSizeSelect = document.getElementById("mask-size") as HTMLSelectElement;
  const imageSetSelect = document.getElementById("image-set") as HTMLSelectElement;
  const maskedImages = document.querySelectorAll<HTMLDivElement>(".masked-image");

  const originalUrls = Array.from(maskedImages).map(
    (el) => el.style.backgroundImage
  );

  bgColorInput.addEventListener("input", () => {
    maskedImages.forEach((el) => {
      el.style.backgroundColor = bgColorInput.value;
    });
    document.querySelectorAll<HTMLElement>(".card").forEach((card) => {
      card.style.backgroundColor = bgColorInput.value;
    });
  });

  maskSizeSelect.addEventListener("change", () => {
    const val = maskSizeSelect.value;
    maskedImages.forEach((el) => {
      el.style.maskSize = val;
      el.style.setProperty("-webkit-mask-size", val);
    });
  });

  const ccaPhotos: string[] = JSON.parse(grid.dataset.ccaPhotos || '[]');

  imageSetSelect.addEventListener("change", () => {
    const set = imageSetSelect.value;
    maskedImages.forEach((el, i) => {
      const idx = parseInt(el.dataset.index || "0", 10);
      switch (set) {
        case "photos":
          el.style.backgroundImage = originalUrls[i];
          break;
        case "cca": {
          const photo = ccaPhotos[idx % ccaPhotos.length];
          el.style.backgroundImage = `url(${photo})`;
          break;
        }
        case "gradient": {
          const hue = (idx * 29) % 360;
          el.style.backgroundImage = `linear-gradient(135deg, hsl(${hue}, 80%, 60%), hsl(${(hue + 120) % 360}, 80%, 40%))`;
          break;
        }
        case "solid": {
          const hue = (idx * 29) % 360;
          el.style.backgroundImage = `linear-gradient(0deg, hsl(${hue}, 70%, 50%), hsl(${hue}, 70%, 50%))`;
          break;
        }
      }
    });
  });
</script>

<style>
  .demo-masks {
    max-width: 90rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .back-link {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .back-link:hover { color: var(--color-accent); }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .controls {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .control {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .control input[type="color"] {
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    cursor: pointer;
    padding: 0;
    background: none;
  }

  .control select {
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns, 6), 1fr);
    gap: var(--space-4);
  }

  .card {
    margin: 0;
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
  }

  .masked-image {
    aspect-ratio: 1;
    background-size: cover;
    background-position: center;
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-position: center;
    margin-bottom: var(--space-2);
  }

  .card-link {
    display: block;
    text-decoration: none;
    border-radius: 0.25rem;
    transition: outline 0.15s ease;
  }

  .card-link:hover {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .card figcaption {
    font-size: var(--text-xs);
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .card figcaption a {
    color: inherit;
    text-decoration: none;
  }

  .card figcaption a:hover {
    color: var(--color-accent);
  }

  .control-columns {
    min-width: 10rem;
  }

  .control-columns input[type="range"] {
    width: 7rem;
    cursor: pointer;
  }

  .control-columns output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }
</style>
