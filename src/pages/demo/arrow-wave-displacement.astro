---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
---

<DemoEffectLayout title="Arrow Wave Displacement Demo">
  <div class="arrow-bg" id="arrow-bg" aria-hidden="true">
    <svg id="arrow-grid" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <defs>
        <filter id="arrow-warp" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
          <feTurbulence
            id="turbulence"
            type="fractalNoise"
            baseFrequency="0.0036 0.00252"
            numOctaves="2"
            seed="5"
            result="rawNoise"
          >
            <animate
              id="freq-anim"
              attributeName="baseFrequency"
              values="0.0036 0.00252;0.0084 0.00588;0.0036 0.00252"
              dur="5s"
              repeatCount="indefinite"
              calcMode="spline"
              keySplines="0.45 0 0.55 1;0.45 0 0.55 1"
            />
          </feTurbulence>
          <!-- Pre-blur the noise field to smooth out displacement vectors -->
          <feGaussianBlur id="noise-blur" in="rawNoise" stdDeviation="3" result="noise"/>
          <feDisplacementMap
            id="displacement"
            in="SourceGraphic"
            in2="noise"
            scale="30"
            xChannelSelector="R"
            yChannelSelector="G"
          />
        </filter>
        <symbol id="arrow" viewBox="0 0 54 30">
          <path d="M46.7232 13.1647L46.7232 16.8721L-5.7384e-07 16.8721L-7.35894e-07 13.1647L46.7232 13.1647ZM39.2093 27.3791L41.7907 30L54 17.6008L51.4185 14.9799L39.2093 27.3791ZM41.7907 -1.82673e-06L39.2093 2.6209L51.4218 15.0167L54 12.3992L41.7907 -1.82673e-06Z" fill="currentColor"/>
        </symbol>
        <!-- Initial width/height values are for arrowSize=48, gap=24; JS updates these -->
        <pattern id="arrow-pattern" x="0" y="0" width="72" height="50.6667" patternUnits="userSpaceOnUse">
          <use href="#arrow" x="0" y="0" width="48" height="26.6667"/>
        </pattern>
      </defs>
      <!-- Bleeds 10% past viewport edges so displacement doesn't expose white edges -->
      <rect
        id="arrow-rect"
        x="-10%"
        y="-10%"
        width="120%"
        height="120%"
        fill="url(#arrow-pattern)"
        filter="url(#arrow-warp)"
      />
    </svg>
  </div>

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Arrow Wave</h1>
    <p class="demo-technique">SVG grid + feTurbulence feDisplacementMap</p>
  </div>

  <div class="perf-counter" id="perf-counter" aria-live="off" aria-hidden="true">
    <span id="fps-val">--</span> <span class="perf-label">fps</span>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      A grid of right-arrow SVGs displaced by an animated turbulence field, creating a liquid wave effect across the pattern.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="disp-scale">Displacement Scale: <output id="disp-scale-val">30</output></label>
        <input type="range" id="disp-scale" min="0" max="200" value="30" step="1" />
      </div>
      <div class="control-group">
        <label for="disp-freq">Frequency: <output id="disp-freq-val">0.006</output></label>
        <input type="range" id="disp-freq" min="0.001" max="0.03" value="0.006" step="0.001" />
      </div>
      <div class="control-group">
        <label for="disp-speed">Speed: <output id="disp-speed-val">0.002</output></label>
        <input type="range" id="disp-speed" min="0" max="0.01" value="0.002" step="0.0005" />
      </div>
      <div class="control-group">
        <label for="arrow-size">Arrow Size: <output id="arrow-size-val">48</output>px</label>
        <input type="range" id="arrow-size" min="16" max="120" value="48" step="4" />
      </div>
      <div class="control-group">
        <label for="arrow-gap">Gap: <output id="arrow-gap-val">24</output>px</label>
        <input type="range" id="arrow-gap" min="4" max="80" value="24" step="2" />
      </div>
      <div class="control-group">
        <label for="disp-opacity">Opacity: <output id="disp-opacity-val">1</output></label>
        <input type="range" id="disp-opacity" min="0.05" max="1" value="1" step="0.01" />
      </div>
      <div class="control-group">
        <label>Arrow Color</label>
        <div class="swatch-picker" id="color-swatches">
          <button class="swatch active" data-color="#231f20" style="background:#231f20" title="Black"></button>
          <button class="swatch" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch" data-color="#E57200" style="background:#E57200" title="Orange"></button>
          <button class="swatch" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch" data-color="#B7BF10" style="background:#B7BF10" title="Lime"></button>
          <button class="swatch" data-color="#F1BDC8" style="background:#F1BDC8" title="Pink"></button>
          <button class="swatch" data-color="#005776" style="background:#005776" title="Navy"></button>
          <button class="swatch swatch--custom" title="Custom">
            <span>+</span>
            <input type="color" value="#231f20" tabindex="-1" />
          </button>
        </div>
      </div>
      <div class="control-group">
        <label>Background</label>
        <div class="swatch-picker" id="bg-swatches">
          <button class="swatch active" data-color="#ffffff" style="background:#ffffff;border:1px solid #ddd" title="White"></button>
          <button class="swatch" data-color="#231f20" style="background:#231f20" title="Black"></button>
          <button class="swatch" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch swatch--custom" title="Custom">
            <span>+</span>
            <input type="color" value="#ffffff" tabindex="-1" />
          </button>
        </div>
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  .arrow-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: #ffffff;
    transition: background 0.3s ease;
  }

  #arrow-grid {
    display: block;
    width: 100%;
    height: 100%;
    will-change: contents;
  }

  #arrow-rect {
    color: #231f20;
    transition: color 0.3s ease;
  }

  /* Overlay info */
  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  /* Sidebar toggle */
  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] {
    display: none;
  }

  /* Sidebar */
  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open {
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar { transition: none; }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-muted);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }

  .swatch-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .swatch {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    position: relative;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .swatch:hover {
    transform: scale(1.15);
  }

  .swatch.active {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
  }

  .swatch--custom {
    background: conic-gradient(from 0deg, #f00, #ff0, #0f0, #0ff, #00f, #f0f, #f00) !important;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .swatch--custom span {
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    pointer-events: none;
  }

  .swatch--custom input[type="color"] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    padding: 0;
    border: none;
  }

  .perf-counter {
    position: fixed;
    bottom: var(--space-4);
    left: var(--space-4);
    z-index: 10;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
    pointer-events: none;
    line-height: 1.4;
  }

  #fps-val {
    color: var(--color-accent);
    font-weight: 600;
    min-width: 2.5ch;
    display: inline-block;
  }

  .perf-label {
    color: var(--color-muted);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (prefers-reduced-motion: reduce) {
    .perf-counter { display: none; }
  }
</style>

<script>
  // Sidebar
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });
  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  // Grid layout — 3 attribute updates instead of 672 DOM nodes
  const arrowPattern = document.getElementById('arrow-pattern') as SVGPatternElement;
  const arrowUse = arrowPattern.querySelector('use') as SVGUseElement;
  const arrowRect = document.getElementById('arrow-rect') as SVGRectElement;
  const arrowBg = document.getElementById('arrow-bg') as HTMLElement;

  const ARROW_ASPECT = 54 / 30;
  let arrowSize = 48;
  let gap = 24;

  function setGridLayout() {
    const arrowH = arrowSize / ARROW_ASPECT;
    arrowPattern.setAttribute('width', String(arrowSize + gap));
    arrowPattern.setAttribute('height', (arrowH + gap).toFixed(4));
    arrowUse.setAttribute('width', String(arrowSize));
    arrowUse.setAttribute('height', arrowH.toFixed(4));
  }
  setGridLayout();

  // SMIL-driven animation
  const freqAnim = document.getElementById('freq-anim') as SVGAnimateElement;
  const turbulence = document.getElementById('turbulence') as SVGFETurbulenceElement;
  const displacement = document.getElementById('displacement') as SVGFEDisplacementMapElement;

  let baseFreq = 0.006;
  let speed = 0.002;
  let scale = 30;

  function computeFreqValues(freq: number): string {
    const lo = freq * 0.6, hi = freq * 1.4;
    return `${lo.toFixed(5)} ${(lo * 0.7).toFixed(5)};${hi.toFixed(5)} ${(hi * 0.7).toFixed(5)};${lo.toFixed(5)} ${(lo * 0.7).toFixed(5)}`;
  }

  function computeDur(spd: number): string {
    return spd > 0 ? `${(0.6 / spd).toFixed(2)}s` : '999999s';
  }

  function updateSMIL() {
    freqAnim.setAttribute('values', computeFreqValues(baseFreq));
    freqAnim.setAttribute('dur', computeDur(speed));
  }

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  function pauseAnimation() {
    freqAnim.setAttribute('begin', 'indefinite');
    turbulence.setAttribute('baseFrequency', `${baseFreq.toFixed(5)} ${(baseFreq * 0.7).toFixed(5)}`);
  }

  function resumeAnimation() {
    freqAnim.removeAttribute('begin');
    updateSMIL();
  }

  prefersReducedMotion.addEventListener('change', () => {
    prefersReducedMotion.matches ? pauseAnimation() : resumeAnimation();
  });

  if (prefersReducedMotion.matches) pauseAnimation();
  else updateSMIL();

  // Controls
  const scaleInput = document.getElementById('disp-scale') as HTMLInputElement;
  const scaleVal = document.getElementById('disp-scale-val') as HTMLOutputElement;

  // Mobile: reduce complexity for smaller/lower-power devices
  const isMobile = window.matchMedia('(max-width: 768px)');
  function applyMobileSettings() {
    if (isMobile.matches) {
      turbulence.setAttribute('numOctaves', '1');
      if (scale > 20) {
        scale = 20;
        displacement.setAttribute('scale', '20');
        scaleInput.value = '20';
        scaleVal.textContent = '20';
      }
    } else {
      turbulence.setAttribute('numOctaves', '2');
    }
  }
  isMobile.addEventListener('change', applyMobileSettings);
  applyMobileSettings();
  scaleInput.addEventListener('input', () => {
    scale = parseInt(scaleInput.value);
    scaleVal.textContent = String(scale);
    displacement.setAttribute('scale', String(scale));
  });

  const freqInput = document.getElementById('disp-freq') as HTMLInputElement;
  const freqVal = document.getElementById('disp-freq-val') as HTMLOutputElement;
  freqInput.addEventListener('input', () => {
    baseFreq = parseFloat(freqInput.value);
    freqVal.textContent = String(baseFreq);
    if (prefersReducedMotion.matches) {
      turbulence.setAttribute('baseFrequency', `${baseFreq.toFixed(5)} ${(baseFreq * 0.7).toFixed(5)}`);
    } else {
      freqAnim.setAttribute('values', computeFreqValues(baseFreq));
    }
  });

  const speedInput = document.getElementById('disp-speed') as HTMLInputElement;
  const speedVal = document.getElementById('disp-speed-val') as HTMLOutputElement;
  speedInput.addEventListener('input', () => {
    speed = parseFloat(speedInput.value);
    speedVal.textContent = String(speed);
    if (!prefersReducedMotion.matches) freqAnim.setAttribute('dur', computeDur(speed));
  });

  const sizeInput = document.getElementById('arrow-size') as HTMLInputElement;
  const sizeVal = document.getElementById('arrow-size-val') as HTMLOutputElement;
  sizeInput.addEventListener('input', () => {
    arrowSize = parseInt(sizeInput.value);
    sizeVal.textContent = String(arrowSize);
    setGridLayout();
  });

  const gapInput = document.getElementById('arrow-gap') as HTMLInputElement;
  const gapVal = document.getElementById('arrow-gap-val') as HTMLOutputElement;
  gapInput.addEventListener('input', () => {
    gap = parseInt(gapInput.value);
    gapVal.textContent = String(gap);
    setGridLayout();
  });

  const opacityInput = document.getElementById('disp-opacity') as HTMLInputElement;
  const opacityVal = document.getElementById('disp-opacity-val') as HTMLOutputElement;
  opacityInput.addEventListener('input', () => {
    const v = parseFloat(opacityInput.value);
    opacityVal.textContent = String(v);
    arrowRect.style.opacity = String(v);
  });

  // Arrow color swatches
  const colorPicker = document.getElementById('color-swatches')!;

  const arrowPath = document.querySelector('#arrow path') as SVGPathElement;

  function setArrowColor(color: string) {
    arrowPath.setAttribute('fill', color);
  }

  colorPicker.querySelectorAll('.swatch:not(.swatch--custom)').forEach(swatch => {
    swatch.addEventListener('click', () => {
      colorPicker.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
      swatch.classList.add('active');
      setArrowColor((swatch as HTMLElement).dataset.color!);
    });
  });

  const colorCustomBtn = colorPicker.querySelector('.swatch--custom') as HTMLElement;
  const colorCustomInput = colorCustomBtn.querySelector('input[type="color"]') as HTMLInputElement;
  colorCustomInput.addEventListener('input', () => {
    colorPicker.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
    colorCustomBtn.classList.add('active');
    colorCustomBtn.style.background = colorCustomInput.value;
    setArrowColor(colorCustomInput.value);
  });

  // Background color swatches
  const bgPicker = document.getElementById('bg-swatches')!;

  function setBgColor(color: string) {
    arrowBg.style.background = color;
  }

  bgPicker.querySelectorAll('.swatch:not(.swatch--custom)').forEach(swatch => {
    swatch.addEventListener('click', () => {
      bgPicker.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
      swatch.classList.add('active');
      setBgColor((swatch as HTMLElement).dataset.color!);
    });
  });

  const bgCustomBtn = bgPicker.querySelector('.swatch--custom') as HTMLElement;
  const bgCustomInput = bgCustomBtn.querySelector('input[type="color"]') as HTMLInputElement;
  bgCustomInput.addEventListener('input', () => {
    bgPicker.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
    bgCustomBtn.classList.add('active');
    bgCustomBtn.style.background = bgCustomInput.value;
    setBgColor(bgCustomInput.value);
  });

  // FPS counter — lightweight rolling average over 30 frames
  const fpsVal = document.getElementById('fps-val')!;
  const frameTimes: number[] = [];
  let lastTs = 0;

  function tickFps(ts: number) {
    if (lastTs > 0) {
      frameTimes.push(ts - lastTs);
      if (frameTimes.length > 30) frameTimes.shift();
      const avg = frameTimes.reduce((a, b) => a + b, 0) / frameTimes.length;
      fpsVal.textContent = String(Math.round(1000 / avg));
    }
    lastTs = ts;
    requestAnimationFrame(tickFps);
  }
  requestAnimationFrame(tickFps);
</script>
