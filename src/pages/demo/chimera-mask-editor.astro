---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ccaPhotography, photoCollections } from "../../data/cca-photography";

// Build src → space-separated collection IDs map
const photoCollectionAttr = new Map<string, string>();
for (const { id, photos } of photoCollections) {
  for (const p of photos) {
    const existing = photoCollectionAttr.get(p.src);
    photoCollectionAttr.set(p.src, existing ? `${existing} ${id}` : id);
  }
}
const getCollAttr = (src: string) => photoCollectionAttr.get(src) ?? 'cca';

// Deduplicated master list of all photos across all collections
const seenSrcs = new Set<string>();
const allPhotos = photoCollections.flatMap(c => c.photos).filter(p => {
  if (seenSrcs.has(p.src)) return false;
  seenSrcs.add(p.src);
  return true;
});

const shapeCount = 104;
const shapes = Array.from({ length: shapeCount }, (_, i) => {
  const num = String(i + 1).padStart(3, "0");
  return { id: `shape-${num}`, file: `shape-${num}.svg`, src: `/images/chimera-expanded-2026/shape-${num}.svg` };
});
---

<BaseLayout title="Chimera Mask Editor" minimalHeader={true}>
  <main class="editor">
    <div class="editor-header">
      <a href="/demo/chimera-image-mask-2026/" class="back-link">&larr; Back to Grid</a>
      <h1>Chimera Mask Editor</h1>
    </div>

    <div class="editor-layout">
      <!-- Left: Canvas viewport -->
      <div class="viewport-wrap">
        <div class="viewport" id="viewport">
          <canvas id="canvas" width="800" height="800"></canvas>
          <div class="viewport-hint" id="viewport-hint">Drag to pan &middot; Scroll to zoom</div>
        </div>
        <div class="viewport-toolbar">
          <button id="btn-reset" class="toolbar-btn" title="Reset pan & zoom">Reset View</button>
          <span class="toolbar-sep"></span>
          <label class="toolbar-label">
            Zoom: <output id="zoom-val">100%</output>
          </label>
          <input type="range" id="zoom-slider" min="10" max="500" value="100" step="5" class="toolbar-slider" />
          <span class="toolbar-sep"></span>
          <label class="toolbar-label">
            Export size
            <select id="export-size">
              <option value="800">800px</option>
              <option value="1200">1200px</option>
              <option value="1600" selected>1600px</option>
              <option value="2400">2400px</option>
              <option value="3200">3200px</option>
            </select>
          </label>
          <button id="btn-download" class="toolbar-btn toolbar-btn-primary" title="Download as PNG">Download PNG</button>
        </div>
      </div>

      <!-- Right: Controls panel -->
      <aside class="panel">
        <!-- Shape picker -->
        <section class="panel-section">
          <h2>Shape</h2>
          <div class="shape-grid" id="shape-grid">
            {shapes.map((shape, i) => (
              <button
                class={`shape-thumb${i === 0 ? ' active' : ''}`}
                data-shape-index={i}
                data-shape-src={shape.src}
                title={shape.id}
              >
                <img src={shape.src} alt={shape.id} loading="lazy" />
              </button>
            ))}
          </div>
        </section>

        <!-- Image source -->
        <section class="panel-section">
          <h2>Image</h2>

          <div class="image-source-tabs">
            <button class="tab active" data-tab="collection">Collection</button>
            <button class="tab" data-tab="upload">Upload</button>
          </div>

          <div class="tab-content active" id="tab-collection">
            <label class="field">
              <span>Collection</span>
              <select id="collection-select">
                <option value="all">All Photos</option>
                {photoCollections.map(c => (
                  <option value={c.id}>{c.label}</option>
                ))}
              </select>
            </label>
            <label class="field">
              <span>Image</span>
              <select id="image-select">
                {allPhotos.map((photo, i) => (
                  <option value={photo.src} data-collection={getCollAttr(photo.src)} selected={i === 0}>{photo.alt}</option>
                ))}
              </select>
            </label>
            <div class="image-preview-grid" id="image-preview-grid">
              {allPhotos.map((photo, i) => (
                <button
                  class={`image-thumb${i === 0 ? ' active' : ''}`}
                  data-src={photo.src}
                  data-collection={getCollAttr(photo.src)}

                  title={photo.alt}
                >
                  <img src={photo.src} alt={photo.alt} loading="lazy" />
                </button>
              ))}
            </div>
          </div>

          <div class="tab-content" id="tab-upload">
            <div class="drop-zone" id="drop-zone">
              <p>Drag &amp; drop an image here</p>
              <p class="drop-zone-or">or</p>
              <button class="toolbar-btn" id="btn-browse">Browse files</button>
              <input type="file" id="file-input" accept="image/*" hidden />
            </div>
          </div>
        </section>

        <!-- Background color -->
        <section class="panel-section">
          <h2>Background</h2>
          <div class="bg-swatches" id="bg-swatches">
            <button class="swatch active" data-color="#ffffff" title="White" style="background:#ffffff;"></button>
            <button class="swatch" data-color="#FDFAF5" title="Sand Light" style="background:#FDFAF5;"></button>
            <button class="swatch" data-color="#F7F3E9" title="Sand" style="background:#F7F3E9;"></button>
            <button class="swatch" data-color="#1a1a1a" title="Black" style="background:#1a1a1a;"></button>
            <button class="swatch" data-color="#00BFB3" title="Teal" style="background:#00BFB3;"></button>
            <button class="swatch" data-color="#002f40" title="Dark Teal" style="background:#002f40;"></button>
            <button class="swatch" data-color="#005776" title="Navy" style="background:#005776;"></button>
            <button class="swatch" data-color="#563D82" title="Purple" style="background:#563D82;"></button>
            <button class="swatch" data-color="#FFC845" title="Yellow" style="background:#FFC845;"></button>
            <button class="swatch" data-color="#E57200" title="Orange" style="background:#E57200;"></button>
            <button class="swatch" data-color="#B7BF10" title="Lime" style="background:#B7BF10;"></button>
            <button class="swatch" data-color="#F1BDC8" title="Pink" style="background:#F1BDC8;"></button>
          </div>
          <div class="bg-options">
            <label class="field field-inline">
              <span>Custom</span>
              <input type="color" id="bg-color" value="#ffffff" />
            </label>
            <label class="field field-inline">
              <input type="checkbox" id="bg-transparent" />
              <span>Transparent</span>
            </label>
          </div>
        </section>
      </aside>
    </div>
  </main>
</BaseLayout>

<script>
  const canvas = document.getElementById('canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const viewport = document.getElementById('viewport')!;
  const viewportHint = document.getElementById('viewport-hint')!;

  // --- State ---
  let currentShapeSrc = '/images/chimera-expanded-2026/shape-001.svg';
  let currentImageSrc = '';
  let bgColor = '#ffffff';
  let bgTransparent = false;
  let zoom = 1;
  let panX = 0;
  let panY = 0;

  // Loaded assets
  let shapeImg: HTMLImageElement | null = null;
  let photoImg: HTMLImageElement | null = null;

  // --- Helpers ---
  function loadImage(src: string): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => resolve(img);
      img.onerror = reject;
      img.src = src;
    });
  }

  async function loadShape(src: string) {
    currentShapeSrc = src;
    shapeImg = await loadImage(src);
    resetView();
    render();
  }

  async function loadPhoto(src: string) {
    currentImageSrc = src;
    photoImg = await loadImage(src);
    render();
  }

  function loadPhotoFromFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const url = e.target!.result as string;
      currentImageSrc = url;
      const img = new Image();
      img.onload = () => {
        photoImg = img;
        render();
      };
      img.src = url;
    };
    reader.readAsDataURL(file);
  }

  function resetView() {
    zoom = 1;
    panX = 0;
    panY = 0;
    zoomSlider.value = '100';
    zoomVal.textContent = '100%';
    render();
  }

  // --- Render ---
  function render() {
    const size = canvas.width;
    ctx.clearRect(0, 0, size, size);

    // Background
    if (!bgTransparent) {
      ctx.fillStyle = bgColor;
      ctx.fillRect(0, 0, size, size);
    }

    if (!photoImg || !shapeImg) return;

    // Create offscreen canvas for the masked image
    const offscreen = new OffscreenCanvas(size, size);
    const offCtx = offscreen.getContext('2d')!;

    // Draw the shape as mask (white = visible)
    // Center the shape in the canvas, fitting it to the viewport
    const shapeAspect = shapeImg.naturalWidth / shapeImg.naturalHeight;
    let sw: number, sh: number;
    if (shapeAspect > 1) {
      sw = size * 0.85;
      sh = sw / shapeAspect;
    } else {
      sh = size * 0.85;
      sw = sh * shapeAspect;
    }
    const sx = (size - sw) / 2;
    const sy = (size - sh) / 2;

    offCtx.drawImage(shapeImg, sx, sy, sw, sh);

    // Use destination-in to mask the photo with the shape
    offCtx.globalCompositeOperation = 'source-in';

    // Draw photo with pan and zoom
    const photoAspect = photoImg.naturalWidth / photoImg.naturalHeight;
    let pw: number, ph: number;
    // Fill the canvas area then apply zoom
    if (photoAspect > 1) {
      ph = size * zoom;
      pw = ph * photoAspect;
    } else {
      pw = size * zoom;
      ph = pw / photoAspect;
    }
    const px = (size - pw) / 2 + panX;
    const py = (size - ph) / 2 + panY;

    offCtx.drawImage(photoImg, px, py, pw, ph);

    // Draw the composited result onto the main canvas
    ctx.drawImage(offscreen, 0, 0);
  }

  // --- Render for export at arbitrary size ---
  function renderForExport(exportSize: number): HTMLCanvasElement {
    const expCanvas = document.createElement('canvas');
    expCanvas.width = exportSize;
    expCanvas.height = exportSize;
    const expCtx = expCanvas.getContext('2d')!;

    if (!bgTransparent) {
      expCtx.fillStyle = bgColor;
      expCtx.fillRect(0, 0, exportSize, exportSize);
    }

    if (!photoImg || !shapeImg) return expCanvas;

    const offscreen = new OffscreenCanvas(exportSize, exportSize);
    const offCtx = offscreen.getContext('2d')!;

    const shapeAspect = shapeImg.naturalWidth / shapeImg.naturalHeight;
    let sw: number, sh: number;
    if (shapeAspect > 1) {
      sw = exportSize * 0.85;
      sh = sw / shapeAspect;
    } else {
      sh = exportSize * 0.85;
      sw = sh * shapeAspect;
    }
    const sx = (exportSize - sw) / 2;
    const sy = (exportSize - sh) / 2;
    offCtx.drawImage(shapeImg, sx, sy, sw, sh);

    offCtx.globalCompositeOperation = 'source-in';

    const photoAspect = photoImg.naturalWidth / photoImg.naturalHeight;
    let pw: number, ph: number;
    if (photoAspect > 1) {
      ph = exportSize * zoom;
      pw = ph * photoAspect;
    } else {
      pw = exportSize * zoom;
      ph = pw / photoAspect;
    }
    // Scale pan proportionally
    const scale = exportSize / canvas.width;
    const px = (exportSize - pw) / 2 + panX * scale;
    const py = (exportSize - ph) / 2 + panY * scale;
    offCtx.drawImage(photoImg, px, py, pw, ph);

    expCtx.drawImage(offscreen, 0, 0);
    return expCanvas;
  }

  // --- Pan & Zoom ---
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let panStartX = 0;
  let panStartY = 0;

  viewport.addEventListener('pointerdown', (e) => {
    if (e.target === canvas || e.target === viewport) {
      isDragging = true;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      panStartX = panX;
      panStartY = panY;
      viewport.setPointerCapture(e.pointerId);
      viewport.style.cursor = 'grabbing';
      viewportHint.style.display = 'none';
    }
  });

  viewport.addEventListener('pointermove', (e) => {
    if (!isDragging) return;
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    panX = panStartX + (e.clientX - dragStartX) * scaleX;
    panY = panStartY + (e.clientY - dragStartY) * scaleY;
    render();
  });

  viewport.addEventListener('pointerup', () => {
    isDragging = false;
    viewport.style.cursor = 'grab';
  });

  viewport.addEventListener('wheel', (e) => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? -0.05 : 0.05;
    zoom = Math.max(0.1, Math.min(5, zoom + delta));
    zoomSlider.value = String(Math.round(zoom * 100));
    zoomVal.textContent = Math.round(zoom * 100) + '%';
    render();
  }, { passive: false });

  // --- Controls ---
  const zoomSlider = document.getElementById('zoom-slider') as HTMLInputElement;
  const zoomVal = document.getElementById('zoom-val') as HTMLOutputElement;

  zoomSlider.addEventListener('input', () => {
    zoom = parseInt(zoomSlider.value) / 100;
    zoomVal.textContent = zoomSlider.value + '%';
    render();
  });

  document.getElementById('btn-reset')!.addEventListener('click', resetView);

  // Shape picker
  const shapeGrid = document.getElementById('shape-grid')!;
  shapeGrid.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.shape-thumb') as HTMLButtonElement | null;
    if (!btn) return;
    shapeGrid.querySelector('.active')?.classList.remove('active');
    btn.classList.add('active');
    loadShape(btn.dataset.shapeSrc!);
  });

  // Image tabs
  const tabs = document.querySelectorAll<HTMLButtonElement>('.image-source-tabs .tab');
  const tabContents = document.querySelectorAll<HTMLDivElement>('.tab-content');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tabContents.forEach((tc) => tc.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`tab-${tab.dataset.tab}`)!.classList.add('active');
    });
  });

  // Image select (dropdown)
  const imageSelect = document.getElementById('image-select') as HTMLSelectElement;
  imageSelect.addEventListener('change', () => {
    loadPhoto(imageSelect.value);
    // Sync thumbnail highlight
    const thumbs = document.querySelectorAll<HTMLButtonElement>('#image-preview-grid .image-thumb');
    thumbs.forEach((t) => t.classList.toggle('active', t.dataset.src === imageSelect.value));
  });

  // Image thumbnail grid
  const imagePreviewGrid = document.getElementById('image-preview-grid')!;
  imagePreviewGrid.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.image-thumb') as HTMLButtonElement | null;
    if (!btn) return;
    imagePreviewGrid.querySelector('.active')?.classList.remove('active');
    btn.classList.add('active');
    imageSelect.value = btn.dataset.src!;
    loadPhoto(btn.dataset.src!);
  });

  // Collection switching
  const collectionSelect = document.getElementById('collection-select') as HTMLSelectElement;
  // Snapshot all option data before any filtering
  const allImageOptions = Array.from(imageSelect.options).map(o => ({
    value: o.value, label: o.text, collection: o.dataset.collection ?? 'cca',
  }));

  collectionSelect.addEventListener('change', () => {
    const coll = collectionSelect.value;

    // Rebuild image-select dropdown for this collection
    imageSelect.innerHTML = '';
    let firstSrc = '';
    allImageOptions.forEach(p => {
      if (coll !== 'all' && !p.collection.split(' ').includes(coll)) return;
      const o = document.createElement('option');
      o.value = p.value; o.text = p.label; o.dataset.collection = p.collection;
      if (!firstSrc) firstSrc = p.value;
      imageSelect.appendChild(o);
    });

    // Show/hide thumbnails
    const thumbs = imagePreviewGrid.querySelectorAll<HTMLButtonElement>('.image-thumb');
    thumbs.forEach(t => {
      const visible = coll === 'all' || (t.dataset.collection ?? 'cca').split(' ').includes(coll);
      t.style.display = visible ? '' : 'none';
      t.classList.remove('active');
    });

    // Load first photo in collection
    if (firstSrc) {
      imageSelect.value = firstSrc;
      imagePreviewGrid.querySelector<HTMLButtonElement>(`[data-src="${CSS.escape(firstSrc)}"]`)?.classList.add('active');
      loadPhoto(firstSrc);
    }
  });

  // File upload
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  document.getElementById('btn-browse')!.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) loadPhotoFromFile(fileInput.files[0]);
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('drag-over');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) {
      loadPhotoFromFile(file);
      // Switch to upload tab
      tabs.forEach((t) => t.classList.toggle('active', t.dataset.tab === 'upload'));
      tabContents.forEach((tc) => tc.classList.toggle('active', tc.id === 'tab-upload'));
    }
  });

  // Background
  const bgColorInput = document.getElementById('bg-color') as HTMLInputElement;
  const bgTransparentCheck = document.getElementById('bg-transparent') as HTMLInputElement;
  const bgSwatches = document.getElementById('bg-swatches')!;

  function selectBgColor(color: string) {
    bgColor = color;
    bgColorInput.value = color;
    bgTransparentCheck.checked = false;
    bgTransparent = false;
    render();
  }

  bgSwatches.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.swatch') as HTMLButtonElement | null;
    if (!btn) return;
    bgSwatches.querySelector('.active')?.classList.remove('active');
    btn.classList.add('active');
    selectBgColor(btn.dataset.color!);
  });

  bgColorInput.addEventListener('input', () => {
    bgSwatches.querySelector('.active')?.classList.remove('active');
    bgColor = bgColorInput.value;
    render();
  });

  bgTransparentCheck.addEventListener('change', () => {
    bgTransparent = bgTransparentCheck.checked;
    if (bgTransparent) bgSwatches.querySelector('.active')?.classList.remove('active');
    render();
  });

  // Download
  const exportSizeSelect = document.getElementById('export-size') as HTMLSelectElement;
  document.getElementById('btn-download')!.addEventListener('click', () => {
    const exportSize = parseInt(exportSizeSelect.value);
    const expCanvas = renderForExport(exportSize);
    expCanvas.toBlob((blob) => {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const shapeId = currentShapeSrc.split('/').pop()?.replace('.svg', '') || 'shape';
      a.download = `cca-mask-${shapeId}-${exportSize}px.png`;
      a.href = url;
      a.click();
      URL.revokeObjectURL(url);
    }, 'image/png');
  });

  // --- Init: read URL params for shape pre-selection ---
  const params = new URLSearchParams(window.location.search);
  const shapeParam = params.get('shape');
  if (shapeParam) {
    const idx = parseInt(shapeParam) - 1;
    if (idx >= 0 && idx < 104) {
      const btn = shapeGrid.children[idx] as HTMLButtonElement;
      shapeGrid.querySelector('.active')?.classList.remove('active');
      btn.classList.add('active');
      btn.scrollIntoView({ block: 'nearest' });
      currentShapeSrc = btn.dataset.shapeSrc!;
    }
  }

  // Load initial shape and first photo
  (async () => {
    await Promise.all([
      loadShape(currentShapeSrc),
      loadPhoto(imageSelect.value),
    ]);
  })();
</script>

<style>
  .editor {
    max-width: 100rem;
    margin: 0 auto;
    padding: var(--space-4) var(--space-4) var(--space-8);
  }

  .editor-header {
    margin-bottom: var(--space-4);
  }

  .back-link {
    display: inline-block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }

  .back-link:hover { color: var(--color-accent); }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
  }

  /* Layout */
  .editor-layout {
    display: grid;
    grid-template-columns: 1fr 22rem;
    gap: var(--space-6);
    align-items: start;
  }

  @media (max-width: 64rem) {
    .editor-layout {
      grid-template-columns: 1fr;
    }
  }

  /* Viewport */
  .viewport-wrap {
    position: sticky;
    top: var(--space-4);
  }

  .viewport {
    position: relative;
    aspect-ratio: 1;
    /* Never taller than the window — width drives height via aspect-ratio */
    width: min(100%, calc(100dvh - 7rem));
    background: repeating-conic-gradient(#e8e8e8 0% 25%, #f5f5f5 0% 50%) 0 0 / 20px 20px;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: grab;
  }

  .viewport canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .viewport-hint {
    position: absolute;
    bottom: var(--space-3);
    left: 50%;
    transform: translateX(-50%);
    background: hsla(0, 0%, 0%, 0.6);
    color: #fff;
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: 1rem;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .viewport-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-3);
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .toolbar-btn {
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    white-space: nowrap;
  }

  .toolbar-btn:hover {
    border-color: var(--color-accent);
  }

  .toolbar-btn-primary {
    background: var(--color-accent, #00BFB3);
    color: #fff;
    border-color: transparent;
    font-weight: 600;
  }

  .toolbar-btn-primary:hover {
    opacity: 0.9;
  }

  .toolbar-label {
    font-size: var(--text-sm);
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }

  .toolbar-label output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    min-width: 3rem;
  }

  .toolbar-label select {
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .toolbar-slider {
    width: 6rem;
    cursor: pointer;
  }

  .toolbar-sep {
    width: 1px;
    height: 1.25rem;
    background: var(--color-border);
  }

  /* Panel */
  .panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .panel-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: var(--space-4);
  }

