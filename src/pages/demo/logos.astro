---
import BaseLayout from "../../layouts/BaseLayout.astro";

const logos = [
  { file: "cca-lettermark-simple.svg", label: "Lettermark (Simple)" },
  { file: "lettermark-dynamic-1.svg", label: "Lettermark Dynamic 1" },
  { file: "lettermark-dynamic-2.svg", label: "Lettermark Dynamic 2" },
  { file: "lockup-single.svg", label: "Lockup (Single Line)" },
  { file: "lockup-double.svg", label: "Lockup (Double Line)" },
  { file: "lockup-stacked.svg", label: "Lockup (Stacked)" },
  { file: "wordmark-single.svg", label: "Wordmark (Single Line)" },
];
---

<BaseLayout title="CCA Logos" minimalHeader={true}>
  <main class="demo-logos">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1>CCA Logos</h1>
    <p class="subtitle">Lettermarks, lockups, and the institutional seal.</p>

    <section>
      <h2>Logos <span class="count">({logos.length})</span></h2>
      <div class="grid">
        {logos.map(({ file, label }) => (
          <figure class="card">
            <img src={`/images/logos/${file}`} alt={label} loading="lazy" />
            <figcaption>{label}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section>
      <h2>Seal</h2>
      <div class="grid grid--seal">
        <figure class="card">
          <img src="/images/cca-seal.svg" alt="CCA Seal" loading="lazy" />
          <figcaption>CCA Seal</figcaption>
        </figure>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .demo-logos {
    max-width: 80rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: var(--space-10);
  }

  section {
    margin-bottom: var(--space-12);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .count {
    color: var(--color-muted);
    font-weight: 400;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-4);
  }

  .grid--seal {
    grid-template-columns: minmax(0, 20rem);
  }

  .card {
    margin: 0;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-align: center;
  }

  .card img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 12rem;
    object-fit: contain;
    margin-bottom: var(--space-2);
  }

  .card figcaption {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-family: var(--font-mono);
  }
</style>
