---
import DemoEffectLayout from "../../layouts/DemoEffectLayout.astro";
import fs from "node:fs";
import path from "node:path";

const framesDir = path.resolve("public/images/scanned-graphics/frames");
const frameIds = [
  "frame-01", "frame-02", "frame-03", "frame-04", "frame-05",
  "frame-07", "frame-09", "frame-10", "frame-11", "frame-12",
  "frame-13", "frame-14", "frame-15", "frame-16", "frame-17",
  "frame-18", "frame-19", "frame-20", "frame-21", "frame-22", "frame-23",
];

// Read SVGs at build time and swap fill color to currentColor
const frameSvgs = frameIds.map(id => {
  const svg = fs.readFileSync(path.join(framesDir, `${id}.svg`), "utf-8");
  return svg.replace(/fill:#231f20/g, "fill:currentColor");
});
---

<DemoEffectLayout title="Frame Loop">
  <div class="stage">
    <div class="frame-slot" id="slot-a"></div>
    <div class="frame-slot" id="slot-b"></div>
  </div>

  <!-- Preload frame SVGs as hidden data -->
  <script id="frame-data" type="application/json" set:html={JSON.stringify(frameSvgs)} />

  <div class="demo-overlay">
    <a href="/demo/" class="back-link">&larr; Demo Pages</a>
    <h1 class="demo-title">Frame Loop</h1>
    <p class="demo-technique">Scanned frames · Crossfade · Rotation · Color cycling</p>
  </div>

  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle controls" aria-expanded="false">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="6" cy="4" r="1.5"/><line x1="6" y1="5.5" x2="6" y2="18"/>
      <circle cx="14" cy="10" r="1.5"/><line x1="14" y1="2" x2="14" y2="8.5"/><line x1="14" y1="11.5" x2="14" y2="18"/>
      <circle cx="10" cy="15" r="1.5"/><line x1="10" y1="2" x2="10" y2="13.5"/><line x1="10" y1="16.5" x2="10" y2="18"/>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Controls</h2>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close controls">&times;</button>
    </div>
    <p class="sidebar-description">
      Hand-scanned decorative frames cycle with smooth crossfades. Each frame gets a
      celebration palette color and a subtle rotation.
    </p>
    <div class="controls">
      <div class="control-group">
        <label for="cycle-speed">Cycle Duration: <output id="cycle-speed-val">3s</output></label>
        <input type="range" id="cycle-speed" min="1" max="8" value="3" step="0.5" />
      </div>
      <div class="control-group">
        <label for="rotation">Rotation: <output id="rotation-val">4</output>&deg;</label>
        <input type="range" id="rotation" min="0" max="20" value="4" step="1" />
      </div>
      <div class="control-group">
        <label for="scale-pulse">Scale Pulse: <output id="scale-pulse-val">0.05</output></label>
        <input type="range" id="scale-pulse" min="0" max="0.2" value="0.05" step="0.01" />
      </div>
      <div class="control-group">
        <label>Tint Colors</label>
        <div class="swatch-picker" id="tint-swatches">
          <button class="swatch active" data-color="#00BFB3" style="background:#00BFB3" title="Teal"></button>
          <button class="swatch active" data-color="#563D82" style="background:#563D82" title="Purple"></button>
          <button class="swatch active" data-color="#E57200" style="background:#E57200" title="Orange"></button>
          <button class="swatch active" data-color="#FFC845" style="background:#FFC845" title="Yellow"></button>
          <button class="swatch active" data-color="#B7BF10" style="background:#B7BF10" title="Lime"></button>
          <button class="swatch active" data-color="#F1BDC8" style="background:#F1BDC8" title="Pink"></button>
          <button class="swatch active" data-color="#005776" style="background:#005776" title="Navy"></button>
        </div>
        <p class="swatch-hint">Click to toggle colors in the cycle</p>
      </div>
      <div class="control-group">
        <button class="toggle-btn" id="toggle-pause">Pause</button>
      </div>
    </div>
  </aside>
</DemoEffectLayout>

<style>
  .stage {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .frame-slot {
    position: absolute;
    width: 50vmin;
    height: 50vmin;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: opacity, transform;
  }

  .frame-slot :global(svg) {
    width: 100%;
    height: 100%;
  }

  .demo-overlay {
    position: fixed;
    top: 5rem;
    left: var(--space-6);
    z-index: 10;
    pointer-events: none;
  }

  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
    pointer-events: auto;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: var(--space-1) var(--space-2);
    border-radius: 0.25rem;
  }

  .demo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-1);
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .demo-technique {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px hsla(0, 0%, 0%, 0.3);
  }

  .sidebar-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.9);
  }

  .sidebar-toggle[aria-expanded="true"] { display: none; }

  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 280px;
    height: 100vh;
    z-index: 30;
    background: hsla(var(--color-bg-rgb, 0 0% 99%), 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .sidebar.open { transform: translateX(0); }

  @media (prefers-reduced-motion: reduce) {
    .sidebar { transition: none; }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .sidebar-header h2 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: var(--text-xl);
    cursor: pointer;
    color: var(--color-muted);
    padding: var(--space-1);
    line-height: 1;
  }

  .sidebar-description {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .control-group {
    margin-bottom: var(--space-3);
  }

  .control-group label {
    display: block;
    font-size: var(--text-sm);
    margin-bottom: var(--space-1);
  }

  .control-group output {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .control-group input[type="range"] {
    width: 100%;
    cursor: pointer;
  }

  .toggle-btn {
    width: 100%;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .toggle-btn:hover { border-color: var(--color-accent); }

  .swatch-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-1);
  }

  .swatch {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: border-color 0.15s ease, transform 0.15s ease, opacity 0.15s ease;
    opacity: 0.35;
  }

  .swatch:hover { transform: scale(1.15); }

  .swatch.active {
    border-color: var(--color-text);
    opacity: 1;
  }

  .swatch-hint {
    font-size: var(--text-xs);
    color: var(--color-muted);
    opacity: 0.7;
  }
</style>

<script>
  const frameSvgs: string[] = JSON.parse(
    document.getElementById('frame-data')!.textContent!
  );

  const allColors = ['#00BFB3', '#563D82', '#E57200', '#FFC845', '#B7BF10', '#F1BDC8', '#005776'];
  let activeColors = [...allColors];

  const slotA = document.getElementById('slot-a') as HTMLElement;
  const slotB = document.getElementById('slot-b') as HTMLElement;

  let cycleDuration = 3;
  let rotationMax = 4;
  let scalePulse = 0.05;
  let paused = false;
  let frameIndex = 0;
  let colorIdx = 0;

  function nextColor(): string {
    if (activeColors.length === 0) return '#231f20';
    const c = activeColors[colorIdx % activeColors.length];
    colorIdx++;
    return c;
  }

  function nextFrame(): string {
    const svg = frameSvgs[frameIndex % frameSvgs.length];
    frameIndex++;
    return svg;
  }

  function easeInOut(t: number) {
    return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
  }

  // Each frame gets a random-ish rotation direction
  function rotDir(): number {
    return Math.random() < 0.5 ? -1 : 1;
  }

  type Phase = 'idle' | 'fade-in' | 'hold' | 'fade-out';
  const state = [
    { phase: 'idle' as Phase, start: 0, rot: 1 },
    { phase: 'idle' as Phase, start: 0, rot: 1 },
  ];
  const slots = [slotA, slotB];

  function kick(slot: number, now: number) {
    const svg = nextFrame();
    const color = nextColor();
    slots[slot].innerHTML = svg;
    slots[slot].style.color = color;
    state[slot].phase = 'fade-in';
    state[slot].start = now;
    state[slot].rot = rotDir();
  }

  function tick(now: number) {
    if (paused) { requestAnimationFrame(tick); return; }

    const fadeDur = cycleDuration * 0.35;
    const holdDur = cycleDuration * 0.30;

    for (let i = 0; i < 2; i++) {
      const s = state[i];
      const el = slots[i];
      if (s.phase === 'idle') continue;

      const elapsed = (now - s.start) / 1000;

      if (s.phase === 'fade-in') {
        const t = Math.min(elapsed / fadeDur, 1);
        const e = easeInOut(t);
        el.style.opacity = String(e);
        const rot = (1 - e) * rotationMax * s.rot;
        const scale = (1 - scalePulse) + scalePulse * e;
        el.style.transform = `rotate(${rot}deg) scale(${scale})`;
        if (t >= 1) { s.phase = 'hold'; s.start = now; }
      } else if (s.phase === 'hold') {
        const t = elapsed / holdDur;
        const breathe = Math.sin(elapsed * 2) * scalePulse * 0.4;
        el.style.transform = `scale(${1 + breathe})`;
        if (t >= 1) {
          s.phase = 'fade-out';
          s.start = now;
          kick(i === 0 ? 1 : 0, now);
        }
      } else if (s.phase === 'fade-out') {
        const t = Math.min(elapsed / fadeDur, 1);
        const e = easeInOut(t);
        el.style.opacity = String(1 - e);
        const rot = e * rotationMax * -s.rot;
        const scale = 1 + scalePulse * e;
        el.style.transform = `rotate(${rot}deg) scale(${scale})`;
        if (t >= 1) { s.phase = 'idle'; el.style.opacity = '0'; }
      }
    }
    requestAnimationFrame(tick);
  }

  // --- Controls ---
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  toggle.addEventListener('click', () => {
    sidebar.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => {
    sidebar.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  const rangeControls: Array<{ id: string; valId: string; suffix: string; setter: (v: number) => void }> = [
    { id: 'cycle-speed', valId: 'cycle-speed-val', suffix: 's', setter: v => { cycleDuration = v; } },
    { id: 'rotation', valId: 'rotation-val', suffix: '', setter: v => { rotationMax = v; } },
    { id: 'scale-pulse', valId: 'scale-pulse-val', suffix: '', setter: v => { scalePulse = v; } },
  ];

  for (const ctrl of rangeControls) {
    const input = document.getElementById(ctrl.id) as HTMLInputElement;
    const output = document.getElementById(ctrl.valId) as HTMLOutputElement;
    input.addEventListener('input', () => {
      output.textContent = input.value + ctrl.suffix;
      ctrl.setter(parseFloat(input.value));
    });
  }

  document.getElementById('tint-swatches')!.querySelectorAll('.swatch').forEach(swatch => {
    swatch.addEventListener('click', () => {
      swatch.classList.toggle('active');
      activeColors = [];
      document.getElementById('tint-swatches')!.querySelectorAll('.swatch.active').forEach(s => {
        activeColors.push((s as HTMLElement).dataset.color!);
      });
      if (activeColors.length === 0) activeColors = ['#231f20'];
    });
  });

  const pauseBtn = document.getElementById('toggle-pause') as HTMLButtonElement;
  pauseBtn.addEventListener('click', () => {
    paused = !paused;
    pauseBtn.textContent = paused ? 'Play' : 'Pause';
  });

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    paused = true;
    pauseBtn.textContent = 'Play';
  }

  kick(0, performance.now());
  requestAnimationFrame(tick);
</script>
