---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import StickyTocLayout from '../../components/ui/StickyTocLayout.astro';
import InfoSection from '../../components/sections/InfoSection.astro';
import ContactBlock from '../../components/ui/ContactBlock.astro';

const info = await getEntry('commencement-info', 'current');
if (!info) throw new Error('Commencement info not found');

/** Extract headings from markdown content for TOC. */
function extractHeadings(md: string): Array<{ label: string; href: string }> {
  const items: Array<{ label: string; href: string }> = [];
  const regex = /^#{2,3} (.+)$/gm;
  let match;
  while ((match = regex.exec(md)) !== null) {
    const slug = match[1].toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    items.push({ label: match[1], href: `#${slug}` });
  }
  return items;
}

const tocItems = [
  ...extractHeadings(info.data.forStudents.content),
  { label: 'Contact', href: '#contact' },
];
---

<BaseLayout title="For Students — Commencement" themeKey="commencement">
  <div class="container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Commencement', href: '/commencement/' },
      { label: 'For Students' },
    ]} />

    <StickyTocLayout items={tocItems}>
      <div class="page-content">
        <InfoSection
          heading={info.data.forStudents.heading}
          content={info.data.forStudents.content}
        />

        <section id="contact" class="contact-section">
          <ContactBlock
            email={info.data.contact.email}
            phone={info.data.contact.phone}
          />
        </section>
      </div>
    </StickyTocLayout>
  </div>
</BaseLayout>

<style>
  .page-content {
    padding-bottom: var(--space-10);
  }

  .contact-section {
    padding-block: var(--space-8);
  }
</style>
