---
import { getEntry } from "astro:content";
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';
import EventLayout from "../../layouts/EventLayout.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import TableOfContents from "../../components/ui/TableOfContents.astro";
import ProgramHero from "../../components/program/ProgramHero.astro";
import ProgramAgenda from "../../components/program/ProgramAgenda.astro";
import ProgramDisclaimer from "../../components/program/ProgramDisclaimer.astro";
import CandidatesList from "../../components/program/CandidatesList.astro";
import CeremonySchedule from "../../components/events/CeremonySchedule.astro";
import EventContextSection from "../../components/events/EventContextSection.astro";
import SpeakerFeature from "../../components/events/SpeakerFeature.astro";
import DownloadLink from "../../components/ui/DownloadLink.astro";
import { formatDate, formatTime } from "../../lib/utils/format";
import { getCandidatesGroupedByDivision } from "../../lib/utils/collections";

const phase = getCurrentPhase(Astro.url);
if (isPhaseBefore(phase, 'during-event')) {
  return Astro.redirect('/commencement/');
}

const eventId = "commencement-undergraduate";
const event = await getEntry("events", eventId);
if (!event) throw new Error(`Event ${eventId} not found`);

const { ceremonyProgram, longDescription, description, date, time, location, address, livestreamUrl, schedule } = event.data;

let studentSpeakerEntry = null;
if (ceremonyProgram?.studentSpeaker?.student) {
  studentSpeakerEntry = await getEntry("students", ceremonyProgram.studentSpeaker.student.id);
}

const commencementInfo = await getEntry("commencement-info", "current");
const programBooklet = commencementInfo?.data.downloadableAssets?.find(
  (a: { label: string }) => a.label === "Commencement Program"
);

const candidateGroups = await getCandidatesGroupedByDivision(eventId);

const introParagraphs = (longDescription ?? description ?? "").split(/\n\n+/).filter(Boolean);

const introMeta = [
  { label: "Date", value: formatDate(date) },
  ...(time ? [{ label: "Time", value: formatTime(time) }] : []),
  {
    label: "Venue",
    value: location,
    href: `https://maps.google.com/?q=${encodeURIComponent(address)}`,
  },
  ...(livestreamUrl ? [{ label: "Livestream", value: "Watch online", href: livestreamUrl }] : []),
];

const hasProgramSection =
  !!ceremonyProgram?.programItems?.length ||
  !!ceremonyProgram?.landAcknowledgment ||
  !!ceremonyProgram?.studentSpeaker;

const tocItems: Array<{ label: string; href: string }> = [];
if (introParagraphs.length > 0) tocItems.push({ label: "About", href: "#about" });
if (schedule && schedule.length > 0) tocItems.push({ label: "Day-of Schedule", href: "#schedule" });
if (hasProgramSection) tocItems.push({ label: "Ceremony Program", href: "#program" });
if (candidateGroups.length > 0) tocItems.push({ label: "Degree Candidates", href: "#candidates" });
---

<EventLayout event={event} title={event.data.title}>
  <div class="container">
    <Breadcrumb items={[
      { label: "Home", href: "/" },
      { label: "Commencement", href: "/commencement/" },
      { label: "Bachelor's Ceremony" },
    ]} />
  </div>

  <ProgramHero event={event} />

  <div class="container">
    <div class="program-layout">
      <div class="program-main">

        {introParagraphs.length > 0 && (
          <EventContextSection
            id="about"
            kicker="About the ceremony"
            paragraphs={introParagraphs}
            meta={introMeta}
          />
        )}

        {schedule && schedule.length > 0 && (
          <section id="schedule" class="program-section">
            <h2 class="section-heading">Day-of Schedule</h2>
            <p class="section-lede">
              A guide to the afternoon's arrivals, processional, ceremony, and reception.
            </p>
            <CeremonySchedule schedule={schedule} />
          </section>
        )}

        {hasProgramSection && (
          <section id="program" class="program-section">
            <h2 class="section-heading">Ceremony Program</h2>

            {ceremonyProgram?.programItems && ceremonyProgram.programItems.length > 0 && (
              <div class="subsection">
                <h3 class="subsection-heading">Order of Ceremony</h3>
                <ProgramAgenda items={ceremonyProgram.programItems} />
                {programBooklet && (
                  <div class="program-booklet-download">
                    <DownloadLink
                      label={programBooklet.label}
                      url={programBooklet.url}
                      description={programBooklet.description}
                    />
                  </div>
                )}
              </div>
            )}

            {ceremonyProgram?.studentSpeaker && (
              <div class="subsection">
                <h3 class="subsection-heading">Student Speaker</h3>
                <SpeakerFeature
                  speaker={ceremonyProgram.studentSpeaker}
                  student={studentSpeakerEntry}
                />
              </div>
            )}

            {ceremonyProgram?.landAcknowledgment && (
              <div class="subsection">
                <h3 class="subsection-heading">Land Acknowledgment</h3>
                <p class="acknowledgment-text">{ceremonyProgram.landAcknowledgment}</p>
              </div>
            )}
          </section>
        )}

        {candidateGroups.length > 0 && (
          <section id="candidates" class="program-section">
            <h2 class="section-heading">Degree Candidates</h2>
            <p class="section-lede">
              Candidates listed by division. Recognition during the ceremony does not
              constitute formal conferral of the degree.
            </p>
            <CandidatesList groups={candidateGroups} />
            {ceremonyProgram?.disclaimer && (
              <div class="subsection subsection--disclaimer">
                <ProgramDisclaimer text={ceremonyProgram.disclaimer} />
              </div>
            )}
          </section>
        )}

      </div>

      <aside class="program-sidebar">
        <TableOfContents items={tocItems} />
      </aside>
    </div>
  </div>
</EventLayout>

<style>
  .program-layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .program-sidebar {
    order: -1;
  }

  .program-main {
    flex: 1;
    min-width: 0;
  }

  .program-main > * + * {
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 1024px) {
    .program-layout {
      flex-direction: row;
      gap: var(--space-10);
    }

    .program-sidebar {
      order: 0;
      flex: 0 0 220px;
      position: sticky;
      top: calc(60px + var(--space-8));
      align-self: flex-start;
    }
  }

  .program-section {
    padding-block: var(--space-12);
    scroll-margin-top: calc(60px + var(--space-4));
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: normal;
    line-height: 1.2;
    margin-bottom: var(--space-4);
    position: relative;
    display: inline-block;
  }

  :global([data-theme^="commencement"]) .section-heading::after {
    content: "";
    display: block;
    width: 40px;
    height: 2px;
    background: var(--color-gold, var(--color-accent));
    margin-top: var(--space-2);
  }

  .section-lede {
    font-size: var(--text-base);
    color: var(--color-text);
    opacity: 0.85;
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }

  .acknowledgment-text {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
    max-width: 65ch;
    font-style: italic;
  }

  .program-booklet-download {
    margin-top: var(--space-6);
  }

  .subsection + .subsection {
    margin-top: var(--space-10);
  }

  .subsection-heading {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .subsection--disclaimer {
    margin-top: var(--space-8);
  }
</style>
