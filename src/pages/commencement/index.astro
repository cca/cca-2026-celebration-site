---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParticleField from '../../components/effects/ParticleField.astro';
import { chimeraExpanded2026Paths } from '../../data/chimera-expanded-2026-paths';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import Button from '../../components/ui/Button.astro';
import ChimeraLoop3D from '../../components/effects/ChimeraLoop3D.astro';

import QuoteBlock from '../../components/ui/QuoteBlock.astro';
import StatisticsGrid from '../../components/sections/StatisticsGrid.astro';
import TableOfContents from '../../components/ui/TableOfContents.astro';
import { Image } from 'astro:assets';
import { formatDate, formatTime } from '../../lib/utils/format';
import { getPeopleByRole } from '../../lib/utils/collections';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseBefore } from '../../config/phases';

const events = await getCollection('events');
const undergradEvent = events.find(e => e.id === 'commencement-undergraduate');
const gradEvent = events.find(e => e.id === 'commencement-graduate');

const info = await getEntry('commencement-info', 'current');
const inMemoriam = info?.data.inMemoriam ?? [];
const statistics = info?.data.statistics ?? [];
const presidentQuote = info?.data.presidentQuote;

const honoraryDoctorates = await getPeopleByRole('honorary-doctorate');
const professorsEmerit = await getPeopleByRole('professor-emeritus');

const undergradHonoree = honoraryDoctorates.find(p => p.data.ceremony?.id === 'commencement-undergraduate');
const gradHonoree = honoraryDoctorates.find(p => p.data.ceremony?.id === 'commencement-graduate');

const undergradSpeaker = undergradEvent?.data.ceremonyProgram?.studentSpeaker;
const gradSpeaker = gradEvent?.data.ceremonyProgram?.studentSpeaker;

function paragraphs(text?: string): string[] {
  if (!text) return [];
  return text.split(/\n\n+/).map(p => p.trim()).filter(Boolean);
}

const tocItems = [
  { label: 'Ceremonies', href: '#ceremonies' },
  { label: 'Cause for Celebration', href: '#cause-for-celebration' },
  { label: "Bachelor's Ceremony", href: '#bachelors' },
  { label: "Master's Ceremony", href: '#masters' },
  { label: 'In Memoriam', href: '#in-memoriam' },
];

const phase = getCurrentPhase(Astro.url);
---

<BaseLayout title="Commencement" themeKey="commencement">
  <ParticleField
    mode="svg"
    svgPaths={chimeraExpanded2026Paths}
    colors={['#00bfb3', '#f2b23a', '#7ec8e3']}
    count={60}
    sizeRange={[18, 55]}
    opacityRange={[0.12, 0.45]}
  />

  {/* ── Hero ── */}
  <section class="comm-hero" data-cursor-scope>
    <div class="comm-hero__collage" aria-hidden="true">
      <div
        class="comm-hero__fragment comm-hero__fragment--1"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.035"
        data-cursor-max="36"
        data-cursor-lerp="0.06"
      >
        <div class="comm-hero__masked-loop" data-comm-chimera>
          <div class="comm-hero__masked-slot" data-slot="a">
            <div class="comm-hero__masked-shape" data-shape="a"></div>
          </div>
          <div class="comm-hero__masked-slot" data-slot="b">
            <div class="comm-hero__masked-shape" data-shape="b"></div>
          </div>
        </div>
      </div>
      <div
        class="comm-hero__fragment comm-hero__fragment--2"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.055"
        data-cursor-max="28"
        data-cursor-lerp="0.12"
      >
        <div class="comm-hero__masked-loop" data-comm-chimera>
          <div class="comm-hero__masked-slot" data-slot="a">
            <div class="comm-hero__masked-shape" data-shape="a"></div>
          </div>
          <div class="comm-hero__masked-slot" data-slot="b">
            <div class="comm-hero__masked-shape" data-shape="b"></div>
          </div>
        </div>
      </div>
      <div
        class="comm-hero__fragment comm-hero__fragment--3"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.03"
        data-cursor-max="20"
        data-cursor-lerp="0.08"
      >
        <div class="comm-hero__masked-loop" data-comm-chimera>
          <div class="comm-hero__masked-slot" data-slot="a">
            <div class="comm-hero__masked-shape" data-shape="a"></div>
          </div>
          <div class="comm-hero__masked-slot" data-slot="b">
            <div class="comm-hero__masked-shape" data-shape="b"></div>
          </div>
        </div>
      </div>
      <div
        class="comm-hero__fragment comm-hero__doodle comm-hero__doodle--1"
        data-cursor-track
        data-cursor-strength="0.05"
        data-cursor-max="45"
        data-cursor-lerp="0.12"
      >
        <ChimeraLoop3D
          id="comm-hero-chimera-1"
          cycleDuration={4}
          fadeOverlap={0.3}
          elasticIntensity={1}
          skewAmount={15}
          driftSpeed={1}
          sizeVariance={0.25}
          color="#ffffff"
        />
      </div>
      <div
        class="comm-hero__fragment comm-hero__doodle comm-hero__doodle--2"
        data-cursor-track
        data-cursor-strength="0.038"
        data-cursor-max="32"
        data-cursor-lerp="0.09"
      >
        <ChimeraLoop3D
          id="comm-hero-chimera-2"
          cycleDuration={4}
          fadeOverlap={0.3}
          elasticIntensity={1}
          skewAmount={15}
          driftSpeed={1}
          sizeVariance={0.25}
          color="#ffffff"
          startDelay={2}
        />
      </div>
    </div>
    <div class="comm-hero__content">
      <h1 class="comm-hero__logo-wrap">
        <img
          src="/images/commencement/commencement-secondary-36.svg"
          alt="CCA Commencement 2026"
          class="comm-hero__logo"
          width="900"
          height="630"
        />
      </h1>
    </div>
    <div class="comm-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── Intro ── */}
  <section class="comm-intro">
    <div class="container container--narrow">
      <p class="comm-intro__lead reveal">Join the commencement class of 2026 as they celebrate the culmination of their achievements at CCA. We mark this occasion together at this year's commencement ceremonies, thesis exhibitions, and capstone events.</p>
    </div>
  </section>

  {/* ── Anchored content with sticky TOC ── */}
  <div class="container">
    <div class="program-layout">
      <div class="program-main">

        {/* ── Ceremonies ── */}
        <section id="ceremonies" class="program-section">
          <span class="section-label reveal">Ceremonies</span>
          <h2 class="section-heading reveal">All together now</h2>
          <p class="program-section__lead reveal">We look forward to celebrating CCA&rsquo;s 119th Commencement on Saturday, May 16, 2026.</p>
          {(gradEvent || undergradEvent) && (() => {
            const sharedEvent = (gradEvent || undergradEvent)!;
            return (
              <p class="ceremony-shared-meta reveal">
                <time>{formatDate(sharedEvent.data.date)}</time>
                {' · '}
                <a href="https://maps.app.goo.gl/EzMx1kDnNCpppUwS6" target="_blank" rel="noopener noreferrer">
                  {sharedEvent.data.location}
                </a>
              </p>
            );
          })()}
          <p class="program-section__lead reveal">Witness the commencement class of 2026 cross the stage during two ceremonies:</p>
          <div class="ceremony-cards">
            {undergradEvent && isPhaseBefore(phase, 'during-event') ? (
              <div class="ceremony-info reveal">
                <div class="ceremony-info__accent" aria-hidden="true"></div>
                <span class="ceremony-info__badge">{undergradEvent.data.time ? formatTime(undergradEvent.data.time) : null}</span>
                <h3 class="ceremony-info__title">{undergradEvent.data.title}</h3>
              </div>
            ) : undergradEvent && (
              <a href="/commencement/bachelors/" class="ceremony-card reveal">
                <div class="ceremony-card__accent" aria-hidden="true"></div>
                <span class="ceremony-card__badge">{undergradEvent.data.time ? formatTime(undergradEvent.data.time) : null}</span>
                <h3 class="ceremony-card__title">{undergradEvent.data.title}</h3>
                <span class="ceremony-card__cta">Details &rarr;</span>
              </a>
            )}

            {gradEvent && isPhaseBefore(phase, 'during-event') ? (
              <div class="ceremony-info reveal">
                <div class="ceremony-info__accent" aria-hidden="true"></div>
                <span class="ceremony-info__badge">{gradEvent.data.time ? formatTime(gradEvent.data.time) : null}</span>
                <h3 class="ceremony-info__title">{gradEvent.data.title}</h3>
              </div>
            ) : gradEvent && (
              <a href="/commencement/masters/" class="ceremony-card reveal">
                <div class="ceremony-card__accent" aria-hidden="true"></div>
                <span class="ceremony-card__badge">{gradEvent.data.time ? formatTime(gradEvent.data.time) : null}</span>
                <h3 class="ceremony-card__title">{gradEvent.data.title}</h3>
                <span class="ceremony-card__cta">Details &rarr;</span>
              </a>
            )}
          </div>

          <div class="ceremonies-cta reveal">
            <Button href="mailto:commencement@cca.edu" variant="link" arrow="10">If you have questions, send us an email</Button>
          </div>
        </section>

        {/* ── Cause for Celebration ── */}
        <section id="cause-for-celebration" class="program-section">
          <span class="section-label reveal">Cause for Celebration</span>
          <h2 class="section-heading reveal">Tams off for a job well done!</h2>
          <p class="program-section__lead reveal">We commemorate the Commencement Class of 2026 with ceremonies on Saturday, May 16. After years of creative and academic dedication, these students are ready to take steps forward on to new challenges and into their professional practices. Our programming celebrates their momentous scholarly achievements with events and festivities.</p>

          {presidentQuote && (
            <QuoteBlock variant="gradient" text={presidentQuote.text} attribution={presidentQuote.attribution} />
          )}

          <h3 class="subsection-heading reveal">By the numbers</h3>
          <p class="program-section__lead reveal">CCA's 119th Commencement Class represents students across 21 bachelor's and 11 master's programs:</p>
          {statistics.length > 0 && <StatisticsGrid statistics={statistics} />}

          <h3 class="subsection-heading reveal">Honorary doctorates and professors emerit</h3>
          <p class="program-section__lead reveal">CCA is proud to award an honorary doctorate degree to inspirational artists, designers, and thinkers each year at its Commencement Ceremony.</p>

          {honoraryDoctorates.length > 0 && (
            <div class="honor-list reveal">
              <span class="honor-list__label">Honorary Doctorates</span>
              <p class="honor-list__intro">CCA is thrilled to announce the Honorary Doctorate recipients for the 119th Commencement Ceremony:</p>
              <ul class="honor-list__items">
                {honoraryDoctorates.map(p => (
                  <li>
                    <span class="honor-list__name">{p.data.name}</span>
                    {p.data.ccaConnection && <span class="honor-list__detail"> {p.data.ccaConnection}</span>}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {professorsEmerit.length > 0 && (
            <div class="honor-list reveal">
              <span class="honor-list__label">Professors Emerit</span>
              <p class="honor-list__intro">The following tenured faculty members were awarded a professor emerit designation in 2026:</p>
              <ul class="honor-list__items">
                {professorsEmerit.map(p => (
                  <li>
                    <span class="honor-list__name">{p.data.name}</span>
                    {p.data.title && <span class="honor-list__detail"> ({p.data.title})</span>}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="ceremonies-cta reveal">
            <Button href="https://www.cca.edu/about/honorary-doctorates-professors-emerit/" variant="link">View the list</Button>
          </div>
        </section>

        {/* ── Bachelor's Ceremony ── */}
        <section id="bachelors" class="program-section">
          <span class="section-label reveal">Bachelor's Ceremony</span>
          <h2 class="section-heading reveal">Celebrating 281 undergraduate candidates</h2>

          {undergradHonoree && (
            <p class="program-section__lead reveal">The Bachelor's Degree Candidates Ceremony features the conferring of CCA's Honorary Doctorate of Fine Arts on {undergradHonoree.data.name} {undergradHonoree.data.ccaConnection ?? ''}.</p>
          )}

          <div class="ceremonies-cta reveal">
            <Button href="/commencement/bachelors/" variant="link">View bachelor's degree program and candidates</Button>
          </div>

          {undergradHonoree && (
            <article class="ceremony-spotlight reveal">
              <div class="ceremony-spotlight__photo">
                {undergradHonoree.data.photo ? (
                  <Image
                    src={undergradHonoree.data.photo.src}
                    alt={undergradHonoree.data.photo.alt}
                    width={480}
                    height={480}
                    loading="lazy"
                    inferSize
                  />
                ) : (
                  <span class="ceremony-spotlight__initial" aria-hidden="true">{undergradHonoree.data.name.charAt(0)}</span>
                )}
              </div>
              <div class="ceremony-spotlight__info">
                <span class="ceremony-spotlight__role">Honorary Doctorate</span>
                <h3 class="ceremony-spotlight__name">{undergradHonoree.data.name}</h3>
                {undergradHonoree.data.ccaConnection && <p class="ceremony-spotlight__cca">{undergradHonoree.data.ccaConnection}</p>}
                {undergradHonoree.data.title && <p class="ceremony-spotlight__title">{undergradHonoree.data.title}</p>}
                {undergradHonoree.data.bio && (
                  <details class="ceremony-spotlight__bio-toggle">
                    <summary>Read more</summary>
                    <div class="ceremony-spotlight__bio">
                      {paragraphs(undergradHonoree.data.bio).map(p => <p>{p}</p>)}
                    </div>
                  </details>
                )}
              </div>
            </article>
          )}

          {undergradSpeaker && (
            <div class="speaker-card reveal">
              <span class="speaker-card__label">Student speaker</span>
              <p class="speaker-card__intro">Bachelor's speaker {undergradSpeaker.name} ({undergradSpeaker.program}) spoke to classmates about adaptation, presence, and the creative instincts they carry with them from CCA.</p>
              {undergradSpeaker.speechHighlights && (
                <blockquote class="speaker-card__quote">
                  {paragraphs(undergradSpeaker.speechHighlights).map(p => <p>{p}</p>)}
                  <footer class="speaker-card__attribution">
                    <span class="speaker-card__name">{undergradSpeaker.name}</span>
                    <span class="speaker-card__program">{undergradSpeaker.program}</span>
                  </footer>
                </blockquote>
              )}
            </div>
          )}
        </section>

        {/* ── Master's Ceremony ── */}
        <section id="masters" class="program-section">
          <span class="section-label reveal">Master's Ceremony</span>
          <h2 class="section-heading reveal">Celebrating 139 graduate candidates</h2>

          {gradHonoree && (
            <p class="program-section__lead reveal">{gradHonoree.data.name} {gradHonoree.data.ccaConnection ?? ''} will deliver the Distinguished Alumni Address at the 2026 Master's Degree Candidates Ceremony.</p>
          )}

          <div class="ceremonies-cta reveal">
            <Button href="/commencement/masters/" variant="link">View master's degree program and candidates</Button>
          </div>

          {gradHonoree && (
            <article class="ceremony-spotlight reveal">
              <div class="ceremony-spotlight__photo">
                {gradHonoree.data.photo ? (
                  <Image
                    src={gradHonoree.data.photo.src}
                    alt={gradHonoree.data.photo.alt}
                    width={480}
                    height={480}
                    loading="lazy"
                    inferSize
                  />
                ) : (
                  <span class="ceremony-spotlight__initial" aria-hidden="true">{gradHonoree.data.name.charAt(0)}</span>
                )}
              </div>
              <div class="ceremony-spotlight__info">
                <span class="ceremony-spotlight__role">Distinguished Alumni Address · Honorary Doctorate</span>
                <h3 class="ceremony-spotlight__name">{gradHonoree.data.name}</h3>
                {gradHonoree.data.ccaConnection && <p class="ceremony-spotlight__cca">{gradHonoree.data.ccaConnection}</p>}
                {gradHonoree.data.title && <p class="ceremony-spotlight__title">{gradHonoree.data.title}</p>}
                {gradHonoree.data.bio && (
                  <details class="ceremony-spotlight__bio-toggle">
                    <summary>Read more</summary>
                    <div class="ceremony-spotlight__bio">
                      {paragraphs(gradHonoree.data.bio).map(p => <p>{p}</p>)}
                    </div>
                  </details>
                )}
              </div>
            </article>
          )}

          {gradSpeaker && (
            <div class="speaker-card reveal">
              <span class="speaker-card__label">Student speaker</span>
              <p class="speaker-card__intro">Master's student speaker {gradSpeaker.name} ({gradSpeaker.program}) spoke to classmates about pride, resilience, and the belonging they built together at CCA — and what they carry with them from here.</p>
              {gradSpeaker.speechHighlights && (
                <blockquote class="speaker-card__quote">
                  {paragraphs(gradSpeaker.speechHighlights).map(p => <p>{p}</p>)}
                  <footer class="speaker-card__attribution">
                    <span class="speaker-card__name">{gradSpeaker.name}</span>
                    <span class="speaker-card__program">{gradSpeaker.program}</span>
                  </footer>
                </blockquote>
              )}
            </div>
          )}
        </section>

        {/* ── In Memoriam ── */}
        {inMemoriam.length > 0 && (
          <section id="in-memoriam" class="program-section memoriam-section">
            <span class="section-label reveal">In Memoriam</span>
            <h2 class="section-heading reveal">Remembering community members who have passed</h2>

            <QuoteBlock
              text="Please take a moment to honor these members of our CCA community. They are part of our creative legacy—teachers, friends, and colleagues who changed our lives, and whom we cherish."
              attribution="David C. Howse, President, California College of the Arts"
            />

            <ul class="memoriam-list reveal">
              {inMemoriam.map((person) => (
                <li class="memoriam-entry">
                  <span class="memoriam-entry__name">{person.name}</span>
                  {person.role && <span class="memoriam-entry__role">{person.role}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}

      </div>

      <aside class="program-sidebar">
        <TableOfContents items={tocItems} />
      </aside>
    </div>
  </div>

  {/* ── Email Signup ── */}
  <EmailSignup doodleVariant="chimera" />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>
<script src="../../scripts/chimera-loop-3d.ts"></script>

<script>
  function initCommChimera() {
    const PRESETS = [
      { image: '/images/commencement-past/previousCommencementPhotos-002-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-003-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-004-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-005-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-006-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-007-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-008-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-009-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-010-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-011-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-012-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-013-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-014-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-015-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-016-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-017-03-2026-JL.jpg', shape: 97 },
    ];

    const LOOP_CONFIGS = [
      { cycleDuration: 9  },
      { cycleDuration: 13 },
      { cycleDuration: 11 },
    ];

    const containers = document.querySelectorAll<HTMLElement>('[data-comm-chimera]');
    containers.forEach((container, i) => initLoop(container, PRESETS, i, LOOP_CONFIGS[i] ?? LOOP_CONFIGS[0]));
  }

  function initLoop(
    container: HTMLElement,
    PRESETS: { image: string; shape: number }[],
    _startOffset: number,
    config: { cycleDuration: number },
  ) {
    const CYCLE_DURATION = config.cycleDuration;
    const FADE_OVERLAP = 0.2;
    const ELASTIC_INTENSITY = 0.8;
    const SKEW_AMOUNT = 8;
    const DRIFT_SPEED = 0.5;
    const SIZE_VARIANCE = 0.06;

    const morphDur = CYCLE_DURATION * FADE_OVERLAP;
    const holdDur = CYCLE_DURATION * (1 - FADE_OVERLAP * 2);

    function pad(n: number) { return String(n).padStart(3, '0'); }
    function shapeUrl(n: number) { return `/images/chimera-expanded-2026/shape-${pad(n)}.svg`; }
    function easeInOut(t: number) { return t < 0.5 ? 2*t*t : 1 - Math.pow(-2*t+2, 2)/2; }
    function elasticOut(t: number) {
      if (t === 0 || t === 1) return t;
      const p = 0.4;
      return Math.pow(2, -10*t) * Math.sin((t - p/4) * (2*Math.PI) / p) + 1;
    }
    function easeInCubic(t: number) { return t * t * t; }

    const slotEls = [
      container.querySelector<HTMLElement>('[data-slot="a"]')!,
      container.querySelector<HTMLElement>('[data-slot="b"]')!,
    ] as [HTMLElement, HTMLElement];
    const shapeEls = [
      container.querySelector<HTMLElement>('[data-shape="a"]')!,
      container.querySelector<HTMLElement>('[data-shape="b"]')!,
    ] as [HTMLElement, HTMLElement];

    type Phase = 'idle' | 'morph-in' | 'hold' | 'morph-out';
    interface SlotState { phase: Phase; start: number; skewDir: number; rotDir: number; sizeMult: number; }

    const state: [SlotState, SlotState] = [
      { phase: 'idle', start: 0, skewDir: 1, rotDir: 1, sizeMult: 1 },
      { phase: 'idle', start: 0, skewDir: 1, rotDir: 1, sizeMult: 1 },
    ];

    function kick(slot: 0 | 1, now: number) {
      const s = state[slot];
      const preset = PRESETS[Math.floor(Math.random() * PRESETS.length)];
      const url = shapeUrl(preset.shape);
      shapeEls[slot].style.maskImage = `url('${url}')`;
      shapeEls[slot].style.setProperty('-webkit-mask-image', `url('${url}')`);
      shapeEls[slot].style.backgroundImage = `url('${preset.image}')`;
      s.phase = 'morph-in';
      s.start = now;
      s.skewDir = Math.random() < 0.5 ? -1 : 1;
      s.rotDir = Math.random() < 0.5 ? -1 : 1;
      s.sizeMult = 1 + (Math.random() * 2 - 1) * SIZE_VARIANCE;
    }

    function updateSlot(slotIdx: 0 | 1, now: number) {
      const s = state[slotIdx];
      const el = slotEls[slotIdx];
      if (s.phase === 'idle') return;
      const elapsed = (now - s.start) / 1000;

      if (s.phase === 'morph-in') {
        const t = Math.min(elapsed / morphDur, 1);
        const elastic = elasticOut(t) * ELASTIC_INTENSITY + (1 - ELASTIC_INTENSITY) * easeInOut(t);
        const smooth = easeInOut(t);
        const scale = s.sizeMult * (0.3 + 0.7 * elastic);
        const skew = (1 - elastic) * SKEW_AMOUNT * s.skewDir;
        const rotate = (1 - smooth) * 12 * s.rotDir;
        el.style.opacity = String(Math.min(t / 0.6, 1));
        el.style.transform = `rotate(${rotate}deg) skew(${skew}deg) scale(${scale})`;
        if (t >= 1) {
          s.phase = 'hold'; s.start = now;
          el.style.opacity = '1';
          el.style.transform = `scale(${s.sizeMult})`;
        }
      } else if (s.phase === 'hold') {
        const t = elapsed / Math.max(holdDur, 0.1);
        const ds = DRIFT_SPEED;
        const breathe = Math.sin(elapsed * ds * 0.8) * 0.04;
        const driftRotate = Math.sin(elapsed * ds * 0.5) * 2 * s.rotDir;
        const driftSkew = Math.sin(elapsed * ds * 0.3) * 1.5 * s.skewDir;
        const driftY = Math.sin(elapsed * ds * 0.4) * 4;
        el.style.transform = `translateY(${driftY}px) rotate(${driftRotate}deg) skew(${driftSkew}deg) scale(${s.sizeMult * (1 + breathe)})`;
        if (t >= 1) {
          s.phase = 'morph-out'; s.start = now;
          kick((slotIdx === 0 ? 1 : 0) as 0 | 1, now);
        }
      } else if (s.phase === 'morph-out') {
        const t = Math.min(elapsed / morphDur, 1);
        const e = easeInCubic(t);
        const scaleX = s.sizeMult * (1 + e * 1.2);
        const scaleY = s.sizeMult * (1 - e * 0.4);
        const skew = e * SKEW_AMOUNT * 1.5 * -s.skewDir;
        const rotate = e * 20 * -s.rotDir;
        el.style.opacity = String(1 - easeInOut(t));
        el.style.transform = `rotate(${rotate}deg) skew(${skew}deg) scaleX(${scaleX}) scaleY(${scaleY})`;
        if (t >= 1) { s.phase = 'idle'; el.style.opacity = '0'; }
      }
    }

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
      const first = PRESETS[Math.floor(Math.random() * PRESETS.length)];
      shapeEls[0].style.maskImage = `url('${shapeUrl(first.shape)}')`;
      shapeEls[0].style.setProperty('-webkit-mask-image', `url('${shapeUrl(first.shape)}')`);
      shapeEls[0].style.backgroundImage = `url('${first.image}')`;
      slotEls[0].style.opacity = '1';
      return;
    }

    kick(0, performance.now());

    function tick(now: number) {
      updateSlot(0, now);
      updateSlot(1, now);
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  initCommChimera();
</script>

