---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CelebrationCard from '../../components/events/CelebrationCard.astro';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import Button from '../../components/ui/Button.astro';
import PastGallery from '../../components/sections/PastGallery.astro';
import HonoreeSpotlight from '../../components/sections/HonoreeSpotlight.astro';
import { formatDate } from '../../lib/utils/format';
import { getCelebrationEvents, getPeopleByRole } from '../../lib/utils/collections';

const events = await getCollection('events');
const undergradEvent = events.find(e => e.id === 'commencement-undergraduate');
const gradEvent = events.find(e => e.id === 'commencement-graduate');
const celebrations = await getCelebrationEvents();
const info = await getEntry('commencement-info', 'current');
const inMemoriam = info?.data.inMemoriam ?? [];

// Build unified honorees list
const roleLabels: Record<string, string> = {
  'honorary-doctorate': 'Honorary Doctorate',
  'distinguished-alumni': 'Distinguished Alumni',
  'professor-emeritus': 'Professor Emeritus',
};
const allPeople = [
  ...await getPeopleByRole('honorary-doctorate'),
  ...await getPeopleByRole('distinguished-alumni'),
  ...await getPeopleByRole('professor-emeritus'),
];
const honorees = [
  ...allPeople.map(p => ({
    name: p.data.name,
    role: roleLabels[p.data.role] ?? p.data.role,
    photo: p.data.photo,
    title: p.data.title,
    bio: p.data.bio,
    detail: p.data.ccaConnection,
  })),
  ...[
    { event: undergradEvent, placeholder: 'https://images.unsplash.com/photo-1529068755536-a5ade0dcb4e8?w=600&h=600&fit=crop&crop=face' },
    { event: gradEvent, placeholder: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=600&h=600&fit=crop&crop=face' },
  ]
    .filter(({ event }) => event?.data.ceremonyProgram?.studentSpeaker)
    .map(({ event, placeholder }) => {
      const sp = event!.data.ceremonyProgram!.studentSpeaker!;
      return {
        name: sp.name,
        role: 'Student Speaker',
        photo: { src: placeholder, alt: sp.name },
        title: sp.program,
        bio: sp.speechHighlights,
      };
    }),
];
// Determine if commencement has passed
const commencementEvents = events.filter(e => e.data.type === 'commencement');
const latestDate = commencementEvents.reduce((latest, e) => {
  const d = new Date(e.data.date);
  return d > latest ? d : latest;
}, new Date(0));
const isPostEvent = new Date() > latestDate;
---

<BaseLayout title="Commencement" themeKey="commencement">
  {/* ── Hero ── */}
  <section class="comm-hero" data-cursor-scope>
    <div class="comm-hero__seal" aria-hidden="true"></div>
    <div class="comm-hero__inner">
      <div class="comm-hero__content">
        <span class="comm-hero__label">CCA {info?.data.commencementNumber}</span>
        <h1 class="comm-hero__title shimmer-text">Commencement</h1>
        <p class="comm-hero__subtitle">
          {isPostEvent
            ? 'Congratulations to the Class of 2026'
            : 'Celebrate the Class of 2026'}
        </p>
        <div class="comm-hero__cta stagger-1">
          <Button href="#ceremonies" variant="primary">View Ceremonies</Button>
        </div>
      </div>
      <div class="comm-hero__media">
        <div class="comm-hero__frame" data-cursor-track data-cursor-strength="0.012" data-cursor-max="12" data-cursor-lerp="0.04">
          <img
            src="https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg"
            alt="Graduates celebrating at CCA Commencement"
            class="comm-hero__img"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="comm-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── Ceremonies ── */}
  <section id="ceremonies" class="ceremonies-section">
    <div class="container">
      <span class="section-label reveal">Ceremonies</span>
      <h2 class="section-heading reveal">Two Ceremonies, One Celebration</h2>
      <div class="ceremony-cards">
        {undergradEvent && (
          <a href="/commencement/undergraduate/" class="ceremony-card reveal">
            <div class="ceremony-card__accent" aria-hidden="true"></div>
            <span class="ceremony-card__badge">Undergraduate</span>
            <h3 class="ceremony-card__title">{undergradEvent.data.title}</h3>
            <time class="ceremony-card__date">{formatDate(undergradEvent.data.date)}</time>
            <p class="ceremony-card__meta">{undergradEvent.data.time}</p>
            <p class="ceremony-card__meta">{undergradEvent.data.location}</p>
            <span class="ceremony-card__cta">Details &rarr;</span>
          </a>
        )}

        {gradEvent && (
          <a href="/commencement/graduate/" class="ceremony-card reveal">
            <div class="ceremony-card__accent" aria-hidden="true"></div>
            <span class="ceremony-card__badge">Graduate</span>
            <h3 class="ceremony-card__title">{gradEvent.data.title}</h3>
            <time class="ceremony-card__date">{formatDate(gradEvent.data.date)}</time>
            <p class="ceremony-card__meta">{gradEvent.data.time}</p>
            <p class="ceremony-card__meta">{gradEvent.data.location}</p>
            <span class="ceremony-card__cta">Details &rarr;</span>
          </a>
        )}
      </div>
    </div>
  </section>

  {/* ── Honored People ── */}
  {honorees.length > 0 && (
    <HonoreeSpotlight honorees={honorees} />
  )}

  {/* ── Special Celebrations ── */}
  {celebrations.length > 0 && (
    <section class="celebrations-section">
      <div class="container">
        <span class="section-label reveal">Pre-Commencement</span>
        <h2 class="section-heading reveal">Special Celebrations</h2>
        <p class="section-desc reveal">Join us for celebrations honoring all graduating students before the main ceremonies.</p>
        <div class="celebrations-grid">
          {celebrations.map((event) => (
            <CelebrationCard event={event} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Past Commencement Gallery ── */}
  <PastGallery
    label="Past Commencements"
    title="Celebrating Generations of Graduates"
    images={[
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Graduates celebrating at a previous CCA commencement' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Commencement ceremony processional' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Students receiving their diplomas' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Families and friends at commencement' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Cap toss celebration moment' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Graduate portraits from past years' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/commencement-masters24-2025-body-001.original.jpg', alt: 'Decorated graduation caps' },
      { src: 'https://storage.googleapis.com/ccaedu-prod/media/images/large_digital_jpg-CCA_EOY-Show_SP25-115-jrl2.original.jpg', alt: 'Celebration with faculty and staff' },
    ]}
  />

  {/* ── In Memoriam ── */}
  {inMemoriam.length > 0 && (
    <section class="memoriam-section">
      <div class="container">
        <span class="section-label reveal">In Memoriam</span>
        <h2 class="section-heading reveal">Remembering Members of Our Community</h2>
        <p class="memoriam-intro reveal">We honor the members of the CCA community who passed during this academic year. Their contributions continue to inspire us.</p>
        <ul class="memoriam-list reveal">
          {inMemoriam.map((person) => (
            <li class="memoriam-entry">
              <span class="memoriam-entry__name">{person.name}</span>
              {person.role && <span class="memoriam-entry__role">{person.role}</span>}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ── Email Signup ── */}
  <EmailSignup />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>

<style>
  /* ── Hero ── */
  .comm-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .comm-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: var(--space-8);
    width: 100%;
    max-width: 1440px;
    padding-inline: var(--space-4);
  }

  @media (min-width: 768px) {
    .comm-hero__inner {
      grid-template-columns: 45fr 55fr;
      gap: var(--space-10);
      padding-inline: var(--space-10);
    }
  }

  @media (min-width: 1024px) {
    .comm-hero__inner {
      padding-inline: var(--space-12);
    }
  }

  .comm-hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .comm-hero__content {
      align-items: flex-start;
      text-align: left;
    }
  }

  .comm-hero__label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
  }

  .comm-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 8rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  .comm-hero__subtitle {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-muted);
    margin-top: var(--space-4);
  }

  .comm-hero__cta {
    margin-top: var(--space-6);
  }

  /* ── Hero media ── */
  .comm-hero__media {
    display: flex;
    justify-content: center;
  }

  .comm-hero__frame {
    border-radius: var(--radius-card);
    padding: 3px;
    background: var(--gradient-prismatic);
    background-size: 200% 200%;
    width: 95%;
    max-width: 560px;
  }

  @media (min-width: 768px) {
    .comm-hero__frame {
      width: 100%;
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .comm-hero__frame {
      animation: prismatic-shift 6s linear infinite;
    }
  }

  .comm-hero__img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center 30%;
    border-radius: calc(var(--radius-card) - 2px);
  }

  .comm-hero__seal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(280px, 60vw, 600px);
    aspect-ratio: 1;
    background: var(--color-accent);
    opacity: 0.07;
    mask-image: url('/images/cca-seal.svg');
    -webkit-mask-image: url('/images/cca-seal.svg');
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  @media (min-width: 768px) {
    .comm-hero__seal {
      left: 70%;
      width: clamp(200px, 35vw, 400px);
      opacity: 0.05;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .comm-hero__seal {
      animation: seal-hero-breathe 12s ease-in-out infinite;
    }
  }

  .comm-hero__scroll {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .comm-hero__scroll {
      animation: none;
      opacity: 0.6;
    }
  }

  /* ── Section rhythm ── */
  .ceremonies-section,
  .celebrations-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    margin-bottom: var(--space-10);
  }

  .section-desc {
    font-size: var(--text-base);
    color: var(--color-muted);
    max-width: 55ch;
    line-height: 1.6;
    margin-bottom: var(--space-8);
  }

  .container--narrow {
    max-width: 700px;
    margin-inline: auto;
  }

  /* ── Ceremony cards ── */
  .ceremony-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .ceremony-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ceremony-card {
    display: block;
    position: relative;
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    overflow: hidden;
    transition: transform 0.3s var(--ease-out-expo),
                box-shadow 0.3s var(--ease-out-expo);
  }

  .ceremony-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  .ceremony-card__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-prismatic);
  }

  @media (prefers-reduced-motion: no-preference) {
    .ceremony-card__accent {
      animation: prismatic-shift 6s linear infinite;
    }

    .ceremony-card:hover .ceremony-card__accent {
      animation-duration: 2s;
    }
  }

  .ceremony-card__badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    margin-bottom: var(--space-4);
  }

  .ceremony-card__title {
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .ceremony-card__date {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .ceremony-card__meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-1);
  }

  .ceremony-card__cta {
    display: inline-block;
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    transition: letter-spacing 0.2s var(--ease-out-expo);
  }

  .ceremony-card:hover .ceremony-card__cta {
    letter-spacing: 0.05em;
  }

  /* ── Celebrations grid ── */
  .celebrations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: var(--space-6);
  }

  /* ── In Memoriam ── */
  .memoriam-section {
    padding-block: var(--space-20);
  }

  .memoriam-intro {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 50ch;
    margin-bottom: var(--space-10);
  }

  .memoriam-list {
    list-style: none;
    padding: 0;
    margin: 0;
    column-count: 1;
    column-gap: var(--space-8);
    text-align: left;
  }

  @media (min-width: 640px) {
    .memoriam-list {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .memoriam-list {
      column-count: 3;
    }
  }

  .memoriam-entry {
    break-inside: avoid;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .memoriam-entry__name {
    display: block;
    font-size: var(--text-base);
    font-weight: 600;
  }

  .memoriam-entry__role {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.02em;
    margin-top: 2px;
  }

</style>
