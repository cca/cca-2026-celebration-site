---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParticleField from '../../components/effects/ParticleField.astro';
import { chimeraExpanded2026Paths } from '../../data/chimera-expanded-2026-paths';
import CelebrationCard from '../../components/events/CelebrationCard.astro';
import EmailSignup from '../../components/sections/EmailSignup.astro';
import Button from '../../components/ui/Button.astro';
import ChimeraLoop3D from '../../components/effects/ChimeraLoop3D.astro';

import PastGallery from '../../components/sections/PastGallery.astro';
import HonoreeSpotlight from '../../components/sections/HonoreeSpotlight.astro';
import { formatDate, formatTime } from '../../lib/utils/format';
import { getCelebrationEvents, getPeopleByRole } from '../../lib/utils/collections';
import PhaseGate from '../../components/PhaseGate.astro';
import { getCurrentPhase } from '../../lib/utils/phase';
import { isPhaseAtLeast, isPhaseBefore } from '../../config/phases';

const events = await getCollection('events');
const undergradEvent = events.find(e => e.id === 'commencement-undergraduate');
const gradEvent = events.find(e => e.id === 'commencement-graduate');
const celebrations = await getCelebrationEvents();
const info = await getEntry('commencement-info', 'current');
const inMemoriam = info?.data.inMemoriam ?? [];

// Build unified honorees list
const roleLabels: Record<string, string> = {
  'honorary-doctorate': 'Honorary Doctorate',
  'distinguished-alumni': 'Distinguished Alumni',
  'professor-emeritus': 'Professor Emeritus',
};
const allPeople = [
  ...await getPeopleByRole('honorary-doctorate'),
  ...await getPeopleByRole('distinguished-alumni'),
  ...await getPeopleByRole('professor-emeritus'),
];
const honorees = [
  ...allPeople.map(p => ({
    name: p.data.name,
    role: roleLabels[p.data.role] ?? p.data.role,
    photo: p.data.photo,
    title: p.data.title,
    bio: p.data.bio,
    detail: p.data.ccaConnection,
  })),
  ...[undergradEvent, gradEvent]
    .filter((event) => event?.data.ceremonyProgram?.studentSpeaker)
    .map((event) => {
      const sp = event!.data.ceremonyProgram!.studentSpeaker!;
      return {
        name: sp.name,
        role: 'Student Speaker',
        title: sp.program,
        bio: sp.speechHighlights,
      };
    }),
];
const phase = getCurrentPhase(Astro.url);
---

<BaseLayout title="Commencement" themeKey="commencement">
  <ParticleField
    mode="svg"
    svgPaths={chimeraExpanded2026Paths}
    colors={['#00bfb3', '#f2b23a', '#7ec8e3']}
    count={60}
    sizeRange={[18, 55]}
    opacityRange={[0.12, 0.45]}
  />

  {/* ── Hero ── */}
  <section class="comm-hero" data-cursor-scope>
    <div class="comm-hero__collage" aria-hidden="true">
      <div
        class="comm-hero__fragment comm-hero__fragment--1"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.035"
        data-cursor-max="36"
        data-cursor-lerp="0.06"
      >
        <div class="comm-hero__masked-loop" data-comm-chimera>
          <div class="comm-hero__masked-slot" data-slot="a">
            <div class="comm-hero__masked-shape" data-shape="a"></div>
          </div>
          <div class="comm-hero__masked-slot" data-slot="b">
            <div class="comm-hero__masked-shape" data-shape="b"></div>
          </div>
        </div>
      </div>
      <div
        class="comm-hero__fragment comm-hero__fragment--2"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.055"
        data-cursor-max="28"
        data-cursor-lerp="0.12"
      >
        <div class="comm-hero__masked-loop" data-comm-chimera>
          <div class="comm-hero__masked-slot" data-slot="a">
            <div class="comm-hero__masked-shape" data-shape="a"></div>
          </div>
          <div class="comm-hero__masked-slot" data-slot="b">
            <div class="comm-hero__masked-shape" data-shape="b"></div>
          </div>
        </div>
      </div>
      <div
        class="comm-hero__fragment comm-hero__fragment--3"
        data-cursor-track
        data-cursor-direction="towards"
        data-cursor-strength="0.03"
        data-cursor-max="20"
        data-cursor-lerp="0.08"
      >
        <div class="comm-hero__masked-loop" data-comm-chimera>
          <div class="comm-hero__masked-slot" data-slot="a">
            <div class="comm-hero__masked-shape" data-shape="a"></div>
          </div>
          <div class="comm-hero__masked-slot" data-slot="b">
            <div class="comm-hero__masked-shape" data-shape="b"></div>
          </div>
        </div>
      </div>
      <div
        class="comm-hero__fragment comm-hero__doodle comm-hero__doodle--1"
        data-cursor-track
        data-cursor-strength="0.05"
        data-cursor-max="45"
        data-cursor-lerp="0.12"
      >
        <ChimeraLoop3D
          id="comm-hero-chimera-1"
          cycleDuration={4}
          fadeOverlap={0.3}
          elasticIntensity={1}
          skewAmount={15}
          driftSpeed={1}
          sizeVariance={0.25}
          color="#ffffff"
        />
      </div>
      <div
        class="comm-hero__fragment comm-hero__doodle comm-hero__doodle--2"
        data-cursor-track
        data-cursor-strength="0.038"
        data-cursor-max="32"
        data-cursor-lerp="0.09"
      >
        <ChimeraLoop3D
          id="comm-hero-chimera-2"
          cycleDuration={4}
          fadeOverlap={0.3}
          elasticIntensity={1}
          skewAmount={15}
          driftSpeed={1}
          sizeVariance={0.25}
          color="#ffffff"
          startDelay={2}
        />
      </div>
    </div>
    <div class="comm-hero__content">
      <h1 class="comm-hero__logo-wrap">
        <img
          src="/images/commencement/commencement-secondary-36.svg"
          alt="CCA Commencement 2026"
          class="comm-hero__logo"
          width="900"
          height="630"
        />
      </h1>
    </div>
    <div class="comm-hero__scroll" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  {/* ── Ceremonies ── */}
  <section id="ceremonies" class="ceremonies-section">
    <div class="container">
      <span class="section-label reveal">Ceremonies</span>
      <h2 class="section-heading reveal">Two ceremonies, one celebration</h2>
      {(gradEvent || undergradEvent) && (() => {
        const sharedEvent = (gradEvent || undergradEvent)!;
        return (
          <p class="ceremony-shared-meta reveal">
            <time>{formatDate(sharedEvent.data.date)}</time>
            {' · '}
            <a href={`https://maps.google.com/?q=${encodeURIComponent(sharedEvent.data.address)}`} target="_blank" rel="noopener noreferrer">
              {sharedEvent.data.location}
            </a>
          </p>
        );
      })()}
      <div class="ceremony-cards">
        {gradEvent && isPhaseBefore(phase, 'during-event') ? (
          <div class="ceremony-info reveal">
            <div class="ceremony-info__accent" aria-hidden="true"></div>
            <span class="ceremony-info__badge">{gradEvent.data.time ? formatTime(gradEvent.data.time) : null}</span>
            <h3 class="ceremony-info__title">{gradEvent.data.title}</h3>
          </div>
        ) : gradEvent && (
          <a href="/commencement/masters/" class="ceremony-card reveal">
            <div class="ceremony-card__accent" aria-hidden="true"></div>
            <span class="ceremony-card__badge">{gradEvent.data.time ? formatTime(gradEvent.data.time) : null}</span>
            <h3 class="ceremony-card__title">{gradEvent.data.title}</h3>
            <span class="ceremony-card__cta">Details &rarr;</span>
          </a>
        )}

        {undergradEvent && isPhaseBefore(phase, 'during-event') ? (
          <div class="ceremony-info reveal">
            <div class="ceremony-info__accent" aria-hidden="true"></div>
            <span class="ceremony-info__badge">{undergradEvent.data.time ? formatTime(undergradEvent.data.time) : null}</span>
            <h3 class="ceremony-info__title">{undergradEvent.data.title}</h3>
          </div>
        ) : undergradEvent && (
          <a href="/commencement/bachelors/" class="ceremony-card reveal">
            <div class="ceremony-card__accent" aria-hidden="true"></div>
            <span class="ceremony-card__badge">{undergradEvent.data.time ? formatTime(undergradEvent.data.time) : null}</span>
            <h3 class="ceremony-card__title">{undergradEvent.data.title}</h3>
            <span class="ceremony-card__cta">Details &rarr;</span>
          </a>
        )}
      </div>
      <div class="ceremonies-cta reveal">
        <Button href="https://portal.cca.edu/thriving/student-engagement/commencement/#latest-updates--emails" variant="link">Up-to-date information, deadlines, and important links</Button>
      </div>
    </div>
  </section>

  {/* ── Honored People ── */}
  <PhaseGate hiddenIn={['save-the-date', 'pre-event']}>
    {honorees.length > 0 && (
      <HonoreeSpotlight honorees={honorees} />
    )}
  </PhaseGate>

  {/* ── Special Celebrations ── */}
  <PhaseGate hiddenIn={['save-the-date']}>
    {celebrations.length > 0 && (
      <section class="celebrations-section">
        <div class="container">
          <h2 class="section-heading reveal">Special celebrations</h2>
          <p class="section-desc reveal">Join us for celebrations honoring all graduating students before the main ceremonies. Hosted by the Office of Student Belonging &amp; Inclusion.</p>
          <div class="celebrations-grid">
            {celebrations.map((event) => (
              <CelebrationCard event={event} />
            ))}
          </div>
        </div>
      </section>
    )}
  </PhaseGate>

  {/* ── Past Commencement Gallery ── */}
  <PastGallery
    label="Past commencements"
    title="Celebrating generations of graduates"
    marqueeDuration={90}
    images={[
      { src: '/images/commencement-past/previousCommencementPhotos-001-03-2026-JL.jpg', alt: 'A graduate in a vibrant pink shawl stands next to colorful paper lanterns and rainbow streamers, smiling during a commencement celebration.' },
      { src: '/images/commencement-past/previousCommencementPhotos-002-03-2026-JL.jpg', alt: 'A group of ten students dressed in casual clothing pose together in front of decorative purple lanterns and colorful ribbons at an indoor celebration.' },
      { src: '/images/commencement-past/previousCommencementPhotos-003-03-2026-JL.jpg', alt: 'Three male graduates wearing black robes and colorful cultural sashes stand together outdoors on a brick plaza, smiling at the camera.' },
      { src: '/images/commencement-past/previousCommencementPhotos-004-03-2026-JL.jpg', alt: 'Two graduates in formal attire pose together outdoors; one wears a green dress and the other a pink blazer, both smiling in front of a white building.' },
      { src: '/images/commencement-past/previousCommencementPhotos-005-03-2026-JL.jpg', alt: 'Four graduates dressed in vibrant pink and purple outfits pose together in a parking lot during a bright, sunny commencement day.' },
      { src: '/images/commencement-past/previousCommencementPhotos-006-03-2026-JL.jpg', alt: 'Three graduates with colorful hair stand together on a white courtyard; one wears navy and black, another a gray dress, and the third a teal skirt with yellow sash.' },
      { src: '/images/commencement-past/previousCommencementPhotos-007-03-2026-JL.jpg', alt: 'Nine graduates in black academic robes and regalia pose together indoors, with two seated in front and seven standing behind them.' },
      { src: '/images/commencement-past/previousCommencementPhotos-008-03-2026-JL.jpg', alt: 'Two graduates in black robes with colorful cultural sashes sit together on red auditorium seats, smiling during the commencement ceremony.' },
      { src: '/images/commencement-past/previousCommencementPhotos-009-03-2026-JL.jpg', alt: 'Four graduates pose together outdoors against a brick building; they wear a mix of casual and formal attire, including vibrant pink and maroon colors.' },
      { src: '/images/commencement-past/previousCommencementPhotos-010-03-2026-JL.jpg', alt: 'A group of graduates in black robes and mortarboards stand together in front of a brick building, celebrating with raised arms and smiling at the camera.' },
      { src: '/images/commencement-past/previousCommencementPhotos-011-03-2026-JL.jpg', alt: 'A diverse group of young graduates wearing leis and graduation regalia pose together outdoors in front of a modern building with colorful turquoise architectural elements.' },
      { src: '/images/commencement-past/previousCommencementPhotos-012-03-2026-JL.jpg', alt: 'Two graduates embrace in front of a celebration backdrop decorated with purple and white balloons, with a paved courtyard and building visible behind them.' },
      { src: '/images/commencement-past/previousCommencementPhotos-013-03-2026-JL.jpg', alt: 'Graduates in caps, gowns, and cultural regalia stand in an auditorium with red seats, many wearing decorative sashes and stoles representing their cultural heritage.' },
      { src: '/images/commencement-past/previousCommencementPhotos-014-03-2026-JL.jpg', alt: 'Two speakers in academic regalia stand at a CCAlum podium during a commencement ceremony, with one holding a microphone as they address the audience.' },
      { src: '/images/commencement-past/previousCommencementPhotos-015-03-2026-JL.jpg', alt: 'A group of graduates in caps and gowns pose together indoors, smiling and posing for a photo in a hallway with windows and other attendees visible in the background.' },
      { src: '/images/commencement-past/previousCommencementPhotos-016-03-2026-JL.jpg', alt: 'Graduates in academic regalia celebrate in a courtyard, some wearing colorful leis and sashes, with historic buildings featuring arched architecture surrounding them.' },
      { src: '/images/commencement-past/previousCommencementPhotos-017-03-2026-JL.jpg', alt: 'A group of graduates wearing black gowns and yellow sashes pose together in a brick courtyard, standing in front of historic buildings on the campus grounds.' },
    ]}
  />

  {/* ── In Memoriam ── */}
  {isPhaseAtLeast(phase, 'during-event') && inMemoriam.length > 0 && (
    <section class="memoriam-section">
      <div class="container">
        <span class="section-label reveal">In Memoriam</span>
        <h2 class="section-heading reveal">Remembering members of our community</h2>
        <p class="memoriam-intro reveal">We honor the members of the CCA community who passed during this academic year. Their contributions continue to inspire us.</p>
        <ul class="memoriam-list reveal">
          {inMemoriam.map((person) => (
            <li class="memoriam-entry">
              <span class="memoriam-entry__name">{person.name}</span>
              {person.role && <span class="memoriam-entry__role">{person.role}</span>}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* ── Email Signup ── */}
  <EmailSignup doodleVariant="chimera" />
</BaseLayout>

<script src="../../scripts/cursor-track.ts"></script>
<script src="../../scripts/chimera-loop-3d.ts"></script>

<script>
  function initCommChimera() {
    const PRESETS = [
      { image: '/images/commencement-past/previousCommencementPhotos-001-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-002-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-003-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-004-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-005-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-006-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-007-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-008-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-009-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-010-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-011-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-012-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-013-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-014-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-015-03-2026-JL.jpg', shape: 97 },
      { image: '/images/commencement-past/previousCommencementPhotos-016-03-2026-JL.jpg', shape: 40 },
      { image: '/images/commencement-past/previousCommencementPhotos-017-03-2026-JL.jpg', shape: 97 },
    ];

    const LOOP_CONFIGS = [
      { cycleDuration: 9  },
      { cycleDuration: 13 },
      { cycleDuration: 11 },
    ];

    const containers = document.querySelectorAll<HTMLElement>('[data-comm-chimera]');
    containers.forEach((container, i) => initLoop(container, PRESETS, i, LOOP_CONFIGS[i] ?? LOOP_CONFIGS[0]));
  }

  function initLoop(
    container: HTMLElement,
    PRESETS: { image: string; shape: number }[],
    _startOffset: number,
    config: { cycleDuration: number },
  ) {
    const CYCLE_DURATION = config.cycleDuration;
    const FADE_OVERLAP = 0.2;
    const ELASTIC_INTENSITY = 0.8;
    const SKEW_AMOUNT = 8;
    const DRIFT_SPEED = 0.5;
    const SIZE_VARIANCE = 0.06;

    const morphDur = CYCLE_DURATION * FADE_OVERLAP;
    const holdDur = CYCLE_DURATION * (1 - FADE_OVERLAP * 2);

    function pad(n: number) { return String(n).padStart(3, '0'); }
    function shapeUrl(n: number) { return `/images/chimera-expanded-2026/shape-${pad(n)}.svg`; }
    function easeInOut(t: number) { return t < 0.5 ? 2*t*t : 1 - Math.pow(-2*t+2, 2)/2; }
    function elasticOut(t: number) {
      if (t === 0 || t === 1) return t;
      const p = 0.4;
      return Math.pow(2, -10*t) * Math.sin((t - p/4) * (2*Math.PI) / p) + 1;
    }
    function easeInCubic(t: number) { return t * t * t; }

    const slotEls = [
      container.querySelector<HTMLElement>('[data-slot="a"]')!,
      container.querySelector<HTMLElement>('[data-slot="b"]')!,
    ] as [HTMLElement, HTMLElement];
    const shapeEls = [
      container.querySelector<HTMLElement>('[data-shape="a"]')!,
      container.querySelector<HTMLElement>('[data-shape="b"]')!,
    ] as [HTMLElement, HTMLElement];

    type Phase = 'idle' | 'morph-in' | 'hold' | 'morph-out';
    interface SlotState { phase: Phase; start: number; skewDir: number; rotDir: number; sizeMult: number; }

    const state: [SlotState, SlotState] = [
      { phase: 'idle', start: 0, skewDir: 1, rotDir: 1, sizeMult: 1 },
      { phase: 'idle', start: 0, skewDir: 1, rotDir: 1, sizeMult: 1 },
    ];

    function kick(slot: 0 | 1, now: number) {
      const s = state[slot];
      const preset = PRESETS[Math.floor(Math.random() * PRESETS.length)];
      const url = shapeUrl(preset.shape);
      shapeEls[slot].style.maskImage = `url('${url}')`;
      shapeEls[slot].style.setProperty('-webkit-mask-image', `url('${url}')`);
      shapeEls[slot].style.backgroundImage = `url('${preset.image}')`;
      s.phase = 'morph-in';
      s.start = now;
      s.skewDir = Math.random() < 0.5 ? -1 : 1;
      s.rotDir = Math.random() < 0.5 ? -1 : 1;
      s.sizeMult = 1 + (Math.random() * 2 - 1) * SIZE_VARIANCE;
    }

    function updateSlot(slotIdx: 0 | 1, now: number) {
      const s = state[slotIdx];
      const el = slotEls[slotIdx];
      if (s.phase === 'idle') return;
      const elapsed = (now - s.start) / 1000;

      if (s.phase === 'morph-in') {
        const t = Math.min(elapsed / morphDur, 1);
        const elastic = elasticOut(t) * ELASTIC_INTENSITY + (1 - ELASTIC_INTENSITY) * easeInOut(t);
        const smooth = easeInOut(t);
        const scale = s.sizeMult * (0.3 + 0.7 * elastic);
        const skew = (1 - elastic) * SKEW_AMOUNT * s.skewDir;
        const rotate = (1 - smooth) * 12 * s.rotDir;
        el.style.opacity = String(Math.min(t / 0.6, 1));
        el.style.transform = `rotate(${rotate}deg) skew(${skew}deg) scale(${scale})`;
        if (t >= 1) {
          s.phase = 'hold'; s.start = now;
          el.style.opacity = '1';
          el.style.transform = `scale(${s.sizeMult})`;
        }
      } else if (s.phase === 'hold') {
        const t = elapsed / Math.max(holdDur, 0.1);
        const ds = DRIFT_SPEED;
        const breathe = Math.sin(elapsed * ds * 0.8) * 0.04;
        const driftRotate = Math.sin(elapsed * ds * 0.5) * 2 * s.rotDir;
        const driftSkew = Math.sin(elapsed * ds * 0.3) * 1.5 * s.skewDir;
        const driftY = Math.sin(elapsed * ds * 0.4) * 4;
        el.style.transform = `translateY(${driftY}px) rotate(${driftRotate}deg) skew(${driftSkew}deg) scale(${s.sizeMult * (1 + breathe)})`;
        if (t >= 1) {
          s.phase = 'morph-out'; s.start = now;
          kick((slotIdx === 0 ? 1 : 0) as 0 | 1, now);
        }
      } else if (s.phase === 'morph-out') {
        const t = Math.min(elapsed / morphDur, 1);
        const e = easeInCubic(t);
        const scaleX = s.sizeMult * (1 + e * 1.2);
        const scaleY = s.sizeMult * (1 - e * 0.4);
        const skew = e * SKEW_AMOUNT * 1.5 * -s.skewDir;
        const rotate = e * 20 * -s.rotDir;
        el.style.opacity = String(1 - easeInOut(t));
        el.style.transform = `rotate(${rotate}deg) skew(${skew}deg) scaleX(${scaleX}) scaleY(${scaleY})`;
        if (t >= 1) { s.phase = 'idle'; el.style.opacity = '0'; }
      }
    }

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
      const first = PRESETS[Math.floor(Math.random() * PRESETS.length)];
      shapeEls[0].style.maskImage = `url('${shapeUrl(first.shape)}')`;
      shapeEls[0].style.setProperty('-webkit-mask-image', `url('${shapeUrl(first.shape)}')`);
      shapeEls[0].style.backgroundImage = `url('${first.image}')`;
      slotEls[0].style.opacity = '1';
      return;
    }

    kick(0, performance.now());

    function tick(now: number) {
      updateSlot(0, now);
      updateSlot(1, now);
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  initCommChimera();
</script>

<style>
  /* ── Hero ── */
  .comm-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-x: clip;
    overflow-y: visible;
  }

  .comm-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: var(--space-4);
  }

  .comm-hero__logo-wrap {
    margin: 0 0 var(--space-6);
    line-height: 0;
  }

  .comm-hero__logo {
    width: clamp(300px, 52vw, 640px);
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .comm-hero__cta {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Collage fragments ── */
  .comm-hero__collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .comm-hero__fragment {
    position: absolute;
  }

  .comm-hero__fragment--1 {
