---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/fonts.css';
import '../styles/global.css';
import '../styles/themes.css';
import '../styles/grid.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description?: string;
  themeKey?: string;
  minimalHeader?: boolean;
  ogImage?: string;
}

const { title, description, themeKey, minimalHeader = false, ogImage } = Astro.props;
const pageTitle = `${title} | CCA 2026`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://2026.cca.edu');
const defaultDescription = "Celebrate the achievements of CCA's Class of 2026 at commencement ceremonies, exhibitions, and showcases.";
const metaDescription = description ?? defaultDescription;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-5CZR96');</script>
    <!-- End Google Tag Manager -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="CCA 2026 Celebrations" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/lineto-brown-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ChimeraDisplay-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <ViewTransitions />
  </head>
  <body data-theme={themeKey}>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5CZR96"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip-link" href="#main">Skip to main content</a>
    <Header minimal={minimalHeader} transition:animate="none" />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/scroll-reveal.ts"></script>
    <script src="../scripts/header-scroll.ts"></script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-bg);
    z-index: 100;
    text-decoration: none;
    font-weight: 700;
  }

  .skip-link:focus {
    top: var(--space-4);
  }
</style>
