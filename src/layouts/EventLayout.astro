---
import BaseLayout from './BaseLayout.astro';
import ParticleField from '../components/effects/ParticleField.astro';
import { chimeraPaths } from '../data/chimera-paths';

interface Props {
  event: {
    data: {
      title: string;
      themeKey: string;
      description: string;
      [key: string]: unknown;
    };
  };
  title?: string;
}

const { event, title } = Astro.props;
const pageTitle = title ?? event.data.title;
---

<BaseLayout title={pageTitle} description={event.data.description} themeKey={event.data.themeKey}>
  <ParticleField
    mode="svg"
    svgPaths={chimeraPaths}
    colors={['#005776', '#00BFB3', '#563D82', '#FFC845']}
    count={40}
    sizeRange={[18, 52]}
    opacityRange={[0.06, 0.25]}
  />
  <div class="event-page">
    <slot />
  </div>
</BaseLayout>

<style>
  .event-page {
    min-height: 100vh;
  }
</style>
