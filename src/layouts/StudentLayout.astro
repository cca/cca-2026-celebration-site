---
import BaseLayout from './BaseLayout.astro';
import { fullName } from '../lib/utils/format';

interface Props {
  student: {
    data: {
      firstName: string;
      lastName: string;
      pronouns?: string;
      photo: { src: string; alt: string };
      program: { id: string };
      degreeLevel: string;
      degreeType: string;
      expectedGraduation: string;
      bio?: string;
      links?: Array<{ label: string; url: string; type: string }>;
      newsroomStories?: Array<{ title: string; url: string; date?: string; summary?: string; listingTitle?: string; image?: { src: string; alt: string } }>;
    };
  };
}

const { student } = Astro.props;
const name = fullName(student);
---

<BaseLayout title={name}>
  <article class="student-profile container">
    <slot name="breadcrumb" />
    <header class="student-header reveal">
      <div class="student-photo">
        <img src={student.data.photo.src} alt={student.data.photo.alt} loading="lazy" />
      </div>
      <div class="student-info">
        <h1>{name}</h1>
        {student.data.pronouns && <p class="pronouns">{student.data.pronouns}</p>}
        <p class="degree">{student.data.degreeType} &middot; {student.data.expectedGraduation}</p>
        {student.data.bio && <p class="bio">{student.data.bio}</p>}
        {student.data.links && student.data.links.length > 0 && (
          <ul class="links">
            {student.data.links.map(link => (
              <li><a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a></li>
            ))}
          </ul>
        )}
      </div>
    </header>

    {student.data.newsroomStories && student.data.newsroomStories.length > 0 && (
      <section class="newsroom-stories reveal">
        <h2>In the News</h2>
        <ul class="story-cards">
          {student.data.newsroomStories.map(story => (
            <li>
              <a class="story-card" href={`https://www.cca.edu${story.url}`} target="_blank" rel="noopener noreferrer">
                {story.image && (
                  <img class="story-thumb" src={story.image.src} alt={story.image.alt} loading="lazy" />
                )}
                <div class="story-text">
                  <span class="story-title">{story.listingTitle || story.title}</span>
                  {story.summary && <p class="story-summary">{story.summary}</p>}
                  {story.date && (
                    <span class="story-date">
                      {new Date(story.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </span>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="student-works">
      <slot />
    </section>
  </article>
</BaseLayout>

<style>
  .student-profile {
    padding-block: var(--space-12);
  }

  .student-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .student-header {
      grid-template-columns: 280px 1fr;
    }
  }

  .student-photo img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 8px;
  }

  .student-info h1 {
    margin-bottom: var(--space-2);
  }

  .pronouns {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }

  .degree {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .bio {
    margin-bottom: var(--space-6);
  }

  .links {
    list-style: none;
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .links a {
    font-size: var(--text-sm);
  }

  .newsroom-stories {
    margin-top: var(--space-6);
  }

  .newsroom-stories h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .story-cards {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .story-card {
    display: flex;
    gap: var(--space-4);
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border, #e5e5e5);
    transition: box-shadow 0.2s ease;
  }

  .story-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .story-thumb {
    width: 160px;
    min-height: 120px;
    object-fit: cover;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .story-card {
      flex-direction: column;
    }
    .story-thumb {
      width: 100%;
      height: 160px;
    }
  }

  .story-text {
    padding: var(--space-3) var(--space-4) var(--space-3) 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
  }

  .story-card:not(:has(.story-thumb)) .story-text {
    padding-left: var(--space-4);
  }

  .story-title {
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.3;
  }

  .story-summary {
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .story-date {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-size: var(--text-xs);
  }
</style>
