---
import BaseLayout from './BaseLayout.astro';
import DocsNav from '../components/docs/DocsNav.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import '../styles/docs.css';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
}

const { title, description, currentSlug, breadcrumb } = Astro.props;
---

<BaseLayout title={`${title} — Developer Docs`} description={description}>
  <div class="docs-shell">
    <!-- Desktop sidebar -->
    <aside class="docs-sidebar">
      <div class="docs-sidebar-header">
        <a href="/docs/" class="docs-home-link">Developer Docs</a>
        <div class="docs-brand-strip" aria-hidden="true"></div>
        <a href="/" class="docs-back-link"><span class="back-arrow">←</span> Back to site</a>
      </div>
      <DocsNav currentSlug={currentSlug} />
    </aside>

    <!-- Mobile sidebar (details/summary, zero JS) -->
    <details class="docs-sidebar-mobile">
      <summary>
        <span>Developer Docs — Navigation</span>
        <span class="chevron" aria-hidden="true">▾</span>
      </summary>
      <div class="docs-sidebar-mobile-panel">
        <DocsNav currentSlug={currentSlug} />
      </div>
    </details>

    <!-- Main content -->
    <div class="docs-content">
      {breadcrumb && breadcrumb.length > 0 && (
        <Breadcrumb items={breadcrumb} />
      )}
      <article class="docs-prose">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .docs-shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    grid-template-rows: auto 1fr;
    min-height: calc(100vh - 4rem);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--grid-gutter);
    gap: 0 var(--space-8);
  }

  /* Desktop sidebar */
  .docs-sidebar {
    grid-row: 1 / -1;
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
    padding-block: var(--space-8);
    border-right: 1px solid color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .docs-sidebar-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-inline: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .docs-home-link {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--color-text);
    text-decoration: none;
  }

  .docs-home-link:hover {
    color: var(--color-accent);
    background-size: 0%;
  }

  .docs-brand-strip {
    height: 3px;
    background: var(--gradient-prismatic);
    border-radius: var(--radius-sm);
    opacity: 0.6;
    margin-block: var(--space-3);
  }

  .docs-back-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text);
    opacity: 0.75;
    text-decoration: none;
    transition: opacity var(--duration-fast);
  }

  .docs-back-link:hover {
    opacity: 1;
    background-size: 0%;
  }

  .back-arrow {
    color: var(--color-accent);
  }

  /* Mobile sidebar — hidden by default */
  .docs-sidebar-mobile {
    display: none;
    grid-column: 1 / -1;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    margin-block: var(--space-4);
    overflow: hidden;
  }

  .docs-sidebar-mobile summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    font-weight: 600;
    font-size: var(--text-sm);
    background: var(--color-surface);
    list-style: none;
    user-select: none;
  }

  .docs-sidebar-mobile summary::-webkit-details-marker {
    display: none;
  }

  .docs-sidebar-mobile[open] .chevron {
    transform: rotate(180deg);
  }

  .chevron {
    display: inline-block;
    transition: transform var(--duration-fast);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .docs-sidebar-mobile-panel {
    padding: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  /* Main content */
  .docs-content {
    padding-block: var(--space-8);
    min-width: 0; /* prevent overflow */
  }

  /* Mobile: single column */
  @media (max-width: 899px) {
    .docs-shell {
      grid-template-columns: 1fr;
    }

    .docs-sidebar {
      display: none;
    }

    .docs-sidebar-mobile {
      display: block;
    }
  }
</style>
