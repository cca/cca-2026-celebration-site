{
  "id": "celebration-teal",
  "name": "Celebration Teal",
  "thumbnail": "/celebration-kit/assets/celebration-teal/thumb.svg",
  "canvasWidth": 1080,
  "supportedRatios": ["1:1", "4:5", "9:16"],

  "backgrounds": {
    "1:1": { "type": "color", "value": "#FDFAF5" },
    "4:5": { "type": "color", "value": "#FDFAF5" },
    "9:16": { "type": "color", "value": "#FDFAF5" }
  },

  "photo": {
    "x": 540, "y": 440, "width": 720, "height": 720,
    "shape": "rounded-rect",
    "borderRadius": 24,
    "borderColor": "#00BFB3", "borderWidth": 6,
    "objectFit": "cover"
  },

  "textFields": [
    {
      "id": "name",
      "label": "Your Name",
      "placeholder": "Jane Doe",
      "maxLength": 40,
      "x": 540, "y": 880,
      "maxWidth": 900,
      "fontFamily": "heading",
      "fontSize": 52,
      "fontWeight": 700,
      "color": "#1a1a1a",
      "align": "center",
      "lineHeight": 1.2
    },
    {
      "id": "program",
      "label": "Program",
      "placeholder": "MFA Design",
      "maxLength": 60,
      "x": 540, "y": 942,
      "maxWidth": 900,
      "fontFamily": "mono",
      "fontSize": 26,
      "fontWeight": 400,
      "color": "#00BFB3",
      "align": "center",
      "lineHeight": 1.3,
      "letterSpacing": 2
    }
  ],

  "overlays": [
    {
      "id": "top-label",
      "type": "text",
      "text": "CCA CLASS OF 2026",
      "x": 540, "y": 60,
      "fontFamily": "mono",
      "fontSize": 22,
      "fontWeight": 500,
      "color": "#00BFB3",
      "align": "center",
      "letterSpacing": 8
    },
    {
      "id": "accent-line-top",
      "type": "rect",
      "x": 390, "y": 84, "width": 300, "height": 2,
      "color": "#00BFB3", "opacity": 0.3
    },
    {
      "id": "confetti-shapes",
      "type": "confetti",
      "count": 30,
      "region": { "x": 0, "y": 0, "width": 1080, "height": 1080 },
      "opacity": 1.0,
      "seed": 202
    },
    {
      "id": "seal-accent",
      "type": "seal",
      "x": 920, "y": 920,
      "size": 180,
      "opacity": 0.85,
      "color": "#00BFB3"
    }
  ],

  "ratioOverrides": {
    "4:5": {
      "photo": { "y": 500 },
      "textFields": {
        "name": { "y": 960 },
        "program": { "y": 1022 }
      }
    },
    "9:16": {
      "photo": { "y": 680 },
      "textFields": {
        "name": { "y": 1160 },
        "program": { "y": 1222 }
      },
      "overlays": {
        "top-label": { "y": 120 },
        "accent-line-top": { "y": 144 },
        "confetti-shapes": { "region": { "x": 0, "y": 0, "width": 1080, "height": 1920 } },
        "seal-accent": { "x": 920, "y": 1760 }
      }
    }
  }
}
